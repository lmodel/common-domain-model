{% if element.annotations %}
{#- Separate rosetta_functions from other (flat) annotations -#}
{%- set ns = namespace(has_flat=false) -%}
{%- for a in element.annotations -%}
  {%- if a|string|first != '_' and a|string != 'rosetta_functions' -%}
    {%- set ns.has_flat = true -%}
  {%- endif -%}
{%- endfor -%}

{%- if ns.has_flat %}
### Annotations

| property | value |
| --- | --- |
{% for a in element.annotations -%}
{%- if a|string|first != '_' and a|string != 'rosetta_functions' -%}
