{% endif -%}
{% endfor %}
{% endif -%}

{#- Render rosetta_functions as structured function-signature cards -#}
{%- if 'rosetta_functions' in element.annotations -%}
{%- set funcs = element.annotations['rosetta_functions'].value -%}
{%- if funcs is iterable and funcs is not string and funcs|length > 0 %}

### Rosetta Functions

{% for func in funcs %}
<details>
<summary><code>{{ func.name }}</code>{% if func.description is defined and func.description %} — {{ func.description|truncate(120, True) }}{% endif %}</summary>

{% if func.description is defined and func.description -%}
{{ func.description }}
{%- endif %}

{% if func.inputs is defined and func.inputs %}
**Inputs**

| Parameter | Type | Cardinality |
| --- | --- | --- |
{% for p in func.inputs -%}
| `{{ p.name }}` | {{ p.type }} | {{ p.cardinality }} |
{% endfor %}
{% endif -%}

{% if func.output is defined and func.output %}
**Output**

| Parameter | Type | Cardinality |
| --- | --- | --- |
| `{{ func.output.name }}` | {{ func.output.type }} | {{ func.output.cardinality }} |
{% endif -%}

{% if func.code_implementation is defined and func.code_implementation -%}
> ⚠️ This function has `[codeImplementation]` — the body is provided externally.
{% endif -%}

</details>

{% endfor %}
{% endif -%}
