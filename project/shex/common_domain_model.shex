<Inventory> CLOSED {
    (  $<Inventory_tes> <inventoryRecord> @<InventoryRecord> * ;
       rdf:type [ <Inventory> ] ?
    )
}

<InventoryRecord>  (
    CLOSED {
       (  $<InventoryRecord_tes> (  <identifer> @<AssignedIdentifier> ;
             <security> @<Security>
          ) ;
          rdf:type [ <InventoryRecord> ] ?
       )
    } OR @<AvailableInventoryRecord>
)

<InvstmtDcsnPrsn> CLOSED {
    (  $<InvstmtDcsnPrsn_tes> <prsn> @<Prsn> ;
       rdf:type [ <InvstmtDcsnPrsn> ] ?
    )
}

<IssuerAgencyRating> CLOSED {
    (  $<IssuerAgencyRating_tes> <issuerAgencyRating> @<AgencyRatingCriteria> ;
       rdf:type [ <IssuerAgencyRating> ] ?
    )
}

