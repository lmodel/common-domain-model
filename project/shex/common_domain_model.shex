<InterestRateIndex> {
    (  $<InterestRateIndex_tes> rdf:type . * ;
       rdf:type [ <InterestRateIndex> ] ?
    )
}

<InterestRatePayout> CLOSED {
    (  $<InterestRatePayout_tes> (  &<PayoutBase_tes> ;
          rdf:type [ <PayoutBase> ] ? ;
          <rateSpecification> @<RateSpecification> ? ;
          <dayCountFraction> [ <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_360>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_365L> <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_364>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_365_FIXED>
