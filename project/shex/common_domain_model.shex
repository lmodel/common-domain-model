                <https://w3id.org/finos/cdm/RateTreatmentEnum#MoneyMarketYield> ] ? ;
             <calculationParameters> @<FloatingRateCalculationParameters> ? ;
             <fallbackRate> @<FallbackRateParameters> ?
          ) ;
          rdf:type [ <FloatingRate> ] ?
       )
    } OR @<FloatingRateSpecification>
)

<FloatingRateBase>  (
    CLOSED {
       (  $<FloatingRateBase_tes> (  <rateOption> @<InterestRateIndex> ? ;
             <spreadSchedule> @<SpreadSchedule> ? ;
             <capRateSchedule> @<StrikeSchedule> ? ;
             <floorRateSchedule> @<StrikeSchedule> ?
          ) ;
          rdf:type [ <FloatingRateBase> ] ?
       )
    } OR @<CollateralAgreementFloatingRate> OR @<FloatingRate>
)

<FloatingRateCalculationParameters> CLOSED {
    (  $<FloatingRateCalculationParameters_tes> (  <calculationMethod> [
             <https://w3id.org/finos/cdm/CalculationMethodEnum#Averaging>
             <https://w3id.org/finos/cdm/CalculationMethodEnum#Compounding>
             <https://w3id.org/finos/cdm/CalculationMethodEnum#CompoundedIndex> ] ;
          <observationShiftCalculation> @<ObservationShiftCalculation> ? ;
          <lookbackCalculation> @<OffsetCalculation> ? ;
          <lockoutCalculation> @<OffsetCalculation> ? ;
          <applicableBusinessDays> @<BusinessCenters> ? ;
          <observationParameters> @<ObservationParameters> ?
       ) ;
       rdf:type [ <FloatingRateCalculationParameters> ] ?
    )
}

<FloatingRateDefinition> CLOSED {
    (  $<FloatingRateDefinition_tes> (  <calculatedRate> @linkml:Decimal ? ;
          <rateObservation> @<RateObservation> * ;
          <floatingRateMultiplier> @linkml:Decimal ? ;
          <spread> @linkml:Decimal ;
          <capRate> @<Strike> * ;
          <floorRate> @<Strike> *
