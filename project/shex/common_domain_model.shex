)

<InitialFixingDate> CLOSED {
    (  $<InitialFixingDate_tes> (  <relativeDateOffset> @<RelativeDateOffset> ? ;
          <initialFixingDate> @linkml:Date ?
       ) ;
       rdf:type [ <InitialFixingDate> ] ?
    )
}

<Instruction> CLOSED {
    (  $<Instruction_tes> (  <primitiveInstruction> @<PrimitiveInstruction> ? ;
          <before> @<TradeState> ?
       ) ;
       rdf:type [ <Instruction> ] ?
    )
}

<Instrument> {
    (  $<Instrument_tes> rdf:type . * ;
       rdf:type [ <Instrument> ] ?
    )
}

<InstrumentBase>  (
    CLOSED {
       (  $<InstrumentBase_tes> (  &<AssetBase_tes> ;
             rdf:type [ <AssetBase> ] ?
          ) ;
          rdf:type [ <InstrumentBase> ] ?
       )
    } OR @<ListedDerivative> OR @<Loan> OR @<Security>
)

<InterestAdjustment> CLOSED {
    (  $<InterestAdjustment_tes> (  <isApplicable> @linkml:Boolean ;
          <periodicity> @<InterestAdjustmentPeriodicity>
       ) ;
       rdf:type [ <InterestAdjustment> ] ?
    )
}

<InterestAdjustmentPeriodicity> CLOSED {
    (  $<InterestAdjustmentPeriodicity_tes> (  <standardElection> [
             <https://w3id.org/finos/cdm/InterestAdjustmentPeriodicityEnum#LastLocalBusinessDayOfMonth>
             <https://w3id.org/finos/cdm/InterestAdjustmentPeriodicityEnum#EachDay> ] ? ;
          <customElection> @linkml:String ?
       ) ;
       rdf:type [ <InterestAdjustmentPeriodicity> ] ?
    )
}

<InterestAmount> CLOSED {
    (  $<InterestAmount_tes> (  <returnAmount> @<ReturnAmount> ;
          <deliveryAmount> @<DeliveryAmount>
       ) ;
       rdf:type [ <InterestAmount> ] ?
    )
}

<InterestAmountApplication> CLOSED {
    (  $<InterestAmountApplication_tes> (  <returnAmount> @<ReturnAmount> ;
          <deliveryAmount> @<DeliveryAmount>
       ) ;
       rdf:type [ <InterestAmountApplication> ] ?
    )
}

