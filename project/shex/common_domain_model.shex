    (  $<TradePricingReport_tes> (  <trade> @<Trade> ;
          <pricingTime> @<TimeZone> ;
          <discountingIndex> [ <https://w3id.org/finos/cdm/FloatingRateIndexEnum#AED_EBOR_Reuters>
