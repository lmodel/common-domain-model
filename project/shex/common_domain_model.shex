<Swp> CLOSED {
    (  $<Swp_tes> (  <swpIn> @<SwpIn> ;
          <swpOut> @<SwpOut>
       ) ;
       rdf:type [ <Swp> ] ?
    )
}

<SwpIn> CLOSED {
    (  $<SwpIn_tes> <sngl> @<Sngl> ;
       rdf:type [ <SwpIn> ] ?
    )
}

<SwpOut> CLOSED {
    (  $<SwpOut_tes> <sngl> @<Sngl> ;
       rdf:type [ <SwpOut> ] ?
    )
}

<Taxonomy>  (
    CLOSED {
       (  $<Taxonomy_tes> (  <source> [ <https://w3id.org/finos/cdm/TaxonomySourceEnum#CFI>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#ISDA> <https://w3id.org/finos/cdm/TaxonomySourceEnum#ICAD>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#EMIR>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#EU_EMIR_EligibleCollateralAssetClass>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#UK_EMIR_EligibleCollateralAssetClass>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#CFTC>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#US_CFTC_PR_EligibleCollateralAssetClass>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#MAS> <https://w3id.org/finos/cdm/TaxonomySourceEnum#CSA>
                <https://w3id.org/finos/cdm/TaxonomySourceEnum#Other> ] ;
             <value> @<TaxonomyValue> ?
          ) ;
          rdf:type [ <Taxonomy> ] ?
       )
    } OR @<ProductTaxonomy>
)

<TaxonomyClassification> CLOSED {
    (  $<TaxonomyClassification_tes> (  <className> @linkml:String ? ;
          <value> @linkml:String ;
          <description> @linkml:String ? ;
          <ordinal> @linkml:Integer ?
       ) ;
       rdf:type [ <TaxonomyClassification> ] ?
    )
}

<TaxonomyValue> CLOSED {
    (  $<TaxonomyValue_tes> (  <name> @linkml:String ? ;
          <classification> @<TaxonomyClassification> *
       ) ;
       rdf:type [ <TaxonomyValue> ] ?
    )
}

<TelephoneNumber> CLOSED {
    (  $<TelephoneNumber_tes> (  <telephoneNumberType> [ <https://w3id.org/finos/cdm/TelephoneTypeEnum#Work>
             <https://w3id.org/finos/cdm/TelephoneTypeEnum#Mobile> <https://w3id.org/finos/cdm/TelephoneTypeEnum#Fax>
             <https://w3id.org/finos/cdm/TelephoneTypeEnum#Personal> ] ? ;
          <number> @linkml:String
       ) ;
       rdf:type [ <TelephoneNumber> ] ?
    )
}

<Term> CLOSED {
    (  $<Term_tes> (  <unit> @linkml:String ;
          <val> @linkml:String
       ) ;
       rdf:type [ <Term> ] ?
    )
}

<TerminationCurrency> CLOSED {
    (  $<TerminationCurrency_tes> (  <statedTerminationCurrency> @<TerminationCurrencySelection> ? ;
          <partyOptionTerminationCurrency> @<PartyOptionTerminationCurrency> ?
       ) ;
       rdf:type [ <TerminationCurrency> ] ?
    )
}

<TerminationCurrencyAmendment> CLOSED {
    (  $<TerminationCurrencyAmendment_tes> (  <isApplicable> @linkml:Boolean ;
          <effectiveDate> @<AmendmentEffectiveDate> ? ;
          <partyElection> @<TerminationCurrencyElection> +
       ) ;
       rdf:type [ <TerminationCurrencyAmendment> ] ?
    )
}

<TerminationCurrencyElection> CLOSED {
    (  $<TerminationCurrencyElection_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] + ;
          <isSpecified> @linkml:Boolean ;
          <currency> @linkml:String ?
       ) ;
       rdf:type [ <TerminationCurrencyElection> ] ?
    )
}

<TerminationCurrencySelection> CLOSED {
    (  $<TerminationCurrencySelection_tes> (  <statedCurrency> @linkml:String ? ;
          <fallbackCurrency> @linkml:String ? ;
          <partyElection> @<PartyTerminationCurrencySelection> + ;
          <bothAffected> @linkml:String ?
       ) ;
       rdf:type [ <TerminationCurrencySelection> ] ?
    )
}

<TerminationProvision> CLOSED {
    (  $<TerminationProvision_tes> (  <cancelableProvision> @<CancelableProvision> ? ;
          <earlyTerminationProvision> @<EarlyTerminationProvision> ? ;
          <evergreenProvision> @<EvergreenProvision> ? ;
          <extendibleProvision> @<ExtendibleProvision> ? ;
          <recallProvision> @<RecallProvision> ?
       ) ;
       rdf:type [ <TerminationProvision> ] ?
    )
}

<TermsChangeInstruction> CLOSED {
    (  $<TermsChangeInstruction_tes> (  <product> @<NonTransferableProduct> ;
          <ancillaryParty> @<AncillaryParty> * ;
          <adjustment> [ <https://w3id.org/finos/cdm/NotionalAdjustmentEnum#Execution>
             <https://w3id.org/finos/cdm/NotionalAdjustmentEnum#PortfolioRebalancing>
             <https://w3id.org/finos/cdm/NotionalAdjustmentEnum#Standard> ] ?
       ) ;
       rdf:type [ <TermsChangeInstruction> ] ?
    )
}

<Threshold> CLOSED {
    (  $<Threshold_tes> <partyElection> @<ThresholdElection> + ;
       rdf:type [ <Threshold> ] ?
    )
}

<ThresholdElection> CLOSED {
    (  $<ThresholdElection_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ;
          <fixedAmount> @<ThresholdMinimumTransferAmountFixedAmount> ? ;
          <ratingsBased> @<ThresholdRatingsBased> ? ;
          <infinity> @linkml:Boolean ? ;
          <other> @linkml:String ?
       ) ;
       rdf:type [ <ThresholdElection> ] ?
    )
}

<ThresholdMinimumTransferAmountBase>  (
    CLOSED {
       (  $<ThresholdMinimumTransferAmountBase_tes> (  <zeroEvent> @linkml:Boolean ;
             <event> [ <https://w3id.org/finos/cdm/ZeroEventEnum#EventOfDefault>
                <https://w3id.org/finos/cdm/ZeroEventEnum#TerminationEvent>
                <https://w3id.org/finos/cdm/ZeroEventEnum#TerminationEventAllAffectedTransactions>
                <https://w3id.org/finos/cdm/ZeroEventEnum#PotentialEventOfDefault>
                <https://w3id.org/finos/cdm/ZeroEventEnum#AdditionalTerminationEvent>
                <https://w3id.org/finos/cdm/ZeroEventEnum#Other> ] *
          ) ;
          rdf:type [ <ThresholdMinimumTransferAmountBase> ] ?
       )
    } OR @<MinimumTransferAmountRatingsBased> OR @<ThresholdMinimumTransferAmountFixedAmount> OR @<ThresholdRatingsBased>
)

<ThresholdMinimumTransferAmountFixedAmount> CLOSED {
    (  $<ThresholdMinimumTransferAmountFixedAmount_tes> (  &<ThresholdMinimumTransferAmountBase_tes> ;
          rdf:type [ <ThresholdMinimumTransferAmountBase> ] ? ;
          <amount> @<Money>
       ) ;
       rdf:type [ <ThresholdMinimumTransferAmountFixedAmount> ] ?
    )
}

