<AgreementTerms> CLOSED {
    (  $<AgreementTerms_tes> (  <agreement> @<Agreement> ;
          <clauseLibrary> @linkml:Boolean ? ;
          <counterparty> @<Counterparty> +
       ) ;
       rdf:type [ <AgreementTerms> ] ?
    )
}

<AllCriteria> CLOSED {
    (  $<AllCriteria_tes> <allCriteria> @<CollateralCriteria> + ;
       rdf:type [ <AllCriteria> ] ?
    )
}

<AllDirectionRating> CLOSED {
    (  $<AllDirectionRating_tes> <allDirectionRating> @<DirectionRatingSet> + ;
       rdf:type [ <AllDirectionRating> ] ?
    )
}

<AllEligibilityToHoldCollateralCriteria> CLOSED {
    (  $<AllEligibilityToHoldCollateralCriteria_tes> <allCriteria> @<EligibilityToHoldCollateralCriteria> + ;
       rdf:type [ <AllEligibilityToHoldCollateralCriteria> ] ?
    )
}

<AmendmentEffectiveDate> CLOSED {
    (  $<AmendmentEffectiveDate_tes> (  <date> @linkml:Date + ;
          <specificDate> [ <https://w3id.org/finos/cdm/AmendmentEffectiveDateEnum#AnnexDate>
             <https://w3id.org/finos/cdm/AmendmentEffectiveDateEnum#DeedDate>
             <https://w3id.org/finos/cdm/AmendmentEffectiveDateEnum#AgreementDate>
             <https://w3id.org/finos/cdm/AmendmentEffectiveDateEnum#AmendmentEffectiveDate> ] ? ;
          <customProvision> @linkml:String ?
       ) ;
       rdf:type [ <AmendmentEffectiveDate> ] ?
    )
}

<AmountOfNetCapital> CLOSED {
    (  $<AmountOfNetCapital_tes> <amountOfNetCapital> @<Money> ? ;
       rdf:type [ <AmountOfNetCapital> ] ?
    )
}

<AmountSchedule> CLOSED {
    (  $<AmountSchedule_tes> (  &<Schedule_tes> ;
          rdf:type [ <Schedule> ] ? ;
          <currency> @linkml:String +
       ) ;
       rdf:type [ <AmountSchedule> ] ?
    )
}

<AncillaryEntity> CLOSED {
    (  $<AncillaryEntity_tes> (  <ancillaryParty> [ <https://w3id.org/finos/cdm/AncillaryRoleEnum#DisruptionEventsDeterminingParty>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExtraordinaryDividendsParty>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#PredeterminedClearingOrganizationParty>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyManual>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyOptionalEarlyTermination>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyCancelableProvision>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyExtendibleProvision>
