             <https://w3id.org/finos/cdm/BusinessDayConventionEnum#NotApplicable> ]
       ) ;
       rdf:type [ <FinalCalculationPeriodDateAdjustment> ] ?
    )
}

<FinalReturns> CLOSED {
    (  $<FinalReturns_tes> (  <applicable> @linkml:Boolean ;
          <additionalLanguage> @linkml:String ?
       ) ;
       rdf:type [ <FinalReturns> ] ?
    )
}

<FinInstrm> CLOSED {
    (  $<FinInstrm_tes> <othr> @<Othr> ;
       rdf:type [ <FinInstrm> ] ?
    )
}

<FinInstrmGnlAttrbts> CLOSED {
    (  $<FinInstrmGnlAttrbts_tes> (  <fullNm> @linkml:String ;
          <clssfctnTp> @linkml:String ;
          <ntnlCcy> @linkml:String
       ) ;
       rdf:type [ <FinInstrmGnlAttrbts> ] ?
    )
}

<FinInstrmRptgTxRpt> CLOSED {
    (  $<FinInstrmRptgTxRpt_tes> <tx> @<Tx> ;
       rdf:type [ <FinInstrmRptgTxRpt> ] ?
    )
}

<FixedAmountCalculationDetails> CLOSED {
    (  $<FixedAmountCalculationDetails_tes> (  <calculationPeriod> @<CalculationPeriodBase> ;
          <calculationPeriodNotionalAmount> @<Money> ;
          <fixedRate> @linkml:Decimal ;
          <yearFraction> @linkml:Decimal ;
          <calculatedAmount> @linkml:Decimal
       ) ;
       rdf:type [ <FixedAmountCalculationDetails> ] ?
    )
}

<FixedPrice> CLOSED {
    (  $<FixedPrice_tes> <price> @<PriceSchedule> ? ;
       rdf:type [ <FixedPrice> ] ?
    )
}

<FixedPricePayout> CLOSED {
    (  $<FixedPricePayout_tes> (  &<PayoutBase_tes> ;
          rdf:type [ <PayoutBase> ] ? ;
          <paymentDates> @<PaymentDates> ;
          <fixedPrice> @<FixedPrice> ;
          <schedule> @<CalculationSchedule> *
       ) ;
       rdf:type [ <FixedPricePayout> ] ?
    )
}

<FixedRateSpecification> CLOSED {
    (  $<FixedRateSpecification_tes> <rateSchedule> @<RateSchedule> ? ;
       rdf:type [ <FixedRateSpecification> ] ?
    )
}

<FloatingAmountCalculationDetails> CLOSED {
    (  $<FloatingAmountCalculationDetails_tes> (  <calculationPeriod> @<CalculationPeriodBase> ;
          <calculationPeriodNotionalAmount> @<Money> ;
          <floatingRate> @<FloatingRateSettingDetails> * ;
          <processingDetails> @<FloatingRateProcessingDetails> ? ;
          <appliedRate> @linkml:Decimal ;
          <yearFraction> @linkml:Decimal ;
          <calculatedAmount> @linkml:Decimal ;
          <spreadExclusiveCalculatedAMount> @linkml:Decimal
       ) ;
       rdf:type [ <FloatingAmountCalculationDetails> ] ?
    )
}

<FloatingAmountEvents> CLOSED {
    (  $<FloatingAmountEvents_tes> (  <failureToPayPrincipal> @linkml:Boolean ? ;
          <interestShortfall> @<InterestShortFall> ? ;
