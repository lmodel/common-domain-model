             <https://w3id.org/finos/cdm/RegulatoryRegimeEnum#UnitedKingdomMarginRules>
             <https://w3id.org/finos/cdm/RegulatoryRegimeEnum#SouthAfricaMarginRules>
             <https://w3id.org/finos/cdm/RegulatoryRegimeEnum#SouthKoreaMarginRules>
             <https://w3id.org/finos/cdm/RegulatoryRegimeEnum#HongKongSFCMarginRules> ] ;
          <additionalRegime> @linkml:String ? ;
          <regimeTerms> @<RegimeTerms> + ;
          <additionalType> [ <https://w3id.org/finos/cdm/AdditionalTypeEnum#NotApplicable>
             <https://w3id.org/finos/cdm/AdditionalTypeEnum#EquityOptionOrIndexOption>
             <https://w3id.org/finos/cdm/AdditionalTypeEnum#Other> ] ? ;
          <additionalTerms> @linkml:String ?
       ) ;
       rdf:type [ <ApplicableRegime> ] ?
    )
}

<AppropriatedCollateralValuation> CLOSED {
    (  $<AppropriatedCollateralValuation_tes> (  <isSpecified> @linkml:Boolean ;
          <election> @linkml:String ?
       ) ;
       rdf:type [ <AppropriatedCollateralValuation> ] ?
    )
}

<Asset>  (
    @<SpecificAsset> OR @<TransferableProduct>
)

<Asset_struct> {
    (  $<Asset_tes> rdf:type . * ;
       rdf:type [ <Asset> ] ?
    )
}

<AssetAgencyRating> CLOSED {
    (  $<AssetAgencyRating_tes> <assetAgencyRating> @<AgencyRatingCriteria> ;
       rdf:type [ <AssetAgencyRating> ] ?
    )
}

<AssetBase>  (
    CLOSED {
       (  $<AssetBase_tes> (  <identifier> @<AssetIdentifier> + ;
             <taxonomy> @<Taxonomy> * ;
             <isExchangeListed> @linkml:Boolean ? ;
             <exchange> @<LegalEntity> ? ;
             <relatedExchange> @<LegalEntity> * ;
             <assetType> [ <https://w3id.org/finos/cdm/AssetTypeEnum#Security> <https://w3id.org/finos/cdm/AssetTypeEnum#Cash>
                <https://w3id.org/finos/cdm/AssetTypeEnum#Commodity> <https://w3id.org/finos/cdm/AssetTypeEnum#ListedDerivative>
                <https://w3id.org/finos/cdm/AssetTypeEnum#Loan> <https://w3id.org/finos/cdm/AssetTypeEnum#LetterOfCredit>
                <https://w3id.org/finos/cdm/AssetTypeEnum#Other> ]
          ) ;
          rdf:type [ <AssetBase> ] ?
       )
    } OR @<Basket> OR @<Cash> OR @<Commodity> OR @<DigitalAsset> OR @<IndexBase> OR @<InstrumentBase>
)

