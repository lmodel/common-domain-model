             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#CumulativeInterestPaid>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#CumulativeInterestPaidInclReset>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#CumulativeInterestPaidBeforeReset>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#DividendPaymentDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#DividendValuationDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#EquityPaymentDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#ExDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#FloatingAmountPaymentDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#FollowingPaymentDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#RecordDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#SharePayment>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#TerminationDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#TradeDate>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#UnwindOrEquityExDiv>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#UnwindOrEquityPaid>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#UnwindOrInterestExDiv>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#UnwindOrInterestPaid>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#UnwindExDiv>
             <https://w3id.org/finos/cdm/DividendDateReferenceEnum#UnwindPaid> ] ;
          <paymentDateOffset> @<Offset> ?
       ) ;
       rdf:type [ <DividendDateReference> ] ?
    )
}

<DividendPaymentDate> CLOSED {
    (  $<DividendPaymentDate_tes> (  <dividendDateReference> @<DividendDateReference> ? ;
          <dividendDate> @<AdjustableOrRelativeDate> ?
       ) ;
       rdf:type [ <DividendPaymentDate> ] ?
    )
}

<DividendPayoutRatio> CLOSED {
    (  $<DividendPayoutRatio_tes> (  <totalRatio> @linkml:Decimal ;
          <cashRatio> @linkml:Decimal ? ;
          <nonCashRatio> @linkml:Decimal ? ;
          <basketConstituent> @<BasketConstituent> +
       ) ;
       rdf:type [ <DividendPayoutRatio> ] ?
    )
}

<DividendPeriod> CLOSED {
    (  $<DividendPeriod_tes> (  <startDate> @<DividendPaymentDate> ;
          <endDate> @<DividendPaymentDate> ;
          <dateAdjustments> @<BusinessDayAdjustments> ;
          <basketConstituent> @<BasketConstituent> + ;
          <dividendPaymentDate> @<DividendPaymentDate> ;
          <dividendValuationDate> @<AdjustableOrRelativeDate> ?
       ) ;
       rdf:type [ <DividendPeriod> ] ?
    )
}

<DividendReturnTerms> CLOSED {
    (  $<DividendReturnTerms_tes> (  <dividendPayoutRatio> @<DividendPayoutRatio> * ;
          <dividendReinvestment> @linkml:Boolean ? ;
          <dividendEntitlement> [ <https://w3id.org/finos/cdm/DividendEntitlementEnum#ExDate>
             <https://w3id.org/finos/cdm/DividendEntitlementEnum#RecordDate> ] ? ;
          <dividendAmountType> [ <https://w3id.org/finos/cdm/DividendAmountTypeEnum#RecordAmount>
             <https://w3id.org/finos/cdm/DividendAmountTypeEnum#ExAmount>
             <https://w3id.org/finos/cdm/DividendAmountTypeEnum#PaidAmount>
             <https://w3id.org/finos/cdm/DividendAmountTypeEnum#AsSpecifiedInMasterConfirmation> ] ? ;
          <performance> @linkml:String ? ;
          <firstOrSecondPeriod> [ <https://w3id.org/finos/cdm/DividendPeriodEnum#FirstPeriod>
             <https://w3id.org/finos/cdm/DividendPeriodEnum#SecondPeriod> ] ? ;
          <extraordinaryDividendsParty> [ <https://w3id.org/finos/cdm/AncillaryRoleEnum#DisruptionEventsDeterminingParty>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExtraordinaryDividendsParty>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#PredeterminedClearingOrganizationParty>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyManual>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyOptionalEarlyTermination>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyCancelableProvision>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#ExerciseNoticeReceiverPartyExtendibleProvision>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentIndependent>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentOptionalEarlyTermination>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentMandatoryEarlyTermination>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentFallback> ] ? ;
          <excessDividendAmount> [ <https://w3id.org/finos/cdm/DividendAmountTypeEnum#RecordAmount>
             <https://w3id.org/finos/cdm/DividendAmountTypeEnum#ExAmount>
             <https://w3id.org/finos/cdm/DividendAmountTypeEnum#PaidAmount>
             <https://w3id.org/finos/cdm/DividendAmountTypeEnum#AsSpecifiedInMasterConfirmation> ] ? ;
          <dividendCurrency> @<DividendCurrency> ? ;
          <nonCashDividendTreatment> [ <https://w3id.org/finos/cdm/NonCashDividendTreatmentEnum#PotentialAdjustmentEvent>
             <https://w3id.org/finos/cdm/NonCashDividendTreatmentEnum#CashEquivalent> ] ? ;
          <dividendComposition> [ <https://w3id.org/finos/cdm/DividendCompositionEnum#EquityAmountReceiverElection>
             <https://w3id.org/finos/cdm/DividendCompositionEnum#CalculationAgentElection> ] ? ;
          <specialDividends> @linkml:Boolean ? ;
          <materialDividend> @linkml:Boolean ? ;
          <dividendPeriod> @<DividendPeriod> *
       ) ;
       rdf:type [ <DividendReturnTerms> ] ?
    )
}

<DividendTerms> CLOSED {
    (  $<DividendTerms_tes> (  <manufacturedIncomeRequirement> @<DividendPayoutRatio> ;
          <dividendEntitlement> [ <https://w3id.org/finos/cdm/DividendEntitlementEnum#ExDate>
             <https://w3id.org/finos/cdm/DividendEntitlementEnum#RecordDate> ] ? ;
          <minimumBillingAmount> @<Money> ?
       ) ;
       rdf:type [ <DividendTerms> ] ?
    )
}

<Document> CLOSED {
    (  $<Document_tes> <finInstrmRptgTxRpt> @<FinInstrmRptgTxRpt> ;
       rdf:type [ <Document> ] ?
    )
}

<DomesticCurrencyIssued> CLOSED {
    (  $<DomesticCurrencyIssued_tes> <domesticCurrencyIssued> @linkml:Boolean ;
       rdf:type [ <DomesticCurrencyIssued> ] ?
    )
}

<EarlyTerminationEvent> CLOSED {
    (  $<EarlyTerminationEvent_tes> (  <adjustedExerciseDate> @linkml:Date ;
          <adjustedEarlyTerminationDate> @linkml:Date ;
          <adjustedCashSettlementValuationDate> @linkml:Date ;
          <adjustedCashSettlementPaymentDate> @linkml:Date ;
          <adjustedExerciseFeePaymentDate> @linkml:Date ?
       ) ;
       rdf:type [ <EarlyTerminationEvent> ] ?
    )
}

<EarlyTerminationProvision> CLOSED {
    (  $<EarlyTerminationProvision_tes> (  <mandatoryEarlyTermination> @<MandatoryEarlyTermination> ? ;
          <mandatoryEarlyTerminationDateTenor> @<Period> ? ;
          <optionalEarlyTermination> @<OptionalEarlyTermination> ? ;
          <optionalEarlyTerminationParameters> @<ExercisePeriod> ?
       ) ;
       rdf:type [ <EarlyTerminationProvision> ] ?
    )
}

<EconomicTerms> CLOSED {
    (  $<EconomicTerms_tes> (  <effectiveDate> @<AdjustableOrRelativeDate> ? ;
          <effectiveTime> @<DirectOrRelativeTime> ? ;
          <terminationDate> @<AdjustableOrRelativeDate> ? ;
          <terminationTime> @<DirectOrRelativeTime> ? ;
          <dateAdjustments> @<BusinessDayAdjustments> ? ;
          <payout> @<Payout> + ;
          <terminationProvision> @<TerminationProvision> ? ;
          <calculationAgent> @<CalculationAgent> ? ;
          <nonStandardisedTerms> @linkml:Boolean ? ;
          <collateral> @<Collateral> ?
       ) ;
       rdf:type [ <EconomicTerms> ] ?
    )
}

<ElectiveAmountElection> CLOSED {
    (  $<ElectiveAmountElection_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ;
          <electiveAmount> [ <https://w3id.org/finos/cdm/ElectiveAmountEnum#Zero>
             <https://w3id.org/finos/cdm/ElectiveAmountEnum#Unlimited> ] ? ;
          <amount> @<Money> ;
          <customElection> @linkml:String ?
       ) ;
       rdf:type [ <ElectiveAmountElection> ] ?
    )
}

