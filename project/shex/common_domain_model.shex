<FloatingRateIndexCalculationDefaults> CLOSED {
    (  $<FloatingRateIndexCalculationDefaults_tes> (  <category> [
             <https://w3id.org/finos/cdm/FloatingRateIndexCategoryEnum#ScreenRate>
             <https://w3id.org/finos/cdm/FloatingRateIndexCategoryEnum#Calculated>
             <https://w3id.org/finos/cdm/FloatingRateIndexCategoryEnum#ReferenceBanks> ] ;
          <indexStyle> [ <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#AverageFRO>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#CompoundedIndex>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#Index>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#Other>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#Overnight>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#PublishedAverage>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#SpecifiedFormula>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#SwapRate>
             <https://w3id.org/finos/cdm/FloatingRateIndexStyleEnum#TermRate> ] ? ;
          <method> [ <https://w3id.org/finos/cdm/FloatingRateIndexCalculationMethodEnum#OISCompound>
             <https://w3id.org/finos/cdm/FloatingRateIndexCalculationMethodEnum#Average>
             <https://w3id.org/finos/cdm/FloatingRateIndexCalculationMethodEnum#Compounded>
             <https://w3id.org/finos/cdm/FloatingRateIndexCalculationMethodEnum#AllInCompounded> ] ? ;
          <fixing> @<FloatingRateIndexFixingDetails> * ;
          <dayCountFraction> [ <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_360>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_365L> <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_364>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_365_FIXED>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_ACT_AFB>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_ACT_ICMA>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_ACT_ISDA>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#ACT_ACT_ISMA>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#CAL_252> <https://w3id.org/finos/cdm/DayCountFractionEnum#_1_1>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#_30E_360>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#_30E_360_ISDA>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#_30_360>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#RBA_BOND_BASIS> ] ;
          <applicableBusinessDays> @<BusinessCenters> ? ;
          <publicationCalendar> @<BusinessCenter> ?
       ) ;
       rdf:type [ <FloatingRateIndexCalculationDefaults> ] ?
    )
}

<FloatingRateIndexDefinition> CLOSED {
    (  $<FloatingRateIndexDefinition_tes> (  <fro> @<FloatingRateIndexIdentification> ;
          <calculationDefaults> @<FloatingRateIndexCalculationDefaults> ? ;
          <supportedDefinition> @<ContractualDefinition> * ;
          <definitionalSource> @linkml:String ? ;
          <designatedMaturityApplicable> @linkml:Boolean ? ;
          <mappings> @<FloatingRateIndexMappings> ? ;
          <externalMappings> @<FloatingRateIndexExternalMappings> ? ;
          <inLoan> @linkml:Boolean ? ;
          <history> @<FroHistory> ? ;
          <deprecationReason> @linkml:String ? ;
          <fpmlDescription> @linkml:String ?
       ) ;
       rdf:type [ <FloatingRateIndexDefinition> ] ?
    )
}

<FloatingRateIndexExternalMap> CLOSED {
    (  $<FloatingRateIndexExternalMap_tes> (  <externalId> @linkml:String ;
          <externalStandard> @linkml:String ?
       ) ;
       rdf:type [ <FloatingRateIndexExternalMap> ] ?
    )
}

<FloatingRateIndexExternalMappings> CLOSED {
    (  $<FloatingRateIndexExternalMappings_tes> <isoCode> @<FloatingRateIndexExternalMap> ? ;
       rdf:type [ <FloatingRateIndexExternalMappings> ] ?
    )
}

<FloatingRateIndexFixingDetails> CLOSED {
    (  $<FloatingRateIndexFixingDetails_tes> (  <fixingTime> @<FloatingRateIndexFixingTime> ? ;
          <fixingOffset> @<BusinessDayOffset> ?
       ) ;
       rdf:type [ <FloatingRateIndexFixingDetails> ] ?
    )
}

<FloatingRateIndexFixingOffset> CLOSED {
    (  $<FloatingRateIndexFixingOffset_tes> (  &<BusinessDayOffset_tes> ;
          rdf:type [ <BusinessDayOffset> ] ? ;
          <designatedMaturity> @linkml:String ?
       ) ;
       rdf:type [ <FloatingRateIndexFixingOffset> ] ?
    )
}

<FloatingRateIndexFixingTime> CLOSED {
    (  $<FloatingRateIndexFixingTime_tes> (  &<BusinessCenterTime_tes> ;
          rdf:type [ <BusinessCenterTime> ] ? ;
          <designatedMaturity> @linkml:String ? ;
          <fixingTimeDefinition> @linkml:String ? ;
          <fixingReason> @linkml:String ?
       ) ;
       rdf:type [ <FloatingRateIndexFixingTime> ] ?
    )
}

