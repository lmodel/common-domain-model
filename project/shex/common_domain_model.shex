<MasterAgreementDatedAsOfDate> CLOSED {
    (  $<MasterAgreementDatedAsOfDate_tes> (  <masterAgreementDatedAsOfDate> @linkml:Date ? ;
          <additionalLanguage> @linkml:String ?
       ) ;
       rdf:type [ <MasterAgreementDatedAsOfDate> ] ?
    )
}

<MasterAgreementElections> CLOSED {
    (  $<MasterAgreementElections_tes> rdf:type . * ;
       rdf:type [ <MasterAgreementElections> ] ?
    )
}

<MasterAgreementSchedule> CLOSED {
    (  $<MasterAgreementSchedule_tes> <clause> @<MasterAgreementClause> + ;
       rdf:type [ <MasterAgreementSchedule> ] ?
    )
}

<MasterAgreementVariableSet> CLOSED {
    (  $<MasterAgreementVariableSet_tes> (  <variableSet> @<MasterAgreementVariableSet> * ;
          <name> @linkml:String ? ;
          <value> @linkml:String ?
       ) ;
       rdf:type [ <MasterAgreementVariableSet> ] ?
    )
}

<MasterConfirmationBase>  (
    CLOSED {
       (  $<MasterConfirmationBase_tes> rdf:type . * ;
          rdf:type [ <MasterConfirmationBase> ] ?
       )
    } OR @<EquityMasterConfirmation>
)

<MaterialChangeInCircumstance> CLOSED {
    (  $<MaterialChangeInCircumstance_tes> (  <materialChangeInCircumstanceIsApplicable> @linkml:Boolean ;
          <escrowArrangement> @<EscrowArrangement> ? ;
          <maximumDaysOfDisruption> @<ValuationPostponement> ?
       ) ;
       rdf:type [ <MaterialChangeInCircumstance> ] ?
    )
}

<Measure> CLOSED {
    (  $<Measure_tes> (  &<MeasureBase_tes> ;
          rdf:type [ <MeasureBase> ] ?
       ) ;
       rdf:type [ <Measure> ] ?
    )
}

<MeasureBase>  (
    CLOSED {
       (  $<MeasureBase_tes> (  <value> @linkml:Decimal ? ;
             <unit> @<UnitType> ?
          ) ;
          rdf:type [ <MeasureBase> ] ?
       )
    } OR @<Measure> OR @<MeasureSchedule>
)

<MeasureSchedule>  (
    CLOSED {
       (  $<MeasureSchedule_tes> (  &<MeasureBase_tes> ;
             rdf:type [ <MeasureBase> ] ? ;
             <datedValue> @<DatedValue> *
          ) ;
          rdf:type [ <MeasureSchedule> ] ?
       )
    } OR @<PriceSchedule> OR @<QuantitySchedule>
)

<Merger> CLOSED {
    (  $<Merger_tes> (  <purchaserSecurity> @<Security> ;
          <purchaserSecurityPrice> @<Price> ;
          <acquiredSecurity> @<Security> ;
          <acquiredSecurityPrice> @<Price>
       ) ;
       rdf:type [ <Merger> ] ?
    )
}

<MessageInformation> CLOSED {
    (  $<MessageInformation_tes> (  <messageId> @linkml:String ;
          <sentBy> @linkml:String ? ;
          <sentTo> @linkml:String * ;
          <copyTo> @linkml:String *
       ) ;
       rdf:type [ <MessageInformation> ] ?
    )
}

<MinimumTransferAmount> CLOSED {
    (  $<MinimumTransferAmount_tes> <partyElection> @<MinimumTransferAmountElection> + ;
       rdf:type [ <MinimumTransferAmount> ] ?
    )
}

<MinimumTransferAmountAmendment> CLOSED {
    (  $<MinimumTransferAmountAmendment_tes> (  <isApplicable> @linkml:Boolean ;
          <effectiveDate> @<AmendmentEffectiveDate> ? ;
          <partyElections> @<ElectiveAmountElection> *
       ) ;
       rdf:type [ <MinimumTransferAmountAmendment> ] ?
    )
}

<MinimumTransferAmountElection> CLOSED {
    (  $<MinimumTransferAmountElection_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ;
          <fixedAmount> @<ThresholdMinimumTransferAmountFixedAmount> ? ;
          <ratingsBased> @<MinimumTransferAmountRatingsBased> ? ;
          <other> @linkml:String ?
       ) ;
       rdf:type [ <MinimumTransferAmountElection> ] ?
    )
}

