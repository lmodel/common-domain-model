<InflationRateSpecification> CLOSED {
    (  $<InflationRateSpecification_tes> (  &<FloatingRateSpecification_tes> ;
          rdf:type [ <FloatingRateSpecification> ] ? ;
          <inflationLag> @<Offset> ;
          <indexSource> @linkml:String ;
          <mainPublication> @linkml:String ;
          <interpolationMethod> [ <http://www.fpml.org/coding-scheme/interpolation-method-1-2#Linear>
             <http://www.fpml.org/coding-scheme/interpolation-method-1-2#LinearZeroYield>
             <http://www.fpml.org/coding-scheme/interpolation-method-1-2#None> ] ;
          <initialIndexLevel> @linkml:Decimal ? ;
          <fallbackBondApplicable> @linkml:Boolean ;
          <calculationMethod> [ <https://w3id.org/finos/cdm/InflationCalculationMethodEnum#Ratio>
             <https://w3id.org/finos/cdm/InflationCalculationMethodEnum#Return>
             <https://w3id.org/finos/cdm/InflationCalculationMethodEnum#Spread> ] ;
          <calculationStyle> [ <https://w3id.org/finos/cdm/InflationCalculationStyleEnum#YearOnYear>
             <https://w3id.org/finos/cdm/InflationCalculationStyleEnum#ZeroCoupon> ] ? ;
          <finalPrincipalExchangeCalculation> [ <https://w3id.org/finos/cdm/FinalPrincipalExchangeCalculationEnum#Floored>
             <https://w3id.org/finos/cdm/FinalPrincipalExchangeCalculationEnum#NonFloored> ] ?
       ) ;
       rdf:type [ <InflationRateSpecification> ] ?
