          <interimValuationPrice> @<PriceSchedule> * ;
          <finalValuationPrice> @<PriceSchedule> *
       ) ;
       rdf:type [ <BasketConstituent> ] ?
    )
}

<BasketReferenceInformation> CLOSED {
