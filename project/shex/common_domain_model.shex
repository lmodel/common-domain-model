             <baseCurrencyExposure> @<MarginCallExposure> ? ;
             <collateralPortfolio> @<CollateralPortfolio> ? ;
             <independentAmountBalance> @<CollateralBalance> ?
          ) ;
          rdf:type [ <MarginCallBase> ] ?
       )
    } OR @<MarginCallExposure> OR @<MarginCallIssuance> OR @<MarginCallResponse>
)

<MarginCallExposure> CLOSED {
    (  $<MarginCallExposure_tes> (  &<MarginCallBase_tes> ;
          rdf:type [ <MarginCallBase> ] ? ;
          <overallExposure> @<Exposure> ;
          <simmIMExposure> @<Exposure> ? ;
          <scheduleGridIMExposure> @<Exposure> ?
       ) ;
       rdf:type [ <MarginCallExposure> ] ?
    )
}

<MarginCallInstructionType> CLOSED {
    (  $<MarginCallInstructionType_tes> (  <callType> [ <https://w3id.org/finos/cdm/CallTypeEnum#MarginCall>
             <https://w3id.org/finos/cdm/CallTypeEnum#Notification> <https://w3id.org/finos/cdm/CallTypeEnum#ExpectedCall> ] ;
          <visibilityIndicator> @linkml:Boolean ?
       ) ;
       rdf:type [ <MarginCallInstructionType> ] ?
    )
}

<MarginCallIssuance> CLOSED {
    (  $<MarginCallIssuance_tes> (  &<MarginCallBase_tes> ;
          rdf:type [ <MarginCallBase> ] ? ;
          <callAmountInBaseCurrency> @<Money> ;
          <recallNonCashCollateralDescription> @<EligibleCollateralCriteria> *
       ) ;
       rdf:type [ <MarginCallIssuance> ] ?
    )
}

<MarginCallResponse> CLOSED {
    (  $<MarginCallResponse_tes> (  &<MarginCallBase_tes> ;
          rdf:type [ <MarginCallBase> ] ? ;
          <marginCallResponseAction> @<MarginCallResponseAction> + ;
          <marginResponseType> [ <https://w3id.org/finos/cdm/MarginCallResponseTypeEnum#AgreeinFull>
             <https://w3id.org/finos/cdm/MarginCallResponseTypeEnum#PartiallyAgree>
             <https://w3id.org/finos/cdm/MarginCallResponseTypeEnum#Dispute> ] ;
          <agreedAmountBaseCurrency> @<Money>
       ) ;
       rdf:type [ <MarginCallResponse> ] ?
    )
}

<MarginCallResponseAction> CLOSED {
    (  $<MarginCallResponseAction_tes> (  <collateralPositionComponent> @<CollateralPosition> + ;
          <marginCallAction> [ <https://w3id.org/finos/cdm/MarginCallActionEnum#Delivery>
             <https://w3id.org/finos/cdm/MarginCallActionEnum#Return> ]
       ) ;
       rdf:type [ <MarginCallResponseAction> ] ?
    )
}

<MasterAgreement> CLOSED {
    (  $<MasterAgreement_tes> (  &<MasterAgreementBase_tes> ;
          rdf:type [ <MasterAgreementBase> ] ? ;
          <automaticEarlyTermination> @<AutomaticEarlyTermination> ;
          <terminationCurrency> @<TerminationCurrency> ;
          <addressForNotices> @<DemandsAndNotices> ;
          <nonContractualObligations> @linkml:Boolean ;
          <creditSupportDocument> @<CreditSupportDocument> + ;
          <creditSupportProvider> @<CreditSupportProvider> + ;
          <specifiedEntities> @<SpecifiedEntities> +
       ) ;
       rdf:type [ <MasterAgreement> ] ?
    )
}

<MasterAgreementBase>  (
    CLOSED {
       (  $<MasterAgreementBase_tes> rdf:type . * ;
          rdf:type [ <MasterAgreementBase> ] ?
       )
    } OR @<GlobalMasterRepoAgreement> OR @<GlobalMasterSecuritiesLendingAgreement> OR @<MasterAgreement>
)

