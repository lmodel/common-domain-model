<Rounding> CLOSED {
    (  $<Rounding_tes> (  <roundingDirection> [ <https://w3id.org/finos/cdm/RoundingDirectionEnum#Up>
             <https://w3id.org/finos/cdm/RoundingDirectionEnum#Down> <https://w3id.org/finos/cdm/RoundingDirectionEnum#Nearest> ] ;
          <precision> @linkml:Integer ?
       ) ;
       rdf:type [ <Rounding> ] ?
    )
}

<Schedule>  (
    CLOSED {
       (  $<Schedule_tes> (  <value> @linkml:Decimal ;
             <datedValue> @<DatedValue> *
          ) ;
          rdf:type [ <Schedule> ] ?
       )
    } OR @<AmountSchedule>
)

<ScheduledTransfer> CLOSED {
    (  $<ScheduledTransfer_tes> (  &<TransferBase_tes> ;
          rdf:type [ <TransferBase> ] ? ;
          <transferType> [ <https://w3id.org/finos/cdm/ScheduledTransferEnum#CorporateAction>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#Coupon>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#CreditEvent>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#DividendReturn>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#Exercise>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#FixedRateReturn>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#FloatingRateReturn>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#FractionalAmount>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#InterestReturn>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#NetInterest>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#Performance>
             <https://w3id.org/finos/cdm/ScheduledTransferEnum#Principal> ] ;
          <corporateActionTransferType> [ <https://w3id.org/finos/cdm/CorporateActionTypeEnum#CashDividend>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#StockDividend>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#StockSplit>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#ReverseStockSplit>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#SpinOff>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#Merger>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#Delisting>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#StockNameChange>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#StockIdentifierChange>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#RightsIssue>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#Takeover>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#StockReclassification>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#BonusIssue>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#ClassAction>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#EarlyRedemption>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#Liquidation>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#BankruptcyOrInsolvency>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#IssuerNationalization>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#Relisting>
             <https://w3id.org/finos/cdm/CorporateActionTypeEnum#BespokeEvent> ] ? ;
          <payoutReference> @<Payout> ?
       ) ;
       rdf:type [ <ScheduledTransfer> ] ?
    )
}

<SchedulePeriod> CLOSED {
    (  $<SchedulePeriod_tes> (  <calculationPeriod> @<DateRange> ;
          <paymentDate> @linkml:Date ;
          <fixingPeriod> @<DateRange> ;
          <deliveryPeriod> @<CalculationScheduleDeliveryPeriods> ?
       ) ;
       rdf:type [ <SchedulePeriod> ] ?
    )
}

<SchmeNm> CLOSED {
    (  $<SchmeNm_tes> <prtry> @linkml:String ;
       rdf:type [ <SchmeNm> ] ?
    )
}

<SecuredDebt> CLOSED {
    (  $<SecuredDebt_tes> (  <securedType> [ <https://w3id.org/finos/cdm/SecuredTypeEnum#AssetBacked>
             <https://w3id.org/finos/cdm/SecuredTypeEnum#CollateralizedObligation>
             <https://w3id.org/finos/cdm/SecuredTypeEnum#CoveredBonds> ] ? ;
          <assetBacked> [ <https://w3id.org/finos/cdm/AssetBackedEnum#HomeEquity>
             <https://w3id.org/finos/cdm/AssetBackedEnum#AutoLoan> <https://w3id.org/finos/cdm/AssetBackedEnum#StudentLoan>
             <https://w3id.org/finos/cdm/AssetBackedEnum#CreditCard> <https://w3id.org/finos/cdm/AssetBackedEnum#Property>
             <https://w3id.org/finos/cdm/AssetBackedEnum#Mortgage> <https://w3id.org/finos/cdm/AssetBackedEnum#Other> ] ? ;
          <collateralizedObligation> [ <https://w3id.org/finos/cdm/CollateralizedObligationEnum#CDO>
             <https://w3id.org/finos/cdm/CollateralizedObligationEnum#CMO>
             <https://w3id.org/finos/cdm/CollateralizedObligationEnum#CLO>
             <https://w3id.org/finos/cdm/CollateralizedObligationEnum#CBO> ] ? ;
          <coveredBond> [ <https://w3id.org/finos/cdm/CoveredBondEnum#Pfandbriefe>
             <https://w3id.org/finos/cdm/CoveredBondEnum#JumboPfandbriefe> ] ? ;
          <propertyType> [ <https://w3id.org/finos/cdm/PropertyTypeEnum#Commercial>
             <https://w3id.org/finos/cdm/PropertyTypeEnum#Residential> ] ?
       ) ;
       rdf:type [ <SecuredDebt> ] ?
    )
}

<SecuredPartyRightsEvent> CLOSED {
    (  $<SecuredPartyRightsEvent_tes> (  <securedPartyRightsEventElection> @<SecuredPartyRightsEventElection> * ;
          <earlyTerminationDateOptionalLanguage> @linkml:Boolean ;
          <failureToPayEarlyTermination> @linkml:Boolean ?
       ) ;
       rdf:type [ <SecuredPartyRightsEvent> ] ?
    )
}

<SecuredPartyRightsEventElection> CLOSED {
    (  $<SecuredPartyRightsEventElection_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ;
          <rightsEvent> @linkml:Boolean
       ) ;
       rdf:type [ <SecuredPartyRightsEventElection> ] ?
    )
}

<Security> CLOSED {
    (  $<Security_tes> (  &<InstrumentBase_tes> ;
          rdf:type [ <InstrumentBase> ] ? ;
          <securityType> [ <https://w3id.org/finos/cdm/SecurityTypeEnum#Debt> <https://w3id.org/finos/cdm/SecurityTypeEnum#Equity>
             <https://w3id.org/finos/cdm/SecurityTypeEnum#Fund> <https://w3id.org/finos/cdm/SecurityTypeEnum#Warrant>
             <https://w3id.org/finos/cdm/SecurityTypeEnum#Certificate> ] ;
          <debtType> @<DebtType> ? ;
          <equityType> @<EquityType> ? ;
          <fundType> [ <https://w3id.org/finos/cdm/FundProductTypeEnum#MoneyMarketFund>
             <https://w3id.org/finos/cdm/FundProductTypeEnum#ExchangeTradedFund>
             <https://w3id.org/finos/cdm/FundProductTypeEnum#MutualFund> <https://w3id.org/finos/cdm/FundProductTypeEnum#OtherFund>
             ] ?
       ) ;
       rdf:type [ <Security> ] ?
    )
}

<SecurityAgreementElections> CLOSED {
    (  $<SecurityAgreementElections_tes> (  <pledgedAccount> @<Account> ? ;
          <enforcementEvent> @<EnforcementEvent> ? ;
          <deliveryInLieuRight> @linkml:Boolean ? ;
          <fullDischarge> @linkml:Boolean ? ;
          <appropriatedCollateralValuation> @<AppropriatedCollateralValuation> ? ;
          <processAgent> @<ProcessAgent> ;
          <jurisdictionRelatedTerms> @<JurisdictionRelatedTerms> ? ;
          <additionalAmendments> @linkml:String ? ;
          <additionalBespokeTerms> @linkml:String ? ;
          <executionTerms> @<ExecutionTerms> ?
       ) ;
       rdf:type [ <SecurityAgreementElections> ] ?
    )
}

<SecurityInterestForObligations> CLOSED {
    (  $<SecurityInterestForObligations_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] + ;
          <obligations> [ <https://w3id.org/finos/cdm/SecurityInterestObligationsEnum#NotApplicable>
             <https://w3id.org/finos/cdm/SecurityInterestObligationsEnum#AllObligationsOfPartyA>
             <https://w3id.org/finos/cdm/SecurityInterestObligationsEnum#AllObligationsOfPartyB>
             <https://w3id.org/finos/cdm/SecurityInterestObligationsEnum#Other> ] ;
          <obligee> [ <https://w3id.org/finos/cdm/SecurityInterestObligeeEnum#PartyA>
             <https://w3id.org/finos/cdm/SecurityInterestObligeeEnum#PartyAOrAffiliate>
             <https://w3id.org/finos/cdm/SecurityInterestObligeeEnum#PartyB>
             <https://w3id.org/finos/cdm/SecurityInterestObligeeEnum#PartyBOrAffiliate>
             <https://w3id.org/finos/cdm/SecurityInterestObligeeEnum#Other> ] ;
          <other> @linkml:String ?
       ) ;
       rdf:type [ <SecurityInterestForObligations> ] ?
    )
}

<SecurityLendingInvoice> CLOSED {
    (  $<SecurityLendingInvoice_tes> (  <sendingParty> @<Party> ;
          <receivingParty> @<Party> ;
          <billingStartDate> @linkml:Date ;
          <billingEndDate> @linkml:Date ;
          <billingRecord> @<BillingRecord> + ;
          <billingSummary> @<BillingSummary> +
       ) ;
       rdf:type [ <SecurityLendingInvoice> ] ?
    )
}

<SecurityLocate> CLOSED {
    (  $<SecurityLocate_tes> (  &<AvailableInventory_tes> ;
          rdf:type [ <AvailableInventory> ] ?
       ) ;
       rdf:type [ <SecurityLocate> ] ?
    )
}

<SecurityProviderRightsEvent> CLOSED {
    (  $<SecurityProviderRightsEvent_tes> (  <partyElection> @<SecurityProviderRightsEventElection> + ;
          <includeCoolingOffLanguage> @linkml:Boolean ;
          <fullDischarge> @linkml:Boolean ? ;
          <automaticSetOff> @linkml:Boolean ? ;
          <customElection> @linkml:String ?
       ) ;
       rdf:type [ <SecurityProviderRightsEvent> ] ?
    )
}

<SecurityProviderRightsEventElection> CLOSED {
    (  $<SecurityProviderRightsEventElection_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ;
          <rightsEvent> @linkml:Boolean
       ) ;
       rdf:type [ <SecurityProviderRightsEventElection> ] ?
    )
}

<Sellr> CLOSED {
    (  $<Sellr_tes> <acctOwnr> @<AcctOwnr> ;
       rdf:type [ <Sellr> ] ?
    )
}

<SensitivityMethodologies> CLOSED {
    (  $<SensitivityMethodologies_tes> <partyElection> @<SensitivityMethodologiesPartyElection> + ;
       rdf:type [ <SensitivityMethodologies> ] ?
    )
}

<SensitivityMethodologiesPartyElection> CLOSED {
    (  $<SensitivityMethodologiesPartyElection_tes> (  <party> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ;
          <sensitivityToEquity> @<SensitivityToEquity> ;
          <sensitivityToCommodity> @<SensitivityMethodology>
       ) ;
       rdf:type [ <SensitivityMethodologiesPartyElection> ] ?
    )
}

<SensitivityMethodology> CLOSED {
    (  $<SensitivityMethodology_tes> (  <specifiedMethodology> [ <https://w3id.org/finos/cdm/SensitivitiesEnum#Alternative>
             <https://w3id.org/finos/cdm/SensitivitiesEnum#Standard> ] ? ;
          <customMethodology> @linkml:String ?
       ) ;
       rdf:type [ <SensitivityMethodology> ] ?
    )
}

<SensitivityToEquity> CLOSED {
    (  $<SensitivityToEquity_tes> (  <sensitivityToIndices> @<SensitivityMethodology> ;
          <sensitivityToFunds> @<SensitivityMethodology> ;
          <sensitivityToETFs> @<SensitivityMethodology>
       ) ;
       rdf:type [ <SensitivityToEquity> ] ?
    )
}

<SettledEntityMatrix> CLOSED {
    (  $<SettledEntityMatrix_tes> (  <matrixSource> [
             <http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#ConfirmationAnnex>
             <http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#NotApplicable>
             <http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#Publisher> ] ;
          <publicationDate> @linkml:Date ?
       ) ;
       rdf:type [ <SettledEntityMatrix> ] ?
    )
}

<SettlementBase>  (
    CLOSED {
       (  $<SettlementBase_tes> (  <settlementType> [ <https://w3id.org/finos/cdm/SettlementTypeEnum#Cash>
                <https://w3id.org/finos/cdm/SettlementTypeEnum#Physical> <https://w3id.org/finos/cdm/SettlementTypeEnum#Election>
                <https://w3id.org/finos/cdm/SettlementTypeEnum#CashOrPhysical> ] ;
             <transferSettlementType> [ <https://w3id.org/finos/cdm/TransferSettlementEnum#DeliveryVersusDelivery>
                <https://w3id.org/finos/cdm/TransferSettlementEnum#DeliveryVersusPayment>
                <https://w3id.org/finos/cdm/TransferSettlementEnum#PaymentVersusPayment>
                <https://w3id.org/finos/cdm/TransferSettlementEnum#NotCentralSettlement> ] ? ;
             <settlementCurrency> @linkml:String ? ;
             <settlementDate> @<SettlementDate> ;
             <settlementCentre> [ <https://w3id.org/finos/cdm/SettlementCentreEnum#EuroclearBank>
                <https://w3id.org/finos/cdm/SettlementCentreEnum#ClearstreamBankingLuxembourg> ] ? ;
             <settlementProvision> @<SettlementProvision> ? ;
             <standardSettlementStyle> [ <https://w3id.org/finos/cdm/StandardSettlementStyleEnum#Standard>
                <https://w3id.org/finos/cdm/StandardSettlementStyleEnum#Net>
                <https://w3id.org/finos/cdm/StandardSettlementStyleEnum#StandardAndNet>
                <https://w3id.org/finos/cdm/StandardSettlementStyleEnum#PairAndNet> ] ?
          ) ;
          rdf:type [ <SettlementBase> ] ?
       )
    } OR @<SettlementTerms>
)

<SettlementDate> CLOSED {
    (  $<SettlementDate_tes> (  <adjustableOrRelativeDate> @<AdjustableOrAdjustedOrRelativeDate> ? ;
          <valueDate> @linkml:Date ;
          <adjustableDates> @<AdjustableDates> ? ;
          <businessDateRange> @<BusinessDateRange> ? ;
          <cashSettlementBusinessDays> @linkml:Integer ? ;
          <paymentDelay> @linkml:Boolean ?
       ) ;
       rdf:type [ <SettlementDate> ] ?
    )
}

<SettlementPayout> CLOSED {
    (  $<SettlementPayout_tes> (  &<PayoutBase_tes> ;
          rdf:type [ <PayoutBase> ] ? ;
          <underlier> @<Underlier> ;
          <deliveryTerm> @linkml:String ? ;
          <delivery> @<AssetDeliveryInformation> ? ;
          <schedule> @<CalculationSchedule> *
       ) ;
       rdf:type [ <SettlementPayout> ] ?
    )
}

<SettlementProvision> CLOSED {
    (  $<SettlementProvision_tes> <shapingProvisions> @<ShapingProvision> ? ;
       rdf:type [ <SettlementProvision> ] ?
    )
}

