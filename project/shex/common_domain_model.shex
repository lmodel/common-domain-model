<TradeState> CLOSED {
    (  $<TradeState_tes> (  <trade> @<Trade> ;
          <state> @<State> ? ;
          <resetHistory> @<Reset> * ;
          <transferHistory> @<TransferState> * ;
          <observationHistory> @<ObservationEvent> * ;
          <valuationHistory> @<Valuation> *
       ) ;
       rdf:type [ <TradeState> ] ?
    )
}

<Tranche> CLOSED {
    (  $<Tranche_tes> (  <attachmentPoint> @linkml:Decimal ;
          <exhaustionPoint> @linkml:Decimal ;
          <incurredRecoveryApplicable> @linkml:Boolean ?
       ) ;
       rdf:type [ <Tranche> ] ?
    )
}

<TransactedPrice> CLOSED {
    (  $<TransactedPrice_tes> (  <marketFixedRate> @linkml:Decimal ? ;
          <initialPoints> @linkml:Decimal ? ;
          <marketPrice> @linkml:Decimal ? ;
          <quotationStyle> [ <https://w3id.org/finos/cdm/QuotationStyleEnum#PointsUpFront>
             <https://w3id.org/finos/cdm/QuotationStyleEnum#TradedSpread> <https://w3id.org/finos/cdm/QuotationStyleEnum#Price> ] ?
       ) ;
       rdf:type [ <TransactedPrice> ] ?
    )
}

<TransactionAdditionalTerms> CLOSED {
    (  $<TransactionAdditionalTerms_tes> (  <equityAdditionalTerms> @<EquityAdditionalTerms> ? ;
          <foreignExchangeAdditionalTerms> @<FxAdditionalTerms> ? ;
          <commoditiesAdditionalTerms> @linkml:String ? ;
          <creditAdditionalTerms> @linkml:String ? ;
          <interestRateAdditionalTerms> @linkml:String ? ;
          <digitalAssetAdditionalTerms> @linkml:String ?
       ) ;
       rdf:type [ <TransactionAdditionalTerms> ] ?
    )
}

<Transfer> {
    (  $<Transfer_tes> rdf:type . * ;
       rdf:type [ <Transfer> ] ?
    )
}

<TransferableProduct> CLOSED {
    (  $<TransferableProduct_tes> (  &<Asset_tes> ;
          rdf:type [ <Asset> ] ? ;
          <economicTerms> @<EconomicTerms>
       ) ;
       rdf:type [ <TransferableProduct> ] ?
    )
}

<TransferBase>  (
    CLOSED {
       (  $<TransferBase_tes> (  &<AssetFlowBase_tes> ;
             rdf:type [ <AssetFlowBase> ] ? ;
             <identifier> @<Identifier> + ;
             <payerReceiver> @<PartyReferencePayerReceiver>
          ) ;
          rdf:type [ <TransferBase> ] ?
       )
    } OR @<ScheduledTransfer> OR @<UnscheduledTransfer>
)

<TransferContactInformation> CLOSED {
    (  $<TransferContactInformation_tes> (  &<ContactInformation_tes> ;
          rdf:type [ <ContactInformation> ] ? ;
          <account> @<Account> * ;
          <additionalInformation> @linkml:String ?
       ) ;
       rdf:type [ <TransferContactInformation> ] ?
    )
}

<TransferInformationElection> CLOSED {
    (  $<TransferInformationElection_tes> (  &<ContactInformationElection_tes> ;
          rdf:type [ <ContactInformationElection> ] ?
       ) ;
       rdf:type [ <TransferInformationElection> ] ?
    )
}

<TransferInstruction> CLOSED {
    (  $<TransferInstruction_tes> <transferState> @<TransferState> * ;
       rdf:type [ <TransferInstruction> ] ?
    )
}

<TransferSettlementTiming> CLOSED {
    (  $<TransferSettlementTiming_tes> (  <cashCollateralTransferSettlementTime> [
             <https://w3id.org/finos/cdm/CashCTSTimeEnum#Same> <https://w3id.org/finos/cdm/CashCTSTimeEnum#Next>
             <https://w3id.org/finos/cdm/CashCTSTimeEnum#FirstLBD> <https://w3id.org/finos/cdm/CashCTSTimeEnum#SecondLBD>
             <https://w3id.org/finos/cdm/CashCTSTimeEnum#Other> ] ? ;
          <securititesCollateralTransferSettlementTime> [ <https://w3id.org/finos/cdm/SecuritiesCTSTimeEnum#Same>
             <https://w3id.org/finos/cdm/SecuritiesCTSTimeEnum#Next> <https://w3id.org/finos/cdm/SecuritiesCTSTimeEnum#FirstDay>
             <https://w3id.org/finos/cdm/SecuritiesCTSTimeEnum#SecondDay>
             <https://w3id.org/finos/cdm/SecuritiesCTSTimeEnum#ThirdDay> <https://w3id.org/finos/cdm/SecuritiesCTSTimeEnum#Other> ]
          ? ;
          <additionalLanguage> @linkml:String ?
       ) ;
       rdf:type [ <TransferSettlementTiming> ] ?
    )
}

<TransferState> CLOSED {
    (  $<TransferState_tes> (  <transfer> @<Transfer> ;
          <transferStatus> [ <https://w3id.org/finos/cdm/TransferStatusEnum#Disputed>
             <https://w3id.org/finos/cdm/TransferStatusEnum#Instructed> <https://w3id.org/finos/cdm/TransferStatusEnum#Pending>
             <https://w3id.org/finos/cdm/TransferStatusEnum#Settled> <https://w3id.org/finos/cdm/TransferStatusEnum#Netted> ] ?
       ) ;
       rdf:type [ <TransferState> ] ?
    )
}

<Trigger> CLOSED {
    (  $<Trigger_tes> (  <level> @<PriceSchedule> * ;
          <creditEvents> @<CreditEvents> ? ;
          <creditEventsReference> @<CreditEvents> ? ;
          <triggerType> [ <https://w3id.org/finos/cdm/TriggerTypeEnum#EqualOrLess>
             <https://w3id.org/finos/cdm/TriggerTypeEnum#EqualOrGreater> <https://w3id.org/finos/cdm/TriggerTypeEnum#Equal>
             <https://w3id.org/finos/cdm/TriggerTypeEnum#Less> <https://w3id.org/finos/cdm/TriggerTypeEnum#Greater> ] ? ;
          <triggerTimeType> [ <https://w3id.org/finos/cdm/TriggerTimeTypeEnum#Closing>
             <https://w3id.org/finos/cdm/TriggerTimeTypeEnum#Anytime> ] ?
       ) ;
       rdf:type [ <Trigger> ] ?
    )
}

<TriggerEvent> CLOSED {
    (  $<TriggerEvent_tes> (  <schedule> @<AveragingSchedule> * ;
          <triggerDates> @<DateList> ? ;
          <trigger> @<Trigger> ;
          <featurePayment> @<FeaturePayment> ?
       ) ;
       rdf:type [ <TriggerEvent> ] ?
    )
}

<Tx> CLOSED {
    (  $<Tx_tes> (  <newTx> @<New> ;
          <tradDt> @linkml:String ;
          <tradgCpcty> @linkml:String ;
          <qty> @<Qty> ;
          <pric> @<Pric> ;
          <tradVn> @linkml:String ;
          <ctryOfBrnch> @linkml:String
       ) ;
       rdf:type [ <Tx> ] ?
    )
}

<UmbrellaAgreement> CLOSED {
    (  $<UmbrellaAgreement_tes> <agreementSet> @<UmbrellaAgreementSet> + ;
       rdf:type [ <UmbrellaAgreement> ] ?
    )
}

<UmbrellaAgreementParty> CLOSED {
    (  $<UmbrellaAgreementParty_tes> (  <party> @<Party> ? ;
          <actingAs> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ? ;
          <partyRole> [ <https://w3id.org/finos/cdm/UmbrellaPartyRoleEnum#Agent>
             <https://w3id.org/finos/cdm/UmbrellaPartyRoleEnum#InvestmentManager>
             <https://w3id.org/finos/cdm/UmbrellaPartyRoleEnum#Principal>
             <https://w3id.org/finos/cdm/UmbrellaPartyRoleEnum#SubAccount>
             <https://w3id.org/finos/cdm/UmbrellaPartyRoleEnum#Sleeve> ] ? ;
          <nonLegalEntity> @<NonLegalEntity> ? ;
          <parentParty> @<Party> ?
