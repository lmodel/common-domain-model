<Indx> CLOSED {
    (  $<Indx_tes> <nm> @<Nm> ;
       rdf:type [ <Indx> ] ?
    )
}

<IneligibleCreditSupport> CLOSED {
    (  $<IneligibleCreditSupport_tes> (  <totalIneligibilityDate> @linkml:String ? ;
          <transferIneligibilityDate> @linkml:String ? ;
          <specifiedParty> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] *
       ) ;
       rdf:type [ <IneligibleCreditSupport> ] ?
