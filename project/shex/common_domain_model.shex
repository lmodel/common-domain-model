          <amount> @linkml:Decimal ;
          <time> [ <https://w3id.org/finos/cdm/TimeTypeEnum#Close> <https://w3id.org/finos/cdm/TimeTypeEnum#Open>
             <https://w3id.org/finos/cdm/TimeTypeEnum#OSP> <https://w3id.org/finos/cdm/TimeTypeEnum#SpecificTime>
             <https://w3id.org/finos/cdm/TimeTypeEnum#XETRA> <https://w3id.org/finos/cdm/TimeTypeEnum#DerivativesClose>
             <https://w3id.org/finos/cdm/TimeTypeEnum#AsSpecifiedInMasterConfirmation> ] ;
          <currency> @linkml:String ? ;
          <paymentDate> @<AdjustableOrRelativeDate> ?
       ) ;
       rdf:type [ <FeaturePayment> ] ?
    )
}

<FinalCalculationPeriodDateAdjustment> CLOSED {
    (  $<FinalCalculationPeriodDateAdjustment_tes> (  <relevantUnderlyingDateReference> @<AdjustableOrRelativeDates> ;
          <swapStreamReference> @<InterestRatePayout> ;
