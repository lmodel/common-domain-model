             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentIndependent>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentOptionalEarlyTermination>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentMandatoryEarlyTermination>
             <https://w3id.org/finos/cdm/AncillaryRoleEnum#CalculationAgentFallback> ] ;
          <partyReference> @<Party> + ;
          <onBehalfOf> [ <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party1>
             <https://w3id.org/finos/cdm/CounterpartyRoleEnum#Party2> ] ?
       ) ;
       rdf:type [ <AncillaryParty> ] ?
    )
}

<AnyCriteria> CLOSED {
    (  $<AnyCriteria_tes> <anyCriteria> @<CollateralCriteria> + ;
       rdf:type [ <AnyCriteria> ] ?
    )
}

<AnyDirectionRating> CLOSED {
    (  $<AnyDirectionRating_tes> <anyDirectionRating> @<DirectionRatingSet> + ;
       rdf:type [ <AnyDirectionRating> ] ?
    )
}

<AnyEligibilityToHoldCollateralCriteria> CLOSED {
    (  $<AnyEligibilityToHoldCollateralCriteria_tes> <anyCriteria> @<EligibilityToHoldCollateralCriteria> + ;
