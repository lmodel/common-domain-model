    )
}

<ApplicableRegime> CLOSED {
    (  $<ApplicableRegime_tes> (  <regime> [ <https://w3id.org/finos/cdm/RegulatoryRegimeEnum#AustraliaMarginRules>
             <https://w3id.org/finos/cdm/RegulatoryRegimeEnum#CanadaMarginRules>
