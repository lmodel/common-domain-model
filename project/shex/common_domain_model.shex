          <namedAffiliate> @linkml:String ? ;
          <compare> [ <https://w3id.org/finos/cdm/CreditNotationMismatchResolutionEnum#Lowest>
             <https://w3id.org/finos/cdm/CreditNotationMismatchResolutionEnum#Highest>
             <https://w3id.org/finos/cdm/CreditNotationMismatchResolutionEnum#ReferenceAgency>
             <https://w3id.org/finos/cdm/CreditNotationMismatchResolutionEnum#Average>
             <https://w3id.org/finos/cdm/CreditNotationMismatchResolutionEnum#SecondBest>
             <https://w3id.org/finos/cdm/CreditNotationMismatchResolutionEnum#Other> ] ? ;
          <noRating> @linkml:Boolean ;
          <notRatedBy> [ <https://w3id.org/finos/cdm/NotRatedByEnum#All> <https://w3id.org/finos/cdm/NotRatedByEnum#One>
             <https://w3id.org/finos/cdm/NotRatedByEnum#Two> ] ? ;
          <numberOfRatingAgencies> [ <https://w3id.org/finos/cdm/NumberOfRatingAgenciesEnum#All>
             <https://w3id.org/finos/cdm/NumberOfRatingAgenciesEnum#AnyOne>
             <https://w3id.org/finos/cdm/NumberOfRatingAgenciesEnum#AnyTwo>
             <https://w3id.org/finos/cdm/NumberOfRatingAgenciesEnum#Other> ] ?
       ) ;
       rdf:type [ <ThresholdRatingsBased> ] ?
    )
}

<TimeRounding> CLOSED {
    (  $<TimeRounding_tes> (  <roundingDirection> [ <https://w3id.org/finos/cdm/RoundingDirectionEnum#Up>
             <https://w3id.org/finos/cdm/RoundingDirectionEnum#Down> <https://w3id.org/finos/cdm/RoundingDirectionEnum#Nearest> ] ;
          <roundToUnit> [ <https://w3id.org/finos/cdm/TimeUnitEnum#Second> <https://w3id.org/finos/cdm/TimeUnitEnum#Minute>
             <https://w3id.org/finos/cdm/TimeUnitEnum#Hour> <https://w3id.org/finos/cdm/TimeUnitEnum#Day>
             <https://w3id.org/finos/cdm/TimeUnitEnum#Week> <https://w3id.org/finos/cdm/TimeUnitEnum#Month>
             <https://w3id.org/finos/cdm/TimeUnitEnum#Year> ] ?
       ) ;
       rdf:type [ <TimeRounding> ] ?
    )
}

<TimeZone> CLOSED {
    (  $<TimeZone_tes> (  <time> @linkml:Time ;
          <location> @linkml:String ?
       ) ;
       rdf:type [ <TimeZone> ] ?
    )
}

<TradableProduct>  (
    CLOSED {
       (  $<TradableProduct_tes> (  <product> @<NonTransferableProduct> ;
             <tradeLot> @<TradeLot> + ;
             <counterparty> @<Counterparty> + ;
             <ancillaryParty> @<AncillaryParty> * ;
             <adjustment> [ <https://w3id.org/finos/cdm/NotionalAdjustmentEnum#Execution>
                <https://w3id.org/finos/cdm/NotionalAdjustmentEnum#PortfolioRebalancing>
                <https://w3id.org/finos/cdm/NotionalAdjustmentEnum#Standard> ] ?
          ) ;
          rdf:type [ <TradableProduct> ] ?
       )
    } OR @<Trade>
)

<Trade> CLOSED {
    (  $<Trade_tes> (  &<TradableProduct_tes> ;
          rdf:type [ <TradableProduct> ] ? ;
          <tradeIdentifier> @<TradeIdentifier> + ;
          <tradeDate> @linkml:Date ;
          <tradeTime> @<TimeZone> ? ;
          <party> @<Party> * ;
          <partyRole> @<PartyRole> * ;
          <executionDetails> @<ExecutionDetails> ;
          <contractDetails> @<ContractDetails> ? ;
          <clearedDate> @linkml:Date ? ;
          <collateral> @<Collateral> ? ;
          <account> @<Account> *
       ) ;
       rdf:type [ <Trade> ] ?
    )
}

<TradeIdentifier> CLOSED {
    (  $<TradeIdentifier_tes> (  &<Identifier_tes> ;
          rdf:type [ <Identifier> ] ? ;
          <identifierType> [ <https://w3id.org/finos/cdm/TradeIdentifierTypeEnum#UniqueTransactionIdentifier>
             <https://w3id.org/finos/cdm/TradeIdentifierTypeEnum#UniqueSwapIdentifier> ]
       ) ;
       rdf:type [ <TradeIdentifier> ] ?
    )
}

<TradeLot> CLOSED {
    (  $<TradeLot_tes> (  <lotIdentifier> @<Identifier> * ;
          <priceQuantity> @<PriceQuantity> +
       ) ;
       rdf:type [ <TradeLot> ] ?
    )
}

