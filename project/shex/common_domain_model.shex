             <https://w3id.org/finos/cdm/DayCountFractionEnum#CAL_252> <https://w3id.org/finos/cdm/DayCountFractionEnum#_1_1>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#_30E_360>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#_30E_360_ISDA>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#_30_360>
             <https://w3id.org/finos/cdm/DayCountFractionEnum#RBA_BOND_BASIS> ] ;
          <calculationPeriodDates> @<CalculationPeriodDates> ? ;
          <paymentDates> @<PaymentDates> ;
          <paymentDate> @<AdjustableDate> ? ;
          <paymentDelay> @linkml:Boolean ? ;
          <resetDates> @<ResetDates> ? ;
          <discountingMethod> @<DiscountingMethod> ? ;
          <compoundingMethod> [ <https://w3id.org/finos/cdm/CompoundingMethodEnum#Flat>
             <https://w3id.org/finos/cdm/CompoundingMethodEnum#None> <https://w3id.org/finos/cdm/CompoundingMethodEnum#Straight>
             <https://w3id.org/finos/cdm/CompoundingMethodEnum#SpreadExclusive> ] ? ;
          <cashflowRepresentation> @<CashflowRepresentation> ? ;
          <stubPeriod> @<StubPeriod> ? ;
          <bondReference> @<BondReference> ? ;
          <fixedAmount> @linkml:String ? ;
          <floatingAmount> @linkml:String ? ;
          <spreadCalculationMethod> [ <https://w3id.org/finos/cdm/SpreadCalculationMethodEnum#ParPar>
             <https://w3id.org/finos/cdm/SpreadCalculationMethodEnum#Proceeds> ] ?
       ) ;
       rdf:type [ <InterestRatePayout> ] ?
    )
}

