       ) ;
       rdf:type [ <FloatingAmountEvents> ] ?
    )
}

<FloatingAmountProvisions> CLOSED {
    (  $<FloatingAmountProvisions_tes> (  <wacCapInterestProvision> @linkml:Boolean ? ;
          <stepUpProvision> @linkml:Boolean ?
       ) ;
       rdf:type [ <FloatingAmountProvisions> ] ?
    )
}

<FloatingRate>  (
    CLOSED {
       (  $<FloatingRate_tes> (  &<FloatingRateBase_tes> ;
             rdf:type [ <FloatingRateBase> ] ? ;
             <floatingRateMultiplierSchedule> @<RateSchedule> ? ;
