<Basket> CLOSED {
    (  $<Basket_tes> (  &<AssetBase_tes> ;
          rdf:type [ <AssetBase> ] ? ;
          <basketConstituent> @<BasketConstituent> +
       ) ;
       rdf:type [ <Basket> ] ?
    )
}

<BasketConstituent> CLOSED {
    (  $<BasketConstituent_tes> (  &<Observable_tes> ;
