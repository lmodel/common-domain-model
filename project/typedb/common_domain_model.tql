  # Relations (from object-ranged slots)
  relation dateadjustments,
      relates adjustabledate,
      relates businessdayadjustments,
      relates adjustabledates,
      relates adjustableoradjusteddate,
      relates adjustableoradjustedorrelativedate,
      relates dividendperiod,
