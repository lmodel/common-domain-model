            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:floatingRateIndex ] ;
    sh:targetClass common_domain_model:FloatingRateIndex .

common_domain_model:FxSpotRateSource a sh:NodeShape ;
    rdfs:comment "A class defining the rate source and fixing time for an FX rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InformationSource ;
            sh:description "An alternative, or secondary, source for where the rate observation will occur. Will typically be either a page or a reference bank published rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:secondarySource ],
        [ sh:class common_domain_model:InformationSource ;
            sh:description "The primary source for where the rate observation will occur. Will typically be either a page or a reference bank published rate." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:primarySource ] ;
    sh:targetClass common_domain_model:FxSpotRateSource .

common_domain_model:InflationIndex a sh:NodeShape ;
    rdfs:comment "Specification of an index that measures inflation in a specific market, e.g. the US Consumer Price Index." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:Period ;
            sh:description "The ISDA Designated Maturity, i.e. the floating rate tenor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:indexTenor ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The organisation that creates or maintains the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:provider ],
        [ sh:description "The reference index that is used to specify the inflation interest rate." ;
            sh:in ( "AUD_CPI" "AUS_CPI" "AUS_HICP" "BLG_CPI_GI" "BLG_CPI_HI" "BLG_HICP" "BRL_IGPM" "BRL_IPCA" "CAD_CPI" "CLP_CPI" "CNY_CPI" "CZK_CPI" "DEK_CPI" "DEK_HICP" "DEM_CPI" "DEM_CPI_NRW" "DEM_HICP" "ESP_CPI" "ESP_HICP" "ESP_R_CPI" "ESP_R_HICP" "EUR_AI_CPI" "EUR_AI_R_CPI" "EUR_EXT_CPI" "EUR_EXT_R_CPI" "FIN_CPI" "FIN_HICP" "FRC_EXT_CPI" "FRC_HICP" "GRD_CPI" "GRD_HICP" "HKD_CPI" "HUF_CPI" "IDR_CPI" "ILS_CPI" "IRL_CPI" "IRL_HICP" "ISK_CPI" "ISK_HICP" "ITL_BC_EXT_CPI" "ITL_BC_INT_CPI" "ITL_HICP" "ITL_WC_EXT_CPI" "ITL_WC_INT_CPI" "JPY_CPI_EXF" "KRW_CPI" "LUX_CPI" "LUX_HICP" "MXN_CPI" "MXN_UDI" "MYR_CPI" "NLG_CPI" "NLG_HICP" "NOK_CPI" "NZD_CPI" "PER_CPI" "PLN_CPI" "POR_CPI" "POR_HICP" "RUB_CPI" "SEK_CPI" "SGD_CPI" "SWF_CPI" "TRY_CPI" "TWD_CPI" "UK_CPIH" "UK_HICP" "UK_RPI" "UK_RPIX" "USA_CPI_U" "ZAR_CPI" "ZAR_CPIX" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:inflationRateIndex ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:name ],
        [ sh:description "The Asset Class of the Index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:assetClass ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:assetType ] ;
    sh:targetClass common_domain_model:InflationIndex .

common_domain_model:InterestRatePayout a sh:NodeShape ;
    rdfs:comment " A class to specify all of the terms necessary to define and calculate a cash flow based on a fixed, a floating or an inflation index rate. The interest rate payout can be applied to interest rate swaps and FRA (which both have two associated interest rate payouts), credit default swaps (to represent the fee leg when subject to periodic payments) and equity swaps (to represent the funding leg). The associated globalKey denotes the ability to associate a hash value to the InterestRatePayout instantiations for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Method by which spread is calculated. For example on an asset swap: 'ParPar' or 'Proceeds' may be the method indicated." ;
            sh:in ( "ParPar" "Proceeds" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path common_domain_model:spreadCalculationMethod ],
        [ sh:class common_domain_model:PaymentDates ;
            sh:description "The payment date schedule, as defined by the parameters that are needed to specify it, either in a parametric way or by reference to another schedule of dates (e.g. the reset dates)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:paymentDates ],
        [ sh:datatype xsd:string ;
            sh:description "Fixed Amount Calculation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path common_domain_model:fixedAmount ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:datatype xsd:string ;
            sh:description "Floating Amount Calculation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path common_domain_model:floatingAmount ],
        [ sh:description "The specification of the rate value(s) applicable to the contract using either a floating rate calculation, a single fixed rate, a fixed rate schedule, or an inflation rate calculation." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:FixedRateSpecification ] [ sh:class common_domain_model:FloatingRateSpecification ] [ sh:class common_domain_model:InflationRateSpecification ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:rateSpecification ],
        [ sh:description "The day count fraction. The cardinality has been relaxed when compared with the FpML interest rate swap for the purpose of accommodating standardized credit default swaps which DCF is not explicitly stated as part of the economic terms. The data rule InterestRatePayout_dayCountFraction requires that the DCF be stated for interest rate products." ;
            sh:in ( "ACT_360" "ACT_365L" "ACT_364" "ACT_365_FIXED" "ACT_ACT_AFB" "ACT_ACT_ICMA" "ACT_ACT_ISDA" "ACT_ACT_ISMA" "CAL_252" "_1_1" "_30E_360" "_30E_360_ISDA" "_30_360" "RBA_BOND_BASIS" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:dayCountFraction ],
        [ sh:class common_domain_model:DiscountingMethod ;
            sh:description "The parameters specifying any discounting conventions that may apply. This element must only be included if discounting applies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:discountingMethod ],
        [ sh:class common_domain_model:AdjustableDate ;
            sh:description "The payment date, where only one date is specified, as for the FRA product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:paymentDate ],
        [ sh:class common_domain_model:CashflowRepresentation ;
            sh:description "The cashflow representation of the swap stream." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:cashflowRepresentation ],
        [ sh:class common_domain_model:StubPeriod ;
            sh:description "The stub calculation period amount parameters. This element must only be included if there is an initial or final stub calculation period. Even then, it must only be included if either the stub references a different floating rate tenor to the regular calculation periods, or if the stub is calculated as a linear interpolation of two different floating rate tenors, or if a specific stub rate or stub amount has been negotiated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:stubPeriod ],
        [ sh:class common_domain_model:ResetDates ;
            sh:description "The reset dates schedule, i.e. the dates on which the new observed index value is applied for each period and the interest rate hence begins to accrue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:resetDates ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:CalculationPeriodDates ;
            sh:description "The parameters used to generate the calculation period dates schedule, including the specification of any initial or final stub calculation periods." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:calculationPeriodDates ],
        [ sh:datatype xsd:boolean ;
            sh:description "Applicable to CDS on MBS to specify whether payment delays are applicable to the fixed Amount. RMBS typically have a payment delay of 5 days between the coupon date of the reference obligation and the payment date of the synthetic swap. CMBS do not, on the other hand, with both payment dates being on the 25th of each month." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:paymentDelay ],
        [ sh:class common_domain_model:BondReference ;
            sh:description "Reference to a bond underlier to represent an asset swap or Condition Precedent Bond." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:bondReference ],
        [ sh:description "If one or more calculation period contributes to a single payment amount this element specifies whether compounding is applicable and, if so, what compounding method is to be used. This element must only be included when more than one calculation period contributes to a single payment amount." ;
            sh:in ( "Flat" "None" "Straight" "SpreadExclusive" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:compoundingMethod ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path common_domain_model:principalPayment ] ;
    sh:targetClass common_domain_model:InterestRatePayout .

common_domain_model:LegalAgreement a sh:NodeShape ;
    rdfs:comment "The specification of a legal agreement between two parties, being negotiated or having been executed. This includes the baseline information and the optional specialised elections" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UmbrellaAgreement ;
            sh:description "Specifies a set of legal entities which are part of a legal agreement beyond the two contracting parties to that agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:umbrellaAgreement ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the legal agreement has been agreed between the parties. This corresponds to the Date of Deed in an English Law document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:agreementDate ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "The role(s) that other party(ies) may have in relation to the legal agreement, further to the contractual parties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:otherParty ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which, or as of which, the agreement is effective, if different from the agreement date. It is expected that it will most often correspond to the agreement date, although there could be situations where the parties will explicitly agree on a distinct effective date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:class common_domain_model:Party ;
            sh:description "The two contractual parties to the legal agreement, which reference information is positioned as part of the partyInformation attribute." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:contractualParty ],
        [ sh:class common_domain_model:LegalAgreement ;
            sh:description "Specifies the agreement(s) that govern the agreement, either as a reference to such agreements when specified as part of the CDM, or through identification of some of the key terms of those agreements, such as the type of agreement, the publisher, the vintage, the agreement identifier and the agreement date." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:relatedAgreements ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "The legal agreement identifier. Several identifiers can be specified." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalAgreementIdentification ;
            sh:description "The type of legal agreement, identified via a set of composable attributes: agreementName, publisher, governing law and version, e.g. ISDA 2013 Standard Credit Support Annex English Law." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:legalAgreementIdentification ],
        [ sh:class common_domain_model:Resource ;
            sh:description "A human readable document, for example a confirmation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:attachment ],
        [ sh:class common_domain_model:AgreementTerms ;
            sh:description "Specification of the content of the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:agreementTerms ] ;
    sh:targetClass common_domain_model:LegalAgreement .

common_domain_model:Measure a sh:NodeShape ;
    rdfs:comment "Defines a concrete measure as a number associated to a unit. It extends MeasureBase by requiring the value attribute to be present. A measure may be unit-less so the unit attribute is still optional." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:unit ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:Measure .

common_domain_model:MinimumTransferAmount a sh:NodeShape ;
    rdfs:comment "Represents the threshold specified in the agreement below which collateral need not be delivered, and represents the smallest incremental value of exposure that must be reached before the parties are obliged to transfer collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MinimumTransferAmountElection ;
            sh:description "The party specific elections for the Minimum Transfer Amount clause." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:MinimumTransferAmount .

common_domain_model:NonNegativeQuantity a sh:NodeShape ;
    rdfs:comment "Specifies a quantity as a non-negative number, which condition is enforced through a data rule that only applies to the extending class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Frequency ;
            sh:description "Defines the frequency to be used when defining a quantity. For example a quantity may be specified as a number of barrels of oil per day, which needs multiplying by the number of days in the relevant period to get the total quantity as a number of barrels." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:frequency ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:value ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:datedValue ],
        [ sh:class common_domain_model:Measure ;
            sh:description "Defines an optional number that the quantity should be multiplied by to derive a total quantity. This number is associated to a unit. For example in the case of the Coal (API2) CIF ARA (ARGUS-McCloskey) Futures Contract on the CME, where the unit would be contracts, the multiplier value would 1,000 and the mulitiplier unit would be 1,000 MT (Metric Tons)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:multiplier ],
        [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:unit ] ;
    sh:targetClass common_domain_model:NonNegativeQuantity .

common_domain_model:NonTransferableProduct a sh:NodeShape ;
    rdfs:comment "A data type to specify the financial product's economic terms, alongside the product identification and product taxonomy. The non-transferable product data type represents a product that can be traded (as part of a TradableProduct) but cannot be transferred to others.  It is meant to be used across the pre-execution, execution and (as part of the Contract) post-execution lifecycle contexts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ProductTaxonomy ;
            sh:description "Specifies the product taxonomy, which is composed of a taxonomy value and a taxonomy source." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:class common_domain_model:EconomicTerms ;
            sh:description "The price forming features, including payouts and provisions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:economicTerms ],
        [ sh:class common_domain_model:ProductIdentifier ;
            sh:description "Comprises a identifier and a source to uniquely identify the nonTransferableProduct. " ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ] ;
    sh:targetClass common_domain_model:NonTransferableProduct .

common_domain_model:NotificationTime a sh:NodeShape ;
    rdfs:comment "Specifies the time by which a demand for the Transfer of Eligible Credit Support or Posted Credit Support needs to be made in order for the transfer to take place in accordance with the Transfer Timing provisions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The determination of whether reference is made to dispute resolution notification timing in the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:disputeNotificationReference ],
        [ sh:datatype xsd:boolean ;
            sh:description "The determination of whether transfer timing language is applicable or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:transferTimingProviso ],
        [ sh:class common_domain_model:NotificationTimeElection ;
            sh:description "The parties' Notification Time election." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElections ] ;
    sh:targetClass common_domain_model:NotificationTime .

common_domain_model:OptionPayout a sh:NodeShape ;
    rdfs:comment " The option payout specification terms. The associated globalKey denotes the ability to associate a hash value to the respective OptionPayout instantiation for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:principalPayment ],
        [ sh:class common_domain_model:CalculationSchedule ;
            sh:description "Allows the full representation of a payout by defining a set of schedule periods. It supports standard schedule customization by expressing all the dates, quantities, and pricing data in a non-parametric way." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:schedule ],
        [ sh:class common_domain_model:ObservationTerms ;
            sh:description "Class containing terms that are associated with observing a price/benchmark/index across either single or multple observations. To be used for option contracts that reference a benchmark price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:observationTerms ],
        [ sh:class common_domain_model:OptionStrike ;
            sh:description "Specifies the strike of the option" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:strike ],
        [ sh:class common_domain_model:AssetDeliveryInformation ;
            sh:description "Contains the information relative to the delivery of the asset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:delivery ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:ExerciseTerms ;
            sh:description "The terms for exercising the option, which include the option style (e.g. American style option), the exercise procedure (e.g. manual exercise) and the settlement terms (e.g. physical vs. cash)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:exerciseTerms ],
        [ sh:class common_domain_model:OptionFeature ;
            sh:description "The option feature, such as quanto, Asian, barrier, knock." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:feature ],
        [ sh:class common_domain_model:BuyerSeller ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:buyerSeller ],
        [ sh:description "The financial product underlying the option, which can be of any type including an Asset, Basket, Index or a NonTransferableProduct." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Observable ] [ sh:class common_domain_model:Product ] ) ;
            sh:order 5 ;
            sh:path common_domain_model:underlier ],
        [ sh:description "The type of option transaction. From a usage standpoint, put/call is the default option type, while payer/receiver indicator is used for options on index credit default swaps, consistently with the industry practice. Straddle is used for the case of straddle strategy, that combine a call and a put with the same strike." ;
            sh:in ( "Payer" "Receiver" <http://www.fpml.org/coding-scheme/option-type-1-0#Straddle> ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:optionType ] ;
    sh:targetClass common_domain_model:OptionPayout .

common_domain_model:PartyReferencePayerReceiver a sh:NodeShape ;
    rdfs:comment "Specifies the parties responsible for making and receiving payments defined by this structure." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:paymentDetail ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "The party that receives the payments corresponding to this structure." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:receiverPartyReference ],
        [ sh:class common_domain_model:Account ;
            sh:description "A reference to the account responsible for making the payments defined by this structure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:payerAccountReference ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party responsible for making the payments defined by this structure." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:payerPartyReference ],
        [ sh:class common_domain_model:Account ;
            sh:description "A reference to the account that receives the payments corresponding to this structure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:receiverAccountReference ] ;
    sh:targetClass common_domain_model:PartyReferencePayerReceiver .

common_domain_model:PaymentDiscounting a sh:NodeShape ;
    rdfs:comment "This class corresponds to the FpML PaymentDiscounting.model group for representing the discounting elements that can be associated with a payment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The value representing the discount factor used to calculate the present value of the cash flow." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:discountFactor ],
        [ sh:class common_domain_model:Money ;
            sh:description "The amount representing the present value of the forecast payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:presentValueAmount ] ;
    sh:targetClass common_domain_model:PaymentDiscounting .

common_domain_model:SettlementRateOption a sh:NodeShape ;
    rdfs:comment "Defines the settlement rate option to use for fixing in case of cash settlement. Currently only applicable to foreign exchange fixing in case of cross-currency settlement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The rate source for the conversion to the settlement currency. This source is specified through a scheme that reflects the terms of the Annex A to the 1998 FX and Currency Option Definitions." ;
            sh:in ( "ARS_BNAR_ARS01" "ARS_EMTA_INDICATIVE_SURVEY_RATE_ARS04" "ARS_EMTA_INDUSTRY_SURVEY_RATE_ARS03" "ARS_MAE_ARS05" "ARS_OFFICIAL_RATE_ARS02" "BRL_BRBY_BRL01" "BRL_EMTA_INDICATIVE_SURVEY_RATE_BRL13" "BRL_EMTA_INDUSTRY_SURVEY_RATE_BRL12" "BRL_OFFICIAL_RATE_BRL02" "BRL_PCOT_COMMERCIAL_BRL03" "BRL_PCOT_FLOATING_BRL04" "BRL_PTAX_BRL09" "BRL_PTAX_COMMERCIAL_BRL05" "BRL_PTAX_COMMERCIAL_BRFR_BRL06" "BRL_PTAX_FLOATING_BRL07" "BRL_PTAX_FLOATING_BRFR_BRL08" "CLP_BCCH_CLP01" "CLP_CHILD_INFORMAL_CLP02" "CLP_CHILD_INTERBANK_CLP03" "CLP_CHILD_OBSERVADO_CLP04" "CLP_CHILG_INFORMAL_CLP05" "CLP_CHILG_INTERBANK_CLP06" "CLP_CHILG_OBSERVADO_CLP07" "CLP_DOLAR_OBS_CLP10" "CLP_EMTA_INDICATIVE_SURVEY_RATE_CLP11" "CLP_OFFICIAL_RATE_CLP08" "CLP_TELERATE_38942_CLP09" "CNY_SAEC_CNY01" "CNY_SFEMC_INDICATIVE_SURVEY_RATE_CNY02" "COP_CO_COL03_COP01" "COP_EMTA_INDICATIVE_SURVEY_RATE_COP03" "COP_TRM_COP02" "CURRENCY_IMPLIED_RATE__ADR__CURA1" "CURRENCY_IMPLIED_RATE__LOCAL_ASSET__CURA2" "CURRENCY_MUTUAL_AGREEMENT_CURA3" "CURRENCY_REFERENCE_DEALERS_CURA4" "CURRENCY_WHOLESALE_MARKET_CURA5" "ECS_DNRP_ECS01" "IDR_ABS_IDR01" "IDR_JISDOR_IDR04" "IDR_SFEMC_INDICATIVE_SURVEY_RATE_IDR02" "IDR_VWAP_IDR03" "ILS_BOIJ_ILS01" "ILS_FXIL_ILS02" "INR_FBIL_INR01" "INR_RBIB_INR01" "INR_SFEMC_INDICATIVE_SURVEY_RATE_INR02" "KRW_KEBEY_KRW01" "KRW_KFTC18_KRW02" "KRW_SFEMC_INDICATIVE_SURVEY_RATE_KRW04" "KRW_TELERATE_45644_KRW03" "KZT_EMTA_INDICATIVE_SURVEY_RATE_KZT02" "KZT_KASE_KZT01" "LBP_BDLX_LBP01" "MAD_OFFICIAL_RATE_MAD01" "MXP_BNMX_MXP01" "MXP_FIXING_RATE_MXP02" "MXP_MEX01_MXP03" "MXP_PUBLISHED_MXP04" "MYR_ABS_MYR01" "MYR_KL_REF_MYR04" "MYR_PPKM_MYR03" "MYR_SFEMC_INDICATIVE_SURVEY_RATE_MYR02" "PEN_EMTA_INDICATIVE_SURVEY_RATE_PEN04" "PEN_INTERBANK_AVE_PEN05" "PEN_PDSB_PEN01" "PEN_WT_AVE_PEN03" "PHP_BAPPESO_PHP06" "PHP_PDSPESO_PHP06" "PHP_PHPESO_PHP01" "PHP_SFEMC_INDICATIVE_SURVEY_RATE_PHP05" "PHP_TELERATE_15439_PHP03" "PHP_TELERATE_2920_PHP02" "PKR_SBPK_PKR01" "PKR_SFEMC_INDICATIVE_SURVEY_RATE_PKR02" "PLZ_NBPQ_PLZ01" "PLZ_NBPR_PLZ02" "RUB_CME_EMTA_RUB03" "RUB_EMTA_INDICATIVE_SURVEY_RATE_RUB04" "RUB_MICEXFRX_RUB01" "RUB_MMVB_RUB02" "SGD_VWAP_SGD3" "SKK_NBSB_SKK01" "THB_ABS_THB01" "THB_VWAP_THB01" "TWD_SFEMC_INDICATIVE_SURVEY_RATE_TWD04" "TWD_TAIFX1_TWD03" "TWD_TELERATE_6161_TWD01" "TWD_TFEMA_TWD02" "UAH_EMTA_INDICATIVE_SURVEY_RATE_UAH03" "UAH_EMTA_INDUSTRY_SURVEY_RATE_UAH02" "UAH_GFI_UAH01" "VEF_FIX_VEF01" "VND_ABS_VND01" "VND_FX_VND02" "VND_SFEMC_INDICATIVE_SURVEY_RATE_VND03" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:settlementRateOption ],
        [ sh:class common_domain_model:PriceSourceDisruption ;
            sh:description "An attribute defining the parameters to get a new quote when a settlement rate option is disrupted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:priceSourceDisruption ] ;
    sh:targetClass common_domain_model:SettlementRateOption .

common_domain_model:StubValue a sh:NodeShape ;
    rdfs:comment "A type defining how a stub calculation period amount is calculated. A single floating rate tenor different to that used for the regular part of the calculation periods schedule may be specified, or two floating rate tenors many be specified. If two floating rate tenors are specified then Linear Interpolation (in accordance with the 2000 ISDA Definitions, Section 8.3 Interpolation) is assumed to apply. Alternatively, an actual known stub rate or stub amount may be specified." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "An actual amount to apply for the initial or final stub period may have been agreed between the two parties. If an actual stub amount has been agreed then it would be included in this component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:stubAmount ],
        [ sh:class common_domain_model:StubFloatingRate ;
            sh:description "The rates to be applied to the initial or final stub may be the linear interpolation of two different rates. While the majority of the time, the rate indices will be the same as that specified in the stream and only the tenor itself will be different, it is possible to specift two different rates. For example, a 2 month stub period may use the linear interpolation of a 1 month and 3 month rate. The different rates would be specified in this component. Note that a maximum of two rates can be specified. If a stub period uses the same floating rate index, including tenor, as the regular calculation periods then this should not be specified again within this component, i.e. the stub calculation period amount component may not need to be specified even if there is an initial or final stub period. If a stub period uses a different floating rate index compared to the regular calculation periods then this should be specified within this component. If specified here, they are likely to have id attributes, allowing them to be referenced from within the cashflows component." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:floatingRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "An actual rate to apply for the initial or final stub period may have been agreed between the principal parties (in a similar way to how an initial rate may have been agreed for the first regular period). If an actual stub rate has been agreed then it would be included in this component. It will be a per annum rate, expressed as a decimal. A stub rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:stubRate ] ;
    sh:targetClass common_domain_model:StubValue .

common_domain_model:Substitution a sh:NodeShape ;
    rdfs:comment "A class to specify the conditions under which the Security Provider can substitute posted collateral. The details required for 'Legacy' agreements are substantially different to those required for newer agreements; where the agreement is a 1994 or 1995 CSA, or 1995 CSD, the legacyConsent attribute needs to be used which contains additional values beyond a simple true/false value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SubstitutionPartyElection ;
            sh:description "Party specific elections for substitution of posted collateral." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:Substitution .

common_domain_model:AdjustableDate a sh:NodeShape ;
    rdfs:comment "A class for defining a date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "A date subject to adjustment. While in FpML this date is required, this cardinality constraint has been relaxed as part of the CDM in order to support the FRA representation, which effective and termination dates are specified in FpML as adjusted dates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unadjustedDate ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "A pointer style reference to date adjustments defined elsewhere in the document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:dateAdjustmentsReference ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The business day convention and financial business centers used for adjusting the date if it would otherwise fall on a day that is not a business date in the specified business centers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:dateAdjustments ],
        [ sh:datatype xsd:date ;
            sh:description "The date once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:adjustedDate ] ;
    sh:targetClass common_domain_model:AdjustableDate .

common_domain_model:AdjustableOrAdjustedOrRelativeDate a sh:NodeShape ;
    rdfs:comment "This Rosetta class specifies the date as either an unadjusted, adjusted or relative date. It supplements the features of the AdjustableOrAdjustedDate to support the credit default swap option premium, which uses the relative date construct." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "A date subject to adjustment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unadjustedDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:adjustedDate ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The business day convention and financial business centers used for adjusting the date if it would otherwise fall on a day that is not a business date in the specified business centers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:dateAdjustments ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "A date specified as some offset to another date (the anchor date)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:relativeDate ] ;
    sh:targetClass common_domain_model:AdjustableOrAdjustedOrRelativeDate .

common_domain_model:AdjustableRelativeOrPeriodicDates a sh:NodeShape ;
    rdfs:comment "A class giving the choice between defining a series of dates as an explicit list of dates together with applicable adjustments or as relative to some other series of (anchor) dates, or as a calculation period schedule." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PeriodicDates ;
            sh:description "A calculation period schedule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:periodicDates ],
        [ sh:class common_domain_model:RelativeDates ;
            sh:description "A series of dates specified as some offset to another series of dates (the anchor dates)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:relativeDates ],
        [ sh:class common_domain_model:AdjustableDates ;
            sh:description "A series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:adjustableDates ] ;
    sh:targetClass common_domain_model:AdjustableRelativeOrPeriodicDates .

common_domain_model:AllEligibilityToHoldCollateralCriteria a sh:NodeShape ;
    rdfs:comment "Used to combine two or more Criteria using AND logic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:AnyEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:RatingAgencyValue ] [ sh:class common_domain_model:AmountOfNetCapital ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:allCriteria ] ;
    sh:targetClass common_domain_model:AllEligibilityToHoldCollateralCriteria .

common_domain_model:AmountOfNetCapital a sh:NodeShape ;
    rdfs:comment "The amount of net capital." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "The amount of net capital." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:amountOfNetCapital ] ;
    sh:targetClass common_domain_model:AmountOfNetCapital .

common_domain_model:AnyEligibilityToHoldCollateralCriteria a sh:NodeShape ;
    rdfs:comment "Used to combine two or more Criteria using OR logic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:AnyEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:RatingAgencyValue ] [ sh:class common_domain_model:AmountOfNetCapital ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:anyCriteria ] ;
    sh:targetClass common_domain_model:AnyEligibilityToHoldCollateralCriteria .

common_domain_model:Counterparty a sh:NodeShape ;
    rdfs:comment "Defines a counterparty enumerated value, e.g. Party1 or Party2, with an associated party reference. The product is agnostic to the actual parties to the transaction, with the party references abstracted away from the product definition and replaced by the CounterpartyEnum (e.g. values Party1 or Party2). The CounterpartyEnum can then be positioned in the product (e.g. to specify which counterparty is the payer, receiver etc) and this Counterparty type, which is positioned outside of the product definition, allows the CounterpartyEnum to be associated with an actual party reference." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the CounterpartyEnum, e.g. either Party1 or Party2, that is associated to the partyReference." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:role ],
        [ sh:class common_domain_model:Party ;
            sh:description "Specifies the party that is associated to the counterparty." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:partyReference ] ;
    sh:targetClass common_domain_model:Counterparty .

common_domain_model:CreditNotation a sh:NodeShape ;
    rdfs:comment "Represents a class to specify the credit notation as the combination of agency, notation, scale and debt type qualifications." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:ratingType common_domain_model:direction ) ;
    sh:property [ sh:description "Indicates the potential direction of a short-term or long-term rating. It focuses on identifiable events and short-term trends that cause ratings to be placed under special surveillance." ;
            sh:in ( "Positive" "Negative" "Developing" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:creditWatch ],
        [ sh:description "Specifies The credit agency to which the other variables (notation, scale, debt type) refer to." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#AMBest> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#CBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#DBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Fitch> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Japanagency> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Moodys> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:agency ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the credit rating scale, with a typical distinction between short term, long term. FpML doesn't specify a default scheme, which is hence not specified as an enumeration as part of the CDM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:scale ],
        [ sh:class common_domain_model:CreditRatingDebt ;
            sh:description "Specifies the credit rating debt type (e.g. long term, high yield, deposits, ...) associated with the credit rating notation and scale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:debt ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies The credit rating notation. As it varies among credit rating agencies, FpML doesn't specify a default scheme." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:notation ],
        [ sh:description "Assesses the potential direction of a long-term credit rating over the intermediate term, which is generally up to two years for investment grade and generally up to one year for speculative grade." ;
            sh:in ( "Positive" "Negative" "Stable" "Developing" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:outlook ] ;
    sh:targetClass common_domain_model:CreditNotation .

common_domain_model:DemandsAndNotices a sh:NodeShape ;
    rdfs:comment "Specifies the address where the demands, specifications and notices will be communicated to for each of the parties to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Specifies if notice shall be deemed to be effective at the time such notice is actually received unless such notice is received on a day which is not a Local Business Day or after the Notification Time on any Local Business Day in which event such notice shall be deemed to be effective on the next succeeding Local Business Day. If deemed effective,'True'. If not deemed effective, or not stated,'False'." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:deemedEffectiveNextLBD ],
        [ sh:class common_domain_model:NoticeInformationElection ;
            sh:description "The parties' contact information election." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:DemandsAndNotices .

common_domain_model:Frequency a sh:NodeShape ;
    rdfs:comment "A class for defining a date frequency, e.g. one day, three months, through the combination of an integer value and a standardized period value that is specified as part of an enumeration." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:balanceOfFirstPeriod common_domain_model:rollConvention rdf:type common_domain_model:weeklyRollConvention ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2, or 3. If the period value is T (Term) then period multiplier must contain the value 1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:description "A time period, e.g. a day, week, month, year or term of the stream." ;
            sh:in ( "H" "D" "W" "M" "Y" "T" "C" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:period ] ;
    sh:targetClass common_domain_model:Frequency .

common_domain_model:InformationSource a sh:NodeShape ;
    rdfs:comment "A class defining the source for a piece of information (e.g. a rate fix or an FX fixing). The attribute names have been adjusted from FpML to address the fact that the information is not limited to rates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:fixingTime ) ;
    sh:property [ sh:description "An information source for obtaining a market data point. For example Bloomberg, Reuters, Telerate, etc." ;
            sh:in ( <http://www.fpml.org/coding-scheme/information-provider-2-4#AssocBanksSingapore> <http://www.fpml.org/coding-scheme/information-provider-2-4#BancoCentralChile> <http://www.fpml.org/coding-scheme/information-provider-2-4#BankOfCanada> <http://www.fpml.org/coding-scheme/information-provider-2-4#BankOfEngland> <http://www.fpml.org/coding-scheme/information-provider-2-4#BankOfJapan> <http://www.fpml.org/coding-scheme/information-provider-2-4#Bloomberg> <http://www.fpml.org/coding-scheme/information-provider-2-4#EuroCentralBank> <http://www.fpml.org/coding-scheme/information-provider-2-4#FederalReserve> <http://www.fpml.org/coding-scheme/information-provider-2-4#FHLBSF> <http://www.fpml.org/coding-scheme/information-provider-2-4#ICESWAP> <http://www.fpml.org/coding-scheme/information-provider-2-4#ISDA> <http://www.fpml.org/coding-scheme/information-provider-2-4#Refinitiv> <http://www.fpml.org/coding-scheme/information-provider-2-4#ReserveBankAustralia> <http://www.fpml.org/coding-scheme/information-provider-2-4#ReserveBankNewZealand> <http://www.fpml.org/coding-scheme/information-provider-2-4#Reuters> <http://www.fpml.org/coding-scheme/information-provider-2-4#SAFEX> <http://www.fpml.org/coding-scheme/information-provider-2-4#Telerate> <http://www.fpml.org/coding-scheme/information-provider-2-4#TOKYOSWAP> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:sourceProvider ],
        [ sh:datatype xsd:string ;
            sh:description "A specific page for the source for obtaining a market data point. In FpML, this is specified as a scheme, rateSourcePageScheme, for which no coding Scheme or URI is specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:sourcePage ],
        [ sh:datatype xsd:string ;
            sh:description "The heading for the source on a given source page." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:sourcePageHeading ] ;
    sh:targetClass common_domain_model:InformationSource .

common_domain_model:NonNegativeQuantitySchedule a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Measure ;
            sh:description "Defines an optional number that the quantity should be multiplied by to derive a total quantity. This number is associated to a unit. For example in the case of the Coal (API2) CIF ARA (ARGUS-McCloskey) Futures Contract on the CME, where the unit would be contracts, the multiplier value would 1,000 and the mulitiplier unit would be 1,000 MT (Metric Tons)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:multiplier ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:value ],
        [ sh:class common_domain_model:Frequency ;
            sh:description "Defines the frequency to be used when defining a quantity. For example a quantity may be specified as a number of barrels of oil per day, which needs multiplying by the number of days in the relevant period to get the total quantity as a number of barrels." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:frequency ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:datedValue ],
        [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:unit ] ;
    sh:targetClass common_domain_model:NonNegativeQuantitySchedule .

common_domain_model:PaymentDates a sh:NodeShape ;
    rdfs:comment "Specifies the parameters to generate the payment date schedule, either through a parametric representation or by reference to specified dates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The definition of the business day convention and financial business centers used for adjusting the payment date if it would otherwise fall on a day that is not a business day in the specified business center." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:paymentDatesAdjustments ],
        [ sh:datatype xsd:date ;
            sh:description "The first unadjusted payment date. This day may be subject to adjustment in accordance with any business day convention specified in paymentDatesAdjustments. This element must only be included if there is an initial stub. This date will normally correspond to an unadjusted calculation period start or end date. This is true even if early or delayed payment is specified to be applicable since the actual first payment date will be the specified number of days before or after the applicable adjusted calculation period start or end date with the resulting payment date then being adjusted in accordance with any business day convention specified in paymentDatesAdjustments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:firstPaymentDate ],
        [ sh:description "Specifies whether the payments occur relative to each adjusted calculation period start date or end date, each reset date, valuation date or the last pricing date. Calculation period start date means relative to the start of the first calculation period contributing to a given payment. Similarly, calculation period end date means the end of the last calculation period contributing to a given payment. The valuation date is applicable for Brazilian-CDI and equity swaps." ;
            sh:in ( "CalculationPeriodStartDate" "CalculationPeriodEndDate" "LastPricingDate" "ResetDate" "ValuationDate" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:payRelativeTo ],
        [ sh:class common_domain_model:Offset ;
            sh:description "If early payment or delayed payment is required, specifies the number of days offset that the payment occurs relative to what would otherwise be the unadjusted payment date. The offset can be specified in terms of either calendar or business days. Even in the case of a calendar days offset, the resulting payment date, adjusted for the specified calendar days offset, will still be adjusted in accordance with the specified payment dates adjustments. This element should only be included if early or delayed payment is applicable, i.e. if the periodMultiplier element value is not equal to zero. An early payment would be indicated by a negative periodMultiplier element value and a delayed payment (or payment lag) would be indicated by a positive periodMultiplier element value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:paymentDaysOffset ],
        [ sh:class common_domain_model:PaymentDateSchedule ;
            sh:description "The payment dates when specified as relative to a set of dates specified somewhere else in the instance document/transaction, e.g. the valuation dates as typically the case for equity swaps, or when specified as a calculation period schedule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:paymentDateSchedule ],
        [ sh:datatype xsd:date ;
            sh:description "The last regular payment date when specified as a date, as in the FpML interest rate construct. FpML specifies that this date may be subject to adjustment in accordance with any business day convention specified in the paymentDatesAdjustments attribute." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:lastRegularPaymentDate ],
        [ sh:class common_domain_model:Frequency ;
            sh:description "The frequency at which regular payment dates occur. If the payment frequency is equal to the frequency defined in the calculation period dates component then one calculation period contributes to each payment amount. If the payment frequency is less frequent than the frequency defined in the calculation period dates component then more than one calculation period will contribute to the payment amount. A payment frequency more frequent than the calculation period frequency or one that is not a multiple of the calculation period frequency is invalid. If the payment frequency is of value T (term), the period is defined by the effectiveDate and the terminationDate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:paymentFrequency ] ;
    sh:targetClass common_domain_model:PaymentDates .

common_domain_model:RatingAgencyValue a sh:NodeShape ;
    rdfs:comment "A logical container designed to hold a set of related data. In this case the Rating Agency, Rating Value and Rating Type." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Assesses the potential direction of a long-term credit rating over the intermediate term, which is generally up to two years for investment grade and generally up to one year for speculative grade." ;
            sh:in ( "Positive" "Negative" "Stable" "Developing" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:outlook ],
        [ sh:description "The relevant rating type." ;
            sh:in ( "LongTerm" "ShortTerm" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:ratingType ],
        [ sh:description "Indicates the potential direction of a short-term or long-term rating. It focuses on identifiable events and short-term trends that cause ratings to be placed under special surveillance." ;
            sh:in ( "Positive" "Negative" "Developing" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:creditWatch ],
        [ sh:description "Specifies The credit agency to which the other variables (notation, scale, debt type) refer to." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#AMBest> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#CBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#DBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Fitch> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Japanagency> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Moodys> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:agency ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the credit rating scale, with a typical distinction between short term, long term. FpML doesn't specify a default scheme, which is hence not specified as an enumeration as part of the CDM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:scale ],
        [ sh:class common_domain_model:CreditRatingDebt ;
            sh:description "Specifies the credit rating debt type (e.g. long term, high yield, deposits, ...) associated with the credit rating notation and scale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:debt ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies The credit rating notation. As it varies among credit rating agencies, FpML doesn't specify a default scheme." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:notation ] ;
    sh:targetClass common_domain_model:RatingAgencyValue .

common_domain_model:CalculationPeriodDates a sh:NodeShape ;
    rdfs:comment "A data for:  defining the parameters used to generate the calculation period dates schedule, including the specification of any initial or final stub calculation periods. A calculation period schedule consists of an optional initial stub calculation period, one or more regular calculation periods and an optional final stub calculation period. In the absence of any initial or final stub calculation periods, the regular part of the calculation period schedule is assumed to be between the effective date and the termination date. No implicit stubs are allowed, i.e. stubs must be explicitly specified using an appropriate combination of firstPeriodStartDate, firstRegularPeriodStartDate and lastRegularPeriodEndDate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The start date of the calculation period. FpML specifies that for interest rate swaps this date must only be specified if it is not equal to the effective date. It is always specified in the case of equity swaps and credit default swaps with periodic payments. This date may be subject to adjustment in accordance with a business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:firstPeriodStartDate ],
        [ sh:datatype xsd:date ;
            sh:description "The end date of the initial compounding period when compounding is applicable. It must only be specified when the compoundingMethod element is present and not equal to a value of None. This date may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:firstCompoundingPeriodEndDate ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The last day of the terms of the trade. This date may be subject to adjustments in accordance with the business day convention. It can also be specified in relation to another scheduled date (e.g. the last payment date)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:terminationDate ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The specification of the business day convention and financial business centers used for adjusting any calculation period date if it would otherwise fall on a day that is not a business day in the specified business center." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:calculationPeriodDatesAdjustments ],
        [ sh:description "Method to allocate any irregular period remaining after regular periods have been allocated between the effective and termination date. The multiplicity of 2 allows the possibility of expressing the type for both an initial and final stub at the same time." ;
            sh:in ( "ShortInitial" "ShortFinal" "LongInitial" "LongFinal" ) ;
            sh:order 7 ;
            sh:path common_domain_model:stubPeriodType ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The first day of the terms of the trade. This day may be subject to adjustment in accordance with a business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:datatype xsd:date ;
            sh:description "The end date of the regular part of the calculation period schedule. It must only be specified if there is a final stub calculation period. This day may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:lastRegularPeriodEndDate ],
        [ sh:datatype xsd:date ;
            sh:description "The start date of the regular part of the calculation period schedule. It must only be specified if there is an initial stub calculation period. This day may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:firstRegularPeriodStartDate ],
        [ sh:class common_domain_model:CalculationPeriodFrequency ;
            sh:description "The frequency at which calculation period end dates occur with the regular part of the calculation period schedule and their roll date convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:calculationPeriodFrequency ] ;
    sh:targetClass common_domain_model:CalculationPeriodDates .

common_domain_model:ContactInformation a sh:NodeShape ;
    rdfs:comment "A class to specify contact information associated with a party: telephone, postal/street address, email and web page." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:naturalPerson rdf:type common_domain_model:additionalInformation common_domain_model:account ) ;
    sh:property [ sh:class common_domain_model:TelephoneNumber ;
            sh:description "The telephone number." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:telephone ],
        [ sh:datatype xsd:string ;
            sh:description "The email address." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:email ],
        [ sh:datatype xsd:string ;
            sh:description "The web page. This attribute is not specified as part of the FpML ContactInformation complex type." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:webPage ],
        [ sh:class common_domain_model:Address ;
            sh:description "The street/postal address." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:address ] ;
    sh:targetClass common_domain_model:ContactInformation .

common_domain_model:Observable a sh:NodeShape ;
    rdfs:comment "Specifies the object to be observed for a price, it could be an asset or a reference." ;
    sh:closed false ;
    sh:ignoredProperties ( common_domain_model:interimValuationPrice rdf:type common_domain_model:initialValuationPrice common_domain_model:quantity common_domain_model:finalValuationPrice ) ;
    sh:targetClass common_domain_model:Observable .

common_domain_model:PriceQuantity a sh:NodeShape ;
    rdfs:comment "Defines a settlement as an exchange between two parties of a specified quantity of an asset (the quantity) against a specified quantity of another asset (the price). The settlement is optional and can be either cash or physical. The quantity can additionally be specified in terms of one or more currency amounts. In the case of non-cash products, the settlement of the price/quantity would not be specified here and instead would be delegated to the product mechanics, as parameterised by the price/quantity values." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the object to be observed for a price, it could be an asset or an index. The cardinality is optional as some quantity / price cases have no observable (e.g. a fixed rate in a given currency)." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:Asset ] [ sh:class common_domain_model:Basket ] [ sh:class common_domain_model:Index ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:observable ],
        [ sh:class common_domain_model:NonNegativeQuantitySchedule ;
            sh:description "Specifies a quantity to be associated with an event, for example a trade amount." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies a price to be used for trade amounts and other purposes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:price ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "Specifies the date at which the price and quantity become effective. This day may be subject to adjustment in accordance with a business day convention, or could be specified as relative to a trade date, for instance. Optional cardinality, as the effective date is usually specified in the product definition, so it may only need to be specified as part of the PriceQuantity in an increase/decrease scenario for an existing trade." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:effectiveDate ] ;
    sh:targetClass common_domain_model:PriceQuantity .

common_domain_model:Rounding a sh:NodeShape ;
    rdfs:comment "Defines rounding rules and precision to be used in the rounding of a number." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the rounding rounding rule as up, down, or nearest." ;
            sh:in ( "Up" "Down" "Nearest" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:roundingDirection ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies the rounding precision in terms of a number of decimal places when the number is evaluated in decimal form (not percentage), e.g. 0.09876543 rounded to the nearest 5 decimal places is  0.0987654." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:precision ] ;
    sh:targetClass common_domain_model:Rounding .

common_domain_model:SpreadSchedule a sh:NodeShape ;
    rdfs:comment "Adds an optional spread type element to the Schedule to identify a long or short spread value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceSchedule ;
            sh:description "The initial rate. An initial rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:price ],
        [ sh:description "An element which purpose is to identify a long or short spread value." ;
            sh:in ( <http://www.fpml.org/coding-scheme/spread-schedule-type-1-0#Long> <http://www.fpml.org/coding-scheme/spread-schedule-type-1-0#Short> ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:spreadScheduleType ] ;
    sh:targetClass common_domain_model:SpreadSchedule .

common_domain_model:AssignedIdentifier a sh:NodeShape ;
    rdfs:comment "A class to specify the identifier value and its associated version." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The identifier value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:datatype xsd:integer ;
            sh:description "The identifier version, which is specified as an integer and is meant to be incremented each time the transaction terms (whether contract or event) change. This version is made option to support the use case where the identifier is referenced without the version. The constraint that a contract and a lifecycle event need to have an associated version is enforced through data rules." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:version ] ;
    sh:targetClass common_domain_model:AssignedIdentifier .

common_domain_model:Cash a sh:NodeShape ;
    rdfs:comment "An Asset that consists solely of a monetary holding in a currency. The currency of the Cash asset is held in the string Identifier (from AssetBase) and the AssetIdTypeEnum must be set to define that a CurrencyCode is set.  The function SetCashCurrency can be used to create (or update) a Cash object and the function GetCashCurrency can be used to retrieve the currency of a Cash object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:exchange ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:assetType ] ;
    sh:targetClass common_domain_model:Cash .

common_domain_model:Clause a sh:NodeShape ;
    rdfs:comment "A type for documenting additional clause that cannot yet be represented with the model and yet needed for a digital representation of the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Content of this bespoke clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:terms ],
        [ sh:class common_domain_model:Clause ;
            sh:description "Additional hierarchical components of the clause if relevant." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:subcomponents ],
        [ sh:datatype xsd:string ;
            sh:description "The  name or identifier associated to this clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ] ;
    sh:targetClass common_domain_model:Clause .

common_domain_model:Commodity a sh:NodeShape ;
    rdfs:comment "Identifies a specific commodity by referencing a product identifier or by a product definition." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:datatype xsd:string ;
            sh:description "Provides additional information about the commodity underlier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:description ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:CommodityProductDefinition ;
            sh:description "Specifies the commodity underlier in the event that no ISDA Commodity Reference Benchmark exists." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:commodityProductDefinition ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:description "Describes the required quote type of the underlying price that will be observed. Example values include 'Bid, 'Ask', 'Settlement' (for a futures contract) and 'WeightedAverage' (for some published prices and indices)." ;
            sh:in ( "Afternoon" "Ask" "Bid" "Closing" "High" "Index" "MeanOfBidAndAsk" "LocationalMarginal" "Low" "MarginalHourly" "MarketClearing" "MeanOfHighAndLow" "Morning" "Official" "Opening" "OSP" "Settlement" "Spot" "Mid" "NationalSingle" "WeightedAverage" "UnWeightedAverage" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:priceQuoteType ],
        [ sh:class common_domain_model:DeliveryDateParameters ;
            sh:description "Specifies the parameters for identifying the relevant contract date when the commodity reference price is a futures contract." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:deliveryDateReference ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:assetType ] ;
    sh:targetClass common_domain_model:Commodity .

common_domain_model:DigitalAsset a sh:NodeShape ;
    rdfs:comment "An Asset that exists only in digital form, eg Bitcoin or Ethereum, that is not backed by other Assets; excludes the digital representation of other Assets, eg coins or Tokenised assets." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:assetType ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:exchange ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:relatedExchange ] ;
    sh:targetClass common_domain_model:DigitalAsset .

common_domain_model:Instrument a sh:NodeShape ;
    rdfs:comment "A type of Asset that is issued by one party to one or more others." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:Instrument .

common_domain_model:Security a sh:NodeShape ;
    rdfs:comment "Identifies a security by referencing an identifier and by specifying the sector." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:description "Identifies the type of security using an enumerated list." ;
            sh:in ( "Debt" "Equity" "Fund" "Warrant" "Certificate" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:securityType ],
        [ sh:class common_domain_model:EquityType ;
            sh:description "Identifies the type of equity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:equityType ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:identifier ],
        [ sh:description "Identifies the type of fund." ;
            sh:in ( "MoneyMarketFund" "ExchangeTradedFund" "MutualFund" "OtherFund" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:fundType ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:assetType ],
        [ sh:class common_domain_model:DebtType ;
            sh:description "Identifies the type of debt and selected debt economics." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:debtType ] ;
    sh:targetClass common_domain_model:Security .

common_domain_model:Offset a sh:NodeShape ;
    rdfs:comment "A class defining an offset used in calculating a new date relative to a reference date, e.g. calendar days, business days, commodity Business days, etc." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:businessDayConvention common_domain_model:dateRelativeToCalculationPeriodDates common_domain_model:adjustedDate common_domain_model:relativeDateAdjustments rdf:type common_domain_model:fxFixingDate common_domain_model:businessCenters common_domain_model:periodSkip common_domain_model:dateRelativeToValuationDates common_domain_model:scheduleBounds common_domain_model:dateRelativeTo common_domain_model:dateRelativeToPaymentDates common_domain_model:businessCentersReference ) ;
    sh:property [ sh:description "In the case of an offset specified as a number of days, this element defines whether consideration is given as to whether a day is a good business day or not. If a day type of business days is specified then non-business days are ignored when calculating the offset. The financial business centers to use for determination of business days are implied by the context in which this element is used. This element must only be included when the offset is specified as a number of days. If the offset is zero days then the dayType element should not be included." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:dayType ],
        [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:period ],
        [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:periodMultiplier ] ;
    sh:targetClass common_domain_model:Offset .

common_domain_model:PrincipalPayments a sh:NodeShape ;
    rdfs:comment "A class defining which principal exchanges occur for the stream." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A true/false flag to indicate whether there is an initial exchange of principal on the effective date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:initialPayment ],
        [ sh:datatype xsd:boolean ;
            sh:description "A true/false flag to indicate whether there are intermediate or interim exchanges of principal during the term of the swap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:intermediatePayment ],
        [ sh:datatype xsd:string ;
            sh:description "Indicate the Payout legs which nominal amount may vary in regards of FX Fixing dates as determined in the product terms." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:varyingLegNotionalCurrency ],
        [ sh:class common_domain_model:PrincipalPaymentSchedule ;
            sh:description "Describe dates schedules for Principal Exchanges and related role of the parties when known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:principalPaymentSchedule ],
        [ sh:datatype xsd:boolean ;
            sh:description "A true/false flag to indicate whether there is a final exchange of principal on the termination date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:finalPayment ] ;
    sh:targetClass common_domain_model:PrincipalPayments .

common_domain_model:ValuationPostponement a sh:NodeShape ;
    rdfs:comment "Specifies how long to wait to get a quote from a settlement rate option upon a price source disruption." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The maximum number of days to wait for a quote from the disrupted settlement rate option before proceeding to the next method." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:maximumDaysOfPostponement ] ;
    sh:targetClass common_domain_model:ValuationPostponement .

common_domain_model:DatedValue a sh:NodeShape ;
    rdfs:comment "Defines a date and value pair. This definition is used for varying rate or amount schedules, e.g. a notional amortisation or a step-up coupon schedule." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The rate of amount which becomes effective on the associated step date. A rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:value ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the associated step value becomes effective. This day may be subject to adjustment in accordance with a business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:date ] ;
    sh:targetClass common_domain_model:DatedValue .

common_domain_model:Product a sh:NodeShape ;
    rdfs:comment "Enables either a TransferableProduct or a NonTransferableProduct to be used in an underlier." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:Product .

common_domain_model:Quantity a sh:NodeShape ;
    rdfs:comment "Specifies a quantity as a single value to be associated to a financial product, for example a transfer amount resulting from a trade. This data type extends QuantitySchedule and requires that only the single amount value exists." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:unit ],
        [ sh:class common_domain_model:Measure ;
            sh:description "Defines an optional number that the quantity should be multiplied by to derive a total quantity. This number is associated to a unit. For example in the case of the Coal (API2) CIF ARA (ARGUS-McCloskey) Futures Contract on the CME, where the unit would be contracts, the multiplier value would 1,000 and the mulitiplier unit would be 1,000 MT (Metric Tons)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:multiplier ],
        [ sh:class common_domain_model:Frequency ;
            sh:description "Defines the frequency to be used when defining a quantity. For example a quantity may be specified as a number of barrels of oil per day, which needs multiplying by the number of days in the relevant period to get the total quantity as a number of barrels." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:frequency ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:datedValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:Quantity .

common_domain_model:ResolvablePriceQuantity a sh:NodeShape ;
    rdfs:comment "Generic class to specify the quantity for different payout legs in a contractual product, when that quantity can vary across payout legs or across time. A resolvable quantity can always be resolved into a single quantity from the quantity notation which has a corresponding asset identifier. In addition to the base case, where quantity is directly specified as a number as part of the quantity notation, the other use cases are: (i) quantity based on some pre-defined schedule (eg amortising notional), (ii) quantity based on some pre-defined events (eg resetting cross-currency notional), or quantity set as reference to another quantity (eg equity notional as no. securities x price)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether the quantity is resettable" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:reset ],
        [ sh:class common_domain_model:QuantityMultiplier ;
            sh:description "Quantity multiplier is specified on top of a reference quantity and is used as a multiplying factor when resolving the quantity. A quantity multiplier can only exist when the resolvable quantity specifies a reference quantity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:quantityMultiplier ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Reference quantity when resolvable quantity is defined as relative to another (resolvable) quantity. A resolvable quantity needs to contain either an absolute quantity or a reference to another (resolvable) quantity. This requirement is captured by a choice rule on the class." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:quantityReference ],
        [ sh:class common_domain_model:Quantity ;
            sh:description "A product's quantity as a single, non-negative amount.  When specified as part of a product definition, this quantity attribute would not be set.  Instead it is specified on the quantity notation along with an asset identifier matching this payout's asset identifier.  This allows the quantity to be resolved for a payout leg, which can then be specified here for convenience during data processing.  There needs to be at least one resolvable quantity across payout legs of a product to define an anchor that other payout quantities can refer to.  This attribute is ignored when mapping existing FpML messages." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:resolvedQuantity ],
        [ sh:class common_domain_model:NonNegativeQuantitySchedule ;
            sh:description "A payout's quantity specified as a schedule, which may also contain a single value if that quantity is constant. There can only be a single quantity schedule applicable to a payout: e.g. the notional for an interest rate leg. The quantity must be specified outside of the payout in a PriceQuantity object and only referenced inside the payout using an address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:quantitySchedule ],
        [ sh:class common_domain_model:FutureValueAmount ;
            sh:description "The future value notional is specific to BRL CDI swaps, and is specified alongside the notional amount. The value is calculated as follows: Future Value Notional = Notional Amount * (1 + Fixed Rate) ^ (Fixed Rate Day Count Fraction). The currency should always match that expressed in the notional schedule. The value date should match the adjusted termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:futureValueNotional ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "A payout's price specified as a schedule, which may also contain a single value if that price is constant. There may be multiple prices specified for a single payout: e.g. a floating interest rate leg may specify a spread, a cap and/or floor and a multiplier. The price must be specified outside of the payout in a PriceQuantity object and only referenced inside the payout using an address." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:priceSchedule ] ;
    sh:targetClass common_domain_model:ResolvablePriceQuantity .

common_domain_model:TradeState a sh:NodeShape ;
    rdfs:comment "Defines the fundamental financial information that can be changed by a Primitive Event and by extension any business or life-cycle event. Each TradeState specifies where a Trade is in its life-cycle. TradeState is a root type and as such, can be created independently to any other CDM data type, but can also be used as part of the CDM Event Model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ObservationEvent ;
            sh:description "Represents the observed events related to a particular product or process, such as credit events or corporate actions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:observationHistory ],
        [ sh:class common_domain_model:Valuation ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:valuationHistory ],
        [ sh:class common_domain_model:State ;
            sh:description "Represents the State of the Trade through its life-cycle." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:state ],
        [ sh:class common_domain_model:Trade ;
            sh:description "Represents the Trade that has been effected by a business or life-cycle event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:trade ],
        [ sh:class common_domain_model:Reset ;
            sh:description "Represents the updated Trade attributes which can change as the result of a reset event. Only the changed values are captured, leaving the remaining data attributes empty. See Create_Reset function for further details on how TradeState is used in the Reset event. The TradeState data type is used to maintain backwards compatibility with the current Reset mechanism." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:resetHistory ],
        [ sh:class common_domain_model:TransferState ;
            sh:description "Represents the updated Trade attributes which can change as the result of a transfer event." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:transferHistory ] ;
    sh:targetClass common_domain_model:TradeState .

common_domain_model:Account a sh:NodeShape ;
    rdfs:comment "A class to specify an account as an account number alongside, optionally. an account name, an account type, an account beneficiary and a servicing party." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "A reference to the party to which the account refers to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyReference ],
        [ sh:class common_domain_model:Party ;
            sh:description "The reference to the legal entity that services the account, i.e. in the books of which the account is held." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:servicingParty ],
        [ sh:class common_domain_model:Party ;
            sh:description "A reference to the party beneficiary of the account." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:accountBeneficiary ],
        [ sh:datatype xsd:string ;
            sh:description "The account number." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:accountNumber ],
        [ sh:description "The type of account, e.g. client, house." ;
            sh:in ( <http://www.fpml.org/coding-scheme/account-type-1-1#AggregateClient> <http://www.fpml.org/coding-scheme/account-type-1-1#Client> <http://www.fpml.org/coding-scheme/account-type-1-1#House> ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:accountType ],
        [ sh:datatype xsd:string ;
            sh:description "The name by which the account is known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:accountName ] ;
    sh:targetClass common_domain_model:Account .

common_domain_model:EscrowArrangement a sh:NodeShape ;
    rdfs:comment "Refers to the segregation deposit procedure parties may want to commmit into during the time a Disruption Event is effective" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Clause ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:bespokeEscrowArrangements ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:escrowArrangementIsApplicable ],
        [ sh:class common_domain_model:ValuationPostponement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:maximumDaysOfDisruption ] ;
    sh:targetClass common_domain_model:EscrowArrangement .

common_domain_model:SettlementTerms a sh:NodeShape ;
    rdfs:comment "Specifies the settlement terms, which can either be cash, physical, or fx-based cash-settlement. This class can be used for the settlement of options and forwards, cash transactions (e.g. securities or foreign exchange), or in case of credit event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SettlementProvision ;
            sh:description "Optionally defines the parameters that regulate a settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:settlementProvision ],
        [ sh:class common_domain_model:SettlementDate ;
            sh:description "The date on which the settlement amount will be paid, subject to adjustment in accordance with any applicable business day convention. This component would not be present for a mandatory early termination provision where the cash settlement payment date is the mandatory early termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:description "The qualification as to how the transfer will settle, e.g. a DvP settlement." ;
            sh:in ( "DeliveryVersusDelivery" "DeliveryVersusPayment" "PaymentVersusPayment" "NotCentralSettlement" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:transferSettlementType ],
        [ sh:description "Optional settlement centre as an enumerated list: Euroclear, Clearstream." ;
            sh:in ( "EuroclearBank" "ClearstreamBankingLuxembourg" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:settlementCentre ],
        [ sh:class common_domain_model:PhysicalSettlementTerms ;
            sh:description "Specifies the physical settlement terms which apply to the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:physicalSettlementTerms ],
        [ sh:datatype xsd:string ;
            sh:description "The settlement currency is to be specified when the Settlement Amount cannot be known in advance. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:settlementCurrency ],
        [ sh:description "Settlement Style." ;
            sh:in ( "Standard" "Net" "StandardAndNet" "PairAndNet" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:standardSettlementStyle ],
        [ sh:description "Whether the settlement will be cash, physical, by election, ..." ;
            sh:in ( "Cash" "Physical" "Election" "CashOrPhysical" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:settlementType ],
        [ sh:class common_domain_model:CashSettlementTerms ;
            sh:description "Specifies the parameters associated with the cash settlement procedure." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:cashSettlementTerms ] ;
    sh:targetClass common_domain_model:SettlementTerms .

common_domain_model:StrikeSchedule a sh:NodeShape ;
    rdfs:comment "A class describing a schedule of cap or floor rates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceSchedule ;
            sh:description "The initial rate. An initial rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:price ],
        [ sh:description "The party that has sold." ;
            sh:in ( "Payer" "Receiver" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:seller ],
        [ sh:description "The buyer of the option." ;
            sh:in ( "Payer" "Receiver" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:buyer ] ;
    sh:targetClass common_domain_model:StrikeSchedule .

common_domain_model:TimeZone a sh:NodeShape ;
    rdfs:comment "The time alongside with the timezone location information. This class makes use of the FpML TimezoneLocation construct." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:time ;
            sh:description "The observation time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:time ],
        [ sh:datatype xsd:string ;
            sh:description "FpML specifies the timezoneLocationScheme by reference to the Time Zone Database (a.k.a. tz database) maintained by IANA, the Internet Assigned Numbers Authority." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:location ] ;
    sh:targetClass common_domain_model:TimeZone .

common_domain_model:UnitType a sh:NodeShape ;
    rdfs:comment "Defines the unit to be used for price, quantity, or other purposes" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Provides an enumerated values for a weather unit, generally used in the context of defining quantities for commodities." ;
            sh:in ( "CDD" "CPD" "HDD" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:weatherUnit ],
        [ sh:datatype xsd:string ;
            sh:description "Defines the currency to be used as a unit for a price, quantity, or other purpose." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:currency ],
        [ sh:description "Provides an enumerated value for a capacity unit, generally used in the context of defining quantities for commodities." ;
            sh:in ( "ALW" "BBL" "BCF" "BDFT" "CBM" "CER" "CRT" "DAG" "DAY" "DMTU" "ENVCRD" "ENVOFST" "FEU" "G" "GBBSH" "GBBTU" "GBCWT" "GBGAL" "GBMBTU" "GBMMBTU" "GBT" "GBTHM" "GJ" "GW" "GWH" "HL" "HOGB" "ISOBTU" "ISOMBTU" "ISOMMBTU" "ISOTHM" "J" "KG" "KL" "KW" "KWD" "KWH" "KWM" "KWMIN" "KWY" "L" "LB" "MB" "MBF" "MJ" "MMBF" "MMBBL" "MSF" "MT" "MW" "MWD" "MWH" "MWM" "MWMIN" "MWY" "OZT" "SGB" "TEU" "USBSH" "USBTU" "USCWT" "USGAL" "USMBTU" "USMMBTU" "UST" "USTHM" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:capacityUnit ],
        [ sh:description "Provides an enumerated value for financial units, generally used in the context of defining quantities for securities." ;
            sh:in ( "Contract" "ContractualProduct" "IndexUnit" "LogNormalVolatility" "Share" "ValuePerDay" "ValuePerPercent" "Weight" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:financialUnit ] ;
    sh:targetClass common_domain_model:UnitType .

common_domain_model:BusinessDayAdjustments a sh:NodeShape ;
    rdfs:comment "A class defining the business day convention and financial business centers used for adjusting any relevant date if it would otherwise fall on a day that is not a business day in the specified business center." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The convention for adjusting a date if it would otherwise fall on a day that is not a business day." ;
            sh:in ( "FOLLOWING" "FRN" "MODFOLLOWING" "PRECEDING" "MODPRECEDING" "NEAREST" "NONE" "NotApplicable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:businessDayConvention ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business center(s), specified either explicitly or by reference to those specified somewhere else in the instance document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenters ] ;
    sh:targetClass common_domain_model:BusinessDayAdjustments .

common_domain_model:PayerReceiver a sh:NodeShape ;
    rdfs:comment "Specifies the parties responsible for making and receiving payments defined by this structure." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:notionalReference common_domain_model:feeAmountSchedule rdf:type common_domain_model:feeRateSchedule common_domain_model:feeAmount common_domain_model:feeRate common_domain_model:feePaymentDate ) ;
    sh:property [ sh:description "Specifies the party that receives the payments corresponding to this structure.  The party is one of the two counterparties to the transaction." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:receiver ],
        [ sh:description "Specifies the counterparty responsible for making the payments defined by this structure.  The party is one of the two principal parties to the transaction." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:payer ] ;
    sh:targetClass common_domain_model:PayerReceiver .

common_domain_model:RelativeDateOffset a sh:NodeShape ;
    rdfs:comment "A class defining a date (referred to as the derived date) as a relative offset from another date (referred to as the anchor date). If the anchor date is itself an adjustable date then the offset is assumed to be calculated from the adjusted anchor date. A number of different scenarios can be supported, namely; 1) the derived date may simply be a number of calendar periods (days, weeks, months or years) preceding or following the anchor date; 2) the unadjusted derived date may be a number of calendar periods (days, weeks, months or years) preceding or following the anchor date with the resulting unadjusted derived date subject to adjustment in accordance with a specified business day convention, i.e. the derived date must fall on a good business day; 3) the derived date may be a number of business days preceding or following the anchor date. Note that the businessDayConvention specifies any required adjustment to the unadjusted derived date. A negative or positive value in the periodMultiplier indicates whether the unadjusted derived precedes or follows the anchor date. The businessDayConvention should contain a value NONE if the day type element contains a value of Business (since specifying a negative or positive business days offset would already guarantee that the derived date would fall on a good business day in the specified business centers)." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:periodSkip rdf:type common_domain_model:relativeDateAdjustments common_domain_model:scheduleBounds ) ;
    sh:property [ sh:description "The convention for adjusting a date if it would otherwise fall on a day that is not a business day, as specified by an ISDA convention (e.g. Following, Precedent)." ;
            sh:in ( "FOLLOWING" "FRN" "MODFOLLOWING" "PRECEDING" "MODPRECEDING" "NEAREST" "NONE" "NotApplicable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:businessDayConvention ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "A pointer style reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:businessCentersReference ],
        [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:description "In the case of an offset specified as a number of days, this element defines whether consideration is given as to whether a day is a good business day or not. If a day type of business days is specified then non-business days are ignored when calculating the offset. The financial business centers to use for determination of business days are implied by the context in which this element is used. This element must only be included when the offset is specified as a number of days. If the offset is zero days then the dayType element should not be included." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:dayType ],
        [ sh:datatype xsd:date ;
            sh:description "The date once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:adjustedDate ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the anchor as an href attribute. The href attribute value is a pointer style reference to the element or component elsewhere in the document where the anchor date is defined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:dateRelativeTo ],
        [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:period ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business center(s), specified either explicitly or by reference to those specified somewhere else in the instance document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenters ] ;
    sh:targetClass common_domain_model:RelativeDateOffset .

common_domain_model:Period a sh:NodeShape ;
    rdfs:comment "A class to define recurring periods or time offsets." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:businessDayConvention common_domain_model:dateRelativeToCalculationPeriodDates common_domain_model:fixingOffsetReason rdf:type common_domain_model:fxFixingDate common_domain_model:businessCenters common_domain_model:periodSkip common_domain_model:scheduleBounds common_domain_model:dateRelativeTo common_domain_model:dateRelativeToPaymentDates common_domain_model:fixingOffsetDefinition common_domain_model:designatedMaturity common_domain_model:businessCentersReference common_domain_model:adjustedDate common_domain_model:relativeDateAdjustments common_domain_model:dayType common_domain_model:dateRelativeToValuationDates ) ;
    sh:property [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:period ],
        [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:periodMultiplier ] ;
    sh:targetClass common_domain_model:Period .

common_domain_model:AssetIdentifier a sh:NodeShape ;
    rdfs:comment "The unique identifier for an Asset, specified using an Asset Identifier Type enumerator." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Defines the symbology source of the Asset Identifier, eg CUSIP, ISIN, etc." ;
            sh:in ( "CurrencyCode" "ExchangeCode" "ClearingCode" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:identifierType ],
        [ sh:datatype xsd:string ;
            sh:description "The identifier value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ] ;
    sh:targetClass common_domain_model:AssetIdentifier .

common_domain_model:PartyRole a sh:NodeShape ;
    rdfs:comment "A class to specify the role(s) that party(ies) may have in relation to the execution, contract or other legal agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "A reference to the party that has ownership of this party role information. FpML specifies that For shared trade information, this attribute will reference the originator of the data (for example, an execution facility or clearing house)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:ownershipPartyReference ],
        [ sh:class common_domain_model:Party ;
            sh:description "A reference to the party to which the role refers to." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyReference ],
        [ sh:description "The party role." ;
            sh:in ( <http://www.fpml.org/coding-scheme/party-role-4-0#Accountant> "AgentLender" <http://www.fpml.org/coding-scheme/party-role-4-0#AllocationAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ArrangingBroker> "BarrierDeterminationAgent" "BeneficialOwner" <http://www.fpml.org/coding-scheme/party-role-4-0#Beneficiary> <http://www.fpml.org/coding-scheme/party-role-4-0#BookingParty> "Borrower" <http://www.fpml.org/coding-scheme/party-role-4-0#Buyer> <http://www.fpml.org/coding-scheme/party-role-4-0#BuyerDecisionMaker> "Chargor" <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingClient> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingExceptionParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingFirm> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingOrganization> <http://www.fpml.org/coding-scheme/party-role-4-0#Client> <http://www.fpml.org/coding-scheme/party-role-4-0#ClientDecisionMaker> <http://www.fpml.org/coding-scheme/party-role-4-0#ConfirmationPlatform> <http://www.fpml.org/coding-scheme/party-role-4-0#ContractualParty> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Counterparty> <http://www.fpml.org/coding-scheme/party-role-4-0#CreditSupportProvider> <http://www.fpml.org/coding-scheme/party-role-4-0#Custodian> <http://www.fpml.org/coding-scheme/party-role-4-0#DataSubmitter> "DeterminingParty" <http://www.fpml.org/coding-scheme/party-role-4-0#DisputingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#DocumentRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingEntity> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionFacility> <http://www.fpml.org/coding-scheme/party-role-4-0#Guarantor> "HedgingParty" "Lender" "MarginAffiliate" <http://www.fpml.org/coding-scheme/party-role-4-0#OrderTransmitter> "Pledgor" <http://www.fpml.org/coding-scheme/party-role-4-0#PrimeBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#PriorTradeRepository> "PTRRServiceProvider" <http://www.fpml.org/coding-scheme/party-role-4-0#PublicationVenue> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Seller> <http://www.fpml.org/coding-scheme/party-role-4-0#SellerDecisionMaker> "SecuredParty" <http://www.fpml.org/coding-scheme/party-role-4-0#SettlementAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeSource> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingManager> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingPartner> "TripartyAgent" "ThirdPartyCustodian" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:role ] ;
    sh:targetClass common_domain_model:PartyRole .

common_domain_model:Taxonomy a sh:NodeShape ;
    rdfs:comment "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object)." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:primaryAssetClass rdf:type common_domain_model:secondaryAssetClass common_domain_model:productQualifier ) ;
    sh:property [ sh:description "The source of the taxonomy that defines the rules for classifying the object. The taxonomy source is taken from a enumerated list of taxonomy names. Optional as the taxonomy source may not be provided." ;
            sh:in ( "CFI" "ISDA" "ICAD" "EMIR" "EU_EMIR_EligibleCollateralAssetClass" "UK_EMIR_EligibleCollateralAssetClass" "CFTC" "US_CFTC_PR_EligibleCollateralAssetClass" "MAS" "CSA" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:source ],
        [ sh:class common_domain_model:TaxonomyValue ;
            sh:description "The value according to that taxonomy. Optional as it may not be possible to classify the object in that taxonomy." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:Taxonomy .

common_domain_model:BusinessCenterTime a sh:NodeShape ;
    rdfs:comment "A class for defining a time with respect to a business day calendar location. For example, 11:00:00 GBLO." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:fixingTimeDefinition rdf:type common_domain_model:designatedMaturity common_domain_model:fixingReason ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A code identifying a business day calendar location. A business day calendar location is drawn from the list identified by the business day calendar location enumeration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenter ],
        [ sh:datatype xsd:time ;
            sh:description "A time specified in hh:mm:ss format where the second component must be '00', e.g. 11am would be represented as 11:00:00." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:hourMinuteTime ] ;
    sh:targetClass common_domain_model:BusinessCenterTime .

common_domain_model:BusinessCenters a sh:NodeShape ;
    rdfs:comment "A class for specifying the business day calendar location used in determining whether a day is a business day or not, either by specifying this business center by reference to an enumerated list that is maintained by the FpML standard, or by reference to such specification when it exists elsewhere as part of the instance document. This class corresponds to the FpML BusinessCentersOrReference.model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:in ( <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#ADSM> "AGRUS_FMB" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#APPI> "ARGUS_CRUDE" "ARGUS_EUROPEAN_GAS" "ARGUS_EUROPEAN_PRODUCTS" "ARGUS_INTERNATIONAL_LPG" "ARGUS_MCCLOSKEYS_COAL_REPORT" "ARGUS_US_PRODUCTS" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#ASX> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#AWB> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#AWEX> "BALTIC_EXCHANGE" "BANK_NEGARA_MALAYSIA_POLICY_COMMITTEE" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#BELPEX> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#BLUENEXT> "BM_F" "BURSA_MALAYSIA_SETTLEMENT" "BURSA_MALAYSIA_TRADING" "CANADIAN_GAS_PRICE_REPORTER" "CBOT_SOFT" "CMAI_AROMATICS_MARKET_REPORT" "CMAI_GLOBAL_PLASTICS_AND_POLYMERS_MARKET_REPORT" "CMAI_METHANOL_MARKET_REPORT" "CMAI_MONOMERS_MARKET_REPORT" "CME_DAIRY" "CME_NON_DAIRY_SOFT" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#COMEX> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#CRU> "CRU_LONG" "DEPARTMENT_OF_ENERGY" "DEWITT_BENZENE_DERIVATIVES" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#DME> "DOW_JONES" "DOW_JONES_ENERGY_SERVICE" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#DowJonesPower> "EEX_COAL" "EEX_EMISSIONS" "EEX_GAS" "EEX_POWER" "EURONEX_MATIF" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#FERTECON> "FERTILIZER_WEEK" "GAS_DAILY" "GAS_DAILY_PRICE_GUIDE" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#GLOBALCOAL> "HEREN_REPORT" "ICE_10X_DAILY" "ICE_10X_MONTHLY" "ICE_CANADA" "ICE_ECX" "ICE_GAS" "ICE_OIL" "ICE_US_AGRICULTURAL" "ICIS_PRICING_BENZENE__EUROPE_" "ICIS_PRICING_ETHYLENE__EUROPE_" "ICIS_PRICING_POLYPROPYLENE__EUROPE_" "INSIDE_FERC" "JAPAN_MOF_TSRR" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#KCBOT> "KUALA_LUMPUR_BANK" "LABUAN_BANK" "LIFFE_LONDON_SOFT" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#LME> "LONDON_BULLION_MARKET" "LONDON_BULLION_MARKET_GOLD_A_M_ONLY" "LONDON_PLATINUM_PALLADIUM_MARKET" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#MGEX> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#N2EX> "NASDAQ_OMX" "NATURAL_GAS_WEEK" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#NERC> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#NGI> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#NGX> "NUCLEAR_MARKET_REVIEW" "NYMEX_ELECTRICITY" "NYMEX_GAS" "NYMEX_NATURAL_GAS" "NYMEX_OIL" "OFFICIAL_BOARD_MARKETS" "OPIS_LP_GAS" "OPIS_PROPANE" "PAPER_PACKAGING_MONITOR" "PAPER_TRADER" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#PERTAMINA> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#PETROCHEMWIRE> "PIX_PULP_BENCHMARK_INDICES" "PLATTS_APAG_MARKETSCAN" "PLATTS_BUNKERWIRE" "PLATTS_CLEAN_TANKERWIRE" "PLATTS_CRUDE_OIL_MARKETWIRE" "PLATTS_DIRTY_TANKERWIRE" "PLATTS_EUROPEAN_GAS" "PLATTS_EUROPEAN_MARKETSCAN" "PLATTS_METALS_ALERT" "PLATTS_OILGRAM" "PLATTS_TSI_IRON_ORE" "PLATTS_TSI_SCRAP" "PLATTS_TSI_STEEL" "PLATTS_US_MARKETSCAN" "PULP_AND_PAPER_INTERNATIONAL" "PULP_AND_PAPER_WEEK" "RIM_PRODUCTS_INTELLIGENCE_DAILY" "SAFEX_SOFT" "SFE_SOFT" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#SGX> <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#SICOM> "SP_GSCI" "STATISTICHES_BUNDESAMT" <http://www.fpml.org/coding-scheme/commodity-business-calendar-3-6#TGE> "TOCOM_OIL" "TOCOM_PRECIOUS" "TOCOM_SOFT" "UX_WEEKLY" "WORLD_PULP_MONTHLY" ) ;
            sh:order 1 ;
            sh:path common_domain_model:commodityBusinessCalendar ],
        [ sh:datatype xsd:string ;
            sh:description "A code identifying one or several business day calendar location(s). The set of business day calendar locations are specified by the business day calendar location enumeration which is maintained by the FpML standard." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:businessCenter ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "A reference to a financial business center location specified elsewhere in the instance document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:businessCentersReference ] ;
    sh:targetClass common_domain_model:BusinessCenters .

common_domain_model:PriceSchedule a sh:NodeShape ;
    rdfs:comment "Specifies the price of a financial instrument in a trade as a schedule of measures. A price generically expresses the value of an exchange as a ratio: it measures the amount of one thing needed to be exchanged for 1 unit of another thing (e.g. cash in a specific currency in exchange for a bond or share). This generic representation can be used to support any type of financial price beyond just cash price: e.g. an interest rate, a foreign exchange rate, etc. This data type is generically based on a schedule and can also be used to represent a price as a single value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UnitType ;
            sh:description "Provides an attribute to define the unit of the thing being priced. For example, {amount, unitOfAmount, PerUnitOfAmount} = [10, EUR, Shares] = (10.00 EUR/SHARE) * (300,000 SHARES) = EUR 3,000,000.00 (Shares cancel out in the calculation)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:perUnitOf ],
        [ sh:description "Allows further classification of the chosen price type." ;
            sh:in ( "Fee" "Rebate" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:priceSubType ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:value ],
        [ sh:description "(Optionally) When the price is to be understood as an operator to apply to an observable, i.e. a spread, multiplier or min/max." ;
            sh:in ( "Add" "Subtract" "Multiply" "Divide" "Max" "Min" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:arithmeticOperator ],
        [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:unit ],
        [ sh:description "(Optionally) Additional attribute that can further define any premium to the price." ;
            sh:in ( "PrePaid" "PostPaid" "Variable" "Fixed" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:premiumType ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:datedValue ],
        [ sh:description "(Optionally) Specifies whether the price is expressed in absolute or percentage terms." ;
            sh:in ( "AbsoluteTerms" "PercentageOfNotional" "ParValueFraction" "PerOption" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:priceExpression ],
        [ sh:description "Specifies the price type as an enumeration: interest rate, exchange rate, asset price etc. This attribute is mandatory so that prices can always be clasiffied according to their type. The price type implies some constraints on the price's units." ;
            sh:in ( "AssetPrice" "Premium" "Correlation" "Dividend" "ExchangeRate" "InterestRate" "Variance" "Volatility" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:priceType ],
        [ sh:class common_domain_model:PriceComposite ;
            sh:description "(Optionally) Specifies the underlying price components if the price can be expressed as a composite: e.g. dirty price = clean price + accrued." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:composite ] ;
    sh:targetClass common_domain_model:PriceSchedule .

common_domain_model:AdjustableOrRelativeDate a sh:NodeShape ;
    rdfs:comment "A class giving the choice between defining a date as an explicit date together with applicable adjustments or as relative to some other (anchor) date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustedRelativeDateOffset ;
            sh:description "A date specified as some offset to another date (the anchor date)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:relativeDate ],
        [ sh:class common_domain_model:AdjustableDate ;
            sh:description "A date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:adjustableDate ] ;
    sh:targetClass common_domain_model:AdjustableOrRelativeDate .

common_domain_model:Identifier a sh:NodeShape ;
    rdfs:comment "A class to specify a generic identifier, applicable to CDM artefacts such as executions, contracts, lifecycle events and legal documents. An issuer can be associated with the actual identifier value as a way to properly qualify it." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:identifierType rdf:type common_domain_model:locationIdentifierType ) ;
    sh:property [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "The identifier value. This level of indirection between the issuer and the identifier and its version provides the ability to associate multiple identifiers to one issuer, consistently with the FpML PartyTradeIdentifier." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:assignedIdentifier ],
        [ sh:datatype xsd:string ;
            sh:description "The identifier issuer, when specified explicitly alongside the identifier value (instead of being specified by reference to a party)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:issuer ],
        [ sh:class common_domain_model:Party ;
            sh:description "The identifier issuer, when specified by reference to a party specified as part of the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:issuerReference ] ;
    sh:targetClass common_domain_model:Identifier .

common_domain_model:Price a sh:NodeShape ;
    rdfs:comment "Specifies a price as a single value to be associated to a financial product. This data type extends PriceSchedule and requires that only the amount value exists." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UnitType ;
            sh:description "Provides an attribute to define the unit of the thing being priced. For example, {amount, unitOfAmount, PerUnitOfAmount} = [10, EUR, Shares] = (10.00 EUR/SHARE) * (300,000 SHARES) = EUR 3,000,000.00 (Shares cancel out in the calculation)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:perUnitOf ],
        [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:unit ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:datedValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:value ],
        [ sh:description "(Optionally) When the price is to be understood as an operator to apply to an observable, i.e. a spread, multiplier or min/max." ;
            sh:in ( "Add" "Subtract" "Multiply" "Divide" "Max" "Min" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:arithmeticOperator ],
        [ sh:description "(Optionally) Additional attribute that can further define any premium to the price." ;
            sh:in ( "PrePaid" "PostPaid" "Variable" "Fixed" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:premiumType ],
        [ sh:description "Specifies the price type as an enumeration: interest rate, exchange rate, asset price etc. This attribute is mandatory so that prices can always be clasiffied according to their type. The price type implies some constraints on the price's units." ;
            sh:in ( "AssetPrice" "Premium" "Correlation" "Dividend" "ExchangeRate" "InterestRate" "Variance" "Volatility" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:priceType ],
        [ sh:class common_domain_model:PriceComposite ;
            sh:description "(Optionally) Specifies the underlying price components if the price can be expressed as a composite: e.g. dirty price = clean price + accrued." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:composite ],
        [ sh:description "(Optionally) Specifies whether the price is expressed in absolute or percentage terms." ;
            sh:in ( "AbsoluteTerms" "PercentageOfNotional" "ParValueFraction" "PerOption" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:priceExpression ],
        [ sh:description "Allows further classification of the chosen price type." ;
            sh:in ( "Fee" "Rebate" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:priceSubType ] ;
    sh:targetClass common_domain_model:Price .

common_domain_model:Party a sh:NodeShape ;
    rdfs:comment "A class to specify a party, without a qualification as to whether this party is a legal entity or a natural person, although the model provides the ability to associate a person (or set of persons) to a party, which use case would imply that such party would be a legal entity (even if not formally specified as such). " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ContactInformation ;
            sh:description "The postal/street address, telephone number, email address and/or web page. If the contact information is specific to the associated business unit(s) or person (s), it should be associated with those." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:contactInformation ],
        [ sh:class common_domain_model:Account ;
            sh:description "The account that might be associated with the party. At most one account can be specified, as it is expected that this information is used in the context of a contract or legal document where only one account per party can be associated with such object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:account ],
        [ sh:datatype xsd:string ;
            sh:description "The party name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:name ],
        [ sh:class common_domain_model:BusinessUnit ;
            sh:description "Optional organization unit information used to describe the organization units (e.g. trading desks) involved in a transaction or business process, incl. the contact information (when relevant)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:businessUnit ],
        [ sh:class common_domain_model:NaturalPerson ;
            sh:description "The person(s) who might be associated with the party as part of the execution, contract or legal document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:person ],
        [ sh:class common_domain_model:NaturalPersonRole ;
            sh:description "The role of the person(s) " ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:personRole ],
        [ sh:class common_domain_model:PartyIdentifier ;
            sh:description "The identifier associated with a party, e.g. the 20 digits LEI code." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyId ] ;
    sh:targetClass common_domain_model:Party .

common_domain_model:Money a sh:NodeShape ;
    rdfs:comment "Defines a monetary amount in a specified currency." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:value ],
        [ sh:class common_domain_model:Measure ;
            sh:description "Defines an optional number that the quantity should be multiplied by to derive a total quantity. This number is associated to a unit. For example in the case of the Coal (API2) CIF ARA (ARGUS-McCloskey) Futures Contract on the CME, where the unit would be contracts, the multiplier value would 1,000 and the mulitiplier unit would be 1,000 MT (Metric Tons)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:multiplier ],
        [ sh:class common_domain_model:Frequency ;
            sh:description "Defines the frequency to be used when defining a quantity. For example a quantity may be specified as a number of barrels of oil per day, which needs multiplying by the number of days in the relevant period to get the total quantity as a number of barrels." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:frequency ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:datedValue ],
        [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:unit ] ;
    sh:targetClass common_domain_model:Money .

common_domain_model:LegalEntity a sh:NodeShape ;
    rdfs:comment "A class to specify a legal entity, with a required name and an optional entity identifier (such as the LEI)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The legal entity name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:name ],
        [ sh:class common_domain_model:EntityIdentifier ;
            sh:description "A legal entity identifier with a source (e.g. RED entity code)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:entityIdentifier ] ;
    sh:targetClass common_domain_model:LegalEntity .

