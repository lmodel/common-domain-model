    sh:property [ sh:datatype xsd:string ;
            sh:description "The alternative definition for FX haircut percentage that applies to each party and item of Eligible Collateral unless this item is denominated in a Major Currency or in the Base Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fxHaircut ],
        [ sh:datatype xsd:string ;
            sh:description "The additional currencies that are specified as Major Currency for the purpose of applying the FX Haircut Percentage." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:majorCurrency ],
        [ sh:class common_domain_model:EligibleCreditSupport ;
            sh:description "Specification of the Eligible Collateral or Credit Support applicable to the Agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:eligibleCreditSupport ],
        [ sh:class common_domain_model:CollateralTransferTiming ;
            sh:description "Specification of transfer / settlement timing for cash and securities collateral assuming that the notice is provided before the Notification Time (and with a 1LBD lag introduced if the notice is delivered after the Notification Time), and that securities allow for a further Local Business Day for transfer / settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:collateralTransferTiming ],
        [ sh:class common_domain_model:CSAReturnAmount ;
            sh:description "In respect of a Valuation Date, the amount of collateral which a party is entitled to demand to be recalled to it as a Return Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:returnAmount ],
        [ sh:class common_domain_model:CollateralRounding ;
            sh:description "The rounding methodology applicable to the Delivery Amount and the Return Amount in terms of nearest integral multiple of Base Currency units." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:rounding ],
        [ sh:class common_domain_model:CSADeliveryAmount ;
            sh:description "In respect of a Valuation Date, the amount of collateral which a party is entitled to demand to be transferred to it as a Delivery Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:deliveryAmount ],
        [ sh:class common_domain_model:IneligibleCreditSupport ;
            sh:description "The parties to which the provisions of the Credit Support Annex for Variation Margin will apply to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:ineligibleCreditSupport ],
        [ sh:class common_domain_model:BespokeTransferTiming ;
            sh:description "The time by which the transfer of collateral must take place when different from the Regular Settlement Day as a result of parties' election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:bespokeTransferTiming ],
        [ sh:class common_domain_model:MinimumTransferAmount ;
            sh:description "Represents the threshold specified in the agreement below which collateral need not be delivered, and represents the smallest incremental value of exposure that must be reached before the parties are obliged to transfer collateral." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:minimumTransferAmount ] ;
    sh:targetClass common_domain_model:CreditSupportObligationsVariationMargin .

common_domain_model:CreditSupportProvider a sh:NodeShape ;
    rdfs:comment "Identification of party specific Credit Support Providers applicable to the document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CreditSupportProviderElection ;
            sh:description "The party election of Credit Support Provider(s), if any." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:creditSupportProviderElection ] ;
    sh:targetClass common_domain_model:CreditSupportProvider .

common_domain_model:CreditSupportProviderElection a sh:NodeShape ;
    rdfs:comment "The party election of Credit Support Provider(s), if any." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specification of the Credit Support Provider terms." ;
            sh:in ( "Specified" "Any" "None" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:creditSupportProviderTerms ],
        [ sh:class common_domain_model:Party ;
            sh:description "The elective party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "..." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:bespokeCreditSuppportProvider ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The specified Credit Support Provider(s), if any." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:creditSupportProvider ] ;
    sh:targetClass common_domain_model:CreditSupportProviderElection .

common_domain_model:Custodian a sh:NodeShape ;
    rdfs:comment "A class to specify the custodian and custody account details for each party to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CustodianElection ;
            sh:description "The party specific elections." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:Custodian .

common_domain_model:CustodianElection a sh:NodeShape ;
    rdfs:comment "A class to specify the custodian and custody account details for each party to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "The identity of the relevant custodian where Named Entity is elected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:legacyNamedEntity ],
        [ sh:description "Details how the Custodian is determined." ;
            sh:in ( "NotApplicable" "NamedEntity" "AsAdvised1to2" "AsAdvised2to1" "Party1toParty2" "Party2toParty1" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:legacyVMCustodian ],
        [ sh:class common_domain_model:Account ;
            sh:description "The identification of the segregated security account for the purpose of holding security collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:segregatedSecurityAccount ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The custody agent. While CreateiQ only specifies the custodian's name, specifying the legal entity as part of the CDM is deemed more appropriate, while this will still provide the ability to accommodate situations where only the entity name is available, as the entityId attribute is optional as part of the LegalEntity class." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:custodian ],
        [ sh:class common_domain_model:Account ;
            sh:description "The identification of the segregated cash account for the purpose of holding cash collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:segregatedCashAccount ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:CustodianElection .

common_domain_model:CustodianEvent a sh:NodeShape ;
    rdfs:comment "A class to specify the Custodian Event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CustodianEventEndDate ;
            sh:description "The qualification of the Custodian Event (English Law & New York Law ISDA CSA) or Collateral Manager Event (Japanese Law ISDA CSA) End Date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:endDate ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification as to whether the Custodian Event (English Law & New York Law ISDA CSA) or the Collateral Manager Event (Japanese Law ISDA CSA) is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:CustodianEvent .

common_domain_model:CustodianEventEndDate a sh:NodeShape ;
    rdfs:comment "A class to specify the Custodian Event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CustomisableOffset ;
            sh:description "The parties' election to specify the number of days prior to the end of the safekeeping period (Clearstream CTA) purpose of qualifying the CE/CME End Date, in the case where advance notice is given." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:safekeepingPeriodExpiry ],
        [ sh:class common_domain_model:CustomisableOffset ;
            sh:description "The parties' election to specify the number of days one party has effectively provided the Timely Statement to the other party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:dateOfTimelyStatement ],
        [ sh:class common_domain_model:CustomisableOffset ;
            sh:description "Election to specify the number of days prior to the termination of the Control Agreement /Collateral Management Event for the purpose of qualifying the CE/CME End Date, in the case where advance notice is given." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:releaseDate ],
        [ sh:class common_domain_model:CustomisableOffset ;
            sh:description "Election to specify the number of days after the occurrence of the Custodian Event/Collateral Management Event for the purpose of qualifying the CE/CME End Date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:daysAfterCustodianEvent ] ;
    sh:targetClass common_domain_model:CustodianEventEndDate .

common_domain_model:CustodianRisk a sh:NodeShape ;
    rdfs:comment "A class to specify the Custodian Risk elections specific to a Credit Support Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CustodianRiskElection ;
            sh:description "The party specific elections." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:CustodianRisk .

common_domain_model:CustodianRiskElection a sh:NodeShape ;
    rdfs:comment "A class to specify the Custodian Risk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The qualification as to whether the risk is deemed as Specified." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isSpecified ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The Custodian Risk or Collateral Manager Risk qualification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:qualification ] ;
    sh:targetClass common_domain_model:CustodianRiskElection .

common_domain_model:CustomisedWorkflow a sh:NodeShape ;
    rdfs:comment "In its initial iteration, this class is meant to support the DTCC TIW workflow information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "In this initial iteration, this corresponds to the DTCC TIW element name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:itemName ],
        [ sh:datatype xsd:string ;
            sh:description "In this initial iteration, this corresponds to the DTCC value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:itemValue ] ;
    sh:targetClass common_domain_model:CustomisedWorkflow .

common_domain_model:DateList a sh:NodeShape ;
    rdfs:comment "List of dates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:date ] ;
    sh:targetClass common_domain_model:DateList .

common_domain_model:DateRelativeToCalculationPeriodDates a sh:NodeShape ;
    rdfs:comment "A data to:  provide the ability to point to multiple payment nodes in the document through the unbounded paymentDatesReference." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CalculationPeriodDates ;
            sh:description "A set of href pointers to calculation period dates defined somewhere else in the document." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationPeriodDatesReference ] ;
    sh:targetClass common_domain_model:DateRelativeToCalculationPeriodDates .

common_domain_model:DateRelativeToPaymentDates a sh:NodeShape ;
    rdfs:comment "A data to:  provide the ability to point to multiple payment nodes in the document through the unbounded paymentDatesReference." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PaymentDates ;
            sh:description "A set of href pointers to payment dates defined somewhere else in the document." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:paymentDatesReference ] ;
    sh:targetClass common_domain_model:DateRelativeToPaymentDates .

common_domain_model:DateRelativeToValuationDates a sh:NodeShape ;
    rdfs:comment "A data to:  provide the ability to point to multiple payment nodes in the document through the unbounded paymentDatesReference." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PerformanceValuationDates ;
            sh:description "A set of href pointers to valuation period dates defined somewhere else in the document." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuationDatesReference ] ;
    sh:targetClass common_domain_model:DateRelativeToValuationDates .

common_domain_model:DateTimeList a sh:NodeShape ;
    rdfs:comment "List of dateTimes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "The CDM specifies that the zoned date time is to be expressed in accordance with ISO 8601, either as UTC as an offset to UTC." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:dateTime ] ;
    sh:targetClass common_domain_model:DateTimeList .

common_domain_model:DebtEconomics a sh:NodeShape ;
    rdfs:comment "Specifies selected economics of a debt security." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SecuredDebt ;
            sh:description "Specifies the type of secured debt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:secured ],
        [ sh:class common_domain_model:DebtRedemption ;
            sh:description "Specifies the general rule for redemption of a debt security." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:redemption ],
        [ sh:description "Specifies the order of repayment in the event of a sale or bankruptcy of the issuer or a related party (eg guarantor)." ;
            sh:in ( "Secured" "Senior" "Subordinated" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:seniority ],
        [ sh:description "Specifies the general rule for repayment of principal." ;
            sh:in ( "Bullet" "Callable" "Puttable" "Amortising" "InflationLinked" "IndexLinked" "OtherStructured" "PrincipalOnly" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:principal ],
        [ sh:description "Specifies the general rule for periodic interest rate payment." ;
            sh:in ( "Fixed" "Floating" "InflationLinked" "IndexLinked" "InterestOnly" "OtherStructured" "InverseFloating" "ZeroCoupon" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:interest ] ;
    sh:targetClass common_domain_model:DebtEconomics .

common_domain_model:DebtRedemption a sh:NodeShape ;
    rdfs:comment "Specifies the redemption features and whether the redemption right is exercised at the discretion of the issuer or the holder." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies whether the debt security is redeemed at the election of the Issuer/Holder." ;
            sh:in ( "Holder" "Issuer" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:party ],
        [ sh:description "Specifies the embedded option feature of a debt security." ;
            sh:in ( "Put" "Call" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:putCall ],
        [ sh:description "Specifies the contractual redemption or conversion features associated with a debt security." ;
            sh:in ( "Convertible" "Exchangeable" "ContingentConvertible" "Sinkable" "Extraordinary" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:redemptionType ] ;
    sh:targetClass common_domain_model:DebtRedemption .

common_domain_model:DeliverableObligations a sh:NodeShape ;
    rdfs:comment "A class to specify all the ISDA terms relevant to defining the deliverable obligations." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NotDomesticCurrency ;
            sh:description "An obligation and deliverable obligation characteristic. Any obligation that is payable in any currency other than the domestic currency. Domestic currency is either the currency so specified or, if no currency is specified, the currency of (a) the reference entity, if the reference entity is a sovereign, or (b) the jurisdiction in which the relevant reference entity is organised, if the reference entity is not a sovereign. ISDA 2003 Term: Not Domestic Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:notDomesticCurrency ],
        [ sh:datatype xsd:string ;
            sh:description "A free format string to specify any excluded obligations or deliverable obligations, as the case may be, of the reference entity or excluded types of obligations or deliverable obligations. ISDA 2003 Term: Excluded Obligations/Excluded Deliverable Obligations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path common_domain_model:excluded ],
        [ sh:datatype xsd:boolean ;
            sh:description "A deliverable obligation characteristic. Any obligation that is not a bearer instrument. This applies to Bonds only and is meant to avoid tax, fraud and security/delivery provisions that can potentially be associated with Bearer Bonds. ISDA 2003 Term: Not Bearer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path common_domain_model:notBearer ],
        [ sh:class common_domain_model:PCDeliverableObligationCharac ;
            sh:description "A deliverable obligation characteristic. A loan that is capable of being assigned with the consent of the Reference Entity or the guarantor, if any, of the loan or any agent. ISDA 2003 Term: Consent Required Loan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:consentRequiredLoan ],
        [ sh:class common_domain_model:PCDeliverableObligationCharac ;
            sh:description "A deliverable obligation characteristic. A loan that is freely assignable to a bank or financial institution without the consent of the Reference Entity or the guarantor, if any, of the loan (or the consent of the applicable borrower if a Reference Entity is guaranteeing the loan) or any agent. ISDA 2003 Term: Assignable Loan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:assignableLoan ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. An obligation that ranks at least equal with the most senior Reference Obligation in priority of payment or, if no Reference Obligation is specified in the related Confirmation, the obligations of the Reference Entity that are senior. ISDA 2003 Term: Not Subordinated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:notSubordinated ],
        [ sh:class common_domain_model:LoanParticipation ;
            sh:description "ISDA 1999 Term: Indirect Loan Participation. NOTE: Only applicable as a deliverable obligation under ISDA Credit 1999." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path common_domain_model:indirectLoanParticipation ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. If the reference entity is a Sovereign, this means any obligation that is not subject to the laws of the reference entity. If the reference entity is not a sovereign, this means any obligation that is not subject to the laws of the jurisdiction of the reference entity. ISDA 2003 Term: Not Domestic Law." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:notDomesticLaw ],
        [ sh:datatype xsd:boolean ;
            sh:description "A deliverable obligation characteristic. An obligation that is transferable to institutional investors without any contractual, statutory or regulatory restrictions. ISDA 2003 Term: Transferable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path common_domain_model:transferable ],
        [ sh:datatype xsd:boolean ;
            sh:description "A deliverable obligation characteristic. An obligation at time of default is due to mature and due to be repaid, or as a result of downgrade/bankruptcy is due to be repaid as a result of an acceleration clause. ISDA 2003 Term: Accelerated or Matured." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path common_domain_model:acceleratedOrMatured ],
        [ sh:class common_domain_model:Period ;
            sh:description "A deliverable obligation characteristic. An obligation that has a remaining maturity from the Physical Settlement Date of not greater than the period specified. ISDA 2003 Term: Maximum Maturity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path common_domain_model:maximumMaturity ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published additional provisions for U.S. Municipal as Reference Entity. ISDA 2003 Term: Revenue Obligation Liability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path common_domain_model:revenueObligationLiability ],
        [ sh:description "Used in both obligations and deliverable obligations to represent a class or type of securities which apply. ISDA 2003 Term: Obligation Category/Deliverable Obligation Category." ;
            sh:in ( "Payment" "BorrowedMoney" "ReferenceObligationsOnly" "Bond" "Loan" "BondOrLoan" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:category ],
        [ sh:datatype xsd:string ;
            sh:description "This element is used to specify any other obligations of a reference entity in both obligations and deliverable obligations. The obligations can be specified free-form. ISDA 2003 Term: Other Obligations of a Reference Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path common_domain_model:othReferenceEntityObligations ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Indicates whether or not the obligation is quoted, listed or ordinarily purchased and sold on an exchange. ISDA 2003 Term: Listed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:listed ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published additional provisions for U.S. Municipal as Reference Entity. ISDA 2003 Term: General Fund Obligation Liability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path common_domain_model:generalFundObligationLiability ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published additional provisions for U.S. Municipal as Reference Entity. ISDA 2003 Term: Full Faith and Credit Obligation Liability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path common_domain_model:fullFaithAndCreditObLiability ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether accrued interest is included (true) or not (false). For cash settlement this specifies whether quotations should be obtained inclusive or not of accrued interest. For physical settlement this specifies whether the buyer should deliver the obligation with an outstanding principal balance that includes or excludes accrued interest. ISDA 2003 Term: Include/Exclude Accrued Interest." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:accruedInterest ],
        [ sh:datatype xsd:boolean ;
            sh:description "A deliverable obligation characteristic. In essence Not Contingent means the repayment of principal cannot be dependant on a formula/index, i.e. to prevent the risk of being delivered an instrument that may never pay any element of principal, and to ensure that the obligation is interest bearing (on a regular schedule). ISDA 2003 Term: Not Contingent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:notContingent ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Any obligation that is not primarily (majority) owed to a Sovereign or Supranational Organisation. ISDA 2003 Term: Not Sovereign Lender." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:notSovereignLender ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Any obligation other than an obligation that was intended to be offered for sale primarily in the domestic market of the relevant Reference Entity. This specifies that the obligation must be an internationally recognised bond. ISDA 2003 Term: Not Domestic Issuance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:notDomesticIssuance ],
        [ sh:class common_domain_model:SpecifiedCurrency ;
            sh:description "An obligation and deliverable obligation characteristic. The currency or currencies in which an obligation or deliverable obligation must be payable. ISDA 2003 Term: Specified Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:specifiedCurrency ],
        [ sh:class common_domain_model:LoanParticipation ;
            sh:description "A deliverable obligation characteristic. A loan with a participation agreement whereby the buyer is capable of creating, or procuring the creation of, a contractual right in favour of the seller that provides the seller with recourse to the participation seller for a specified share in any payments due under the relevant loan which are received by the participation seller. ISDA 2003 Term: Direct Loan Participation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:directLoanParticipation ] ;
    sh:targetClass common_domain_model:DeliverableObligations .

common_domain_model:DeliveryDateParameters a sh:NodeShape ;
    rdfs:comment "Specifies a specific date or the parameters for identifying the relevant contract date when the commodity reference price is a futures contract." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:DeliveryDateParameters .

common_domain_model:DerivInstrmAttrbts a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UndrlygInstrm ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:undrlygInstrm ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:xpryDt ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:pricMltplr ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:dlvryTp ] ;
    sh:targetClass common_domain_model:DerivInstrmAttrbts .

common_domain_model:DeterminationMethodology a sh:NodeShape ;
    rdfs:comment "Specifies the method according to which an amount or a date is determined." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents a more granular dimention of observation. Typically relevent for resolving a unique equity price, which can be expressed as trade-weighted or volume-weighted averages." ;
            sh:in ( <http://www.fpml.org/coding-scheme/determination-method-3-4#AgreedInitialPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#AsSpecifiedInMasterConfirmation> <http://www.fpml.org/coding-scheme/determination-method-3-4#CalculationAgent> <http://www.fpml.org/coding-scheme/determination-method-3-4#ClosingPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#DividendCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#ExpiringContractLevel> <http://www.fpml.org/coding-scheme/determination-method-3-4#HedgeExecution> <http://www.fpml.org/coding-scheme/determination-method-3-4#IssuerPaymentCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#NAV> <http://www.fpml.org/coding-scheme/determination-method-3-4#OpenPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#OSPPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#SettlementCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#StrikeDateDetermination> <http://www.fpml.org/coding-scheme/determination-method-3-4#TWAPPrice> "TWAPVE" "TWAPVEExcludingClose" <http://www.fpml.org/coding-scheme/determination-method-3-4#ValuationTime> <http://www.fpml.org/coding-scheme/determination-method-3-4#VWAPPrice> "VWAPVE" "VWAPVEExcludingClose" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:determinationMethod ],
        [ sh:description "Specifies enumerations for the type of averaging calculation." ;
            sh:in ( "Arithmetic" "Geometric" "Harmonic" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:averagingMethod ] ;
    sh:targetClass common_domain_model:DeterminationMethodology .

common_domain_model:DirectionRatingMultiplier a sh:NodeShape ;
    rdfs:comment "A logical container to hold a defined set of related data. In this case the collation of Ratings Information and associated exposure multiplier." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Specifies the multiplier applied to exposure based on the credit rating of the rated party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:exposureMultiplier ],
        [ sh:class common_domain_model:DirectionRatingSet ;
            sh:description "A logical container to hold a defined set of related data. In this case the collation of Ratings Agency, Rating value and an associated direction." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:variableSet ] ;
    sh:targetClass common_domain_model:DirectionRatingMultiplier .

common_domain_model:DirectionRatingSet a sh:NodeShape ;
    rdfs:comment "A logical container to hold a defined set of related data. In this case the collation of Ratings Agency, Rating value and an associated direction that are grouped by either AND or OR logic." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:DirectionRatingSet .

common_domain_model:DiscountingMethod a sh:NodeShape ;
    rdfs:comment "A data defining:  discounting information. The 2000 ISDA definitions, section 8.4. discounting (related to the calculation of a discounted fixed amount or floating amount) apply. This type must only be included if discounting applies." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "A discount rate, expressed as a decimal, to be used in the calculation of a discounted amount. A discount amount of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:discountRate ],
        [ sh:description "The discounting method that is applicable." ;
            sh:in ( "Standard" "FRA" "FRAYield" "AFMA" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:discountingType ],
        [ sh:description "A discount day count fraction to be used in the calculation of a discounted amount." ;
            sh:in ( "ACT_360" "ACT_365L" "ACT_364" "ACT_365_FIXED" "ACT_ACT_AFB" "ACT_ACT_ICMA" "ACT_ACT_ISDA" "ACT_ACT_ISMA" "CAL_252" "_1_1" "_30E_360" "_30E_360_ISDA" "_30_360" "RBA_BOND_BASIS" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:discountRateDayCountFraction ] ;
    sh:targetClass common_domain_model:DiscountingMethod .

common_domain_model:DividendCurrency a sh:NodeShape ;
    rdfs:comment "A class to specify the currency in which the dividends will be denominated, i.e. either in the dividend currency or in a currency specified as part of the contract." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the method according to which the dividend is determined, e.g. the dividend currency." ;
            sh:in ( <http://www.fpml.org/coding-scheme/determination-method-3-4#AgreedInitialPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#AsSpecifiedInMasterConfirmation> <http://www.fpml.org/coding-scheme/determination-method-3-4#CalculationAgent> <http://www.fpml.org/coding-scheme/determination-method-3-4#ClosingPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#DividendCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#ExpiringContractLevel> <http://www.fpml.org/coding-scheme/determination-method-3-4#HedgeExecution> <http://www.fpml.org/coding-scheme/determination-method-3-4#IssuerPaymentCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#NAV> <http://www.fpml.org/coding-scheme/determination-method-3-4#OpenPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#OSPPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#SettlementCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#StrikeDateDetermination> <http://www.fpml.org/coding-scheme/determination-method-3-4#TWAPPrice> "TWAPVE" "TWAPVEExcludingClose" <http://www.fpml.org/coding-scheme/determination-method-3-4#ValuationTime> <http://www.fpml.org/coding-scheme/determination-method-3-4#VWAPPrice> "VWAPVE" "VWAPVEExcludingClose" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:determinationMethod ],
        [ sh:datatype xsd:string ;
            sh:description "The currency in which the dividend is denominated. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:string ;
            sh:description "Reference to a currency specified elsewhere in the document" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:currencyReference ] ;
    sh:targetClass common_domain_model:DividendCurrency .

common_domain_model:DividendDateReference a sh:NodeShape ;
    rdfs:comment "A class to specify the dividend date by reference to another date, with the ability to apply and offset. This class doesn't exist in FpML and is meant to simplify the choice constraint associated with the DividendPaymentDate class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Offset ;
            sh:description "Only to be used when SharePayment has been specified in the dividendDateReference element. The number of Currency Business Days following the day on which the Issuer of the Shares pays the relevant dividend to holders of record of the Shares." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:paymentDateOffset ],
        [ sh:description "Specification of the dividend date using an enumeration, with values such as the pay date, the ex-date or the record date." ;
            sh:in ( "AdHocDate" "CashSettlementPaymentDate" "CashSettlePaymentDateExDiv" "CashSettlePaymentDateIssuerPayment" "CumulativeEquityExDiv" "CumulativeEquityPaid" "CumulativeEquityExDivBeforeReset" "CumulativeEquityPaidBeforeReset" "CumulativeEquityPaidInclReset" "CumulativeInterestExDiv" "CumulativeInterestPaid" "CumulativeInterestPaidInclReset" "CumulativeInterestPaidBeforeReset" "DividendPaymentDate" "DividendValuationDate" "EquityPaymentDate" "ExDate" "FloatingAmountPaymentDate" "FollowingPaymentDate" "RecordDate" "SharePayment" "TerminationDate" "TradeDate" "UnwindOrEquityExDiv" "UnwindOrEquityPaid" "UnwindOrInterestExDiv" "UnwindOrInterestPaid" "UnwindExDiv" "UnwindPaid" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:dateReference ] ;
    sh:targetClass common_domain_model:DividendDateReference .

common_domain_model:DividendPeriod a sh:NodeShape ;
    rdfs:comment "Time bounded dividend payment periods, each with a dividend payment date per period." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:DividendPaymentDate ;
            sh:description "Dividend period end date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:endDate ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "Date adjustments for all unadjusted dates in this dividend period." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:dateAdjustments ],
        [ sh:class common_domain_model:DividendPaymentDate ;
            sh:description "Dividend period start date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:startDate ],
        [ sh:class common_domain_model:BasketConstituent ;
            sh:description "For basket underliers, reference to the basket component which is paying dividends in the specified period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:basketConstituent ],
        [ sh:class common_domain_model:DividendPaymentDate ;
            sh:description "Specifies when the dividend will be paid to the receiver of the equity return. Has the meaning as defined in the ISDA 2002 Equity Derivatives Definitions. Is not applicable in the case of a dividend reinvestment election." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:dividendPaymentDate ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "Specifies the dividend valuation dates of the swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:dividendValuationDate ] ;
    sh:targetClass common_domain_model:DividendPeriod .

common_domain_model:EarlyTerminationEvent a sh:NodeShape ;
    rdfs:comment "A data to:  define the adjusted dates associated with an early termination provision." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date on which the cash settlement amount is paid. This date should already be adjusted for any applicable business date convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:adjustedCashSettlementPaymentDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date by which the cash settlement amount must be agreed. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:adjustedCashSettlementValuationDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which option exercise takes place. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:adjustedExerciseDate ],
        [ sh:datatype xsd:date ;
            sh:description "The early termination date that is applicable if an early termination provision is exercised. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedEarlyTerminationDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the exercise fee amount is paid. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:adjustedExerciseFeePaymentDate ] ;
    sh:targetClass common_domain_model:EarlyTerminationEvent .

common_domain_model:EarlyTerminationProvision a sh:NodeShape ;
    rdfs:comment "A data defining:  an early termination provision for a swap. This early termination is at fair value, i.e. on termination the fair value of the product must be settled between the parties." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ExercisePeriod ;
            sh:description "Definition of the first early termination date and the frequency of the termination dates subsequent to that. American exercise is defined by having a frequency of one day." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:optionalEarlyTerminationParameters ],
        [ sh:class common_domain_model:OptionalEarlyTermination ;
            sh:description "An option for either or both parties to terminate the swap at fair value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:optionalEarlyTermination ],
        [ sh:class common_domain_model:MandatoryEarlyTermination ;
            sh:description "A mandatory early termination provision to terminate the swap at fair value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:mandatoryEarlyTermination ],
        [ sh:class common_domain_model:Period ;
            sh:description "Period after trade date of the mandatory early termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:mandatoryEarlyTerminationDateTenor ] ;
    sh:targetClass common_domain_model:EarlyTerminationProvision .

common_domain_model:ElectiveAmountElection a sh:NodeShape ;
    rdfs:comment "A class to specify the party elective amounts which can be used for the purpose of specifying elections such as the ISDA CSA Threshold and Minimum Transfer Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies an enumerated election to express the elective amount." ;
            sh:in ( "Zero" "Unlimited" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:electiveAmount ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The elective amount when expressed as a custom election by the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:customElection ],
        [ sh:class common_domain_model:Money ;
            sh:description "The elective amount when expressed as a currency amount. The associated PartyElectiveAmount_amount data rule enforces that the currency amount is actually greater than 0." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:amount ] ;
    sh:targetClass common_domain_model:ElectiveAmountElection .

common_domain_model:EligibilityQuery a sh:NodeShape ;
    rdfs:comment "Query to check against an EligibleCollateralSpecification" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Maturity in years" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:maturity ],
        [ sh:class common_domain_model:CollateralIssuerType ;
            sh:description "Represents a filter based on the type of entity issuing the asset." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:issuerType ],
        [ sh:description "The underlying asset denominated currency." ;
            sh:in ( "CNH" "CNT" "GGP" "IMP" "JEP" "KID" "MCF" "SML" "VAL" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:denominatedCurrency ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Specifies the issuing entity name or LEI." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:issuerName ],
        [ sh:class common_domain_model:AgencyRatingCriteria ;
            sh:description "The agency rating based on default risk and creditors claim in event of default associated with specific instrument." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:agencyRating ],
        [ sh:class common_domain_model:AssetType ;
            sh:description "The asset product type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:collateralAssetType ],
        [ sh:description "The asset country of origin." ;
            sh:in ( "AF" "AL" "DZ" "AS" "AD" "AO" "AI" "AQ" "AG" "AR" "AM" "AW" "AU" "AT" "AZ" "BS" "BH" "BD" "BB" "BY" "BE" "BZ" "BJ" "BM" "AX" "BT" "BO" "BQ" "BA" "BW" "BV" "BR" "IO" "BN" "BG" "BF" "BI" "CV" "KH" "CM" "CA" "KY" "CF" "TD" "CL" "CN" "CX" "CC" "CO" "KM" "CD" "CG" "CK" "CR" "HR" "CU" "CW" "CY" "CZ" "CI" "DK" "DJ" "DM" "DO" "EC" "EG" "SV" "GQ" "ER" "EE" "SZ" "ET" "FK" "FO" "FJ" "FI" "FR" "GF" "PF" "TF" "GA" "GM" "GE" "DE" "GH" "GI" "GR" "GL" "GD" "GP" "GU" "GT" "GG" "GN" "GW" "GY" "HT" "HM" "VA" "HN" "HK" "HU" "IS" "IN" "ID" "IR" "IQ" "IE" "IM" "IL" "IT" "JM" "JP" "JE" "JO" "KZ" "KE" "KI" "KP" "KR" "KW" "KG" "LA" "LV" "LB" "LS" "LR" "LY" "LI" "LT" "LU" "MO" "MG" "MW" "MY" "MV" "ML" "MT" "MH" "MQ" "MR" "MU" "YT" "MX" "FM" "MD" "MC" "MN" "ME" "MS" "MA" "MZ" "MM" "NA" "NR" "NP" "NL" "NC" "NZ" "NI" "NE" "NG" "NU" "NF" "MK" "MP" "NO" "OM" "PK" "PW" "PS" "PA" "PG" "PY" "PE" "PH" "PN" "PL" "PT" "PR" "QA" "RO" "RU" "RW" "RE" "BL" "SH" "KN" "LC" "MF" "PM" "VC" "WS" "SM" "ST" "SA" "SN" "RS" "SC" "SL" "SG" "SX" "SK" "SI" "SB" "SO" "ZA" "GS" "SS" "ES" "LK" "SD" "SR" "SJ" "SE" "CH" "SY" "TW" "TJ" "TZ" "TH" "TL" "TG" "TK" "TO" "TT" "TN" "TM" "TC" "TV" "TR" "UG" "UA" "AE" "GB" "UM" "US" "UY" "UZ" "VU" "VE" "VN" "VG" "VI" "WF" "EH" "YE" "ZM" "ZW" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:assetCountryOfOrigin ] ;
    sh:targetClass common_domain_model:EligibilityQuery .

common_domain_model:EligibilityToHoldCollateral a sh:NodeShape ;
    rdfs:comment "Specifies the conditions under which a party and its custodian(s) are entitled to hold collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "A logical container to hold a defined set of related data. In this case the collation of criteria required by the party and its custodian to Hold the other party's Posted Collateral." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:AnyEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:RatingAgencyValue ] [ sh:class common_domain_model:AmountOfNetCapital ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:criteria ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies any additional conditions relevant to the Custodian of the respective parties as set out in the Holding and Using Posted Collateral clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:custodianCondition ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the party's custodian is eligible to hold the other party's posted collateral. If 'True' then the custodian is eligible to hold the Posted Collateral given that the specified criteria are met." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:custodianEligibility ],
        [ sh:datatype xsd:string ;
            sh:description "The restrictions that might be required by a party and its custodian in terms of country(ies) where the other party's collateral can be held." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:eligibleCountry ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Election to specify the initial custodian." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:initialCustodian ] ;
    sh:targetClass common_domain_model:EligibilityToHoldCollateral .

common_domain_model:EligibleCollateralElection a sh:NodeShape ;
    rdfs:comment "Specifies the collateral posting obligations for the security provider party(ies)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the party providing the security." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The excluded collateral as specified in relation to the pledgor/chargor/obligor(s) posting obligation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:excludedCollateral ],
        [ sh:datatype xsd:boolean ;
            sh:description "If set to True, the Control Agreement is a Credit Support Document with respect to the party(ies)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:asPermitted ],
        [ sh:class common_domain_model:EligibleCollateralCriteria ;
            sh:description "The eligible collateral as specified in relation to the pledgor/chargor/obligor(s) posting obligation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:eligibleCollateral ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the Other Eligible Support conditions. If not specified, this election is deemed as not applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:otherEligibleSupport ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:EligibleCollateralElection .

common_domain_model:EligibleCollateralSpecification a sh:NodeShape ;
    rdfs:comment "Represents a set of criteria used to specify eligible collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "The parties associated with the specification." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Specifies the identifier(s) to uniquely identify eligible collateral or a set of eligible collateral, such as a schedule or equivalant for an identity issuer." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:Counterparty ;
            sh:description "Specification of the roles of the counterparties to the specification." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:counterparty ],
        [ sh:description "Represents a set of criteria used to specify eligible collateral." ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:AnyEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:RatingAgencyValue ] [ sh:class common_domain_model:AmountOfNetCapital ] ) ;
            sh:order 3 ;
            sh:path common_domain_model:criteria ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Specifies the role(s) that each of the party(s) is playing in the context of the specification, eg Payor or Receiver." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:partyRole ] ;
    sh:targetClass common_domain_model:EligibleCollateralSpecification .

common_domain_model:EnforcementEvent a sh:NodeShape ;
    rdfs:comment "A class to specify Enforcement Events specific to Security Agreements." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The failure to pay election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:failureToPay ],
        [ sh:datatype xsd:boolean ;
            sh:description "The early termination election." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:earlyTerminationDate ] ;
    sh:targetClass common_domain_model:EnforcementEvent .

common_domain_model:EntityIdentifier a sh:NodeShape ;
    rdfs:comment "Comprises an identifier and a source. The associated metadata key denotes the ability to associate a hash value to the EntityIdentifier instantiations for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Provides an identifier associated with a legal entity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:description "Defines the source of the identifier." ;
            sh:in ( "REDID" "CountryCode" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:identifierType ] ;
    sh:targetClass common_domain_model:EntityIdentifier .

common_domain_model:EquityAdditionalTerms a sh:NodeShape ;
    rdfs:comment "Transaction AdditionalTerms that apply to Equity asset class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UnderlierSubstitutionProvision ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:substitutionProvision ],
        [ sh:class common_domain_model:DeterminationRolesAndTerms ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:determinationTerms ],
        [ sh:class common_domain_model:ExtraordinaryEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:extraordinaryEvents ] ;
    sh:targetClass common_domain_model:EquityAdditionalTerms .

common_domain_model:EventCurrency a sh:NodeShape ;
    rdfs:comment "Defines the currency referenced as such in any terms related to FX Disruption Events" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Quantity ;
            sh:description "Defines the Event Currency Amount to be exchanged on the Settlement Date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:eventCurrentAmount ],
        [ sh:class common_domain_model:BuyerSeller ;
            sh:description "Unless otherwised specified, the Buyer is the party to which the Event Currency Amount is owed on the Settlement Date and the Seller is the party which owes the Event Currency Amount on the Settlement Date." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:eventCurrencyBuyerSeller ],
        [ sh:datatype xsd:string ;
            sh:description "Defines the currency referenced as such in any terms related to FX Disruption Events" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:eventCurrency ] ;
    sh:targetClass common_domain_model:EventCurrency .

common_domain_model:EventsOfDefault a sh:NodeShape ;
    rdfs:comment "The definitions regarding any different events of default relating to the GMSLA." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EventsOfDefaultElection ;
            sh:description "The specified events of default elections for the respective parties signing the GMSLA." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:EventsOfDefault .

common_domain_model:EventsOfDefaultElection a sh:NodeShape ;
    rdfs:comment "The specific party elections for events of default." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Optional string to capture any further information regarding the automatic early termination even of default." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:automaticEarlyTerminationOther ],
        [ sh:datatype xsd:boolean ;
            sh:description "Automatic early termination applies in a modified form only." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:automaticEarlyTerminationInModifiedForm ],
        [ sh:datatype xsd:boolean ;
            sh:description "In the case where party is acting as an agent, is automatic early termination specified on a per principle basis?" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:automaticEarlyTerminationSpecifiedSeparatelyForEachPrinciple ],
        [ sh:description "Are existing loans covered in the event of default (Only relevant to 2010 GMSLAs)?" ;
            sh:in ( "Applicable" "NotApplicable" "NotSpecified" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:existingLoans ],
        [ sh:description "Does automatic early termination apply to the specified party?" ;
            sh:in ( "Applicable" "NotApplicable" "NotSpecified" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:automaticEarlyTerminationApplies ],
        [ sh:datatype xsd:boolean ;
            sh:description "Automatic early termination only applies if required due to system of law, otherwise it is not applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:automaticEarlyTerminationRequiredDueToSystemOfLaw ],
        [ sh:description "Are third party vendors allowed to automate the processing of loans in the event of default (Only relevant to 2010 GMSLAs)?" ;
            sh:in ( "Applicable" "NotApplicable" "NotSpecified" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:automation ],
        [ sh:description "The specified party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:EventsOfDefaultElection .

common_domain_model:EvergreenProvision a sh:NodeShape ;
    rdfs:comment "Specifies a transaction which automatically extends for a specified timeframe until the exercise of an embedded option." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "Defines the minimum period before an evergreen is scheduled to terminate that notice can be given that it will terminate beyond the scheduled termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:noticeDeadlinePeriod ],
        [ sh:class common_domain_model:Price ;
            sh:description "An optional adjustment to the rate for the last period of the evergreen i.e. the period from when notice is given to stop rolling the contract through to the termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:finalPeriodFeeAdjustment ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "If evergreen termination is not available to both parties then this component specifies the buyer and seller of the option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:singlePartyOption ],
        [ sh:class common_domain_model:AdjustableRelativeOrPeriodicDates ;
            sh:description "The frequency with which the evergreen contract will be extended if notice is not given." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:extensionFrequency ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The length of each evergreen extension period relative to the effective date of the preceding contract." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:noticePeriod ],
        [ sh:datatype xsd:dateTime ;
            sh:description "A specific date and time for the notice deadline" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:noticeDeadlineDateTime ] ;
    sh:targetClass common_domain_model:EvergreenProvision .

common_domain_model:ExcludedProducts a sh:NodeShape ;
    rdfs:comment "Description of the relevant derivative transactions excluded from the calculation of exposure." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Description of the relevant derivative transactions excluded from the calculation of exposure." ;
            sh:in ( "FXTransactions" "FXSettlementDate" "CurrencyOptionTransactions" ) ;
            sh:order 0 ;
            sh:path common_domain_model:product ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the specific branch entered into by the relevant party." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:branch ],
        [ sh:datatype xsd:boolean ;
            sh:description "A flag to indicate whether transactions entered into by a specific branch with respect to the relevant party are excluded; set to True if excluded, false if included." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:excluded ] ;
    sh:targetClass common_domain_model:ExcludedProducts .

common_domain_model:ExctgPrsn a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Prsn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:prsn ] ;
    sh:targetClass common_domain_model:ExctgPrsn .

common_domain_model:ExecutionInstruction a sh:NodeShape ;
    rdfs:comment "Specifies instructions for execution of a transaction, consisting of a product, price, quantity, parties, trade identifier, execution details, and settlement terms." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AncillaryParty ;
            sh:description "Maps any ancillary parties, e.g. parties involved in the transaction that are not one of the two principal parties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:ancillaryParty ],
        [ sh:class common_domain_model:PriceQuantity ;
            sh:description "Defines the prices (e.g. spread, equity price, FX rate), quantities (e.g. currency amount, no. shares) and settlement terms (e.g. initial fee, broker fee, up-front cds payment or option premium settlement) associated with the constituents of the transacted product." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "Denotes the trade time and timezone as agreed by the parties to the trade." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:tradeTime ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Lot Identifier associated with the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:lotIdentifier ],
        [ sh:class common_domain_model:Collateral ;
            sh:description "Detail the collateral requirement anticipated with the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:collateral ],
        [ sh:datatype xsd:date ;
            sh:description "Denotes the trade/execution date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:tradeDate ],
        [ sh:class common_domain_model:NonTransferableProduct ;
            sh:description "Defines the financial product to be executed and contract formed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:product ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Defines the role(s) that party(ies) may have in relation to the execution." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:partyRoles ],
        [ sh:class common_domain_model:Party ;
            sh:description "Defines all parties to that execution, including agents and brokers." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:parties ],
        [ sh:class common_domain_model:Counterparty ;
            sh:description "Maps two defined parties to counterparty enums for the transacted product." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:counterparty ],
        [ sh:class common_domain_model:ExecutionDetails ;
            sh:description "Specifies the type and venue of execution, e.g. via voice, or electronically." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:executionDetails ],
        [ sh:class common_domain_model:TradeIdentifier ;
            sh:description "Denotes one or more identifiers associated with the transaction." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:tradeIdentifier ] ;
    sh:targetClass common_domain_model:ExecutionInstruction .

common_domain_model:ExecutionLanguage a sh:NodeShape ;
    rdfs:comment "A class to specify execution language terms of a Security Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A boolean attribute to determine if standard language is applicable or not." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:standardLanguage ],
        [ sh:datatype xsd:string ;
            sh:description "Bespoke execution language to be included when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:otherLanguage ],
        [ sh:datatype xsd:string ;
            sh:description "The number of original documents." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:numberOfOriginals ] ;
    sh:targetClass common_domain_model:ExecutionLanguage .

common_domain_model:ExecutionLocation a sh:NodeShape ;
    rdfs:comment "A class to specify execution location terms of a Security Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The execution location of the agreement." ;
            sh:in ( "ExecutedOutsideBelgium" "ExecutedInBelgium" "OtherLocation" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:executionLocation ],
        [ sh:datatype xsd:string ;
            sh:description "Bespoke execution location language to be included when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:otherLanguage ],
        [ sh:datatype xsd:string ;
            sh:description "Bespoke terms specific to the date that documentary duty will be paid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:dutyPaymentLanguage ],
        [ sh:datatype xsd:string ;
            sh:description "Bespoke terms specific to the payment of documentary duty." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:dutyPayerLanguage ],
        [ sh:datatype xsd:date ;
            sh:description "The date that documentary duty will be paid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:dutyPaymentDate ],
        [ sh:datatype xsd:string ;
            sh:description "The payer of documentary duty." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:dutyPayer ] ;
    sh:targetClass common_domain_model:ExecutionLocation .

common_domain_model:ExecutionTerms a sh:NodeShape ;
    rdfs:comment "A class to specify execution location and language of execution to determine duty to be paid." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ExecutionLocation ;
            sh:description "The bespoke execution location election." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:executionLocation ],
        [ sh:class common_domain_model:ExecutionLanguage ;
            sh:description "The bespoke execution language election." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:executionLanguage ] ;
    sh:targetClass common_domain_model:ExecutionTerms .

common_domain_model:ExerciseFee a sh:NodeShape ;
    rdfs:comment "A class defining the fee payable on exercise of an option. This fee may be defined as an amount or a percentage of the notional exercised. As a difference with FpML, it extends the BuyerSeller class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the party that receives the payments corresponding to this structure.  The party is one of the two counterparties to the transaction." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:receiver ],
        [ sh:datatype xsd:decimal ;
            sh:description "A fee represented as a percentage of some referenced notional. A percentage of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:feeRate ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The date on which exercise fee(s) will be paid. It is specified as a relative date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:feePaymentDate ],
        [ sh:class common_domain_model:Money ;
            sh:description "A pointer style reference to the associated notional schedule defined elsewhere in the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:notionalReference ],
        [ sh:description "Specifies the counterparty responsible for making the payments defined by this structure.  The party is one of the two principal parties to the transaction." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:payer ],
        [ sh:datatype xsd:decimal ;
            sh:description "The amount of fee to be paid on exercise. The fee currency is that of the referenced notional." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:feeAmount ] ;
    sh:targetClass common_domain_model:ExerciseFee .

common_domain_model:ExerciseFeeSchedule a sh:NodeShape ;
    rdfs:comment "A class to define a fee or schedule of fees to be payable on the exercise of an option. This fee may be defined as an amount or a percentage of the notional exercised. As a difference with FpML, it extends the BuyerSeller class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AmountSchedule ;
            sh:description "The exercise fee amount schedule. The fees are expressed as currency amounts. The currency of the fee is assumed to be that of the notional schedule referenced." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:feeAmountSchedule ],
        [ sh:description "Specifies the party that receives the payments corresponding to this structure.  The party is one of the two counterparties to the transaction." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:receiver ],
        [ sh:class common_domain_model:Money ;
            sh:description "A pointer style reference to the associated notional schedule defined elsewhere in the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:notionalReference ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The date on which exercise fee(s) will be paid. It is specified as a relative date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:feePaymentDate ],
        [ sh:description "Specifies the counterparty responsible for making the payments defined by this structure.  The party is one of the two principal parties to the transaction." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:payer ],
        [ sh:class common_domain_model:Schedule ;
            sh:description "The exercise free rate schedule. The fees are expressed as percentage rates of the notional being exercised. The currency of the fee is assumed to be that of the notional schedule referenced." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:feeRateSchedule ] ;
    sh:targetClass common_domain_model:ExerciseFeeSchedule .

common_domain_model:ExerciseInstruction a sh:NodeShape ;
    rdfs:comment "Specifies the information required to communicate the choices made by the exercising party, in a financial product endowing the party with at least one option." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TradeIdentifier ;
            sh:description "Specifies the trade identifier to apply to the replacement trade for physical exercise." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:replacementTradeIdentifier ],
        [ sh:class common_domain_model:AdjustableOrAdjustedDate ;
            sh:description "Specifies the date on which an option contained within the financial product would be exercised. The date may be omitted if the contractual product allows for only a single date of exercise (European exercise)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:exerciseDate ],
        [ sh:class common_domain_model:OptionPayout ;
            sh:description "Specifies the Option Payout being exercised on the trade." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:exerciseOption ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "Specifies the time at which an option contained within the financial product woulld be exercised. The time may be omitted if the contractual product allows for only a single time of exercise (European exercise). " ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:exerciseTime ],
        [ sh:class common_domain_model:PrimitiveInstruction ;
            sh:description "Contains instructions for exercising the option including a quantity change, and optionally a transfer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:exerciseQuantity ] ;
    sh:targetClass common_domain_model:ExerciseInstruction .

common_domain_model:ExercisePeriod a sh:NodeShape ;
    rdfs:comment "This defines the time interval to the start of the exercise period, i.e. the earliest exercise date, and the frequency of subsequent exercise dates (if any)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Period ;
            sh:description "The time interval to the first (and possibly only) exercise date in the exercise period." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:earliestExerciseDateTenor ],
        [ sh:class common_domain_model:Period ;
            sh:description "The frequency of subsequent exercise dates in the exercise period following the earliest exercise date. An interval of 1 day should be used to indicate an American style exercise period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:exerciseFrequency ] ;
    sh:targetClass common_domain_model:ExercisePeriod .

common_domain_model:ExerciseProcedure a sh:NodeShape ;
    rdfs:comment "A class describing how notice of exercise should be given. This can be either manual or automatic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ManualExercise ;
            sh:description "Specifies that the notice of exercise must be given by the buyer to the seller or seller's agent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:manualExercise ],
        [ sh:datatype xsd:boolean ;
            sh:description "Has the meaning defined as part of the 1997 ISDA Government Bond Option Definitions, section 4.5 Limited Right to Confirm Exercise. If present, (i) the Seller may request the Buyer to confirm its intent if not done on or before the expiration time on the Expiration date (ii) specific rules will apply in relation to the settlement mode." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:limitedRightToConfirm ],
        [ sh:datatype xsd:boolean ;
            sh:description "Typically applicable to the physical settlement of bond and convertible bond options. If present, means that the party required to deliver the bonds will divide those to be delivered as notifying party desires to facilitate delivery obligations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:splitTicket ],
        [ sh:class common_domain_model:AutomaticExercise ;
            sh:description "If automatic is specified, then the notional amount of the underlying swap not previously exercised under the swaption will be automatically exercised at the expiration time on the expiration date if at such time the buyer is in-the-money, provided that the difference between the settlement rate and the fixed rate under the relevant underlying swap is not less than the specified threshold rate. The term in-the-money is assumed to have the meaning defining in the 2000 ISDA Definitions, Section 17.4 In-the-money." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:automaticExercise ],
        [ sh:datatype xsd:boolean ;
            sh:description "A flag to indicate whether follow-up confirmation of exercise (written or electronic) is required following telephonic notice by the buyer to the seller or seller's agent." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:followUpConfirmation ] ;
    sh:targetClass common_domain_model:ExerciseProcedure .

common_domain_model:ExposureScope a sh:NodeShape ;
    rdfs:comment "Optionally, for each party, specifies the amendments to the included coverage in the calculation of Exposure." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegacyExposureScopeElection ;
            sh:description "Defines the electice scope for a specific party." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:ExposureScope .

common_domain_model:ExtendibleProvision a sh:NodeShape ;
    rdfs:comment "A data defining:  an option to extend an existing swap transaction on the specified exercise dates for a term ending on the specified new termination date. As a difference from FpML, it extends the BuyerSeller class, which represents the BuyerSeller.model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The length of each extension period relative to the effective date of the preceding contract." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:extensionTerm ],
        [ sh:datatype xsd:dateTime ;
            sh:description "A specific date and time for the notice deadline" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:noticeDeadlineDateTime ],
        [ sh:description "The party with right to exercise a cancellation. Allows for buyer, seller or either." ;
            sh:in ( "InitialBuyer" "InitialSeller" "Either" "AsDefinedInMasterAgreement" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:callingParty ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "If the ability to extend the contract is not available to both parties then this component specifies the buyer and seller of the option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:singlePartyOption ],
        [ sh:description "Buyer party that can be resolved as one of the two principal parties to the transaction. The party that buys this instrument, i.e. pays for this instrument and receives the rights defined by it. ISDA 2002 Equity Definitions section 1.18: `Buyer` means the party specified as such in the related Confirmation. | ISDA 2006 Definitions article 12.1 (b)(i) relating to a Swaption: 'Buyer' means the party that will, on each Premium Payment Date, pay to Seller the Premium | ISDA 2006 Definitions article 12.1 (b)(ii) relating to Swap Transactions with applicable Early Termination: the party specified as such in the related Confirmation, or the Exercising Party if neither party is specified | ISDA 2006 Definitions article 12.1 (b)(iii) relating to any other Option Transaction: the party specified as such in the related Confirmation. | ISDA 2014 Credit Definition article 1.4: `Buyer` means the Fixed Rate Payer." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:buyer ],
        [ sh:class common_domain_model:AdjustableRelativeOrPeriodicDates ;
            sh:description "The period within which notice can be given that the contract will be extended." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:extensionPeriod ],
        [ sh:description "Seller party that can be resolved as one of the two principal parties to the transaction. The party that sells ('writes') this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. ISDA 2002 Equity Definitions section 1.19: `Seller` means the party specified as such in the related Confirmation. | ISDA 2006 Definitions article 12.1 (a)(i) relating to a Swaption: 'Seller' means the party the party specified as such or as writer in the related Confirmation | ISDA 2006 Definitions article 12.1 (a)(ii) relating to Swap Transactions with applicable Early Termination: the party specified as such or as writer in the related Confirmation or, if neither party is specified as such, the Non-exercising Party | ISDA 2006 Definitions article 12.1 (a)(iii) relating to any other Option Transaction: the party specified as such in the related Confirmation. | ISDA 2014 Credit Definition article 1.4: `Seller` means the Floating Rate Payer." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path common_domain_model:seller ],
        [ sh:class common_domain_model:ExerciseTerms ;
            sh:description "The exercise terms associated with the extendible provision, including details such as exercise style, exercise fees, and any other relevant conditions or terms governing the extension of the swap transaction." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:exerciseTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "A flag to indicate whether follow-up confirmation of exercise (written or electronic) is required following telephonic notice by the buyer to the seller or seller's agent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:followUpConfirmation ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "Defines the minimum period before a contract is scheduled to terminate that notice can be given that it will terminate beyond the scheduled termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:noticeDeadlinePeriod ],
        [ sh:class common_domain_model:ExerciseNotice ;
            sh:description "Definition of the party to whom notice of exercise should be given." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:exerciseNotice ],
        [ sh:class common_domain_model:ExtendibleProvisionAdjustedDates ;
            sh:description "The adjusted dates associated with an extendible provision. These dates have been adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:extendibleProvisionAdjustedDates ] ;
    sh:targetClass common_domain_model:ExtendibleProvision .

common_domain_model:ExtendibleProvisionAdjustedDates a sh:NodeShape ;
    rdfs:comment "A data defining:  the adjusted dates associated with a provision to extend a swap." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ExtensionEvent ;
            sh:description "The adjusted dates associated with a single extendible exercise date." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:extensionEvent ] ;
    sh:targetClass common_domain_model:ExtendibleProvisionAdjustedDates .

common_domain_model:ExtensionEvent a sh:NodeShape ;
    rdfs:comment "A data to:  define the adjusted dates associated with an individual extension event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The termination date if an extendible provision is exercised. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedExtendedTerminationDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which option exercise takes place. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:adjustedExerciseDate ] ;
    sh:targetClass common_domain_model:ExtensionEvent .

common_domain_model:FailureToPay a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:GracePeriodExtension ;
            sh:description "If this element is specified, indicates whether or not a grace period extension is applicable. ISDA 2003 Term: Grace Period Extension Applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:gracePeriodExtension ],
        [ sh:class common_domain_model:Money ;
            sh:description "Specifies a threshold for the failure to pay credit event. Market standard is USD 1,000,000 (JPY 100,000,000 for Japanese Yen trades) or its equivalent in the relevant obligation currency. This is applied on an aggregate basis across all Obligations of the Reference Entity. Intended to prevent technical/operational errors from triggering credit events. ISDA 2003 Term: Payment Requirement" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:paymentRequirement ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the failure to pay provision is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ] ;
    sh:targetClass common_domain_model:FailureToPay .

common_domain_model:FeaturePayment a sh:NodeShape ;
    rdfs:comment "Payment made following trigger occurrence." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The monetary quantity in currency units." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:amount ],
        [ sh:datatype xsd:decimal ;
            sh:description "The trigger level percentage." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:levelPercentage ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The feature payment date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:paymentDate ],
        [ sh:class common_domain_model:PartyReferencePayerReceiver ;
            sh:description "This attribute doesn't exist as part of the FpML construct, which makes use of the PayerReceiver.model group." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:datatype xsd:string ;
            sh:description "The currency in which an amount is denominated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:currency ],
        [ sh:description "The feature payment time." ;
            sh:in ( "Close" "Open" "OSP" "SpecificTime" "XETRA" "DerivativesClose" "AsSpecifiedInMasterConfirmation" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:time ] ;
    sh:targetClass common_domain_model:FeaturePayment .

common_domain_model:FinInstrm a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Othr ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:othr ] ;
    sh:targetClass common_domain_model:FinInstrm .

common_domain_model:FinInstrmGnlAttrbts a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:fullNm ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:ntnlCcy ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:clssfctnTp ] ;
    sh:targetClass common_domain_model:FinInstrmGnlAttrbts .

common_domain_model:FinInstrmRptgTxRpt a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Tx ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tx ] ;
    sh:targetClass common_domain_model:FinInstrmRptgTxRpt .

common_domain_model:FinalCalculationPeriodDateAdjustment a sh:NodeShape ;
    rdfs:comment "A data to:  define business date convention adjustment to final payment period per leg." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InterestRatePayout ;
            sh:description "Reference to the leg, where date adjustments may apply." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:swapStreamReference ],
        [ sh:class common_domain_model:AdjustableOrRelativeDates ;
            sh:description "Reference to the unadjusted cancellation effective dates." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:relevantUnderlyingDateReference ],
        [ sh:description "Override business date convention. This takes precedence over leg level information." ;
            sh:in ( "FOLLOWING" "FRN" "MODFOLLOWING" "PRECEDING" "MODPRECEDING" "NEAREST" "NONE" "NotApplicable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:businessDayConvention ] ;
    sh:targetClass common_domain_model:FinalCalculationPeriodDateAdjustment .

common_domain_model:FixedPrice a sh:NodeShape ;
    rdfs:comment "A predefined price accorded by the counterparties." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Fixed price step schedule, including an initial price specified as an absolute number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:price ] ;
    sh:targetClass common_domain_model:FixedPrice .

common_domain_model:FloatingAmountEvents a sh:NodeShape ;
    rdfs:comment "A class to specify the ISDA terms relating to the floating rate payment events and the implied additional fixed payments, applicable to the credit derivatives transactions on mortgage-backed securities with pay-as-you-go or physical settlement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InterestShortFall ;
            sh:description "A floating rate payment event. With respect to any Reference Obligation Payment Date, either (a) the non-payment of an Expected Interest Amount or (b) the payment of an Actual Interest Amount that is less than the Expected Interest Amount. ISDA 2003 Term: Interest Shortfall." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:interestShortfall ],
        [ sh:class common_domain_model:FloatingAmountProvisions ;
            sh:description "Specifies the floating amount provisions associated with the floatingAmountEvents." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:floatingAmountProvisions ],
        [ sh:datatype xsd:boolean ;
            sh:description "A floating rate payment event. Corresponds to the failure by the Reference Entity to pay an expected principal amount or the payment of an actual principal amount that is less than the expected principal amount. ISDA 2003 Term: Failure to Pay Principal." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:failureToPayPrincipal ],
        [ sh:datatype xsd:boolean ;
            sh:description "A floating rate payment event. Results from the fact that the underlier writes down its outstanding principal amount. ISDA 2003 Term: Writedown." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:writedown ],
        [ sh:class common_domain_model:AdditionalFixedPayments ;
            sh:description "Specifies the events that will give rise to the payment additional fixed payments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:additionalFixedPayments ],
        [ sh:datatype xsd:boolean ;
            sh:description "A floating rate payment event. Results from the fact that losses occur to the underlying instruments that do not result in reductions of the outstanding principal of the reference obligation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:impliedWritedown ] ;
    sh:targetClass common_domain_model:FloatingAmountEvents .

common_domain_model:FloatingAmountProvisions a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "As specified by the ISDA Supplement for use with trades on mortgage-backed securities, 'WAC Cap' means a weighted average coupon or weighted average rate cap provision (however defined in the Underlying Instruments) of the Underlying Instruments that limits, increases or decreases the interest rate or interest entitlement, as set out in the Underlying Instruments on the Effective Date without regard to any subsequent amendment The presence of the element with value set to 'true' signifies that the provision is applicable. From a usage standpoint, this provision is typically applicable in the case of CMBS and not applicable in case of RMBS trades." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:wacCapInterestProvision ],
        [ sh:datatype xsd:boolean ;
            sh:description "As specified by the ISDA Standard Terms Supplement for use with trades on mortgage-backed securities. The presence of the element with value set to 'true' signifies that the provision is applicable. If applicable, the applicable step-up terms are specified as part of that ISDA Standard Terms Supplement. From a usage standpoint, this provision is typically applicable in the case of RMBS and not applicable in case of CMBS trades." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:stepUpProvision ] ;
    sh:targetClass common_domain_model:FloatingAmountProvisions .

common_domain_model:FloatingRateDefinition a sh:NodeShape ;
    rdfs:comment "A data defining:  parameters associated with a floating rate reset. This data forms:  part of the cashflows representation of a stream." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The ISDA Spread, if any, which applies for the calculation period. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:spread ],
        [ sh:class common_domain_model:RateObservation ;
            sh:description "The details of a particular rate observation, including the fixing date and observed rate. A list of rate observation elements may be ordered in the document by ascending adjusted fixing date. An FpML document containing an unordered list of rate observations is still regarded as a conformant document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:rateObservation ],
        [ sh:class common_domain_model:Strike ;
            sh:description "The floor rate, if any, which applies to the floating rate for the calculation period. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. The floor rate of 5% would be represented as 0.05." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:floorRate ],
        [ sh:class common_domain_model:Strike ;
            sh:description "The cap rate, if any, which applies to the floating rate for the calculation period. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain strike level. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:capRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "A rate multiplier to apply to the floating rate. The multiplier can be a positive or negative decimal. This element should only be included if the multiplier is not equal to 1 (one)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:floatingRateMultiplier ],
        [ sh:datatype xsd:decimal ;
            sh:description "The final calculated rate for a calculation period after any required averaging of rates A calculated rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:calculatedRate ] ;
    sh:targetClass common_domain_model:FloatingRateDefinition .

common_domain_model:FloatingRateIndexCalculationDefaults a sh:NodeShape ;
    rdfs:comment "This holds the rate calculation defaults applicable for a floating rate index." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The default applicable business days." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:applicableBusinessDays ],
        [ sh:description "The ISDA FRO style (e.g. term rate, swap rate, etc)." ;
            sh:in ( "AverageFRO" "CompoundedIndex" "Index" "Other" "Overnight" "PublishedAverage" "SpecifiedFormula" "SwapRate" "TermRate" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:indexStyle ],
        [ sh:description "The default day count fraction." ;
            sh:in ( "ACT_360" "ACT_365L" "ACT_364" "ACT_365_FIXED" "ACT_ACT_AFB" "ACT_ACT_ICMA" "ACT_ACT_ISDA" "ACT_ACT_ISMA" "CAL_252" "_1_1" "_30E_360" "_30E_360_ISDA" "_30_360" "RBA_BOND_BASIS" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:dayCountFraction ],
        [ sh:description "The ISDA FRO category (e.g. screen rate or calculated rate)." ;
            sh:in ( "ScreenRate" "Calculated" "ReferenceBanks" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:category ],
        [ sh:datatype xsd:string ;
            sh:description "Publication Calendar (e.g. EUR-ICESWAP)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:publicationCalendar ],
        [ sh:class common_domain_model:FloatingRateIndexFixingDetails ;
            sh:description "The default fixing details." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fixing ],
        [ sh:description "The ISDA FRO calculation method (e.g. OIS Compounding)." ;
            sh:in ( "OISCompound" "Average" "Compounded" "AllInCompounded" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:method ] ;
    sh:targetClass common_domain_model:FloatingRateIndexCalculationDefaults .

common_domain_model:FloatingRateIndexExternalMap a sh:NodeShape ;
    rdfs:comment "A map for a single FRO to or from an equivalent or similar codes in a different standard such as ISO." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description " The FRO name that is being mapped to/from." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:externalId ],
        [ sh:datatype xsd:string ;
            sh:description "The standard/version to which the map applies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:externalStandard ] ;
    sh:targetClass common_domain_model:FloatingRateIndexExternalMap .

common_domain_model:FloatingRateIndexExternalMappings a sh:NodeShape ;
    rdfs:comment "Represents the mappings of FRO codes to other." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FloatingRateIndexExternalMap ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:isoCode ] ;
    sh:targetClass common_domain_model:FloatingRateIndexExternalMappings .

common_domain_model:FloatingRateIndexFixingDetails a sh:NodeShape ;
    rdfs:comment "This type holds parameters defining the fixingt time and offset for a floating rate index." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FloatingRateIndexFixingTime ;
            sh:description "Parameters defining the normal fixing time (can vary by index tenor / designated maturity)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:fixingTime ],
        [ sh:class common_domain_model:BusinessDayOffset ;
            sh:description "Parameters defining the normal fixing offset (can vary by index tenor / designated maturity)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fixingOffset ] ;
    sh:targetClass common_domain_model:FloatingRateIndexFixingDetails .

common_domain_model:FloatingRateIndexFixingTime a sh:NodeShape ;
    rdfs:comment "This type holds parameters defining the normal fixing time for a floating rate index." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:time ;
            sh:description "A time specified in hh:mm:ss format where the second component must be '00', e.g. 11am would be represented as 11:00:00." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:hourMinuteTime ],
        [ sh:datatype xsd:string ;
            sh:description "Fixing Reason" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fixingReason ],
        [ sh:datatype xsd:string ;
            sh:description "Allows a designed maturity to be specified for the fixing time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:designatedMaturity ],
        [ sh:datatype xsd:string ;
            sh:description "Legal text that underlies the Fixing Time. ISDA Fixing Time Definition. (e.g. 09:30, Sydney time)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:fixingTimeDefinition ],
        [ sh:datatype xsd:string ;
            sh:description "A code identifying a business day calendar location. A business day calendar location is drawn from the list identified by the business day calendar location enumeration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:businessCenter ] ;
    sh:targetClass common_domain_model:FloatingRateIndexFixingTime .

