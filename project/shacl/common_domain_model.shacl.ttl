            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:floatingRateIndex ],
        [ sh:datatype xsd:string ;
            sh:description "FRO type (e.g. OIS)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:froType ],
        [ sh:description "FRO currency - 3 character ISO currrency code" ;
