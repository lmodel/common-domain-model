            sh:order 0 ;
            sh:path common_domain_model:marginApproach ],
        [ sh:class common_domain_model:MinimumTransferAmount ;
            sh:description "Represents the threshold specified in the agreement below which collateral need not be delivered, and represents the smallest incremental value of exposure that must be reached before the parties are obliged to transfer collateral." ;
            sh:maxCount 1 ;
