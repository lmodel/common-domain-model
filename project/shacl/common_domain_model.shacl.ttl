@prefix common_domain_model: <https://w3id.org/lmodel/common-domain-model/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

common_domain_model:AdditionalTerminationEvent a sh:NodeShape ;
    rdfs:comment "A class to specify an optional termination event, additional to the Termination Events that will be deemed an Access Condition (Initial Margin CSA) or a Specified Condition (Variation Margin CSA)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Whether the additional termination event is applicable for the relevant party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:applicableParty ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the additional termination event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:name ] ;
    sh:targetClass common_domain_model:AdditionalTerminationEvent .

common_domain_model:AdditionalType a sh:NodeShape ;
    rdfs:comment "The specification of the Additional Type of transaction that can require the collection or delivery of initial margin under a given regulatory regime for the purposes of Covered Transactions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The qualification of the Additional Type of transaction that can require the collection or delivery of initial margin when specified as a standard value." ;
            sh:in ( "NotApplicable" "EquityOptionOrIndexOption" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:standardValue ],
        [ sh:datatype xsd:string ;
            sh:description "The qualification of the Additional Type of transaction that can require the collection or delivery of initial margin when specified as a custom value by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customValue ] ;
    sh:targetClass common_domain_model:AdditionalType .

common_domain_model:AssetBase a sh:NodeShape ;
    rdfs:comment "The base data type to specify common attributes for all Assets." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:tranche common_domain_model:provider rdf:type common_domain_model:lien common_domain_model:commodityProductDefinition common_domain_model:inflationRateIndex common_domain_model:indexAnnexSource common_domain_model:fundType common_domain_model:borrower common_domain_model:deliveryTerm common_domain_model:description common_domain_model:optionType common_domain_model:secondaryFxSpotRateSource common_domain_model:floatingRateIndex common_domain_model:basketConstituent common_domain_model:indexFactor common_domain_model:settledEntityMatrix common_domain_model:quotedCurrencyPair common_domain_model:excludedReferenceEntity common_domain_model:priceQuoteType common_domain_model:equityType common_domain_model:primaryFxSpotRateSource common_domain_model:strike common_domain_model:creditAgreementDate common_domain_model:assetClass common_domain_model:seniority common_domain_model:securityType common_domain_model:indexSeries common_domain_model:facilityType common_domain_model:debtType common_domain_model:indexTenor common_domain_model:indexAnnexDate common_domain_model:name common_domain_model:deliveryDateReference common_domain_model:indexAnnexVersion ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:exchange ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:assetType ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:isExchangeListed ] ;
    sh:targetClass common_domain_model:AssetBase .

common_domain_model:AssetFlow a sh:NodeShape ;
    rdfs:comment "Specifies an asset flow, i.e. the outcome of either of computation (e.g. interest accrual) or an assessment of some sort. The asset flow can then be turned into an asset transfer artefact to be used as the input to a payment system or the outcome of it. The associated globalKey denotes the ability to associate a hash value to the AssetFlow instantiations for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents the object that is subject to the transfer, it could be an asset or a reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 3 ;
            sh:path common_domain_model:asset ],
        [ sh:class common_domain_model:NonNegativeQuantity ;
            sh:description "Represents the amount of the asset to be transferred. The cashflow amount is always a positive number, as the cashflow direction is implied by the payer/receiver attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:quantity ],
        [ sh:description "Type of asset flow corresponding to a scheduled event." ;
            sh:in ( "CorporateAction" "Coupon" "CreditEvent" "DividendReturn" "Exercise" "FixedRateReturn" "FloatingRateReturn" "FractionalAmount" "InterestReturn" "NetInterest" "Performance" "Principal" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:assetFlowType ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Specifies who pays / receives the asset flow, through a normalised Party1 / Party2 enumerator." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:AdjustableOrAdjustedOrRelativeDate ;
            sh:description "Represents the date on which the transfer to due." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:class common_domain_model:PaymentDiscounting ;
            sh:description "FpML specifies the FpML PaymentDiscounting.model group for representing the discounting elements that can be associated with a payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:paymentDiscounting ] ;
    sh:targetClass common_domain_model:AssetFlow .

common_domain_model:AssetFlowBase a sh:NodeShape ;
    rdfs:comment "Defines the basic parameters of an asset transfer, e.g. a cashflow: what (the asset), how much (the quantity) and when (the settlement date)." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:identifier rdf:type common_domain_model:assetFlowType common_domain_model:corporateActionTransferType common_domain_model:payoutReference common_domain_model:payerReceiver common_domain_model:transferType ) ;
    sh:property [ sh:class common_domain_model:NonNegativeQuantity ;
            sh:description "Represents the amount of the asset to be transferred. The cashflow amount is always a positive number, as the cashflow direction is implied by the payer/receiver attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:AdjustableOrAdjustedOrRelativeDate ;
            sh:description "Represents the date on which the transfer to due." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:class common_domain_model:PaymentDiscounting ;
            sh:description "FpML specifies the FpML PaymentDiscounting.model group for representing the discounting elements that can be associated with a payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:paymentDiscounting ],
        [ sh:description "Represents the object that is subject to the transfer, it could be an asset or a reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 1 ;
            sh:path common_domain_model:asset ] ;
    sh:targetClass common_domain_model:AssetFlowBase .

common_domain_model:AvailableInventory a sh:NodeShape ;
    rdfs:comment "A data type that can be used to describe the inventory of securities that a party holds. The securities are held in the AvailableInventoryRecord, with each item in the array being an individual security and its associated criteria. Criteria can include the quantity available, the rate at which the security is available to borrow at, as well as other details that can affect the decision as to whether a party wants to utilise the securities listed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Optional comments for this group of inventory records." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:comment ],
        [ sh:class common_domain_model:AvailableInventoryRecord ;
            sh:description "An array holding the list of inventory being described. Each element in the inventoryRecord array represents an individual piece of inventory i.e. a security." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:availableInventoryRecord ],
        [ sh:class common_domain_model:MessageInformation ;
            sh:description "Allows details related to the availability messaging use case to be defined" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:messageInformation ],
        [ sh:description "Defines the purpose of this inventory." ;
            sh:in ( "AvailableToLend" "RequestToBorrow" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:availableInventoryType ],
        [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "Unique identifier for this group. This can be used to uniquely identify a group of inventory records." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:identifer ],
        [ sh:class common_domain_model:Party ;
            sh:description "Defines all parties involved for the list of inventory records in this set of inventory. For example, when used to describe securities lending availability, this could hold the sender of the availability, the intended recipient, the beneficial owner(s), the lender (which may differ from the sender as the lender may have the same piece of availability going through multiple agents), an agent or a venue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Defines the role(s) that party(ies) may have in relation to the inventory." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:partyRole ] ;
    sh:targetClass common_domain_model:AvailableInventory .

common_domain_model:BillingInstruction a sh:NodeShape ;
    rdfs:comment "Specifies the instructions for creation of a Security Lending billing invoice." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BillingSummaryInstruction ;
            sh:description "The billing summaries contained within the invoice" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:billingSummary ],
        [ sh:class common_domain_model:BillingRecordInstruction ;
            sh:description "Instructions for creating the billing records contained within the invoice" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:billingRecordInstruction ],
        [ sh:datatype xsd:date ;
            sh:description "The starting date of the period described by this invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:billingStartDate ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party issuing the invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:sendingParty ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party receiving the invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:receivingParty ],
        [ sh:datatype xsd:date ;
            sh:description "The ending date of the period described by this invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:billingEndDate ] ;
    sh:targetClass common_domain_model:BillingInstruction .

common_domain_model:BoundedCorrelation a sh:NodeShape ;
    rdfs:comment "Describes correlation bounds, which form a cap and a floor on the realized correlation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Maximum Boundary as a percentage of the Strike Price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:maximumBoundaryPercent ],
        [ sh:datatype xsd:decimal ;
            sh:description "Minimum Boundary as a percentage of the Strike Price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:minimumBoundaryPercent ] ;
    sh:targetClass common_domain_model:BoundedCorrelation .

common_domain_model:BrokerConfirmation a sh:NodeShape ;
    rdfs:comment "Identifies the market sector in which the trade has been arranged." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The type of broker confirmation executed between the parties." ;
            sh:in ( <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#ABX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AsiaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AsiaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AustraliaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AustraliaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDSonLeveragedLoans> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDSonMBS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXEmergingMarkets> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXEmergingMarketsDiversified> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CMBX> "DJ_CDX_EM_" "DJ_CDX_NA" <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EmergingEuropeanAndMiddleEasternSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EmergingEuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EmergingEuropeanCorporateLPN> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EuropeanCMBS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EuropeanRMBS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#JapanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#JapanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaCorporateBond> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaCorporateBondOrLoan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#MBX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#MCDX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#NewZealandCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#NewZealandSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#NorthAmericanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#PO> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SingaporeCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SingaporeSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAsiaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAsiaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAustraliaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAustraliaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardCDXTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEmergingEuropeanAndMiddleEasternSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEmergingEuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEmergingEuropeanCorporateLPN> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardJapanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardJapanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDSBullet> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDXBullet> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDXBulletTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLatinAmericaCorporateBond> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLatinAmericaCorporateBondOrLoan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLatinAmericaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardNewZealandCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardNewZealandSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardNorthAmericanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardSingaporeCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardSingaporeSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardSubordinatedEuropeanInsuranceCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardWesternEuropeanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardiTraxxEuropeTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SubordinatedEuropeanInsuranceCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SukukCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SukukSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SyndicatedSecuredLoanCDS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#TRX> "TRX_II" <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#USMunicipalFullFaithAndCredit> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#USMunicipalGeneralFund> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#USMunicipalRevenue> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#WesternEuropeanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAsiaExJapan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAsiaExJapanSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAsiaExJapanTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAustralia> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAustraliaSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAustraliaTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxCJ> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxCJTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxEurope> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxEuropeSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxEuropeTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxJapan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxJapanSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxJapanTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxLevX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxSDI75> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxSovX> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:brokerConfirmationType ] ;
    sh:targetClass common_domain_model:BrokerConfirmation .

common_domain_model:CalculateTransferInstruction a sh:NodeShape ;
    rdfs:comment "Defines the tradeState or payout on which to create a Transfer along with all necessary resets." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Quantity ;
            sh:description "Specifies quantity amount returned if not the full amount from the TradeState, e.g. partial return" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:Reset ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:resets ],
        [ sh:datatype xsd:date ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:date ],
        [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AssetPayout ] [ sh:class common_domain_model:CommodityPayout ] [ sh:class common_domain_model:CreditDefaultPayout ] [ sh:class common_domain_model:FixedPricePayout ] [ sh:class common_domain_model:InterestRatePayout ] [ sh:class common_domain_model:OptionPayout ] [ sh:class common_domain_model:PerformancePayout ] [ sh:class common_domain_model:SettlementPayout ] ) ;
            sh:order 1 ;
            sh:path common_domain_model:payout ],
        [ sh:class common_domain_model:TradeState ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tradeState ] ;
    sh:targetClass common_domain_model:CalculateTransferInstruction .

common_domain_model:CalculatedRateObservationDatesAndWeights a sh:NodeShape ;
    rdfs:comment "Type for reporting the observations dates and the corresponding weights going into a daily calculated rate" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The corresponding weight for each date." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:weights ],
        [ sh:datatype xsd:date ;
            sh:description "The observation date upon which the rate is observed." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:observationDates ] ;
    sh:targetClass common_domain_model:CalculatedRateObservationDatesAndWeights .

common_domain_model:CalculationAndTimingBase a sh:NodeShape ;
    rdfs:comment "A logical container designed to hold a set of related data. In this case, designed to hold a set of clauses that are common amongst Legacy (1994/95), Variation Margin and Initial Margin Credit Support Documents in regards to Calculation, Valuation and Timing terms." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:calculationAgentTerms common_domain_model:bespokeCalculationTime common_domain_model:valuationTime rdf:type common_domain_model:valuationAgent common_domain_model:cashSettlementDay common_domain_model:calculationDateLocation common_domain_model:bespokeCalculationDate common_domain_model:securitiesSettlementDay common_domain_model:valuationDateLocation common_domain_model:valuationDate ) ;
    sh:property [ sh:class common_domain_model:NotificationTime ;
            sh:description "The time by which a demand for the Transfer of Eligible Credit Support (IM) or Posted Credit Support (IM) needs to be made in order for the transfer to take place in accordance with the Transfer Timing provisions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:notificationTime ] ;
    sh:targetClass common_domain_model:CalculationAndTimingBase .

common_domain_model:CalculationPeriodData a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:isFirstPeriod ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:isLastPeriod ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:daysInLeapYearPeriod ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:daysInPeriod ],
        [ sh:datatype xsd:date ;
            sh:description "The last date of a date range." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:endDate ],
        [ sh:datatype xsd:date ;
            sh:description "The first date of a date range." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:startDate ] ;
    sh:targetClass common_domain_model:CalculationPeriodData .

common_domain_model:CheckEligibilityResult a sh:NodeShape ;
    rdfs:comment "Result for the CheckEligibilityByDetails and CheckEligibilityForProduct functions" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EligibilityQuery ;
            sh:description "a copy of the input query that was checked against the eligible collateral specification" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:eligibilityQuery ],
        [ sh:datatype xsd:boolean ;
            sh:description "a simple boolean which is set to true if the asset described in the EligibilityQuery input is eligible" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isEligible ],
        [ sh:class common_domain_model:EligibleCollateralCriteria ;
            sh:description "if there was a match, this will be the one or more criteria that were supplied in the EligbilityCollateralSpecification which matched with the query input" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:matchingEligibleCriteria ],
        [ sh:class common_domain_model:EligibleCollateralSpecification ;
            sh:description "a copy of the input EligbilityCollateralSpecification that was checked against the query" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:specification ] ;
    sh:targetClass common_domain_model:CheckEligibilityResult .

common_domain_model:ClearingInstruction a sh:NodeShape ;
    rdfs:comment "All information required to perform the clear life cycle event; the clearing party (CCP), the two parties facing each other on the alpha contract, and optionally the parties acting as clearing members." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "The Central Counter party (CCP) that the contract will be submitted to for clearing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:clearingParty ],
        [ sh:class common_domain_model:Party ;
            sh:description "Second party facing the CCP if it is clearing for its own account." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:party2 ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "The contract that will be submitted to the clearing house for clearing. The contract should indicate that it should be cleared by assigning a clearing organisation as a party role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:alphaContract ],
        [ sh:class common_domain_model:Party ;
            sh:description "Optional party facing the CCP, acting as clearing member for party2." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:clearerParty2 ],
        [ sh:class common_domain_model:Party ;
            sh:description "First party facing the CCP if it is clearing for its own account." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:party1 ],
        [ sh:class common_domain_model:Party ;
            sh:description "Optional party facing the CCP, acting as clearing member for party1." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:clearerParty1 ],
        [ sh:datatype xsd:boolean ;
            sh:description "Open Offer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:isOpenOffer ] ;
    sh:targetClass common_domain_model:ClearingInstruction .

common_domain_model:CodeList a sh:NodeShape ;
    rdfs:comment "A type hold a list of codes for business data validation" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CodeListIdentification ;
            sh:description "Identification information about the code list" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identification ],
        [ sh:class common_domain_model:CodeValue ;
            sh:description "Code values" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:codes ] ;
    sh:targetClass common_domain_model:CodeList .

common_domain_model:CollateralCriteria a sh:NodeShape ;
    rdfs:comment "The possible different terms that can be combined, using AND, OR and NOT logic, to define the issuers and/or assets that meet a given criteria for collateral." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:CollateralCriteria .

common_domain_model:CollateralCriteriaBase a sh:NodeShape ;
    rdfs:comment "Represents a set of criteria used to specify and describe collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:treatment common_domain_model:concentrationLimitType rdf:type common_domain_model:averageTradingVolume ) ;
    sh:property [ sh:description "Denotes which Criteria has priority if more than one agency rating applies." ;
            sh:in ( "Issuer" "Asset" "Lowest" "Highest" "Average" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:ratingPriorityResolution ],
        [ sh:description "Specifies which of the two counterparties the criteria applies to (either one or both counterparties). This attribute is optional, in case the applicable party is already specified elsewhere within a party election." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:order 1 ;
            sh:path common_domain_model:appliesTo ],
        [ sh:description "Restrict the criteria to only apply to a specific type of margin, ie IM or VM." ;
            sh:in ( "VariationMargin" "InitialMargin" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:restrictTo ],
        [ sh:description "The specific criteria that applies. It can be created using AND, OR and NOT logic, and both asset and issuer characteristics." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllCriteria ] [ sh:class common_domain_model:AnyCriteria ] [ sh:class common_domain_model:NegativeCriteria ] [ sh:class common_domain_model:CollateralIssuerType ] [ sh:class common_domain_model:CollateralGuarantorType ] [ sh:class common_domain_model:AssetType ] [ sh:class common_domain_model:IssuerCountryOfOrigin ] [ sh:class common_domain_model:AssetCountryOfOrigin ] [ sh:in ( "CNH" "CNT" "GGP" "IMP" "JEP" "KID" "MCF" "SML" "VAL" ) ] [ sh:class common_domain_model:IssuerName ] [ sh:class common_domain_model:IssuerAgencyRating ] [ sh:class common_domain_model:SovereignAgencyRating ] [ sh:class common_domain_model:AssetAgencyRating ] [ sh:class common_domain_model:AssetMaturity ] [ sh:class common_domain_model:SpecificAsset ] [ sh:class common_domain_model:CollateralTaxonomy ] [ sh:class common_domain_model:ListingExchange ] [ sh:class common_domain_model:ListingSector ] [ sh:class common_domain_model:IndexType ] [ sh:class common_domain_model:CounterpartyOwnIssuePermitted ] [ sh:class common_domain_model:DomesticCurrencyIssued ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:collateralCriteria ] ;
    sh:targetClass common_domain_model:CollateralCriteriaBase .

common_domain_model:ComputedAmount a sh:NodeShape ;
    rdfs:comment "A class to specify the outcome of a computed amount, for testing purposes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Current value of the outstanding contract" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:amount ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:callFunction ],
        [ sh:datatype xsd:string ;
            sh:description "The currency in which the computed amount is denominated. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:currency ] ;
    sh:targetClass common_domain_model:ComputedAmount .

common_domain_model:ContactInformationElection a sh:NodeShape ;
    rdfs:comment "Specifies the party reference and the associated contact information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:entity common_domain_model:additionalInformation common_domain_model:isApplicable common_domain_model:additionalContactInformation ) ;
    sh:property [ sh:class common_domain_model:ContactInformation ;
            sh:description "The main notice/address information of the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:primaryContactInformation ],
        [ sh:description "The party to which the election and details apply." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:partyReference ] ;
    sh:targetClass common_domain_model:ContactInformationElection .

common_domain_model:ContractBase a sh:NodeShape ;
    rdfs:comment "Encapsulates data features common to trade and position." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:party rdf:type common_domain_model:positionIdentifier common_domain_model:partyRole common_domain_model:openDateTime common_domain_model:positionBase common_domain_model:tradeReference ) ;
    sh:property [ sh:class common_domain_model:ContractDetails ;
            sh:description "Represents information specific to trades or positions involving contractual products." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:contractDetails ],
        [ sh:class common_domain_model:Collateral ;
            sh:description "Represents the collateral obligations of a party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:collateral ],
        [ sh:class common_domain_model:ExecutionDetails ;
            sh:description "Defines specific attributes that relate to trade or position executions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:executionDetails ] ;
    sh:targetClass common_domain_model:ContractBase .

common_domain_model:CreditNotations a sh:NodeShape ;
    rdfs:comment "Represents the credit rating notation higher level construct, which provides the ability to specify multiple rating notations." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CreditNotation ;
            sh:description "Specifies only one credit notation is determined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:creditNotation ],
        [ sh:class common_domain_model:MultipleCreditNotations ;
            sh:description "Specifies if several credit notations exist, alongside an 'any' or 'all' or all condition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:creditNotations ] ;
    sh:targetClass common_domain_model:CreditNotations .

common_domain_model:CreditSupportAgreementElections a sh:NodeShape ;
    rdfs:comment "The set of elections which specify a Credit Support Annex or Deed." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:CreditSupportAgreementElections .

common_domain_model:CreditSupportAgreementElectionsBase a sh:NodeShape ;
    rdfs:comment "A logical container designed to hold a set of related data. In this case, designed to hold a set of clauses that are common amongst Legacy (1994/95), Variation Margin and Initial Margin Credit Support Documents." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:postingObligations rdf:type common_domain_model:exchangeDate common_domain_model:singlePostingParty common_domain_model:rightsEvents common_domain_model:additionalBespokeTerms common_domain_model:creditSupportOffsets common_domain_model:otherAgreements common_domain_model:custodyArrangements common_domain_model:clientAssetSourcebookAdditionalLanguage common_domain_model:fxHaircutCurrency common_domain_model:identifiedCrossCurrencySwap common_domain_model:additionalAmendments common_domain_model:oneWayProvisions common_domain_model:trustSchemeAddendum common_domain_model:calculationAndTiming common_domain_model:securityInterestForObligations common_domain_model:generalSimmElections common_domain_model:processAgent common_domain_model:coveredTransactions common_domain_model:substitutedRegime common_domain_model:regime common_domain_model:appropriatedCollateralValuation common_domain_model:minimumTransferAmountAmendment common_domain_model:creditSupportObligations common_domain_model:addressesForTransfer common_domain_model:sensitivityMethodologies common_domain_model:terminationCurrencyAmendment common_domain_model:interpretationTerms common_domain_model:jurisdictionRelatedTerms ) ;
    sh:property [ sh:class common_domain_model:DistributionAndInterestPayment ;
            sh:description "The Distributions and Interest Payment terms specified as part of the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:distributionAndInterestPayment ],
        [ sh:class common_domain_model:Substitution ;
            sh:description "The conditions under which the Security Provider can substitute posted collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:substitution ],
        [ sh:class common_domain_model:AdditionalRepresentations ;
            sh:description "The specification Additional Representations that may be applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:additionalRepresentations ],
        [ sh:class common_domain_model:OtherEligibleAndPostedSupport ;
            sh:description "The Other Eligible Support elections associated with margin agreements." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:otherEligibleAndPostedSupport ],
        [ sh:class common_domain_model:BaseAndEligibleCurrency ;
            sh:description "The base and eligible currency(ies) for the document as specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:baseAndEligibleCurrency ],
        [ sh:class common_domain_model:MasterAgreementDatedAsOfDate ;
            sh:description "Defines the dates agreed by the parties as the date of the Credit Support Annex or Credit Support Deed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:masterAgreementDatedAsOfDate ],
        [ sh:class common_domain_model:DisputeResolution ;
            sh:description "The election terms under which a party disputes (i) the Calculation Agents calculation of a Delivery Amount or a Return Amount, or (ii) the Value of any Transfer of Eligible Credit Support or Posted Credit Support." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:disputeResolution ],
        [ sh:class common_domain_model:HoldingAndUsingPostedCollateral ;
            sh:description "The elections for the holding and using of posted collateral by the respective parties to the Credit Support Annex for Variation Margin." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:holdingAndUsingPostedCollateral ],
        [ sh:class common_domain_model:FinalReturns ;
            sh:description "A clause providing that final return collateral is to be provided without consideration of any Minimum Transfer Amount and collateral haircut." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:finalReturns ],
        [ sh:class common_domain_model:ConditionsPrecedent ;
            sh:description "The set of elections that may overwrite the default Condition Precedent provision, and the set of provisions that are deemed Access Condition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:conditionsPrecedent ],
        [ sh:class common_domain_model:DemandsAndNotices ;
            sh:description "The optional specification of address where the demands, specifications and notices will be communicated to for each of the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:demandsAndNotices ] ;
    sh:targetClass common_domain_model:CreditSupportAgreementElectionsBase .

common_domain_model:CreditSupportObligationsBase a sh:NodeShape ;
    rdfs:comment "A logical container designed to hold a set of related data. In this case, designed to hold a set of clauses that are common amongst Legacy (1994/95), Variation Margin and Initial Margin Credit Support Documents in regards to Credit Support Obligations." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:threshold common_domain_model:eligibleCreditSupport common_domain_model:marginApproach rdf:type common_domain_model:independentAmount common_domain_model:majorCurrency common_domain_model:ineligibleCreditSupport common_domain_model:fxHaircut common_domain_model:rounding common_domain_model:otherEligibleSupportIM common_domain_model:creditSupportAmount ) ;
    sh:property [ sh:class common_domain_model:BespokeTransferTiming ;
            sh:description "The time by which the transfer of collateral must take place when different from the Regular Settlement Day as a result of parties' election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:bespokeTransferTiming ],
        [ sh:class common_domain_model:CollateralTransferTiming ;
            sh:description "Specification of transfer / settlement timing for cash and securities collateral assuming that the notice is provided before the Notification Time (and with a 1LBD lag introduced if the notice is delivered after the Notification Time), and that securities allow for a further Local Business Day for transfer / settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:collateralTransferTiming ],
        [ sh:class common_domain_model:CSAReturnAmount ;
            sh:description "In respect of a Valuation Date, the amount of collateral which a party is entitled to demand to be recalled to it as a Return Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:returnAmount ],
        [ sh:class common_domain_model:CSADeliveryAmount ;
            sh:description "In respect of a Valuation Date, the amount of collateral which a party is entitled to demand to be transferred to it as a Delivery Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:deliveryAmount ],
        [ sh:class common_domain_model:MinimumTransferAmount ;
            sh:description "Represents the threshold specified in the agreement below which collateral need not be delivered, and represents the smallest incremental value of exposure that must be reached before the parties are obliged to transfer collateral." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:minimumTransferAmount ] ;
    sh:targetClass common_domain_model:CreditSupportObligationsBase .

common_domain_model:Curve a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:in ( "ALUMINIUM_ALLOY_LME_15_MONTH" "COAL_CENTRAL_APPALACHIAN_NYMEX" "COCOA_ICE" "COFFEE_ARABICA_ICE" "COFFEE_ROBUSTA_ICE" "COPPER_COMEX" "CORN_CBOT" "COTTON_NO__2_ICE" "ETHANOL_CBOT" "FEEDER_CATTLE_CME" "FROZEN_CONCENTRATED_ORANGE_JUICE_NO__1_ICE" "GASOLINE_RBOB_NEW_YORK_ICE" "GASOLINE_RBOB_NEW_YORK_NYMEX" "GOLD_COMEX" "HEATING_OIL_NEW_YORK_NYMEX" "LEAN_HOGS_CME" "LIVE_CATTLE_CME" "LUMBER_CME" "MILK_CLASS_III_CME" "MILK_NONFAT_DRY_CME" "NATURAL_GAS_NYMEX" "NATURAL_GAS_PEPL__TEXOK_MAINLINE__INSIDE_FERC" "NATURAL_GAS_W__TEXAS__WAHA__INSIDE_FERC" "OATS_CBOT" "OIL_WTI_NYMEX" "PALLADIUM_NYMEX" "PLATINUM_NYMEX" "RICE_CBOT" "SILVER_COMEX" "SOYBEANS_CBOT" "SOYBEAN_MEAL_CBOT" "SOYBEAN_OIL_CBOT" "SUGAR___11__WORLD__ICE" "SUGAR___16__US__ICE" "WHEAT_CBOT" "WHEAT_HRW_KCBOT" "WHEAT_RED_SPRING_MGE" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:commodityCurve ],
        [ sh:class common_domain_model:InterestRateCurve ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:interestRateCurve ] ;
    sh:targetClass common_domain_model:Curve .

common_domain_model:CustodianTerms a sh:NodeShape ;
    rdfs:comment "A class to specify the requirements applicable to the custodian with respect to the holding of posted collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "The minimal level of assets requirement with respect to the custody agent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:minimumAssets ],
        [ sh:class common_domain_model:CreditNotation ;
            sh:description "The minimal rating requirement with respect to the custody agent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:minimumRating ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Election to specify the initial custodian." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:initialDesignation ] ;
    sh:targetClass common_domain_model:CustodianTerms .

common_domain_model:Document a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FinInstrmRptgTxRpt ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:finInstrmRptgTxRpt ] ;
    sh:targetClass common_domain_model:Document .

common_domain_model:EligibilityToHoldCollateralCriteria a sh:NodeShape ;
    rdfs:comment "Defines a set of Criteria required by the party and its custodian to hold the other party's Posted Collateral." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:EligibilityToHoldCollateralCriteria .

common_domain_model:EquityIndex a sh:NodeShape ;
    rdfs:comment "Specification of an index based on equity securities, e.g. the S&P 500." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:exchange ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:name ],
        [ sh:description "The Asset Class of the Index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:assetClass ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The organisation that creates or maintains the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:provider ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:assetType ] ;
    sh:targetClass common_domain_model:EquityIndex .

common_domain_model:EquityMasterConfirmation a sh:NodeShape ;
    rdfs:comment "Specification for General Terms and Elections of an Equity Master Confirmation that is applicable across multiple Equity confirmations and is referenced by each of these confirmations, an example of which being the 2018 ISDA CDM Equity Confirmation for Security Equity Swap." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:linearInterpolationElection common_domain_model:typeOfSwapElection common_domain_model:equityCashSettlementDates common_domain_model:settlementTerms rdf:type common_domain_model:pricingMethodElection common_domain_model:valuationDates ) ;
    sh:targetClass common_domain_model:EquityMasterConfirmation .

common_domain_model:EquitySwapMasterConfirmation2018 a sh:NodeShape ;
    rdfs:comment "Specification for the General Terms and Relationship Supplement Elections as provided in the 2018 ISDA CDM Equity Confirmation for Security Equity Swap." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Per Part 1 Section 8, 'Settlement', of the 2018 ISDA CDM Equity Confirmation for Security Equity Swap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:PriceReturnTerms ;
            sh:description "Per Part 1 Section 5, 'Pricing', of the 2018 ISDA CDM Equity Confirmation, Para 5.1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:pricingMethodElection ],
        [ sh:description "Per Part 1 Section 4, 'Dividend Obligations', of the 2018 ISDA CDM Equity Confirmation, Para 4.2 'Dividend Returns'." ;
            sh:in ( "Price" "Total" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:typeOfSwapElection ],
        [ sh:description "Per Part 1 Section 3, 'Floating Obligations', of the 2018 ISDA CDM Equity Confirmation. Para 3.3." ;
            sh:in ( <http://www.fpml.org/coding-scheme/interpolation-method-1-2#Linear> <http://www.fpml.org/coding-scheme/interpolation-method-1-2#LinearZeroYield> <http://www.fpml.org/coding-scheme/interpolation-method-1-2#None> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:linearInterpolationElection ],
        [ sh:class common_domain_model:PaymentDates ;
            sh:description "The parameters used to generate the payment date schedule, relative to the equityCalculationPeriod. Per Part 1 Section 12, 'Definitions', of the 2018 ISDA CDM Equity Confirmation. Para 73." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:equityCashSettlementDates ],
        [ sh:class common_domain_model:ValuationDates ;
            sh:description "The parameters used to generate the 'Equity Valuation Dates' schedule, including the Effective Date and Termination Date for the Swap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:valuationDates ] ;
    sh:targetClass common_domain_model:EquitySwapMasterConfirmation2018 .

common_domain_model:ExerciseEvent a sh:NodeShape ;
    rdfs:comment "A data defining:  the adjusted dates associated with a particular exercise event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date on which the cash settlement amount is paid. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:adjustedCashSettlementPaymentDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the exercise fee amount is paid. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:adjustedExerciseFeePaymentDate ],
        [ sh:datatype xsd:date ;
            sh:description "The effective date of the underlying swap associated with a given exercise date. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedRelevantSwapEffectiveDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the option exercise takes place. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:adjustedExerciseDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date by which the cash settlement amount must be agreed. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:adjustedCashSettlementValuationDate ] ;
    sh:targetClass common_domain_model:ExerciseEvent .

common_domain_model:FixedAmountCalculationDetails a sh:NodeShape ;
    rdfs:comment "Type for reporting the detailed results of calculating a cash flow for a calculation period.  This is enhanced relative to the FpML-based cashflows structure to allow more information to be returned about daily compounded rates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The amount of the cash flow that was computed, including any spreads and other processing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:calculatedAmount ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value of the fixed rate that was used." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fixedRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The fraction of a year that this calculation represents, according to the day count fraction method." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:yearFraction ],
        [ sh:class common_domain_model:CalculationPeriodBase ;
            sh:description "The calculation period for which the floating calculation was performed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationPeriod ],
        [ sh:class common_domain_model:Money ;
            sh:description "The notional in effect during the calculation period." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:calculationPeriodNotionalAmount ] ;
    sh:targetClass common_domain_model:FixedAmountCalculationDetails .

common_domain_model:FloatingAmountCalculationDetails a sh:NodeShape ;
    rdfs:comment "Type for reporting the detailed results of calculating a cash flow for a calculation period.  This is enhanced relative to the FpML-based cashflows structure to allow more information to be returned about daily compounded rates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The amount of the cash flow excluding any spread, for subsequent processing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:spreadExclusiveCalculatedAMount ],
        [ sh:datatype xsd:decimal ;
            sh:description "The amount of the cash flow that was computed, including any spreads and other processing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:calculatedAmount ],
        [ sh:class common_domain_model:FloatingRateProcessingDetails ;
            sh:description "Details fo the floating rate treatment after the rate is observed or calculated.  This will include details of things like multipliers, spreads, caps and floors, and the raw and treated rates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:processingDetails ],
        [ sh:class common_domain_model:Money ;
            sh:description "The notional in effect during the calculation period." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:calculationPeriodNotionalAmount ],
        [ sh:class common_domain_model:FloatingRateSettingDetails ;
            sh:description "The details of the floating rate setting.  (If it is a calculated rate, details of that calculation will be inside that." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:floatingRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The rate that was actually applied, after all calculations and treatments." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:appliedRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The fraction of a year that this calculation represents, according to the day count fraction method." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:yearFraction ],
        [ sh:class common_domain_model:CalculationPeriodBase ;
            sh:description "The calculation period for which the floating calculation was performed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationPeriod ] ;
    sh:targetClass common_domain_model:FloatingAmountCalculationDetails .

common_domain_model:FloatingRate a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:inflationLag common_domain_model:mainPublication common_domain_model:interpolationMethod common_domain_model:calculationStyle common_domain_model:finalPrincipalExchangeCalculation common_domain_model:finalRateRounding rdf:type common_domain_model:negativeInterestRateTreatment common_domain_model:indexSource common_domain_model:calculationMethod common_domain_model:averagingMethod common_domain_model:initialRate common_domain_model:initialIndexLevel common_domain_model:fallbackBondApplicable ) ;
    sh:property [ sh:description "The specification of any rate conversion which needs to be applied to the observed rate before being used in any calculations. The two common conversions are for securities quoted on a bank discount basis which will need to be converted to either a Money Market Yield or Bond Equivalent Yield. See the Annex to the 2000 ISDA Definitions, Section 7.3. Certain General Definitions Relating to Floating Rate Options, paragraphs (g) and (h) for definitions of these terms." ;
            sh:in ( "BondEquivalentYield" "MoneyMarketYield" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:rateTreatment ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The cap rate or cap rate schedule, if any, which applies to the floating rate. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain level. A cap rate schedule is expressed as explicit cap rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:capRateSchedule ],
        [ sh:class common_domain_model:FallbackRateParameters ;
            sh:description "Definition of any fallback rate that may be applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fallbackRate ],
        [ sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:FloatingRateIndex ] [ sh:class common_domain_model:InflationIndex ] ) ;
            sh:order 4 ;
            sh:path common_domain_model:rateOption ],
        [ sh:class common_domain_model:SpreadSchedule ;
            sh:description "The ISDA Spread or a Spread schedule expressed as explicit spreads and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:spreadSchedule ],
        [ sh:class common_domain_model:RateSchedule ;
            sh:description "A rate multiplier or multiplier schedule to apply to the floating rate. A multiplier schedule is expressed as explicit multipliers and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in the calculationPeriodDatesAdjustments. The multiplier can be a positive or negative decimal. This element should only be included if the multiplier is not equal to 1 (one) for the term of the stream." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:floatingRateMultiplierSchedule ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The floor rate or floor rate schedule, if any, which applies to the floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. A floor rate schedule is expressed as explicit floor rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:floorRateSchedule ],
        [ sh:class common_domain_model:FloatingRateCalculationParameters ;
            sh:description "Support for modular calculated rates, such such as lockout compound calculations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:calculationParameters ] ;
    sh:targetClass common_domain_model:FloatingRate .

common_domain_model:FloatingRateBase a sh:NodeShape ;
    rdfs:comment "A class defining a floating interest rate through the specification of the floating rate index, the tenor, the multiplier schedule, the spread, the qualification of whether a specific rate treatment and/or a cap or floor apply." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:calculationStyle rdf:type common_domain_model:finalRateRounding common_domain_model:calculationMethod common_domain_model:indexSource common_domain_model:fallbackRate common_domain_model:compressibleSpread common_domain_model:negativeInterest common_domain_model:fallbackBondApplicable common_domain_model:inflationLag common_domain_model:mainPublication common_domain_model:calculationParameters common_domain_model:interpolationMethod common_domain_model:finalPrincipalExchangeCalculation common_domain_model:floatingRateMultiplierSchedule common_domain_model:negativeInterestRateTreatment common_domain_model:averagingMethod common_domain_model:initialRate common_domain_model:initialIndexLevel common_domain_model:rateTreatment ) ;
    sh:property [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The cap rate or cap rate schedule, if any, which applies to the floating rate. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain level. A cap rate schedule is expressed as explicit cap rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:capRateSchedule ],
        [ sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:FloatingRateIndex ] [ sh:class common_domain_model:InflationIndex ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:rateOption ],
        [ sh:class common_domain_model:SpreadSchedule ;
            sh:description "The ISDA Spread or a Spread schedule expressed as explicit spreads and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:spreadSchedule ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The floor rate or floor rate schedule, if any, which applies to the floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. A floor rate schedule is expressed as explicit floor rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:floorRateSchedule ] ;
    sh:targetClass common_domain_model:FloatingRateBase .

common_domain_model:FloatingRateIndexDefinition a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "FpML Description" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path common_domain_model:fpmlDescription ],
        [ sh:class common_domain_model:FloatingRateIndexMappings ;
            sh:description "Any mappings to other FRos." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:mappings ],
        [ sh:class common_domain_model:FroHistory ;
            sh:description "FRO History" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:history ],
        [ sh:datatype xsd:boolean ;
            sh:description "YES / NO to flag FROs identified by the FpML Syndicated Loan WG as having underlying benchmark that may also be referenced in syndicated loans." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:inLoan ],
        [ sh:class common_domain_model:ContractualDefinition ;
            sh:description "The definition version or versions supported by the FRO." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:supportedDefinition ],
        [ sh:datatype xsd:string ;
            sh:description "Deprecation and Code Descriptions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:deprecationReason ],
        [ sh:class common_domain_model:FloatingRateIndexCalculationDefaults ;
            sh:description "Any calculation default values." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:calculationDefaults ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:designatedMaturityApplicable ],
        [ sh:datatype xsd:string ;
            sh:description "The source of an FRO, particularly if not a Contractual Definition (e.g. the broker rates matrix)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:definitionalSource ],
        [ sh:class common_domain_model:FloatingRateIndexExternalMappings ;
            sh:description "Any mappings to other codes for this index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:externalMappings ],
        [ sh:class common_domain_model:FloatingRateIndexIdentification ;
            sh:description "The underlying FRO name and designated maturity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:fro ] ;
    sh:targetClass common_domain_model:FloatingRateIndexDefinition .

common_domain_model:FloatingRateIndexFixingOffset a sh:NodeShape ;
    rdfs:comment "This type holds parameters defining the normal fixing offset for a floating rate index." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:datatype xsd:string ;
            sh:description "Allows a reason to be specified for using the alternative fixing offset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:designatedMaturity ],
        [ sh:datatype xsd:string ;
            sh:description "Legal text that underlies the Fixing Offset. ISDA Fixing Offset Definition. (e.g. One day that is either a Sydney Business Day or a Melbourne Business Day following the Reset Date)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fixingOffsetDefinition ],
        [ sh:datatype xsd:string ;
            sh:description "Fixing Offset Reason" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:fixingOffsetReason ],
        [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:period ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business centers for the offset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenters ] ;
    sh:targetClass common_domain_model:FloatingRateIndexFixingOffset .

common_domain_model:ForeignExchangeRateIndex a sh:NodeShape ;
    rdfs:comment "Specification of a rate based on the exchange of a pair of cash assets in specific currencies, e.g. USD versus GBP." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InformationSource ;
            sh:description "Specifies an alternative, or secondary, source from which a rate should be observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:secondaryFxSpotRateSource ],
        [ sh:description "The Asset Class of the Index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:assetClass ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:InformationSource ;
            sh:description "Specifies the primary source from which a rate should be observed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:primaryFxSpotRateSource ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The organisation that creates or maintains the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:provider ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:name ],
        [ sh:class common_domain_model:QuotedCurrencyPair ;
            sh:description "Describes the composition of a rate that has been quoted or is to be quoted." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:quotedCurrencyPair ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 11 ;
            sh:path common_domain_model:assetType ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:taxonomy ] ;
    sh:targetClass common_domain_model:ForeignExchangeRateIndex .

common_domain_model:FxRateSourceFixing a sh:NodeShape ;
    rdfs:comment "Describes a rate source to be fixed and the date the fixing occurs" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FxSettlementRateSource ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:settlementRateSource ],
        [ sh:class common_domain_model:AdjustableDate ;
            sh:description "The date on which the fixing is scheduled to occur." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fixingDate ] ;
    sh:targetClass common_domain_model:FxRateSourceFixing .

common_domain_model:GlobalMasterRepoAgreement a sh:NodeShape ;
    rdfs:comment "The set of elections that define a GMRA" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:GlobalMasterRepoAgreement .

common_domain_model:GlobalMasterSecuritiesLendingAgreement a sh:NodeShape ;
    rdfs:comment "The set of elections that define a GMSLA." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EventsOfDefault ;
            sh:description "The definitions regarding any different events of default relating to the GMSLA." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:eventsOfDefault ],
        [ sh:class common_domain_model:CollateralSpecification ;
            sh:description "The definitions regarding collateral relating to the GMSLA." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:collateral ],
        [ sh:class common_domain_model:BaseCurrency ;
            sh:description "The definitions regarding base currency determinations relating to the GMSLA." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:baseCurrency ] ;
    sh:targetClass common_domain_model:GlobalMasterSecuritiesLendingAgreement .

common_domain_model:IndependentAmountRatings a sh:NodeShape ;
    rdfs:comment "A logical container designed to hold a set of related data. In this case, designed to hold a set of information required when Independent Amount is determined using credit ratings." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:currency rdf:type common_domain_model:compareVariableSet common_domain_model:highestLowestVariableSet common_domain_model:variableSet ) ;
    sh:property [ sh:description "Specifies how multiple credit ratings are compared when determining the applicable Independent Amount, and whether that measure is highest, lowest, or a comparison of either." ;
            sh:in ( "Compare" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:compare ],
        [ sh:description "Specifies the party to whom the rating agency rating applies to for the purposes of determining the Independent Amount." ;
            sh:in ( "Party" "CreditSupportProvider" "NamedEntity" "PartyOrCreditSupportProvider" "NamedAffiliate" "AllAffiliates" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:ratedParty ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Details the Named Affiliate where the Rated Party is Named Affiliate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:namedAffiliate ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Details the Named Entity where the Rated Party is Named Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:namedEntity ],
        [ sh:description "The relevant rating type." ;
            sh:in ( "LongTerm" "ShortTerm" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:ratingType ] ;
    sh:targetClass common_domain_model:IndependentAmountRatings .

common_domain_model:IndexBase a sh:NodeShape ;
    rdfs:comment "Identifies an index by referencing an identifier." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:quotedCurrencyPair common_domain_model:tranche common_domain_model:description common_domain_model:excludedReferenceEntity common_domain_model:seniority common_domain_model:indexSeries rdf:type common_domain_model:inflationRateIndex common_domain_model:indexAnnexSource common_domain_model:indexTenor common_domain_model:indexAnnexDate common_domain_model:secondaryFxSpotRateSource common_domain_model:indexFactor common_domain_model:floatingRateIndex common_domain_model:primaryFxSpotRateSource common_domain_model:settledEntityMatrix common_domain_model:indexAnnexVersion ) ;
    sh:property [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:identifier ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:assetType ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:name ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:description "The Asset Class of the Index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:assetClass ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The organisation that creates or maintains the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:provider ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:taxonomy ] ;
    sh:targetClass common_domain_model:IndexBase .

common_domain_model:InstrumentBase a sh:NodeShape ;
    rdfs:comment "Defines the common attributes for all Instrument data types." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:tranche common_domain_model:deliveryTerm common_domain_model:securityType rdf:type common_domain_model:lien common_domain_model:facilityType common_domain_model:optionType common_domain_model:debtType common_domain_model:fundType common_domain_model:equityType common_domain_model:strike common_domain_model:borrower common_domain_model:creditAgreementDate ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:assetType ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ] ;
    sh:targetClass common_domain_model:InstrumentBase .

common_domain_model:InterestAdjustment a sh:NodeShape ;
    rdfs:comment "A class to specify whether the Interest Adjustment is applicable and what its periodicity is." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InterestAdjustmentPeriodicity ;
            sh:description "The qualification of the Interest Adjustment periodicity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:periodicity ],
        [ sh:datatype xsd:boolean ;
            sh:description "The Interest Adjustment is applicable when True and not applicable when False." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:InterestAdjustment .

common_domain_model:InterestAmount a sh:NodeShape ;
    rdfs:comment "A class to specify the application of Interest Amount with respect to the Delivery Amount and the Return Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:DeliveryAmount ;
            sh:description "The application of Interest Amount with respect the Delivery Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:deliveryAmount ],
        [ sh:class common_domain_model:ReturnAmount ;
            sh:description "The application of Interest Amount with respect the Return Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:returnAmount ] ;
    sh:targetClass common_domain_model:InterestAmount .

common_domain_model:InterestRateIndex a sh:NodeShape ;
    rdfs:comment "An index based in interest rates or inflation rates in a certain market." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:InterestRateIndex .

common_domain_model:Inventory a sh:NodeShape ;
    rdfs:comment "A data type that can be used to describe an inventory of securities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InventoryRecord ;
            sh:description "An array holding the list of inventory being described. Each element in the inventoryRecord array represents an individual piece of inventory i.e. a security." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:inventoryRecord ] ;
    sh:targetClass common_domain_model:Inventory .

common_domain_model:LegalAgreementBase a sh:NodeShape ;
    rdfs:comment "Specifies the legal agreement baseline information, being negotiated or having been executed. It excludes specialized elections" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:agreementTerms common_domain_model:relatedAgreements common_domain_model:umbrellaAgreement ) ;
    sh:property [ sh:class common_domain_model:Identifier ;
            sh:description "The legal agreement identifier. Several identifiers can be specified." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:Party ;
            sh:description "The two contractual parties to the legal agreement, which reference information is positioned as part of the partyInformation attribute." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:contractualParty ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the legal agreement has been agreed between the parties. This corresponds to the Date of Deed in an English Law document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:agreementDate ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "The role(s) that other party(ies) may have in relation to the legal agreement, further to the contractual parties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:otherParty ],
        [ sh:class common_domain_model:Resource ;
            sh:description "A human readable document, for example a confirmation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:attachment ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which, or as of which, the agreement is effective, if different from the agreement date. It is expected that it will most often correspond to the agreement date, although there could be situations where the parties will explicitly agree on a distinct effective date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:class common_domain_model:LegalAgreementIdentification ;
            sh:description "The type of legal agreement, identified via a set of composable attributes: agreementName, publisher, governing law and version, e.g. ISDA 2013 Standard Credit Support Annex English Law." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:legalAgreementIdentification ] ;
    sh:targetClass common_domain_model:LegalAgreementBase .

common_domain_model:LimitApplicable a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:limitImpactDueToTrade rdf:type common_domain_model:limitAmount common_domain_model:limitLevel ) ;
    sh:property [ sh:class common_domain_model:CreditLimitUtilisation ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:utilization ],
        [ sh:datatype xsd:integer ;
            sh:description "This element is required in FpML, optional in CDM for the purpose of accommodating the CME data representation while making reference to the FpML one." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:clipSize ],
        [ sh:description "Standard code to indicate which type of credit line is being referred to - i.e. IM, DV01, PV01, CS01, Notional, Clip Size, Notional, maximumOrderQuantity." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#CS01> <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#DV01> <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#IM> <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#Notional> "NPV" <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#PV01> ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:limitType ],
        [ sh:datatype xsd:string ;
            sh:description "The currency in which the applicable limit is denominated. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:decimal ;
            sh:description "The limit remaining for the limit level and limit type. This does not take into account any pending trades. While the attribute is of type integer in FpML and the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:amountRemaining ],
        [ sh:class common_domain_model:Velocity ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:velocity ],
        [ sh:datatype xsd:decimal ;
            sh:description "The limit utilised by all the cleared trades for the limit level and limit type. While the attribute is of type integer in FpML and the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:amountUtilized ] ;
    sh:targetClass common_domain_model:LimitApplicable .

common_domain_model:ListedDerivative a sh:NodeShape ;
    rdfs:comment "A securitized derivative on another asset." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:datatype xsd:string ;
            sh:description "Also called contract month or delivery month. However, it's not always a month. It is usually expressed using a code, e.g. Z23 would be the Dec 2023 contract, (Z = December). For crude oil, the corresponding contract might be called CLZ23. Optional as this can be uniquely identified in the identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:deliveryTerm ],
        [ sh:description "The type of option, ie Put or Call. Left empty if it is a Future." ;
            sh:in ( "Put" "Call" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:optionType ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:identifier ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the strike of the option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:strike ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:assetType ] ;
    sh:targetClass common_domain_model:ListedDerivative .

common_domain_model:MarginCallBase a sh:NodeShape ;
    rdfs:comment "Represents common attributes required for Issuance and Response to a Margin Call action as a result of a demand for delivery or return of collateral determined under a legal agreement such as a credit support document or equivalent." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:recallNonCashCollateralDescription common_domain_model:marginCallResponseAction rdf:type common_domain_model:overallExposure common_domain_model:callAmountInBaseCurrency common_domain_model:agreedAmountBaseCurrency common_domain_model:scheduleGridIMExposure common_domain_model:simmIMExposure common_domain_model:marginResponseType ) ;
    sh:property [ sh:class common_domain_model:MarginCallExposure ;
            sh:description "Represents the current mark to market value or IM calculation value of the trade portfolio as recorded by the principle (in base currency), to be referenced in a margin call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:baseCurrencyExposure ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Represents the role each specified party takes in the margin call. further to the principal roles, payer and receiver." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyRole ],
        [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral legal agreement rounding in base currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:agreementRounding ],
        [ sh:class common_domain_model:MarginCallInstructionType ;
            sh:description "Identifies the enumeration values to specify the call notification type, direction, specific action type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:instructionType ],
        [ sh:class common_domain_model:CollateralPortfolio ;
            sh:description "Represents attributes to define the details of collateral assets within a collateral portfolio to be used in margin call messaging and contribute to collateral balances e.g securities in a collateral account recorded by the principal as held or posted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:collateralPortfolio ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Represents a unique Identifier for a margin call message, that can be referenced throughout all points of the process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:callIdentifier ],
        [ sh:class common_domain_model:CollateralBalance ;
            sh:description "Represents additional credit support amount over and above mark to market value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:independentAmountBalance ],
        [ sh:class common_domain_model:Party ;
            sh:description "Represents the parties to the margin call. The cardinality is optional to address the case where both parties of the event are specified and a third party if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:party ],
        [ sh:description "Identifies margin type and if related regulatory mandate" ;
            sh:in ( "VM" "RegIM" "NonRegIM" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:regMarginType ],
        [ sh:description "Indicates the role of the party in an regulatory initial margin call instruction (i.e Pledgor party or Secured party)." ;
            sh:in ( "Pledgor" "Secured" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:regIMRole ],
        [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral legal agreement threshold amount in base currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:agreementThreshold ],
        [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral legal agreement minimum transfer amount in base currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:agreementMinimumTransferAmount ],
        [ sh:class common_domain_model:Party ;
            sh:description "Indicates the name of the Clearing Broker FCM/DCM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:clearingBroker ],
        [ sh:class common_domain_model:AgreementName ;
            sh:description "Specifies the legal agreement type the margin call is generated from and governed by." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:callAgreementType ] ;
    sh:targetClass common_domain_model:MarginCallBase .

