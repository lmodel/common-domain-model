common_domain_model:Swp a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SwpOut ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:swpOut ],
        [ sh:class common_domain_model:SwpIn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:swpIn ] ;
    sh:targetClass common_domain_model:Swp .

common_domain_model:SwpIn a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Sngl ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:sngl ] ;
    sh:targetClass common_domain_model:SwpIn .

common_domain_model:SwpOut a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Sngl ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:sngl ] ;
    sh:targetClass common_domain_model:SwpOut .

common_domain_model:TaxonomyClassification a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name defined by the classification system for a specific attribute in the taxonomy" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:className ],
        [ sh:datatype xsd:string ;
            sh:description "The value set by the taxonomy that is specific to the className attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:value ],
        [ sh:datatype xsd:integer ;
            sh:description "In the case of multi-layered hierarchical classification systems such as commodity classification, the layer the value and className occupy in the classification hierarchy, where 1 represents the top-layer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:ordinal ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the class." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:description ] ;
    sh:targetClass common_domain_model:TaxonomyClassification .

common_domain_model:Term a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unit ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:val ] ;
    sh:targetClass common_domain_model:Term .

common_domain_model:TerminationCurrency a sh:NodeShape ;
    rdfs:comment "Specifies how the Termination Currency for the agreement will be determined." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PartyOptionTerminationCurrency ;
            sh:description "Provides that the Termination Currency will be determined by reference to a contractual mechanism when closing out the Agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:partyOptionTerminationCurrency ],
        [ sh:class common_domain_model:TerminationCurrencySelection ;
            sh:description "Allows for specific Termination Currency(ies) and a fallback Termination Currency to be selected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:statedTerminationCurrency ] ;
    sh:targetClass common_domain_model:TerminationCurrency .

common_domain_model:TerminationCurrencyElection a sh:NodeShape ;
    rdfs:comment "A class to specify the Amendment to Termination Currency election by the parties to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether the Termination Currency is specified in this document (True) or in an Eligible Support Credit Support (IM) Schedule (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isSpecified ],
        [ sh:datatype xsd:string ;
            sh:description "The Termination Currency associated with the party that referenced as part of this class. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:currency ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:TerminationCurrencyElection .

common_domain_model:TerminationCurrencySelection a sh:NodeShape ;
    rdfs:comment "Specifies Termination Currency where a currency is stated at the time the agreement is entered into." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies a single fallback Termination Currency should the stated currency not be freely available." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:fallbackCurrency ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies fallback Termination Currency where both parties are Affected Parties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:bothAffected ],
        [ sh:class common_domain_model:PartyTerminationCurrencySelection ;
            sh:description "Specifies different termination currencies to apply depending on which party or parties are the Defaulting Party Affected Party(ies)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyElection ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies a single Termination Currency for the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:statedCurrency ] ;
    sh:targetClass common_domain_model:TerminationCurrencySelection .

common_domain_model:TerminationProvision a sh:NodeShape ;
    rdfs:comment "A class for defining option provisions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EarlyTerminationProvision ;
            sh:description "Parameters specifying provisions relating to the optional and mandatory early termination of a swap transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:earlyTerminationProvision ],
        [ sh:class common_domain_model:RecallProvision ;
            sh:description "A provision defining criteria controlling the ability for a lender to recall securities it has lent out." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:recallProvision ],
        [ sh:class common_domain_model:EvergreenProvision ;
            sh:description "A data defining: the right of a party to exercise an Evergreen option" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:evergreenProvision ],
        [ sh:class common_domain_model:ExtendibleProvision ;
            sh:description "A provision that allows the specification of an embedded option with a swap giving the buyer of the option the right to extend the swap, in whole or in part, to the extended termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:extendibleProvision ],
        [ sh:class common_domain_model:CancelableProvision ;
            sh:description "A provision that allows the specification of an embedded option within a swap giving the buyer of the option the right to terminate the swap, in whole or in part, on the early termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:cancelableProvision ] ;
    sh:targetClass common_domain_model:TerminationProvision .

common_domain_model:TermsChangeInstruction a sh:NodeShape ;
    rdfs:comment "Specifies instructions for terms change consisting of the new transaction terms, and the renegotiation fee." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:in ( "Execution" "PortfolioRebalancing" "Standard" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:adjustment ],
        [ sh:class common_domain_model:NonTransferableProduct ;
            sh:description "product to be changed" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:product ],
        [ sh:class common_domain_model:AncillaryParty ;
            sh:description "ancillary party to be changed" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:ancillaryParty ] ;
    sh:targetClass common_domain_model:TermsChangeInstruction .

common_domain_model:ThresholdElection a sh:NodeShape ;
    rdfs:comment "Specifies whether the threshold is rating based, a fixed amount, or infinity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The party to which the threshold applies." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:ThresholdRatingsBased ;
            sh:description "Defines that the Threshold is based on a Ratings condition(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:ratingsBased ],
        [ sh:class common_domain_model:ThresholdMinimumTransferAmountFixedAmount ;
            sh:description "Defines that the Threshold is a Fixed Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fixedAmount ],
        [ sh:datatype xsd:string ;
            sh:description "Utilised where the clause data structure is not able to capture a material aspect of the clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:other ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies that the Threshold is Infinity. If 'True' then the threshold for the elective party is Infinity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:infinity ] ;
    sh:targetClass common_domain_model:ThresholdElection .

common_domain_model:ThresholdRatingsBased a sh:NodeShape ;
    rdfs:comment "Defines that the Threshold is based on Ratings condition(s)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Defines the number of Rating Agencies that the Party must be rated by." ;
            sh:in ( "All" "AnyOne" "AnyTwo" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:numberOfRatingAgencies ],
        [ sh:description "Where two ratings are specified whether the higher or lower rating prevails." ;
            sh:in ( "Lowest" "Highest" "ReferenceAgency" "Average" "SecondBest" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:compare ],
        [ sh:description "Specifies the relevant trigger for the Threshold or Minimum Transfer Amount to fall to zero." ;
            sh:in ( "EventOfDefault" "TerminationEvent" "TerminationEventAllAffectedTransactions" "PotentialEventOfDefault" "AdditionalTerminationEvent" "Other" ) ;
            sh:order 11 ;
            sh:path common_domain_model:event ],
        [ sh:description "The party to which a rating applies." ;
            sh:in ( "Party" "CreditSupportProvider" "NamedEntity" "PartyOrCreditSupportProvider" "NamedAffiliate" "AllAffiliates" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:ratedParty ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether a trigger applies for the Threshold or Minimum Transfer Amount to fall to zero. If 'True' then such a trigger exists." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path common_domain_model:zeroEvent ],
        [ sh:datatype xsd:string ;
            sh:description "Details the Named Entity where the Rated Party is Named Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:namedEntity ],
        [ sh:description "The threshold currency code." ;
            sh:in ( "AED" "AFN" "ALL" "AMD" "AOA" "ARS" "AUD" "AWG" "AZN" "BAM" "BBD" "BDT" "BHD" "BIF" "BMD" "BND" "BOB" "BOV" "BRL" "BSD" "BTN" "BWP" "BYN" "BZD" "CAD" "CDF" "CHE" "CHF" "CHW" "CLF" "CLP" "CNY" "COP" "COU" "CRC" "CUP" "CVE" "CZK" "DJF" "DKK" "DOP" "DZD" "EGP" "ERN" "ETB" "EUR" "FJD" "FKP" "GBP" "GEL" "GHS" "GIP" "GMD" "GNF" "GTQ" "GYD" "HKD" "HNL" "HTG" "HUF" "IDR" "ILS" "INR" "IQD" "IRR" "ISK" "JMD" "JOD" "JPY" "KES" "KGS" "KHR" "KMF" "KPW" "KRW" "KWD" "KYD" "KZT" "LAK" "LBP" "LKR" "LRD" "LSL" "LYD" "MAD" "MDL" "MGA" "MKD" "MMK" "MNT" "MOP" "MRU" "MUR" "MVR" "MWK" "MXN" "MXV" "MYR" "MZN" "NAD" "NGN" "NIO" "NOK" "NPR" "NZD" "OMR" "PAB" "PEN" "PGK" "PHP" "PKR" "PLN" "PYG" "QAR" "RON" "RSD" "RUB" "RWF" "SAR" "SBD" "SCR" "SDG" "SEK" "SGD" "SHP" "SLE" "SOS" "SRD" "SSP" "STN" "SVC" "SYP" "SZL" "THB" "TJS" "TMT" "TND" "TOP" "TRY" "TTD" "TWD" "TZS" "UAH" "UGX" "USD" "USN" "UYI" "UYU" "UYW" "UZS" "VED" "VES" "VND" "VUV" "WST" "XAD" "XAF" "XAG" "XAU" "XBA" "XBB" "XBC" "XBD" "XCD" "XCG" "XDR" "XOF" "XPD" "XPF" "XPT" "XSU" "XTS" "XUA" "XXX" "YER" "ZAR" "ZMW" "ZWG" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:string ;
            sh:description "Details the Named Affiliate where the Rated Party is Named Affiliate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:namedAffiliate ],
        [ sh:description "Defines where conditions apply if no Rating where ratings may not exist." ;
            sh:in ( "All" "One" "Two" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:notRatedBy ],
        [ sh:description "The relevant rating type." ;
            sh:in ( "LongTerm" "ShortTerm" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:ratingType ],
        [ sh:datatype xsd:boolean ;
            sh:description "What conditions apply where a party has no rating." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:noRating ],
        [ sh:class common_domain_model:CSAThresholdVariableSet ;
            sh:description "Defines a combination of Rating Agency, Rating Value, Threshold amount and Currency code." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:variableSet ] ;
    sh:targetClass common_domain_model:ThresholdRatingsBased .

common_domain_model:TradableProduct a sh:NodeShape ;
    rdfs:comment "Definition of a product as ready to be traded, i.e. included in an execution or contract, by associating a specific price and quantity to this product plus an (optional) mechanism for any potential future quantity adjustment." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:collateral common_domain_model:clearedDate common_domain_model:party common_domain_model:tradeDate rdf:type common_domain_model:contractDetails common_domain_model:tradeTime common_domain_model:tradeIdentifier common_domain_model:partyRole common_domain_model:executionDetails common_domain_model:account ) ;
    sh:property [ sh:class common_domain_model:AncillaryParty ;
            sh:description "Specifies the parties with ancillary roles in the transaction. The product is agnostic to the actual parties involved in the transaction, with the party references abstracted away from the product definition and replaced by the AncillaryRoleEnum. The AncillaryRoleEnum can then be positioned in the product and this AncillaryParty type, which is positioned outside of the product definition, allows the AncillaryRoleEnum to be associated with an actual party reference." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:ancillaryParty ],
        [ sh:class common_domain_model:Counterparty ;
            sh:description "Specifies the parties which are the two counterparties to the transaction.  The product is agnostic to the actual parties to the transaction, with the party references abstracted away from the product definition and replaced by the counterparty enum (e.g. CounterpartyEnum values Party1 or Party2). The counterparty enum can then be positioned in the product (e.g. to specify which counterparty is the payer, receiver etc) and this counterparties attribute, which is positioned outside of the product definition, allows the counterparty enum to be associated with an actual party reference." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:counterparty ],
        [ sh:description "Specifies the conditions that govern the adjustment to the quantity of a product being traded: e.g. execution, portfolio rebalancing etc. It is typically used in the context of Equity Swaps." ;
            sh:in ( "Execution" "PortfolioRebalancing" "Standard" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:adjustment ],
        [ sh:class common_domain_model:NonTransferableProduct ;
            sh:description "The underlying product to be included in a contract or execution." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:product ],
        [ sh:class common_domain_model:TradeLot ;
            sh:description "Specifies the price, quantity and effective date of each trade lot, when the same product may be traded multiple times in different lots with the same counterparty. In a trade increase, a new trade lot is added to the list, with the corresponding effective date. In a trade decrease, the existing trade lot(s) are decreased of the corresponding quantity (and an unwind fee may have to be settled). The multiple cardinality and the ability to increase existing trades is used for Equity Swaps in particular." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:tradeLot ] ;
    sh:targetClass common_domain_model:TradableProduct .

common_domain_model:TransactedPrice a sh:NodeShape ;
    rdfs:comment " A class to represent the transacted price attributes that are positioned as part of the FpML FeeLeg." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "An optional element that only has meaning in a credit index trade. This element contains the credit spread ('fair value') at which the trade was executed. Unlike the fixedRate of an index, the marketFixedRate varies over the life of the index depending on market conditions. The marketFixedRate is the price of the index as quoted by trading desks." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:marketFixedRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "An optional element that contains the up-front points expressed as a percentage of the notional. An initialPoints value of 5% would be represented as 0.05. The initialPoints element is an alternative to marketFixedRate in quoting the traded level of a trade. When initialPoints is used, the traded level is the sum of fixedRate and initialPoints. The initialPoints is one of the items that are factored into the initialPayment calculation and is payable by the Buyer to the Seller. Note that initialPoints and marketFixedRate may both be present in the same document when both implied values are desired." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:initialPoints ],
        [ sh:datatype xsd:decimal ;
            sh:description "An optional element that only has meaning in a credit index trade. This element contains the price at which the trade was executed and is used instead of marketFixedRate on credit trades on certain indicies which are quoted using a price rather than a spread." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:marketPrice ],
        [ sh:description "An optional element that contains the up-front points expressed as a percentage of the notional. An initialPoints value of 5% would be represented as 0.05. The initialPoints element is an alternative to marketFixedRate in quoting the traded level of a trade. When initialPoints is used, the traded level is the sum of fixedRate and initialPoints. The initialPoints is one of the items that are factored into the initialPayment calculation and is payable by the Buyer to the Seller. Note that initialPoints and marketFixedRate may both be present in the same document when both implied values are desired." ;
            sh:in ( "PointsUpFront" "TradedSpread" "Price" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:quotationStyle ] ;
    sh:targetClass common_domain_model:TransactedPrice .

common_domain_model:TransactionAdditionalTerms a sh:NodeShape ;
    rdfs:comment "Additional specification for the extraordinary events that may affect a trade and the related contractual rights and obligation of the parties when this happens. Such terms are typically required to extend the economics terms, for the purpose of producing the final legal contractual form of the Transaction." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:creditAdditionalTerms ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:interestRateAdditionalTerms ],
        [ sh:class common_domain_model:EquityAdditionalTerms ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:equityAdditionalTerms ],
        [ sh:class common_domain_model:FxAdditionalTerms ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:foreignExchangeAdditionalTerms ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:digitalAssetAdditionalTerms ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:commoditiesAdditionalTerms ] ;
    sh:targetClass common_domain_model:TransactionAdditionalTerms .

common_domain_model:Transfer a sh:NodeShape ;
    rdfs:comment "The type of transfer." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:Transfer .

common_domain_model:TransferInformationElection a sh:NodeShape ;
    rdfs:comment "Specifies the party reference and the associated transfer & contact information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The party to which the election and details apply." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:partyReference ],
        [ sh:class common_domain_model:ContactInformation ;
            sh:description "The main notice/address information of the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:primaryContactInformation ] ;
    sh:targetClass common_domain_model:TransferInformationElection .

common_domain_model:TransferInstruction a sh:NodeShape ;
    rdfs:comment "Defines the payout on which to create a Transfer along with all necessary resets." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TransferState ;
            sh:description "Specifies the terms and state of a transfers." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:transferState ] ;
    sh:targetClass common_domain_model:TransferInstruction .

common_domain_model:TransferSettlementTiming a sh:NodeShape ;
    rdfs:comment "Specification of transfer / settlement timing for cash and securities collateral assuming that the notice is provided before the Notification Time (and with a 1LBD lag introduced if the notice is delivered after the Notification Time), and that securities allow for a further Local Business Day for transfer / settlement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Details the day on which collateral is required to be transferred relative to the Notification Time." ;
            sh:in ( "Same" "Next" "FirstLBD" "SecondLBD" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:cashCollateralTransferSettlementTime ],
        [ sh:description "Details the day on which collateral is required to be transferred relative to the Notification Time." ;
            sh:in ( "Same" "Next" "FirstDay" "SecondDay" "ThirdDay" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:securititesCollateralTransferSettlementTime ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:TransferSettlementTiming .

common_domain_model:Trigger a sh:NodeShape ;
    rdfs:comment "Trigger point at which feature is effective." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceSchedule ;
            sh:description "The trigger level." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:level ],
        [ sh:description "The Triggering condition." ;
            sh:in ( "EqualOrLess" "EqualOrGreater" "Equal" "Less" "Greater" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:triggerType ],
        [ sh:description "The valuation time type of knock condition." ;
            sh:in ( "Closing" "Anytime" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:triggerTimeType ],
        [ sh:class common_domain_model:CreditEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:creditEvents ],
        [ sh:class common_domain_model:CreditEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:creditEventsReference ] ;
    sh:targetClass common_domain_model:Trigger .

common_domain_model:UmbrellaAgreement a sh:NodeShape ;
    rdfs:comment "Specifies the set of agreements, the parties of which are set within UmbrellaAgreementSet, beyond the two contracting parties to that agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UmbrellaAgreementSet ;
            sh:description "The language associated with the umbrella agreement, and which applies to all the parties to the umbrella agreement." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:agreementSet ] ;
    sh:targetClass common_domain_model:UmbrellaAgreement .

common_domain_model:UmbrellaAgreementParty a sh:NodeShape ;
    rdfs:comment "Specifies the entities that are part of the umbrella agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "Represents the identification of a parent child relationship between two entities in the Umbrella agreement, allowing non-legal entities to be linked to the appropriate legal entity and allowing funds, portfolio or managed accounts to be linked to their applicable Investment Manager or Agent within the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:parentParty ],
        [ sh:class common_domain_model:Party ;
            sh:description "Specifies the party to the umbrella agreement" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:description "Represents the legal role that each defined entity to the agreement performs within the structure of that agreement." ;
            sh:in ( "Agent" "InvestmentManager" "Principal" "SubAccount" "Sleeve" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:partyRole ],
        [ sh:description "Specifies the CounterpartyRoleEnum, e.g. either Party1 or Party2, that is associated to the party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:actingAs ],
        [ sh:class common_domain_model:NonLegalEntity ;
            sh:description "Specifies a non-legal entity that exists in the agreement with a defined relationship to a Legal entity to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:nonLegalEntity ] ;
    sh:targetClass common_domain_model:UmbrellaAgreementParty .

common_domain_model:UmbrellaAgreementSet a sh:NodeShape ;
    rdfs:comment "Represents the groups of agreement term elections that exist within the agreement and to which entities that particular group of elections apply. Where all entities under the umbrella have the same set of elections only one agreement set will exist. At least one agreement set must be defined for an Umbrella agreement" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:UmbrellaAgreementParty ;
            sh:description "Specifies the underlying parties to the agreement that either act as legal parties to the agreement or represent legal constructs that are managed by a party to the agreement but do not represent a Legal Entity as of themselves." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "Represents any additional language that may need to be captured regarding the structure or application of terms that may exist for the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:class common_domain_model:Agreement ;
            sh:description "Specification of the standard set of terms that define a legal agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:agreement ] ;
    sh:targetClass common_domain_model:UmbrellaAgreementSet .

common_domain_model:UnderlierSubstitutionProvision a sh:NodeShape ;
    rdfs:comment "Where parties describe any substitution terms." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Where the party who is not granted with the substitution role at least has a right to dispute the determination given by the counterparty with such role. As an example, a given PartyA is the unique Counterparty with the Role of WhoMaySubstitute, yet PartyB could be Disputing Party in regard of such Role." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:disputingParty ],
        [ sh:class common_domain_model:Clause ;
            sh:description "Where parties describe any substitution terms e.g. for instance the election criteria for an Asset to be eligible as the Substitute Asset to the prior Affected Asset in terms of sector of activity, currency, market capitalisation, liquidity, volatility, or any additional features that parties would agree to take into considerations, etc." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:substitutionBeSpokeTerms ],
        [ sh:class common_domain_model:ExtraordinaryEvents ;
            sh:description "Where the parties may optionnally explictly specify the list of Events to be considered as a trigger for a Substitution." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:substitutionTriggerEvents ],
        [ sh:description "Designates which Counterparty to the transaction who has the right to trigger a substitution or to provide related determination e.g. for instance to qualify the effectiveness of an Event which may be a trigger for substitution, determine the replacement Share to substitute, etc. ; cardinality of this object is 2, in case parties jointly have this role." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:whoMaySubstitute ] ;
    sh:targetClass common_domain_model:UnderlierSubstitutionProvision .

common_domain_model:UndrlygInstrm a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Swp ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:swp ] ;
    sh:targetClass common_domain_model:UndrlygInstrm .

common_domain_model:ValuationCalculationDateLocationElection a sh:NodeShape ;
    rdfs:comment "A class to specify each of the party elections with respect to the Calculation Date Location." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The Calculation Date Location when specified as a business center which corresponds to the FpML list of business centers or can be mapped to it." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenter ],
        [ sh:datatype xsd:string ;
            sh:description "The Calculation Date Location when specified a location which doesn't correspond to the FpML list of business centers or cannot be mapped to it." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:customLocation ] ;
    sh:targetClass common_domain_model:ValuationCalculationDateLocationElection .

common_domain_model:ValuationDate a sh:NodeShape ;
    rdfs:comment "A single object that represents the different methods to specify a valuation date, as used for cash settlement. The Single / Multiple ValuationDate is used for the determination of recovery in a credit event, the RelativeDateOffset is used for cash-settled option, and FxFixingDate is used for cross-currency settlement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The date on which the cash settlement amount will be determined according to the cash settlement method if the parties have not otherwise been able to agree the cash settlement amount. This attribute was formerly part of 'OptionCashSettlement', which is now being harmonised into a common 'CashSettlementTerms' that includes a 'ValuationDate'." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:valuationDate ],
        [ sh:class common_domain_model:FxFixingDate ;
            sh:description "The date on which the currency rate will be determined for the purpose of specifying the amount in deliverable currency. This attribute was formerly part of 'NonDeliverableSettlement', which is now being harmonised into a common 'CashSettlementTerms' that includes a 'ValuationDate'." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fxFixingDate ],
        [ sh:class common_domain_model:AdjustableDates ;
            sh:description "The date, when expressed as a schedule of date(s), on which the currency rate will be determined for the purpose of specifying the amount in deliverable currency. This attribute was formerly part of 'NonDeliverableSettlement', which is now being harmonised into a common 'CashSettlementTerms' that includes a 'ValuationDate'." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:fxFixingSchedule ],
        [ sh:class common_domain_model:MultipleValuationDates ;
            sh:description "Where multiple valuation dates are specified as being applicable for cash settlement, this element specifies (a) the number of applicable valuation dates, and (b) the number of business days after satisfaction of all conditions to settlement when the first such valuation date occurs, and (c) the number of business days thereafter of each successive valuation date. ISDA 2003 Term: Multiple Valuation Dates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:multipleValuationDates ],
        [ sh:class common_domain_model:SingleValuationDate ;
            sh:description "Where single valuation date is specified as being applicable for cash settlement, this element specifies the number of business days after satisfaction of all conditions to settlement when such valuation date occurs. ISDA 2003 Term: Single Valuation Date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:singleValuationDate ] ;
    sh:targetClass common_domain_model:ValuationDate .

common_domain_model:ValuationInstruction a sh:NodeShape ;
    rdfs:comment "Specifies inputs needed to process a valuation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Valuation ;
            sh:description "Contains all information related to a valuation." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuation ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the previous valuation tracks in the valuation history are removed (True) or kept (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:replace ] ;
    sh:targetClass common_domain_model:ValuationInstruction .

common_domain_model:ValuationMethod a sh:NodeShape ;
    rdfs:comment "Specifies the parameters required to obtain a valuation, including the source, quotation method (bid, mid etc.) and any applicable quotation amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The ISDA defined methodology for determining the final price of the reference obligation for purposes of cash settlement. (ISDA 2003 Term: Valuation Method). For example, Market, Highest etc." ;
            sh:in ( "Market" "Highest" "AverageMarket" "AverageHighest" "BlendedMarket" "BlendedHighest" "AverageBlendedMarket" "AverageBlendedHighest" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:valuationMethod ],
        [ sh:description "The type of price quotations to be requested from dealers when determining the market value of the reference obligation for purposes of cash settlement, or which rate quote is to be observed for a fixing. For example, Bid, Offer, Mid-market or Exercising Party Pays. ISDA 2003 Term: Quotation Method. The meaning of Exercising Party Pays is defined in the 2000 ISDA Definitions, Section 17.2. Certain Definitions Relating to Cash Settlement, paragraph (j)." ;
            sh:in ( "Bid" "Ask" "Mid" "ExercisingPartyPays" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:quotationMethod ],
        [ sh:class common_domain_model:ValuationSource ;
            sh:description "The source for obtaining a valuation. This may come from some information source (e.g. Reuters), from a rate option fixing (e.g. FX fixing for cross-currency settlement), or from a set of reference banks. This is a mandatory attribute as the valuation method relies on one of those sources to be specified." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuationSource ],
        [ sh:class common_domain_model:Money ;
            sh:description "In the determination of a cash settlement amount, if weighted average quotations are to be obtained, the minimum quotation amount specifies a minimum intended threshold amount of outstanding principal balance of the reference obligation for which the quote should be obtained. If not specified, the ISDA definitions provide for a fallback amount of the lower of either USD 1,000,000 (or its equivalent in the relevant obligation currency) or the quotation amount. ISDA 2003 Term: Minimum Quotation Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:minimumQuotationAmount ],
        [ sh:class common_domain_model:CashCollateralValuationMethod ;
            sh:description "Specifies the parameters representing several mid-market valuation and replacement value methods." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:cashCollateralValuationMethod ],
        [ sh:class common_domain_model:Money ;
            sh:description "In the determination of a cash settlement amount, if weighted average quotations are to be obtained, the quotation amount specifies an upper limit to the outstanding principal balance of the reference obligation for which the quote should be obtained. If not specified, the ISDA definitions provide for a fallback amount equal to the floating rate payer calculation amount. ISDA 2003 Term: Quotation Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:quotationAmount ] ;
    sh:targetClass common_domain_model:ValuationMethod .

common_domain_model:ValuationSource a sh:NodeShape ;
    rdfs:comment "A class describing the method for obtaining a settlement rate, specified through either an information source (page), a settlement rate option (fixing) or by using quotes from reference banks." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AncillaryEntity ;
            sh:description "Holds an identifier for the reference entity that is agreed by both parties as a basis for cash settlement calculations. This could be a dealer from whom quotations are obtained by the calculation agent on the reference obligation for purposes of cash settlement in a credit event. ISDA 2003 Term: Dealer. This could be the clearing organization (CCP, DCO) to which the trade should be cleared, as applicable for cash-settled swaptions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:dealerOrCCP ],
        [ sh:class common_domain_model:FxSpotRateSource ;
            sh:description "The information source where a published or displayed market rate will be obtained, e.g. Telerate Page 3750." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:informationSource ],
        [ sh:class common_domain_model:ReferenceBanks ;
            sh:description "A container for a set of reference institutions that may be called upon to provide rate quotations as part of the method to determine the applicable cash settlement amount. If institutions are not specified, it is assumed that reference institutions will be agreed between the parties on the exercise date, or in the case of swap transaction to which mandatory early termination is applicable, the cash settlement valuation date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:referenceBanks ],
        [ sh:class common_domain_model:SettlementRateOption ;
            sh:description "The rate option to use for the fixing. Currently only applicable to foreign exchange fixing in case of cross-currency settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:settlementRateOption ],
        [ sh:class common_domain_model:QuotedCurrencyPair ;
            sh:description "Defines the two currencies for an FX trade and the quotation relationship between the two currencies.  This attribute was formerly part of 'fxSettlementTerms', which is now being harmonised into a common 'CashSettlementTerms' that includes a 'ValuationDate'." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:quotedCurrencyPair ] ;
    sh:targetClass common_domain_model:ValuationSource .

common_domain_model:VarianceCapFloor a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "If present and true, then variance cap is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:varianceCap ],
        [ sh:class common_domain_model:BoundedVariance ;
            sh:description "Conditions which bound variance. The contract specifies one or more boundary levels. These levels are expressed as prices for confirmation purposes Underlyer price must be equal to or higher than Lower Barrier is known as Up Conditional Swap Underlyer price must be equal to or lower than Upper Barrier is known as Down Conditional Swap Underlyer price must be equal to or higher than Lower Barrier and must be equal to or lower than Upper Barrier is known as Barrier Conditional Swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:boundedVariance ],
        [ sh:datatype xsd:decimal ;
            sh:description "For use when varianceCap is applicable. Contains the scaling factor of the Variance Cap that can differ on a trade-by-trade basis in the European market. For example, a Variance Cap of 2.5^2 x Variance Strike Price has an unadjustedVarianceCap of 2.5." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:unadjustedVarianceCap ] ;
    sh:targetClass common_domain_model:VarianceCapFloor .

common_domain_model:WeightedAveragingObservation a sh:NodeShape ;
    rdfs:comment "A single weighted averaging observation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Observation number, which should be unique, within a series generated by a date schedule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:observationNumber ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Observation date time, which should be used when literal observation dates are required. The CDM specifies that the zoned date time is to be expressed in accordance with ISO 8601, either as UTC as an offset to UTC." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:dateTime ],
        [ sh:datatype xsd:decimal ;
            sh:description "Observation weight, which is used as a multiplier for the observation value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:weight ] ;
    sh:targetClass common_domain_model:WeightedAveragingObservation .

common_domain_model:WorkflowState a sh:NodeShape ;
    rdfs:comment "A class to specify workflow information, which is conceptually applicable to all lifecycle events." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A comment field to be associated with the workflow, e.g. to specify why a transaction event was rejected by a party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:comment ],
        [ sh:description "The workflow status indicator, e.g. Accepted, Rejected, ..." ;
            sh:in ( "Accepted" "Alleged" "Amended" "Cancelled" "Certain" "Cleared" "Pending" "Rejected" "Submitted" "Terminated" "Uncertain" "Unconfirmed" "Affirmed" "Confirmed" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:workflowStatus ],
        [ sh:description "The identity of the warehouse, if any, that is executing that workflow step." ;
            sh:in ( "DTCC_TIW_Gold" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:warehouseIdentity ],
        [ sh:class common_domain_model:PartyCustomisedWorkflow ;
            sh:description "Workflow data that is specific to certain market participants and is expressed as part of the CDM in a very generic manner, which can be party-specific. The initial use cases have been derived from the CME clearing and the DTCC TIW submissions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyCustomisedWorkflow ] ;
    sh:targetClass common_domain_model:WorkflowState .

common_domain_model:WorkflowStepApproval a sh:NodeShape ;
    rdfs:comment "Party approvals associated to the current WorkflowStep. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Flag denoting whether the workflow step is approved or not" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:approved ],
        [ sh:datatype xsd:string ;
            sh:description "Optional reason for rejecting the workflow step" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:rejectedReason ],
        [ sh:class common_domain_model:EventTimestamp ;
            sh:description "Timestamp of the approval" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:timestamp ],
        [ sh:class common_domain_model:Party ;
            sh:description "Reference to the Party who is approving/rejecting this workflow step" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:WorkflowStepApproval .

common_domain_model:AcctOwnr a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Id ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:id ] ;
    sh:targetClass common_domain_model:AcctOwnr .

common_domain_model:Agreement a sh:NodeShape ;
    rdfs:comment "Specification of the standard set of terms that define a legal agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MasterAgreementElections ;
            sh:description "A legal representation of the different possible master agreements" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:masterAgreementElections ],
        [ sh:class common_domain_model:CollateralTransferAgreementElections ;
            sh:description "Elections to specify a Collateral Transfer Agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:collateralTransferAgreementElections ],
        [ sh:class common_domain_model:MasterAgreementSchedule ;
            sh:description "Elections to specify a Master Agreement Schedule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:masterAgreementSchedule ],
        [ sh:class common_domain_model:TransactionAdditionalTerms ;
            sh:description "Any additional terms which mainly intend to specify the extraordinary events that may affect a trade and the related contractual rights and obligation of the parties when this happens" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:transactionAdditionalTerms ],
        [ sh:class common_domain_model:SecurityAgreementElections ;
            sh:description "Elections to specify a Security agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:securityAgreementElections ],
        [ sh:description "Elections to specify a Credit Support Annex or Credit Support Deed for Intial or Variation Margin." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:CreditSupportAgreementInitialMarginElections ] [ sh:class common_domain_model:CreditSupportAgreementVariationMarginElections ] [ sh:class common_domain_model:CreditSupportAgreementLegacyElections ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:creditSupportAgreementElections ] ;
    sh:targetClass common_domain_model:Agreement .

common_domain_model:AllDirectionRating a sh:NodeShape ;
    rdfs:comment "Used to combine two or more Ratings and associated direction using AND logic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllDirectionRating ] [ sh:class common_domain_model:AnyDirectionRating ] [ sh:class common_domain_model:DirectionRating ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:allDirectionRating ] ;
    sh:targetClass common_domain_model:AllDirectionRating .

common_domain_model:AmendmentEffectiveDate a sh:NodeShape ;
    rdfs:comment "A class to specify the effective date of the Amendment to Termination Currency. This date can be specified as either an actual date, a specific date (e.g. the annex date) or as a custom provision." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The effective date of the Amendment to Termination Currency when specified as an actual date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:date ],
        [ sh:description "The effective date of the Amendment to Termination Currency when specified as relative to another date (e.g. the annex date)." ;
            sh:in ( "AnnexDate" "DeedDate" "AgreementDate" "AmendmentEffectiveDate" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:specificDate ],
        [ sh:datatype xsd:string ;
            sh:description "The effective date of the Amendment to Termination Currency when specified as a non normalized custom provision." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:customProvision ] ;
    sh:targetClass common_domain_model:AmendmentEffectiveDate .

common_domain_model:AncillaryEntity a sh:NodeShape ;
    rdfs:comment "Holds an identifier for an ancillary entity, either identified directly via its ancillary role or directly as a legal entity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identifies a party via its ancillary role on a transaction (e.g. CCP or DCO through which the trade should be cleared.)" ;
            sh:in ( "DisruptionEventsDeterminingParty" "ExtraordinaryDividendsParty" "PredeterminedClearingOrganizationParty" "ExerciseNoticeReceiverPartyManual" "ExerciseNoticeReceiverPartyOptionalEarlyTermination" "ExerciseNoticeReceiverPartyCancelableProvision" "ExerciseNoticeReceiverPartyExtendibleProvision" "CalculationAgentIndependent" "CalculationAgentOptionalEarlyTermination" "CalculationAgentMandatoryEarlyTermination" "CalculationAgentFallback" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:ancillaryParty ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:legalEntity ] ;
    sh:targetClass common_domain_model:AncillaryEntity .

common_domain_model:AnyDirectionRating a sh:NodeShape ;
    rdfs:comment "Used to combine two or more Ratings and associated direction using OR logic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllDirectionRating ] [ sh:class common_domain_model:AnyDirectionRating ] [ sh:class common_domain_model:DirectionRating ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:anyDirectionRating ] ;
    sh:targetClass common_domain_model:AnyDirectionRating .

common_domain_model:AppropriatedCollateralValuation a sh:NodeShape ;
    rdfs:comment "A class to specify the Valuation of Appropriated Collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The parties' election that qualify the Valuation of Appropriate Collateral in the case where it is deemed applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:election ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether the Valuation of Appropriate Collateral provision is applicable (True) or not applicable (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isSpecified ] ;
    sh:targetClass common_domain_model:AppropriatedCollateralValuation .

common_domain_model:AssetDeliveryProfile a sh:NodeShape ;
    rdfs:comment "Defines the delivery profile of the asset, including the load type and the delivery intervals." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identification of the delivery profile." ;
            sh:in ( "BaseLoad" "PeakLoad" "OffPeak" "BlockHours" "Shaped" "GasDay" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:loadType ],
        [ sh:class common_domain_model:AssetDeliveryProfileBlock ;
            sh:description "Defines a delivery profile block, including start and end time, days of the week, duration, delivery capacity and price time interval quantity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:block ],
        [ sh:description "Specifies whether the dates defined include holidays or not." ;
            sh:in ( "AsWeekday" "AsWeekend" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:bankHolidaysTreatment ] ;
    sh:targetClass common_domain_model:AssetDeliveryProfile .

common_domain_model:AvailableInventoryRecord a sh:NodeShape ;
    rdfs:comment "An individual piece of available inventory. This represents a single security and its associated criteria. The criteria are used to describe any restrictions on the securities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Quantity ;
            sh:description "The quantity of the security" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:Price ;
            sh:description "An optional element which can be used to hold a rate associated to this piece of availability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:interestRate ],
        [ sh:datatype xsd:dateTime ;
            sh:description "There may be a set period/time restriction associated to the security." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:expirationDateTime ],
        [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "Unique identifier for this record. This can be used to uniquely identify a specific piece of inventory." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:identifer ],
        [ sh:class common_domain_model:Security ;
            sh:description "The security details." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:security ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "An individual security may be held by several agents. Including the party role at this level allows us to reference the party holding this specific item." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyRole ],
        [ sh:class common_domain_model:DividendTerms ;
            sh:description "Specifies the dividend requirements if applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:dividendTerms ],
        [ sh:datatype xsd:string ;
            sh:description "Optional comment for this specific piece of inventory." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:comment ],
        [ sh:class common_domain_model:CollateralProvisions ;
            sh:description "The type of collateral can often be required when determining if the piece of availability being described is suitable for a party." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:collateral ] ;
    sh:targetClass common_domain_model:AvailableInventoryRecord .

common_domain_model:AveragingPeriod a sh:NodeShape ;
    rdfs:comment "Period over which an average value is taken." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AveragingSchedule ;
            sh:description "A schedule for generating averaging observation dates." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:schedule ],
        [ sh:description "The market disruption event as defined by ISDA 2002 Definitions." ;
            sh:in ( <http://www.fpml.org/coding-scheme/market-disruption-1-0#ModifiedPostponement> <http://www.fpml.org/coding-scheme/market-disruption-1-0#Omission> <http://www.fpml.org/coding-scheme/market-disruption-1-0#Postponement> ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:marketDisruption ],
        [ sh:class common_domain_model:DateTimeList ;
            sh:description "An unweighted list of averaging observation date and times." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:averagingDateTimes ],
        [ sh:class common_domain_model:AveragingObservationList ;
            sh:description "A weighted list of averaging observation date and times." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:averagingObservations ] ;
    sh:targetClass common_domain_model:AveragingPeriod .

common_domain_model:AveragingSchedule a sh:NodeShape ;
    rdfs:comment "Class to representing a method for generating a series of dates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Date on which this period ends." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:endDate ],
        [ sh:datatype xsd:date ;
            sh:description "Date on which this period begins." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:startDate ],
        [ sh:class common_domain_model:CalculationPeriodFrequency ;
            sh:description "The frequency at which averaging period occurs with the regular part of the valuation schedule and their roll date convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:averagingPeriodFrequency ] ;
    sh:targetClass common_domain_model:AveragingSchedule .

common_domain_model:BespokeCalculationDate a sh:NodeShape ;
    rdfs:comment "A class to specify bespoke Calculation Date terms for the purposes of Initial Margin." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The Additional Calculation Date terms for the purposes of Initial Margin." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:calculationDateImTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "Additional Calculation Date terms are applicable when True and not applicable when False." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:BespokeCalculationDate .

common_domain_model:BespokeCalculationTime a sh:NodeShape ;
    rdfs:comment "A class to specify additional Calculation Time terms for the purposes of Initial Margin." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional Terms applicable to Calculation Time for Initial Margin." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:bespokeCalculationTimeTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "If set to True, the Calculation Time for Initial Margin is the time as of which the Calculation Agent (IM) computes its end of day valuations of derivatives transactions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:asCalculationAgent ] ;
    sh:targetClass common_domain_model:BespokeCalculationTime .

common_domain_model:CSAValuationDate a sh:NodeShape ;
    rdfs:comment "Specifies the date on which the value of collateral or exposure are calculated in accordance with the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Defines the day of the calendar if this is specified for in the ValuationDateDateEnum." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:calendarDay ],
        [ sh:description "Defines the regularity of the date specified for the Valuation Date." ;
            sh:in ( "Daily" "Weekly" "Fortnightly" "Monthly" "AsAgreed" "AsSelected" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:frequency ],
        [ sh:description "Specific day(s) or day of the week, if any, specified for Valuation Time." ;
            sh:in ( "LocalBusinessDay" "CalendarDay" "NewYorkBankingDay" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:day ],
        [ sh:description "Defines whether a date is defined by a certain day of the week or a particular date in the month. If not specified here, then additional language must be used." ;
            sh:in ( "Each" "Last" "Secondlast" "Thirdlast" "Fourthlast" "CalendarDay" "AsSelected" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:date ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:CSAValuationDate .

common_domain_model:CalculationAgentTerms a sh:NodeShape ;
    rdfs:comment "Details of the party calculating the value of collateral to be delivered or returned." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The Calculation Agent (IM) terms when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:bespokeCalculationAgentTerms ],
        [ sh:description "The party which is specified as Calculation Agent for Initial Margin." ;
            sh:in ( "Party1" "Party2" "PartyMakingDemand" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:CalculationAgentTerms .

common_domain_model:CalculationPeriodBase a sh:NodeShape ;
    rdfs:comment "The calculation period adjusted start and end dates, which are the baseline arguments needed to compute an interest accrual calculation." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:forecastAmount common_domain_model:fxLinkedNotionalAmount common_domain_model:floatingRateDefinition common_domain_model:fixedRate rdf:type common_domain_model:unadjustedEndDate common_domain_model:dayCountYearFraction common_domain_model:notionalAmount common_domain_model:calculationPeriodNumberOfDays common_domain_model:unadjustedStartDate common_domain_model:forecastRate ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The calculation period end date, adjusted according to any relevant business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedEndDate ],
        [ sh:datatype xsd:date ;
            sh:description "The calculation period start date, adjusted according to any relevant business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:adjustedStartDate ] ;
    sh:targetClass common_domain_model:CalculationPeriodBase .

common_domain_model:CashSettlementTerms a sh:NodeShape ;
    rdfs:comment "Defines the terms required to compute and settle a cash settlement amount according to a fixing value, including the fixing source, fixing method and fixing date. In FpML, PhysicalSettlementTerms and CashSettlementTerms extend SettlementTerms. In the CDM, this extension paradigm has not been used because SettlementTerms class has been used for purposes related to securities transactions, while it is not used as such in the FpML standard (i.e. only as an abstract construct." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Used for fixed recovery, specifies the recovery level, determined at contract formation, to be applied on a default. Used to calculate the amount paid by the seller to the buyer for cash settlement on the cash settlement date. Amount calculation is (1 minus the Recovery Factor) multiplied by the Floating Rate Payer Calculation Amount. The currency will be derived from the Floating Rate Payer Calculation Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:recoveryFactor ],
        [ sh:class common_domain_model:Money ;
            sh:description "The amount paid by the seller to the buyer for cash settlement on the cash settlement date. If not otherwise specified, would typically be calculated as 100 (or the Reference Price) minus the price of the Reference Obligation (all expressed as a percentage) times Floating Rate Payer Calculation Amount. ISDA 2003 Term: Cash Settlement Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:cashSettlementAmount ],
        [ sh:description "Specifies the type of cash settlement method: cash price, yield curve etc." ;
            sh:in ( "CashPriceMethod" "CashPriceAlternateMethod" "ParYieldCurveAdjustedMethod" "ZeroCouponYieldAdjustedMethod" "ParYieldCurveUnadjustedMethod" "CrossCurrencyMethod" "CollateralizedCashPriceMethod" "MidMarketIndicativeQuotations" "MidMarketIndicativeQuotationsAlternate" "MidMarketCalculationAgentDetermination" "ReplacementValueFirmQuotations" "ReplacementValueCalculationAgentDetermination" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:cashSettlementMethod ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The time of the cash settlement valuation date when the cash settlement amount will be determined according to the cash settlement method, if the parties have not otherwise been able to agree the cash settlement amount. When using quations, this is the time of day in the specified business center when the calculation agent seeks quotations for an amount of the reference obligation for purposes of cash settlement. ISDA 2003 Term: Valuation Time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:valuationTime ],
        [ sh:class common_domain_model:ValuationDate ;
            sh:description "Defines the different methods to specify a valuation date, as used for cash settlement. The Single / Multiple ValuationDate is used for the determination of recovery in a credit event, the RelativeDateOffset is used for cash-settled option, and FxFixingDate is used for cross-currency settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:valuationDate ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether accrued interest is included (true) or not (false). For cash settlement this specifies whether quotations should be obtained inclusive or not of accrued interest. For physical settlement this specifies whether the buyer should deliver the obligation with an outstanding principal balance that includes or excludes accrued interest. ISDA 2003 Term: Include/Exclude Accrued Interest." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:accruedInterest ],
        [ sh:class common_domain_model:ValuationMethod ;
            sh:description "Specifies the parameters required to obtain a valuation, including the source, quotation method (bid, mid etc.) and any applicable quotation amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:valuationMethod ],
        [ sh:datatype xsd:boolean ;
            sh:description "Used for Recovery Lock, to indicate whether fixed Settlement is Applicable or Not Applicable. If Buyer fails to deliver an effective Notice of Physical Settlement on or before the Buyer NOPS Cut-off Date, and if Seller fails to deliver an effective Seller NOPS on or before the Seller NOPS Cut-off Date, then either: (a) if Fixed Settlement is specified in the related Confirmation as not applicable, then the Seller NOPS Cut-off Date shall be the Termination Date; or (b) if Fixed Settlement is specified in the related Confirmation as applicable, then: (i) if the Fixed Settlement Amount is a positive number, Seller shall, subject to Section 3.1 (except for the requirement of satisfaction of the Notice of Physical Settlement Condition to Settlement), pay the Fixed Settlement Amount to Buyer on the Fixed Settlement Payment Date; and (ii) if the Fixed Settlement Amount is a negative number, Buyer shall, subject to Section 3.1 (except for the requirement of satisfaction of the Notice of Physical Settlement Condition to Settlement), pay the absolute value of the Fixed Settlement Amount to Seller on the Fixed Settlement Payment Date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:fixedSettlement ] ;
    sh:targetClass common_domain_model:CashSettlementTerms .

common_domain_model:CollateralPosition a sh:NodeShape ;
    rdfs:comment "Specifies the individual components of collateral positions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "The aggregate cost of proceeds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:cashBalance ],
        [ sh:class common_domain_model:PriceQuantity ;
            sh:description "Position with many price quantities." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:description "Indicates the collateral positions settlement status." ;
            sh:in ( "FullAmount" "SettledAmount" "InTransitAmount" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:collateralPositionStatus ],
        [ sh:class common_domain_model:CollateralTreatment ;
            sh:description "Specifies if there is any treatment to be applied to collateral, such as percentage discount which will impact collateral value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:treatment ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "Reference to the Contract, in case product is contractual and the contract has been formed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:tradeReference ],
        [ sh:description "The asset that underlies the position." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 4 ;
            sh:path common_domain_model:asset ],
        [ sh:class common_domain_model:Product ;
            sh:description "The product underlying the position." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:product ] ;
    sh:targetClass common_domain_model:CollateralPosition .

common_domain_model:CollateralProvisions a sh:NodeShape ;
    rdfs:comment "Contains collateral attributes which can also inherit information from a GMRA" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EligibleCollateralCriteria ;
            sh:description "The eligible collateral as specified in relation to the transaction." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:eligibleCollateral ],
        [ sh:description "Enumerates the collateral types which are accepted by the Seller." ;
            sh:in ( "Cash" "NonCash" "CashPool" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:collateralType ],
        [ sh:class common_domain_model:SubstitutionProvisions ;
            sh:description "The provisions for collateral substitutions such as how many and when they are allowed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:substitutionProvisions ] ;
    sh:targetClass common_domain_model:CollateralProvisions .

common_domain_model:CollateralTreatment a sh:NodeShape ;
    rdfs:comment "Specifies the treatment terms for the eligible collateral criteria specified." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ConcentrationLimit ;
            sh:description "Specification of concentration limits applicable to the collateral criteria." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:concentrationLimit ],
        [ sh:datatype xsd:boolean ;
            sh:description "A boolean attribute to specify whether collateral critieria are inclusion (True) or exclusion (False) criteria." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:isIncluded ],
        [ sh:class common_domain_model:CollateralValuationTreatment ;
            sh:description "Specification of the valuation treatment for the specified collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuationTreatment ] ;
    sh:targetClass common_domain_model:CollateralTreatment .

common_domain_model:Composite a sh:NodeShape ;
    rdfs:comment "Specifies the conditions to be applied for converting into a reference currency when the actual currency rate is not determined upfront." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the method according to which an amount or a date is determined." ;
            sh:in ( <http://www.fpml.org/coding-scheme/determination-method-3-4#AgreedInitialPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#AsSpecifiedInMasterConfirmation> <http://www.fpml.org/coding-scheme/determination-method-3-4#CalculationAgent> <http://www.fpml.org/coding-scheme/determination-method-3-4#ClosingPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#DividendCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#ExpiringContractLevel> <http://www.fpml.org/coding-scheme/determination-method-3-4#HedgeExecution> <http://www.fpml.org/coding-scheme/determination-method-3-4#IssuerPaymentCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#NAV> <http://www.fpml.org/coding-scheme/determination-method-3-4#OpenPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#OSPPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#SettlementCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#StrikeDateDetermination> <http://www.fpml.org/coding-scheme/determination-method-3-4#TWAPPrice> "TWAPVE" "TWAPVEExcludingClose" <http://www.fpml.org/coding-scheme/determination-method-3-4#ValuationTime> <http://www.fpml.org/coding-scheme/determination-method-3-4#VWAPPrice> "VWAPVE" "VWAPVEExcludingClose" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:determinationMethod ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The time at which the spot currency exchange rate will be observed. It is specified as a time in a business day calendar location, e.g. 11:00am London time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fixingTime ],
        [ sh:class common_domain_model:FxSpotRateSource ;
            sh:description "Specifies the methodology (reference source and, optionally, fixing time) to be used for determining a currency conversion rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:fxSpotRateSource ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "A date specified as some offset to another date (the anchor date)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:relativeDate ] ;
    sh:targetClass common_domain_model:Composite .

common_domain_model:ContractualDefinitionIdentifier a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "e.g. V1" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:contractualDefinitionVersion ],
        [ sh:description "e.g. ISDA2021Definitions" ;
            sh:in ( "ISDA1991InterestRate" "ISDA1993CommodityDerivatives" "ISDA1996EquityDerivatives" "ISDA1997Bullion" "ISDA1997GovernmentBondOption" "ISDA1998FxAndCurrencyOption" "ISDA1999CreditDerivatives" "ISDA2000" "ISDA2002EquityDerivatives" "ISDA2003CreditDerivatives" "ISDA2004Novation" "ISDA2005Commodity" "ISDA2006" "ISDA2006InflationDerivatives" "ISDA2008InflationDerivatives" "ISDA2011EquityDerivatives" "ISDA2014CreditDerivatives" "ISDA2021InterestRateDerivatives" "ISDA2022VerifiedCarbonCredit" "ISDA2023DigitalAssetDerivatives" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:contractualDefinitionType ] ;
    sh:targetClass common_domain_model:ContractualDefinitionIdentifier .

common_domain_model:CorrelationReturnTerms a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:DividendApplicability ;
            sh:description "The parameters which define whether dividends are applicable" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:dividendApplicability ],
        [ sh:datatype xsd:integer ;
            sh:description "Expected number of trading days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:expectedN ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the price of shares is adjusted for dividends or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:sharePriceDividendAdjustment ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether Mean Adjustment is applicable or not in the calculation of the Realized Volatility, Variance or Correlation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path common_domain_model:meanAdjustment ],
        [ sh:description "In this context, this is AgreedInitialPrice - a specified Initial Index Level." ;
            sh:in ( <http://www.fpml.org/coding-scheme/determination-method-3-4#AgreedInitialPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#AsSpecifiedInMasterConfirmation> <http://www.fpml.org/coding-scheme/determination-method-3-4#CalculationAgent> <http://www.fpml.org/coding-scheme/determination-method-3-4#ClosingPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#DividendCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#ExpiringContractLevel> <http://www.fpml.org/coding-scheme/determination-method-3-4#HedgeExecution> <http://www.fpml.org/coding-scheme/determination-method-3-4#IssuerPaymentCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#NAV> <http://www.fpml.org/coding-scheme/determination-method-3-4#OpenPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#OSPPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#SettlementCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#StrikeDateDetermination> <http://www.fpml.org/coding-scheme/determination-method-3-4#TWAPPrice> "TWAPVE" "TWAPVEExcludingClose" <http://www.fpml.org/coding-scheme/determination-method-3-4#ValuationTime> <http://www.fpml.org/coding-scheme/determination-method-3-4#VWAPPrice> "VWAPVE" "VWAPVEExcludingClose" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:initialLevelSource ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of data series, normal market practice is that correlation data sets are drawn from geographic market areas, such as America, Europe and Asia Pacific, each of these geographic areas will have its own data series to avoid contagion." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:numberOfDataSeries ],
        [ sh:class common_domain_model:EquityUnderlierProvisions ;
            sh:description "Contains Equity Underlyer provisions regarding jurisdiction and fallbacks." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:equityUnderlierProvisions ],
        [ sh:datatype xsd:integer ;
            sh:description "This specifies the numerator of an annualization factor. Frequently this number is equal to the number of observations of prices in a year e.g. 252." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:annualizationFactor ],
        [ sh:class common_domain_model:NumberRange ;
            sh:description "Describes correlation bounds, which form a cap and a floor on the realized correlation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:boundedCorrelation ],
        [ sh:class common_domain_model:ValuationTerms ;
            sh:description "Contains all non-date valuation information." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:valuationTerms ],
        [ sh:class common_domain_model:Price ;
            sh:description "Correlation Strike Price in accordance with the ISDA 2011 Equity Derivatives Definitions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:correlationStrikePrice ],
        [ sh:datatype xsd:string ;
            sh:description "Performance calculation, in accordance with Part 1 Section 12 of the 2018 ISDA CDM Equity Confirmation for Security Equity Swap, Para 75. 'Equity Performance'. Cumulative performance is used as a notional multiplier factor on both legs of an Equity Swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path common_domain_model:performance ],
        [ sh:datatype xsd:decimal ;
            sh:description "Contract will strike off this initial level. Providing just the initialLevel without initialLevelSource, infers that this is AgreedInitialPrice - a specified Initial Index Level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:initialLevel ] ;
    sh:targetClass common_domain_model:CorrelationReturnTerms .

common_domain_model:CoveredTransactions a sh:NodeShape ;
    rdfs:comment "Specification of Transactions covered by the legal agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdditionalObligations ;
            sh:description "The party specific additional obligations applicable to the document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:additionalObligations ],
        [ sh:datatype xsd:date ;
            sh:description "Includes any Transaction specified below that is entered into on or after the specified date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:inclusionDate ],
        [ sh:class common_domain_model:ProductTaxonomy ;
            sh:description "Covered Transactions when expressed using the ISDA taxonomy." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:coveredTransactions ],
        [ sh:class common_domain_model:ExposureScope ;
            sh:description "Specification of amendments to the calculation of Exposure in terms of the Transactions covered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:exposure ],
        [ sh:datatype xsd:string ;
            sh:description "Covered Transactions when not expressed using the ISDA taxonomy." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:bespokeCoveredTransactions ] ;
    sh:targetClass common_domain_model:CoveredTransactions .

common_domain_model:CreditLimitUtilisation a sh:NodeShape ;
    rdfs:comment "Credit limit utilisation breakdown by executed trades and pending orders." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CreditLimitUtilisationPosition ;
            sh:description "Credit limit utilisation attributable to executed trades." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:executed ],
        [ sh:class common_domain_model:CreditLimitUtilisationPosition ;
            sh:description "Credit limit utilisation attributable to pending unexecuted orders." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:pending ] ;
    sh:targetClass common_domain_model:CreditLimitUtilisation .

common_domain_model:CreditLimitUtilisationPosition a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Credit limit utilisation attributable to short positions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:shortPosition ],
        [ sh:datatype xsd:decimal ;
            sh:description "Global credit limit utilisation amount, agnostic of long/short position direction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:global_ ],
        [ sh:datatype xsd:decimal ;
            sh:description "Credit limit utilisation attributable to long positions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:longPosition ] ;
    sh:targetClass common_domain_model:CreditLimitUtilisationPosition .

common_domain_model:DebtType a sh:NodeShape ;
    rdfs:comment "Specifies the type of debt security." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:DebtEconomics ;
            sh:description "Specifies selected financial terms of a debt security." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:debtEconomics ] ;
    sh:targetClass common_domain_model:DebtType .

common_domain_model:DeliveryAmount a sh:NodeShape ;
    rdfs:comment "A class to specify the application of Interest Amount with respect the Delivery Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The standard election as specified by an enumeration." ;
            sh:in ( "LastLocalBusinessDay" "LastAndAnyLocalBusinessDay" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:standardElection ],
        [ sh:datatype xsd:string ;
            sh:description "The custom election that might be specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customElection ] ;
    sh:targetClass common_domain_model:DeliveryAmount .

common_domain_model:DeterminationRolesAndTerms a sh:NodeShape ;
    rdfs:comment "Defines the roles and related terms which document the agreement of parties about any determination requirements ; mostly about Extraordinary Events, without being necessarily restricted to such scope, as further specified in the particular product at stake e.g. for instance when Calculation Agent is mentioned as the Price Determination Method enumarated value, etc." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Clause ;
            sh:description "Where parties may optionnaly describe any extra bespoke agreements about fallback procedure attached to a particular determination role. This fallback bespoke paragraph would typically address topics such as : delay for the Disputing Party to notify a disagreement when receiving a determination from the Calculation Agent ; Independent Third Party Dealers election terms e.g. number of Dealers to be jointly elected by the counterparties ; delay for joint election of Dealers by the counterparties ; further fallback election procedure in case of disagreement between parties to jointly elect all the Dealers e.g. typically each party designates 1 Dealer, each a Party Representant, which thus result in 2 Dealers in charge of joint election of 3 other Dealers who will be the final ones to provide the response, each a Final Dealer ; delay for joint election of the Final Dealers by the Party Representants ; fees repartition e.g. typically cost and fees incurred by the election of Dealers are equally shared by the parties ; etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fallbackLanguageBespokeTerms ],
        [ sh:description "Defines the enumerated values to specify the determination roles to the transaction. Such roles mostly address any determination that would be required when some Extraordinary Events would happen, for instance qualifying the effectiveness of such event, or when a calculation is required, etc. else any other kind of determination as need be. Yet for clarity, other kinds of determination may be covered by such roles, which are not necessarily restricted to the scope of Extarordinary Events, depending on particular product specifications e.g. for instance when Calculation Agent is mentioned as the Price Determination Method enumarated value, etc." ;
            sh:in ( "CalculationAgent" "HedgingParty" "DeterminingParty" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:determinationRole ],
        [ sh:description "Where the party who is not granted with the determination role at least has a right to dispute the determination given by the counterparty with such role. As an example, a given PartyA is the unique Counterparty with the Role of CalculationAgent, yet Party B could be Disputing Party in regard of such Role." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:disputingParty ],
        [ sh:description "Designates which Counterparty to the transaction is granted with the particular role ; cardinality of this object is 2, in case parties are both having the same role e.g. jointly CalculationAgent, jointly Determining Party, etc. " ;
            sh:in ( "Party1" "Party2" ) ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:whoToDetermine ] ;
    sh:targetClass common_domain_model:DeterminationRolesAndTerms .

common_domain_model:DirectOrRelativeTime a sh:NodeShape ;
    rdfs:comment "Represents a time definition that can be either an absolute (direct) time or a time calculated relative to another referenced time. Either one directTime or one relativeTime should be provided" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RelativeTime ;
            sh:description "A time value calculated relative to another reference time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:relativeTime ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "An absolute time value expressed in a specific time zone." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:directTime ] ;
    sh:targetClass common_domain_model:DirectOrRelativeTime .

common_domain_model:DirectionRating a sh:NodeShape ;
    rdfs:comment "A logical container to hold a defined set of related data. In this case the collation of Ratings Agency, Rating value and an associated direction." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies The credit agency to which the other variables (notation, scale, debt type) refer to." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#AMBest> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#CBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#DBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Fitch> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Japanagency> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Moodys> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:agency ],
        [ sh:description "Specifies the direction of measurement for the rated party." ;
            sh:in ( "GreaterThan" "GreaterThanOrEquals" "Equals" "LessThanOrEquals" "LessThan" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:direction ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies The credit rating notation. As it varies among credit rating agencies, FpML doesn't specify a default scheme." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:notation ],
        [ sh:class common_domain_model:CreditRatingDebt ;
            sh:description "Specifies the credit rating debt type (e.g. long term, high yield, deposits, ...) associated with the credit rating notation and scale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:debt ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the credit rating scale, with a typical distinction between short term, long term. FpML doesn't specify a default scheme, which is hence not specified as an enumeration as part of the CDM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:scale ],
        [ sh:description "Assesses the potential direction of a long-term credit rating over the intermediate term, which is generally up to two years for investment grade and generally up to one year for speculative grade." ;
            sh:in ( "Positive" "Negative" "Stable" "Developing" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:outlook ],
        [ sh:description "Indicates the potential direction of a short-term or long-term rating. It focuses on identifiable events and short-term trends that cause ratings to be placed under special surveillance." ;
            sh:in ( "Positive" "Negative" "Developing" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:creditWatch ] ;
    sh:targetClass common_domain_model:DirectionRating .

common_domain_model:DividendPayoutRatio a sh:NodeShape ;
    rdfs:comment "A class describing the dividend payout ratio associated with an equity underlier. In certain cases the actual ratio is not known on trade inception, and only general conditions are then specified." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Specifies the total actual dividend payout ratio associated with the equity underlier. A ratio of 90% should be expressed at 0.90." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:totalRatio ],
        [ sh:class common_domain_model:BasketConstituent ;
            sh:description "In the case of a basket underlier, specifies to which component of the basket this particular set of dividend payout ratios correspond." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:basketConstituent ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the non cash actual dividend payout ratio associated with the equity underlier. A ratio of 90% should be expressed at 0.90." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:nonCashRatio ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the cash actual dividend payout ratio associated with the equity underlier. A ratio of 90% should be expressed at 0.90." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:cashRatio ] ;
    sh:targetClass common_domain_model:DividendPayoutRatio .

common_domain_model:DividendReturnTerms a sh:NodeShape ;
    rdfs:comment "A class describing the conditions governing the payment of dividends to the receiver of the equity return, with the exception of the dividend payout ratio, which is defined for each of the underlying components." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Specifies the method according to which special dividends are determined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path common_domain_model:specialDividends ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean element that defines whether the dividend will be reinvested or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:dividendReinvestment ],
        [ sh:description "Specifies how the composition of Dividends is to be determined." ;
            sh:in ( "EquityAmountReceiverElection" "CalculationAgentElection" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:dividendComposition ],
        [ sh:description "2002 ISDA Equity Derivatives Definitions: Dividend Period as either the First Period or the Second Period. | " ;
            sh:in ( "FirstPeriod" "SecondPeriod" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:firstOrSecondPeriod ],
        [ sh:datatype xsd:boolean ;
            sh:description "If present and true, then material non cash dividends are applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path common_domain_model:materialDividend ],
        [ sh:class common_domain_model:DividendCurrency ;
            sh:description "Specifies the currency in which the dividend will be denominated, e.g. the dividend currency, or a specified currency. This class is not specified as such in FpML, which makes use of the CurrencyAndDeterminationMethod.model to specify such terms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:dividendCurrency ],
        [ sh:class common_domain_model:DividendPeriod ;
            sh:description "One to many time bounded dividend payment periods, each with a dividend payment date per period." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:dividendPeriod ],
        [ sh:description "Specifies the party which determines if dividends are extraordinary in relation to normal levels." ;
            sh:in ( "DisruptionEventsDeterminingParty" "ExtraordinaryDividendsParty" "PredeterminedClearingOrganizationParty" "ExerciseNoticeReceiverPartyManual" "ExerciseNoticeReceiverPartyOptionalEarlyTermination" "ExerciseNoticeReceiverPartyCancelableProvision" "ExerciseNoticeReceiverPartyExtendibleProvision" "CalculationAgentIndependent" "CalculationAgentOptionalEarlyTermination" "CalculationAgentMandatoryEarlyTermination" "CalculationAgentFallback" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:extraordinaryDividendsParty ],
        [ sh:datatype xsd:string ;
            sh:description "Performance calculation, in accordance with Part 1 Section 12 of the 2018 ISDA CDM Equity Confirmation for Security Equity Swap, Para 75. 'Equity Performance'. Cumulative performance is used as a notional multiplier factor on both legs of an Equity Swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:performance ],
        [ sh:class common_domain_model:DividendPayoutRatio ;
            sh:description "Specifies the dividend payout ratio associated with each underlier. In FpML 5.10 the payout is positioned at the underlier level, although there is an intent to reconsider this approach and position it at the leg level. This is approach adopted by the CDM." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:dividendPayoutRatio ],
        [ sh:description "Specifies the treatment of Non-Cash Dividends." ;
            sh:in ( "PotentialAdjustmentEvent" "CashEquivalent" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:nonCashDividendTreatment ],
        [ sh:description "Specifies whether the dividend is paid with respect to the Dividend Period." ;
            sh:in ( "RecordAmount" "ExAmount" "PaidAmount" "AsSpecifiedInMasterConfirmation" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:dividendAmountType ],
        [ sh:description "Determination of Gross Cash Dividend per Share." ;
            sh:in ( "RecordAmount" "ExAmount" "PaidAmount" "AsSpecifiedInMasterConfirmation" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:excessDividendAmount ],
        [ sh:description "Defines the date on which the receiver of the equity return is entitled to the dividend." ;
            sh:in ( "ExDate" "RecordDate" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:dividendEntitlement ] ;
    sh:targetClass common_domain_model:DividendReturnTerms .

common_domain_model:DividendTerms a sh:NodeShape ;
    rdfs:comment "Information related to dividends and payments." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "daily fee increments accrue until a threshold is crossed, at which point payment becomes due)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:minimumBillingAmount ],
        [ sh:class common_domain_model:DividendPayoutRatio ;
            sh:description "Specifies the proportion of the value of the dividend on the borrowed shares that the borrower is legally obligated to return to the lender." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:manufacturedIncomeRequirement ],
        [ sh:description "Defines the date on which the receiver of the equity return is entitled to the dividend." ;
            sh:in ( "ExDate" "RecordDate" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:dividendEntitlement ] ;
    sh:targetClass common_domain_model:DividendTerms .

common_domain_model:EconomicTerms a sh:NodeShape ;
    rdfs:comment " This class represents the full set of price-forming features associated with a contractual product: the payout component, the notional/quantity, the effective and termination date and the date adjustment provisions when applying uniformily across the payout components. This class also includes the legal provisions which have valuation implications: cancelable provision, extendible provision, early termination provision and extraordinary events specification." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The payout specifies the future cashflow computation methodology which characterizes a financial product." ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AssetPayout ] [ sh:class common_domain_model:CommodityPayout ] [ sh:class common_domain_model:CreditDefaultPayout ] [ sh:class common_domain_model:FixedPricePayout ] [ sh:class common_domain_model:InterestRatePayout ] [ sh:class common_domain_model:OptionPayout ] [ sh:class common_domain_model:PerformancePayout ] [ sh:class common_domain_model:SettlementPayout ] ) ;
            sh:order 5 ;
            sh:path common_domain_model:payout ],
        [ sh:class common_domain_model:CalculationAgent ;
            sh:description "The ISDA calculation agent responsible for performing duties as defined in the applicable product definitions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:calculationAgent ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The business day adjustment convention when it applies across all the payout components. This specification of the business day convention and financial business centers is used for adjusting any calculation period date if it would otherwise fall on a day that is not a business day in the specified business center." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:dateAdjustments ],
        [ sh:class common_domain_model:TerminationProvision ;
            sh:description "Contains optional provisions pertaining to the termination characteristics of a contract." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:terminationProvision ],
        [ sh:class common_domain_model:DirectOrRelativeTime ;
            sh:description "The time and zone of the last day of the terms of the trade. It can also be specified in relation to another time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:terminationTime ],
        [ sh:class common_domain_model:DirectOrRelativeTime ;
            sh:description "The time and zone of the first day of the terms of the trade. It can also be specified in relation to another time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:effectiveTime ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The first day of the terms of the trade. This day may be subject to adjustment in accordance with a business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The last day of the terms of the trade. This date may be subject to adjustments in accordance with the business day convention. It can also be specified in relation to another scheduled date (e.g. the last payment date)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:terminationDate ],
        [ sh:class common_domain_model:Collateral ;
            sh:description "Represents the collateral obligations of a party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:collateral ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies, when boolean value is True, that additional economic terms exist that have not been included in the product representation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:nonStandardisedTerms ] ;
    sh:targetClass common_domain_model:EconomicTerms .

common_domain_model:EligibleCreditSupport a sh:NodeShape ;
    rdfs:comment "Specifies the collateral posting obligations of the security provider or security providers as specified in the corresponding agreement" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EligibleCollateralElection ;
            sh:description "The specification of the collateral posting obligations for the security provider party(ies)" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:EligibleCreditSupport .

common_domain_model:EquityCorporateEvents a sh:NodeShape ;
    rdfs:comment "A class for defining the merger events and their treatment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Shall occur if a Merger Event occurs and the consideration for the relevant Security consists solely of Other Consideration." ;
            sh:in ( "AlternativeObligation" "CancellationAndPayment" "OptionsExchange" "CalculationAgent" "ModifiedCalculationAgent" "PartialCancellationAndPayment" "Component" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:shareForOther ],
        [ sh:description "Shall occur if a Merger Event occurs and the consideration for the relevant Security consists solely of Combined Consideration." ;
            sh:in ( "AlternativeObligation" "CancellationAndPayment" "OptionsExchange" "CalculationAgent" "ModifiedCalculationAgent" "PartialCancellationAndPayment" "Component" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:shareForCombined ],
        [ sh:description "Shall occur if a Merger Event occurs and the consideration for the relevant Security consists solely of Combined Consideration." ;
            sh:in ( "AlternativeObligation" "CancellationAndPayment" "OptionsExchange" "CalculationAgent" "ModifiedCalculationAgent" "PartialCancellationAndPayment" "Component" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:shareForShare ] ;
    sh:targetClass common_domain_model:EquityCorporateEvents .

common_domain_model:EquityType a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identifies the type of equity." ;
            sh:in ( "Ordinary" "NonConvertiblePreference" "DepositaryReceipt" "ConvertiblePreference" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:equityType ],
        [ sh:in ( "ADR" "GDR" "IDR" "EDR" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:depositaryReceipt ] ;
    sh:targetClass common_domain_model:EquityType .

common_domain_model:EventInstruction a sh:NodeShape ;
    rdfs:comment "Specifies instructions to create a BusinessEvent." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:eventQualifier common_domain_model:after ) ;
    sh:property [ sh:class common_domain_model:TimeZone ;
            sh:description "The time and zone of the date in which the event contractually takes effect." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:effectiveTime ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "The time and zone of the date in which the event is taking place." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:eventTime ],
        [ sh:description "The intent of a corporate action on the position." ;
            sh:in ( "CashDividend" "StockDividend" "StockSplit" "ReverseStockSplit" "SpinOff" "Merger" "Delisting" "StockNameChange" "StockIdentifierChange" "RightsIssue" "Takeover" "StockReclassification" "BonusIssue" "ClassAction" "EarlyRedemption" "Liquidation" "BankruptcyOrInsolvency" "IssuerNationalization" "Relisting" "BespokeEvent" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:corporateActionIntent ],
        [ sh:description "The intent attribute is meant to be specified when the event qualification cannot be programmatically inferred from the event features. As a result it is only associated with those primitives that can give way to such ambiguity, the quantityChange being one of those. An example of such is a reduction in the trade notional, which could be interpreted as either a trade correction (unless a maximum period of time post-event is specified as part of the qualification), a partial termination or a portfolio rebalancing in the case of an equity swap. On the other hand, an event such as the exercise is not expected to have an associated intent as there should not be ambiguity." ;
            sh:in ( "Allocation" "CashFlow" "Clearing" "Compression" "ContractFormation" "ContractTermsAmendment" "CorporateActionAdjustment" "CreditEvent" "Decrease" "EarlyTerminationProvision" "Increase" "IndexTransition" "NotionalReset" "NotionalStep" "Novation" "ObservationRecord" "OptionExercise" "OptionalExtension" "OptionalCancellation" "PortfolioRebalancing" "PrincipalExchange" "Reallocation" "Repurchase" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:intent ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the event contractually takes effect, when different from the event date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:class common_domain_model:IdentifiedList ;
            sh:description "Specifies the package information in case the business event represents several trades executed as a package (hence this attribute is optional). The package information is only instantiated once at the business event level to preserve referential integrity, whereas individual trades make reference to it to identify that they are part of a package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:packageInformation ],
        [ sh:class common_domain_model:Instruction ;
            sh:description "Specifies the instructions to create the Business Event." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:instruction ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date on which the event is taking place. This date is equal to the trade date in the case of a simple execution.  However it can be different from the trade date, for example in the case of a partial termination." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:eventDate ] ;
    sh:targetClass common_domain_model:EventInstruction .

common_domain_model:EventTimestamp a sh:NodeShape ;
    rdfs:comment "A class to represent the various set of timestamps that can be associated with lifecycle events, as a collection of [dateTime, qualifier]." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The timestamp qualifier is specified through an enumeration because the experience of integrating the DTCC and CME data representations suggests that a wide set of timestamps are currently utilized among service providers, while there is not at present an objective set of criteria that could help suggest a defined set of timestamps as part of the CDM. At some future point, one possible baseline could be developed from the review of the set of timestamps specified across regulatory regimes and regulations (incl. regulations such as high frequency trading). Also, the integration with a further set of implementations and the specification of business workflows such as clearing as part of the CDM development should help confirm the implementation approach in this respect." ;
            sh:in ( "clearingDateTime" "clearingConfirmationDateTime" "clearingReceiptDateTime" "clearingSubmissionDateTime" "confirmationDateTime" "eventCreationDateTime" "eventExpirationDateTime" "eventProcessingDateTime" "eventSentDateTime" "eventSubmittedDateTime" "executionDateTime" "transactionCreationDateTime" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:qualification ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The CDM specifies that the zoned date time is to be expressed in accordance with ISO 8601, either as UTC as an offset to UTC." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:dateTime ] ;
    sh:targetClass common_domain_model:EventTimestamp .

common_domain_model:ExtraordinaryEvents a sh:NodeShape ;
    rdfs:comment "Where the underlying is shares, defines market events affecting the issuer of those shares that may require the terms of the transaction to be adjusted." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdditionalDisruptionEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:additionalDisruptionEvents ],
        [ sh:class common_domain_model:Clause ;
            sh:description "Where parties may optionnaly describe any extra bespoke agreements, in regards of the standardized Extraordinary Events." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:additionalBespokeTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, failure to deliver is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:failureToDeliver ],
        [ sh:class common_domain_model:IndexAdjustmentEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:indexAdjustmentEvents ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:compositionOfCombinedConsideration ],
        [ sh:in ( "NegotiatedCloseout" "CancellationAndPayment" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:delisting ],
        [ sh:in ( "NegotiatedCloseout" "CancellationAndPayment" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:nationalizationOrInsolvency ],
        [ sh:class common_domain_model:EquityCorporateEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:tenderOfferEvents ],
        [ sh:class common_domain_model:Representations ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:representations ],
        [ sh:class common_domain_model:EquityCorporateEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:mergerEvents ] ;
    sh:targetClass common_domain_model:ExtraordinaryEvents .

common_domain_model:FallbackReferencePrice a sh:NodeShape ;
    rdfs:comment "The method, prioritised by the order it is listed in this element, to get a replacement rate for the disrupted settlement rate option." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationPostponement ;
            sh:description "Specifies how long to wait to get a quote from a settlement rate option upon a price source disruption." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuationPostponement ],
        [ sh:description "This settlement rate option will be used in its place." ;
