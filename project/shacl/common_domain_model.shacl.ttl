common_domain_model:GeneralSimmElections a sh:NodeShape ;
    rdfs:comment "A class to specify the ISDA SIMM as the Method for all Covered Transactions with respect to all Regimes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SimmCalculationCurrency ;
            sh:description "The SIMM Calculation Currency, as specified for each of the parties to the CSA Initial Margin." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:simmCalculationCurrency ],
        [ sh:class common_domain_model:SimmVersion ;
            sh:description "The qualification of the ISDA SIMM version that is specified for all Covered Transactions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:simmVersion ] ;
    sh:targetClass common_domain_model:GeneralSimmElections .

common_domain_model:Instruction a sh:NodeShape ;
    rdfs:comment "Instruction to a function that will be used to perform a business event" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PrimitiveInstruction ;
            sh:description "Specifies the primitive instructions that will be used to call primitive event functions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:primitiveInstruction ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "Specifies the trade state that will be acted on by the primitive event functions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:before ] ;
    sh:targetClass common_domain_model:Instruction .

common_domain_model:Lineage a sh:NodeShape ;
    rdfs:comment "A class to provide lineage information across lifecycle events through a pointer or set of pointers into the event(s), contract(s) and, possibly, payout components that the event is dependent on or relates to. As an example, if an contractFormation event is corrected, the correction event will have a lineage into the initial event, which takes the form of a globalKey into that initial contract formation event. Two referencing mechanisms are provided as part of the CDM: either the globalKey, which corresponds to the hash value of the CDM class which is referred to, or a reference qualifier which is meant to provide support for the ingestion of xml documents with id/href mechanisms. The CDM recommends the use of the globalKey and provides a default implementation which is accessible in the generated code through org.isda.cdm.globalKey.GlobalKeyHashCalculator. If implementers want to use an alternative hashing mechanism, the API in which they need to plug it is com.rosetta.model.lib.HashFunction." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:WorkflowStep ;
            sh:description "The reference to the instantiation of an Event object, either through a globalKey or an xml-derived id/href mechanism. The definition associated to the Lineage class provides more details with respect to those referencing approaches, their expected usage and available implementation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:eventReference ],
        [ sh:class common_domain_model:PortfolioState ;
            sh:description "The reference to the previous state of a Portfolio, in a chain of Events leading up to a build of that Portfolio as the holding of Product(s) in specific Quantity(ies). As part of the PortfolioState object, a pointer to the previous PortfolioState is provided through a Lineage object, together with pointer(s) to the Event or set of Events leading up to the current (new) state." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:portfolioStateReference ],
        [ sh:class common_domain_model:Trade ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tradeReference ] ;
    sh:targetClass common_domain_model:Lineage .

common_domain_model:LoanParticipation a sh:NodeShape ;
    rdfs:comment "A class to specify loan with a participation agreement whereby the buyer is capable of creating, or procuring the creation of, a contractual right in favour of the seller that provides the seller with recourse to the participation seller for a specified share in any payments due under the relevant loan which are received by the participation seller. ISDA 2003 Term: Direct Loan Participation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "If Direct Loan Participation is specified as a deliverable obligation characteristic, this specifies any requirements for the Qualifying Participation Seller. The requirements may be listed free-form. ISDA 2003 Term: Qualifying Participation Seller." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:qualifyingParticipationSeller ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether either 'Partial Cash Settlement of Assignable Loans', 'Partial Cash Settlement of Consent Required Loans' or 'Partial Cash Settlement of Participations' is applicable. If this element is specified and Assignable Loan is a Deliverable Obligation Characteristic, any Assignable Loan that is deliverable, but where a non-receipt of Consent by the Physical Settlement Date has occurred, the Loan can be cash settled rather than physically delivered. If this element is specified and Consent Required Loan is a Deliverable Obligation Characteristic, any Consent Required Loan that is deliverable, but where a non-receipt of Consent by the Physical Settlement Date has occurred, the Loan can be cash settled rather than physically delivered. If this element is specified and Direct Loan Participation is a Deliverable Obligation Characteristic, any Participation that is deliverable, but where this participation has not been effected (has not come into effect) by the Physical Settlement Date, the participation can be cash settled rather than physically delivered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:partialCashSettlement ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the provision is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:applicable ] ;
    sh:targetClass common_domain_model:LoanParticipation .

common_domain_model:MarginApproach a sh:NodeShape ;
    rdfs:comment "A class for selection of Margin Approach." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the margin approach specific to Initial Margin agreements." ;
            sh:in ( "Distinct" "Allocated" "GreaterOf" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:marginApproach ] ;
    sh:targetClass common_domain_model:MarginApproach .

common_domain_model:MasterAgreementVariableSet a sh:NodeShape ;
    rdfs:comment "Defines a type where additional variables associated to clauses and their variants can be described." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The value for this variable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:value ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the variable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:name ],
        [ sh:class common_domain_model:MasterAgreementVariableSet ;
            sh:description "For some variants a table of variables is required. To support this use case we need to be able to specify variables within variables. Including a variable set here gives us infinite nesting opportunities - realistically we are only ever expecting that a table would need to be defined for any particular clause, so we would expect two levels of nesting as a maximum i.e. variableSet->variableSet->name/value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:variableSet ] ;
    sh:targetClass common_domain_model:MasterAgreementVariableSet .

common_domain_model:MinimumTransferAmountAmendment a sh:NodeShape ;
    rdfs:comment " A class to specify whether Amendment to Minimum Transfer Amount language is applicable or not." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The definition of Minimum Transfer Amount in any Other Regulatory CSA will be amended when applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:class common_domain_model:ElectiveAmountElection ;
            sh:description "The party elective amounts." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyElections ],
        [ sh:class common_domain_model:AmendmentEffectiveDate ;
            sh:description "The effective date of the Amendment to Termination Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:effectiveDate ] ;
    sh:targetClass common_domain_model:MinimumTransferAmountAmendment .

common_domain_model:MoneyBound a sh:NodeShape ;
    rdfs:comment "The money bound is defined as a money amount and whether the bound is inclusive." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "The money amount to be used as the bound, e.g. 1,000 USD." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:money ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the money amount bound is inclusive, e.g. for a lower bound, false would indicate greater than, whereas true would indicate greater than or equal to." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:inclusive ] ;
    sh:targetClass common_domain_model:MoneyBound .

common_domain_model:NotDomesticCurrency a sh:NodeShape ;
    rdfs:comment "A class to specify the ISDA 2003 Term: Not Domestic Currency." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the Not Domestic Currency provision is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ],
        [ sh:datatype xsd:string ;
            sh:description "An explicit specification of the domestic currency. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:currency ] ;
    sh:targetClass common_domain_model:NotDomesticCurrency .

common_domain_model:NumberRange a sh:NodeShape ;
    rdfs:comment "The number range defined as either a lower and upper number bound, or both." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NumberBound ;
            sh:description "The lower bound of a number range, e.g. greater than or equal to 5." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:lowerBound ],
        [ sh:class common_domain_model:NumberBound ;
            sh:description "The upper bound of a number range, e.g. less than 10." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:upperBound ] ;
    sh:targetClass common_domain_model:NumberRange .

common_domain_model:Observation a sh:NodeShape ;
    rdfs:comment "Defines a single, numerical value that was observed in the marketplace. Observations of market data are made independently to business events or trade life-cycle events, so data instances of Observation can be created independently of any other model type, hence it is annotated as a root type. Observations will be broadly reused in many situations, so references to Observation are supported via the 'key' annotation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Price ;
            sh:description "Specifies the observed value as a number." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:observedValue ],
        [ sh:class common_domain_model:ObservationIdentifier ;
            sh:description "Represents the observation was made i.e. how to uniquely identify the observed value among the population of all available market data." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:observationIdentifier ] ;
    sh:targetClass common_domain_model:Observation .

common_domain_model:OffsetCalculation a sh:NodeShape ;
    rdfs:comment "Defines business day shifts for daily componded or averaged rates.  This type is used for lookback and lockout rates. This type is used to represent modular computed rates in interestRatePayouts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The number of business days offset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:offsetDays ] ;
    sh:targetClass common_domain_model:OffsetCalculation .

common_domain_model:OneWayProvisions a sh:NodeShape ;
    rdfs:comment "A class to specify whether One Way Provisions apply." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The determination of whether the One Way Provisions are applicable (true) or not applicable (false)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:description "The Posting Party for the purposes of One Way Provisions. It is specified in the case where the One Way Provision is deemed applicable." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:postingParty ] ;
    sh:targetClass common_domain_model:OneWayProvisions .

common_domain_model:OptionStrike a sh:NodeShape ;
    rdfs:comment "Defines the strike price of an option." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AveragingStrikeFeature ;
            sh:description "Defines an  option strike that is calculated from an average of observed market prices." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:averagingStrikeFeature ],
        [ sh:class common_domain_model:Price ;
            sh:description "Defines the strike of an option in the form of a price that could be a cash price, interestRate, or other types." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:strikePrice ],
        [ sh:class common_domain_model:ReferenceSwapCurve ;
            sh:description "Defines the strike of an option when expressed by reference to a swap curve (Typically the case for a convertible bond option)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:referenceSwapCurve ],
        [ sh:class common_domain_model:FixedRateSpecification ;
            sh:description "Defines the strike of an option in reference to the spread of the underlying swap (typical practice in the case of an option on a credit single name swaps)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:strikeReference ] ;
    sh:targetClass common_domain_model:OptionStrike .

common_domain_model:OtherAgreementTerms a sh:NodeShape ;
    rdfs:comment "A class to specify a related legal agreement. For example, ISDA 2016 Credit Support Annex for Initial Margin, paragraph 13, General Principles, (s): Other CSA and Japanese Law CSA (VM). | ISDA 2016 Credit Support Annex for Variation Margin, paragraph 13, (o): Other CSA." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether some other related agreement is specified (True) or not (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isSpecified ],
        [ sh:datatype xsd:string ;
            sh:description "The specification of this other agreement, when the qualification is True." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:legalDocument ] ;
    sh:targetClass common_domain_model:OtherAgreementTerms .

common_domain_model:Othr a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SchmeNm ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:schmeNm ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:id ],
        [ sh:class common_domain_model:FinInstrmGnlAttrbts ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:finInstrmGnlAttrbts ],
        [ sh:class common_domain_model:DerivInstrmAttrbts ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:derivInstrmAttrbts ] ;
    sh:targetClass common_domain_model:Othr .

common_domain_model:PCDeliverableObligationCharac a sh:NodeShape ;
    rdfs:comment "A class to specify the Partial Cash Deliverable Obligation Characteristic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:qualifyingParticipationSeller ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the provision is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether either 'Partial Cash Settlement of Assignable Loans', 'Partial Cash Settlement of Consent Required Loans' or 'Partial Cash Settlement of Participations' is applicable. If this element is specified and Assignable Loan is a Deliverable Obligation Characteristic, any Assignable Loan that is deliverable, but where a non-receipt of Consent by the Physical Settlement Date has occurred, the Loan can be cash settled rather than physically delivered. If this element is specified and Consent Required Loan is a Deliverable Obligation Characteristic, any Consent Required Loan that is deliverable, but where a non-receipt of Consent by the Physical Settlement Date has occurred, the Loan can be cash settled rather than physically delivered. If this element is specified and Direct Loan Participation is a Deliverable Obligation Characteristic, any Participation that is deliverable, but where this participation has not been effected (has not come into effect) by the Physical Settlement Date, the participation can be cash settled rather than physically delivered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:partialCashSettlement ] ;
    sh:targetClass common_domain_model:PCDeliverableObligationCharac .

common_domain_model:ParametricDates a sh:NodeShape ;
    rdfs:comment "Defines rules for the dates on which the price will be determined." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Denotes the enumerated values to specify the day type classification used in counting the number of days between two dates." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:dayType ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The enumerated values to specify the business centers." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:businessCenters ],
        [ sh:datatype xsd:decimal ;
            sh:description "Defines the occurrence of the dayOfWeek within the pricing period on which pricing will take place, e.g. the 3rd Friday within each Calculation Period. If omitted, every dayOfWeek will be a pricing day." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:dayFrequency ],
        [ sh:description "Indicates the days of the week on which the price will be determined." ;
            sh:in ( "MON" "TUE" "WED" "THU" "FRI" "SAT" "SUN" ) ;
            sh:order 2 ;
            sh:path common_domain_model:dayOfWeek ],
        [ sh:description "Denotes the method by which the pricing days are distributed across the pricing period." ;
            sh:in ( "All" "First" "Last" "Penultimate" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:dayDistribution ],
        [ sh:class common_domain_model:Lag ;
            sh:description "The pricing period per calculation period if the pricing days do not wholly fall within the respective calculation period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:lag ] ;
    sh:targetClass common_domain_model:ParametricDates .

common_domain_model:PeriodBound a sh:NodeShape ;
    rdfs:comment "Indicator to specify if the period bound is defined as a period and whether the bound is inclusive." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the period bound is inclusive, e.g. for a lower bound, false would indicate greater than, whereas true would indicate greater than or equal to." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:inclusive ],
        [ sh:class common_domain_model:Period ;
            sh:description "Specifies the period is to be used as the bound, e.g. 5Y." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:period ] ;
    sh:targetClass common_domain_model:PeriodBound .

common_domain_model:PeriodicDates a sh:NodeShape ;
    rdfs:comment "A class for specifying a calculation period schedule." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The specification of the business day convention and financial business centers used for adjusting any calculation period date if it would otherwise fall on a day that is not a business day in the specified business center." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:periodDatesAdjustments ],
        [ sh:description "Denotes the enumerated values to specify the day type classification used in counting the number of days between two dates." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:dayType ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The start date of the calculation period. FpML specifies that for interest rate swaps this date must only be specified if it is not equal to the effective date. It is always specified in the case of equity swaps and credit default swaps with periodic payments. This date may be subject to adjustment in accordance with a business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:startDate ],
        [ sh:class common_domain_model:CalculationPeriodFrequency ;
            sh:description "The frequency at which calculation period end dates occur with the regular part of the calculation period schedule and their roll date convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:periodFrequency ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The end date of the calculation period. FpML specifies that for interest rate swaps this date must only be specified if it is not equal to the termination date. It is always specified in the case of equity swaps with periodic payments. This date may be subject to adjustment in accordance with a business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:endDate ] ;
    sh:targetClass common_domain_model:PeriodicDates .

common_domain_model:PhysicalSettlementTerms a sh:NodeShape ;
    rdfs:comment "Specifies Physical Settlement Terms characteristics for the settlement of a Credit Default Swap or Option." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the clearing organization (CCP, DCO) to which the trade should be cleared." ;
            sh:in ( "DisruptionEventsDeterminingParty" "ExtraordinaryDividendsParty" "PredeterminedClearingOrganizationParty" "ExerciseNoticeReceiverPartyManual" "ExerciseNoticeReceiverPartyOptionalEarlyTermination" "ExerciseNoticeReceiverPartyCancelableProvision" "ExerciseNoticeReceiverPartyExtendibleProvision" "CalculationAgentIndependent" "CalculationAgentOptionalEarlyTermination" "CalculationAgentMandatoryEarlyTermination" "CalculationAgentFallback" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:predeterminedClearingOrganizationParty ],
        [ sh:datatype xsd:boolean ;
            sh:description "If this element is specified and set to 'true', indicates that physical settlement must take place through the use of an escrow agent. (For Canadian counterparties this is always 'Not Applicable'. ISDA 2003 Term: Escrow." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:escrow ],
        [ sh:class common_domain_model:PhysicalSettlementPeriod ;
            sh:description "The number of business days used in the determination of the physical settlement date. The physical settlement date is this number of business days after all applicable conditions to settlement are satisfied. If a number of business days is not specified fallback provisions apply for determining the number of business days. If Section 8.5/8.6 of the 1999/2003 ISDA Definitions are to apply the businessDaysNotSpecified element should be included. If a specified number of business days are to apply these should be specified in the businessDays element. If Section 8.5/8.6 of the 1999/2003 ISDA Definitions are to apply but capped at a maximum number of business days then the maximum number should be specified in the maximumBusinessDays element. ISDA 2003 Term: Physical Settlement Period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:physicalSettlementPeriod ],
        [ sh:datatype xsd:boolean ;
            sh:description "If this element is specified and set to 'true', for a transaction documented under the 2003 ISDA Credit Derivatives Definitions, has the effect of incorporating the language set forth below into the confirmation. The section references are to the 2003 ISDA Credit Derivatives Definitions. Notwithstanding Section 1.7 or any provisions of Sections 9.9 or 9.10 to the contrary, but without prejudice to Section 9.3 and (where applicable) Sections 9.4, 9.5 and 9.6, if the Termination Date has not occurred on or prior to the date that is 60 Business Days following the Physical Settlement Date, such 60th Business Day shall be deemed to be the Termination Date with respect to this Transaction except in relation to any portion of the Transaction (an 'Affected Portion') in respect of which: (1) a valid notice of Buy-in Price has been delivered that is effective fewer than three Business Days prior to such 60th Business Day, in which case the Termination Date for that Affected Portion shall be the third Business Day following the date on which such notice is effective; or (2) Buyer has purchased but not Delivered Deliverable Obligations validly specified by Seller pursuant to Section 9.10(b), in which case the Termination Date for that Affected Portion shall be the tenth Business Day following the date on which Seller validly specified such Deliverable Obligations to Buyer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:sixtyBusinessDaySettlementCap ],
        [ sh:class common_domain_model:DeliverableObligations ;
            sh:description "This element contains all the ISDA terms relevant to defining the deliverable obligations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:deliverableObligations ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether the swap resulting from physical settlement of the swaption transaction will clear through a clearing house. The meaning of Cleared Physical Settlement is defined in the 2006 ISDA Definitions, Section 15.2 (published in Supplement number 28)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:clearedPhysicalSettlement ] ;
    sh:targetClass common_domain_model:PhysicalSettlementTerms .

common_domain_model:PostingObligations a sh:NodeShape ;
    rdfs:comment "A class to specify the collateral posting obligations of the security provider or security providers as specified in the corresponding agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The security provider party(ies) to which the posting obligations apply to, which can be either one of the parties to the legal agreement, or both of those." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:securityProvider ],
        [ sh:class common_domain_model:PostingObligationsElection ;
            sh:description "The specification of the collateral posting obligations for the security provider party(ies)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:PostingObligations .

common_domain_model:Pric a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:bsisPts ],
        [ sh:class common_domain_model:Pric ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:pric ] ;
    sh:targetClass common_domain_model:Pric .

common_domain_model:PriceComposite a sh:NodeShape ;
    rdfs:comment "Defines the inputs required to calculate a price as a simple composite of 2 other values. The inputs consist of 2 numbers and a simple arithmetic operator. This generic data type applies to a variety of use cases where a price is obtained by simple composition, e.g. dirty = clean + accrued (Bond), forward rate = spot rate + forward point (FX) etc." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The 1st value in the arithmetic operation, which may be non-commutative in some cases: Subtract, Divide). This 1st operand is called 'baseValue' as it refers to the price anchor in the arithmetic operation: e.g. the clean price (Bond) or the spot rate (FX)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:baseValue ],
        [ sh:description "Specifies the arithmetic operator via an enumeration." ;
            sh:in ( "Add" "Subtract" "Multiply" "Divide" "Max" "Min" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:arithmeticOperator ],
        [ sh:description "Optionally qualifies the type of operand: e.g. accrued or forward point." ;
            sh:in ( "AccruedInterest" "Commission" "ForwardPoint" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:operandType ],
        [ sh:datatype xsd:decimal ;
            sh:description "The 2nd value in the arithmetic operation, which may be non-commutative in some cases: Subtract, Divide). The 2nd operand is called 'operand' to distinguish it from the 1st one which is the price anchor." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:operand ] ;
    sh:targetClass common_domain_model:PriceComposite .

common_domain_model:PrincipalPayment a sh:NodeShape ;
    rdfs:comment "Any kind of principal payments when the amount is known and thus fixed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableDate ;
            sh:description "The date where the PrincipalPayment shall be settled." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:principalPaymentDate ],
        [ sh:class common_domain_model:Money ;
            sh:description "When known at the time the transaction is made, the cash amount to be paid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:principalAmount ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value representing the discount factor used to calculate the present value of the principal payment amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:discountFactor ],
        [ sh:class common_domain_model:Money ;
            sh:description "The amount representing the present value of the principal payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:presentValuePrincipalAmount ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Specifies the parties responsible for making and receiving payments defined by this structure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:payerReceiver ] ;
    sh:targetClass common_domain_model:PrincipalPayment .

common_domain_model:ProductTaxonomy a sh:NodeShape ;
    rdfs:comment "Specifies the product taxonomy, which is composed of a taxonomy value and a taxonomy source." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TaxonomyValue ;
            sh:description "The value according to that taxonomy. Optional as it may not be possible to classify the object in that taxonomy." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:value ],
        [ sh:description "Classifies the most important risk class of the trade." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:primaryAssetClass ],
        [ sh:description "The source of the taxonomy that defines the rules for classifying the object. The taxonomy source is taken from a enumerated list of taxonomy names. Optional as the taxonomy source may not be provided." ;
            sh:in ( "CFI" "ISDA" "ICAD" "EMIR" "EU_EMIR_EligibleCollateralAssetClass" "UK_EMIR_EligibleCollateralAssetClass" "CFTC" "US_CFTC_PR_EligibleCollateralAssetClass" "MAS" "CSA" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:source ],
        [ sh:description " Classifies additional risk classes of the trade, if any." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:order 1 ;
            sh:path common_domain_model:secondaryAssetClass ],
        [ sh:datatype xsd:string ;
            sh:description "Derived from the product payout features using a CDM product qualification function that determines the product type based on the product payout features." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:productQualifier ] ;
    sh:targetClass common_domain_model:ProductTaxonomy .

common_domain_model:ProtectionTerms a sh:NodeShape ;
    rdfs:comment "A class to specify the terms for calculating a payout to protect the buyer of the swap in the case of a qualified credit event. These terms include the applicable credit events, the reference obligation, and in the case of a CDS on mortgage-backed securities, the floatingAmountEvents." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FloatingAmountEvents ;
            sh:description "This element contains the ISDA terms relating to the floating rate payment events and the implied additional fixed payments, applicable to the credit derivatives transactions on mortgage-backed securities with pay-as-you-go or physical settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:floatingAmountEvents ],
        [ sh:class common_domain_model:CreditEvents ;
            sh:description "Specifies the applicable Credit Events that would trigger a settlement, as specified in the related Confirmation and defined in the ISDA 2014 Credit Definition article IV section 4.1." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:creditEvents ],
        [ sh:class common_domain_model:Obligations ;
            sh:description "The underlying obligations of the reference entity on which you are buying or selling protection. The credit events Failure to Pay, Obligation Acceleration, Obligation Default, Restructuring, Repudiation/Moratorium are defined with respect to these obligations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:obligations ] ;
    sh:targetClass common_domain_model:ProtectionTerms .

common_domain_model:Prsn a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Othr ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:othr ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:ctryOfBrnch ] ;
    sh:targetClass common_domain_model:Prsn .

common_domain_model:RateObservation a sh:NodeShape ;
    rdfs:comment "A class defining parameters associated with an individual observation or fixing. This class forms part of the cashflow representation of a stream." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The adjusted fixing date, i.e. the actual date the rate is observed. The date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedFixingDate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value representing the forecast rate after applying rate treatment rules. A value of 1% should be represented as 0.01." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:treatedForecastRate ],
        [ sh:class common_domain_model:RateObservation ;
            sh:description "A pointer style reference to a floating rate component defined as part of a stub calculation period amount component. It is only required when it is necessary to distinguish two rate observations for the same fixing date which could occur when linear interpolation of two different rates occurs for a stub calculation period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:rateReference ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of days weighting to be associated with the rate observation, i.e. the number of days such rate is in effect. This is applicable in the case of a weighted average method of calculation where more than one reset date is established for a single calculation period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:observationWeight ],
        [ sh:datatype xsd:decimal ;
            sh:description "The actual observed rate before any required rate treatment is applied, e.g. before converting a rate quoted on a discount basis to an equivalent yield. An observed rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:observedRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The observed rate after any required rate treatment is applied. A treated rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:treatedRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value representing the forecast rate used to calculate the forecast future value of the accrual period.A value of 1% should be represented as 0.01." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:forecastRate ],
        [ sh:datatype xsd:date ;
            sh:description "The reset date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:resetDate ] ;
    sh:targetClass common_domain_model:RateObservation .

common_domain_model:ReferenceObligation a sh:NodeShape ;
    rdfs:comment "A class to specify the reference obligation that is associated with a credit derivative instrument." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "The entity primarily responsible for repaying debt to a creditor as a result of borrowing or issuing bonds. ISDA 2003 Term: Primary Obligor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:primaryObligor ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The party that guarantees by way of a contractual arrangement to pay the debts of an obligor if the obligor is unable to make the required payments itself. ISDA 2003 Term: Guarantor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:guarantor ],
        [ sh:datatype xsd:string ;
            sh:description "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the guarantor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:guarantorReference ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the primary obligor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:primaryObligorReference ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates if the reference obligation is a Standard Reference Obligation. ISDA 2014 Term: Standard Reference Obligation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:standardReferenceObligation ],
        [ sh:class common_domain_model:Security ;
            sh:description "Identifies the underlying asset when it is a security, such as a bond or convertible bond. The security data type requires one or more productIdentifiers, specificaiton of the security type (e.g. debt), and includes optional attributes to specify a debt class, such as asset-backed, as well as seniority." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:security ],
        [ sh:class common_domain_model:Loan ;
            sh:description "Identifies the underlying asset when it is a loan." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:loan ] ;
    sh:targetClass common_domain_model:ReferenceObligation .

common_domain_model:Regime a sh:NodeShape ;
    rdfs:comment "A class to specify one or more regimes that may be specified as relevant to a legal agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ApplicableRegime ;
            sh:description "A class to specify the regime(s) that parties to a legal agreement, such as the ISDA 2016 and 2018 CSA for Initial Margin, might agree to apply to one or both parties when acting as collateral taker, and specific terms associated with that application." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:applicableRegime ],
        [ sh:datatype xsd:decimal ;
            sh:description "The specification of the number of days after effective delivery of notice that Mandatory method fallback applies. Specification is only required when one or more Regimes have Fall Back to Mandatory Method elected as a SIMM exception." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:fallbackToMandatoryMethodDays ] ;
    sh:targetClass common_domain_model:Regime .

common_domain_model:RelativeDates a sh:NodeShape ;
    rdfs:comment "A class describing a set of dates defined as relative to another set of dates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business center(s), specified either explicitly or by reference to those specified somewhere else in the instance document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:businessCenters ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "A pointer style reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:businessCentersReference ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the anchor as an href attribute. The href attribute value is a pointer style reference to the element or component elsewhere in the document where the anchor date is defined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:dateRelativeTo ],
        [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of periods in the referenced date schedule that are between each date in the relative date schedule. Thus a skip of 2 would mean that dates are relative to every second date in the referenced schedule. If present this should have a value greater than 1." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:periodSkip ],
        [ sh:description "In the case of an offset specified as a number of days, this element defines whether consideration is given as to whether a day is a good business day or not. If a day type of business days is specified then non-business days are ignored when calculating the offset. The financial business centers to use for determination of business days are implied by the context in which this element is used. This element must only be included when the offset is specified as a number of days. If the offset is zero days then the dayType element should not be included." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:dayType ],
        [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:period ],
        [ sh:description "The convention for adjusting a date if it would otherwise fall on a day that is not a business day, as specified by an ISDA convention (e.g. Following, Precedent)." ;
            sh:in ( "FOLLOWING" "FRN" "MODFOLLOWING" "PRECEDING" "MODPRECEDING" "NEAREST" "NONE" "NotApplicable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:businessDayConvention ],
        [ sh:datatype xsd:date ;
            sh:description "The date once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:adjustedDate ],
        [ sh:class common_domain_model:DateRange ;
            sh:description "The first and last dates of a schedule. This can be used to restrict the range of values in a reference series of dates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:scheduleBounds ] ;
    sh:targetClass common_domain_model:RelativeDates .

common_domain_model:Reset a sh:NodeShape ;
    rdfs:comment "Defines the reset value or fixing value produced in cashflow calculations, during the life-cycle of a financial instrument. The reset process defined in Create_Reset function joins product definition details with observations to compute the reset value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AveragingCalculation ;
            sh:description "Identifies the aggregation method to use in the case where multiple observations are used to compute the reset value and the method is not defined in a payout." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:averagingMethodology ],
        [ sh:class common_domain_model:Price ;
            sh:description "Specifies the reset or fixing value. The fixing value could be a cash price, interest rate, or other value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:resetValue ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the 'Rate Record Day' for a Fallback rate.  Fallback rate fixing processes typically set the fixing rate in arrears, i.e., the Fallback Rate corresponding to a Rate Record Date is set at the end of the interest accural period.  When this applies, Reset->resetDate occurs at the end of the interest period, and the Reset->rateRecordDate occurs near the start of the interest period.  The Reset->rateRecordDate and Reset->observations->observationIdentifier->observationDate will differ if a Fallback rate is unavailable on the Rate Record Date, and the latest previous available rate is used as the observation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:rateRecordDate ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date on which the reset occurred." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:resetDate ],
        [ sh:class common_domain_model:Observation ;
            sh:description "Represents an audit of the observations used to produce the reset value. If multiple observations were necessary to produce the reset value, the aggregation method should be defined on the payout." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:observations ] ;
    sh:targetClass common_domain_model:Reset .

common_domain_model:ReturnAmount a sh:NodeShape ;
    rdfs:comment "A class to specify the application of Interest Amount with respect the Return Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Default language is included when True, and excluded when False." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:includesDefaultLanguage ],
        [ sh:datatype xsd:string ;
            sh:description "Custom election that might be specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customElection ] ;
    sh:targetClass common_domain_model:ReturnAmount .

common_domain_model:RightsEvents a sh:NodeShape ;
    rdfs:comment "A class to specify the rights of Security Taker and/or Security Provider when an Early Termination or Access Condition event has occurred." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ControlAgreementNecEvent ;
            sh:description "The bespoke provisions that might be specified by the parties to the agreement applicable to a Notice of Exclusive Control Event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:controlAgreementNecEvent ],
        [ sh:datatype xsd:boolean ;
            sh:description "The specification of whether Delivery In Lieu language is applicable to the agreement (true) or not (false)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:deliveryInLieuRight ],
        [ sh:class common_domain_model:AdditionalRightsEvent ;
            sh:description "The Additional Rights Event election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:additionalRightsEvent ],
        [ sh:class common_domain_model:SecurityProviderRightsEvent ;
            sh:description "The bespoke provisions that might be specified by the parties to the agreement applicable to a Security Provider Rights Event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:securityProviderRightsEvent ],
        [ sh:class common_domain_model:SecuredPartyRightsEvent ;
            sh:description "The bespoke provisions that might be specified by the parties to the agreement applicable to a Security Taker Rights Event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:securityTakerRightsEvent ] ;
    sh:targetClass common_domain_model:RightsEvents .

common_domain_model:Schedule a sh:NodeShape ;
    rdfs:comment "A class defining a schedule of rates or amounts in terms of an initial value and then a series of step date and value pairs. On each step date the rate or amount changes to the new step value. The series of step date and value pairs are optional. If not specified, this implies that the initial value remains unchanged over time." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:currency ) ;
    sh:property [ sh:class common_domain_model:DatedValue ;
            sh:description "The schedule of step date and value pairs. On each step date the associated step value becomes effective. A list of steps may be ordered in the document by ascending step date. An FpML document containing an unordered list of steps is still regarded as a conformant document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:datedValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "The initial rate or amount, as the case may be. An initial rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:Schedule .

common_domain_model:SecurityInterestForObligations a sh:NodeShape ;
    rdfs:comment "Security Interest for Obligations clause applicable to 1994 NY CSA, 1995 English Law CSA, 1995 English Law Credit Support Deed, 2016 English Law VM CSA and 2016 New York Law VM CSA." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "A description of any additional obligations secured by the credit support arrangements." ;
            sh:in ( "NotApplicable" "AllObligationsOfPartyA" "AllObligationsOfPartyB" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:obligations ],
        [ sh:datatype xsd:string ;
            sh:description "Exception value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:other ],
        [ sh:description "The elective party to which the Security Interest for Obligations is applicable." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:description "The party to whom obligations under the Master Agreement are owed and secured by the credit support arrangements." ;
            sh:in ( "PartyA" "PartyAOrAffiliate" "PartyB" "PartyBOrAffiliate" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:obligee ] ;
    sh:targetClass common_domain_model:SecurityInterestForObligations .

common_domain_model:SensitivityMethodologies a sh:NodeShape ;
    rdfs:comment "A class to specificy methodologies to compute sensitivities specific to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SensitivityMethodologiesPartyElection ;
            sh:description "Party specific elections for Sensitivity Methodology for Equity and Commodities." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:SensitivityMethodologies .

common_domain_model:SettlementDate a sh:NodeShape ;
    rdfs:comment "A data defining the settlement date(s) for cash or physical settlement as either a set of explicit dates, together with applicable adjustments, or as a date relative to some other (anchor) date, or as any date in a range of contiguous business days. This data type provides a level of abstraction on top of the different legacy methods used to specify a settlement / payment date, which vary across product types, asset classes and delivery types." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessDateRange ;
            sh:description "A range of contiguous business days. This attribute is meant to be merged with the 'settlementDate' at some future point once we refactor 'Date' to use a single complex type across the model. This attributes was formerly part of 'CashSettlementPaymentDate', as included into 'OptionCashSettlement' (which is now merged into a unique 'CashSettlementTerms' data type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:businessDateRange ],
        [ sh:datatype xsd:boolean ;
            sh:description "Applicable to CDS on MBS to specify whether payment delays are applicable to the fixed Amount. RMBS typically have a payment delay of 5 days between the coupon date of the reference obligation and the payment date of the synthetic swap. CMBS do not, on the other hand, with both payment dates being on the 25th of each month." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:paymentDelay ],
        [ sh:datatype xsd:date ;
            sh:description "The settlement date for a forward settling product. For Foreign Exchange contracts, this represents a common settlement date between both currency legs. To specify different settlement dates for each currency leg, see the ForeignExchange class. This attribute was formerly part of 'SettlementTerms', which is now being harmonised to include a common 'SettlementDate', as inherited from 'SettlementBase'." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:valueDate ],
        [ sh:class common_domain_model:AdjustableOrAdjustedOrRelativeDate ;
            sh:description "A single settlement date subject to adjustment or specified as relative to another date (e.g. the trade date). This attribute was formerly part of 'SettlementTerms', which is now being harmonised to include a common 'SettlementDate', as inherited from 'SettlementBase'." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:adjustableOrRelativeDate ],
        [ sh:class common_domain_model:AdjustableDates ;
            sh:description "A series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date. This attributes was formerly part of 'CashSettlementPaymentDate' as included into 'OptionCashSettlement' (which is now merged into a unique 'CashSettlementTerms' data type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:adjustableDates ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of business days used in the determination of the cash settlement payment date. If a cash settlement amount is specified, the cash settlement payment date will be this number of business days following the calculation of the final price. If a cash settlement amount is not specified, the cash settlement payment date will be this number of business days after all conditions to settlement are satisfied. ISDA 2003 Term: Cash Settlement Date. This attribute was formerly part of 'CashSettlementTerms' as used for credit event settlement, which now includes a common 'SettlementDate' attribute." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:cashSettlementBusinessDays ] ;
    sh:targetClass common_domain_model:SettlementDate .

common_domain_model:SettlementProvision a sh:NodeShape ;
    rdfs:comment "Defines parameters that regulate a settlement, for instance whether this settlement should be netted with other ones or broken-down into smaller amounts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ShapingProvision ;
            sh:description "Defines the parameters that are necessary to 'shape' a settlement, i.e. break it down into smaller amounts." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:shapingProvisions ] ;
    sh:targetClass common_domain_model:SettlementProvision .

common_domain_model:Sngl a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Indx ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:indx ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isin ] ;
    sh:targetClass common_domain_model:Sngl .

common_domain_model:SpecifiedCurrency a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The currency in which the specified currency is denominated. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the specified currency provision is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ] ;
    sh:targetClass common_domain_model:SpecifiedCurrency .

common_domain_model:State a sh:NodeShape ;
    rdfs:comment "Defines the state of a trade at a point in the Trade's life cycle. Trades have many state dimensions, all of which are represented here. For example, states useful for position keeping are represented alongside those needed for regulatory reporting." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identifies the state of the position, to distinguish if just executed, formed, already settled, closed, etc." ;
            sh:in ( "Executed" "Formed" "Settled" "Cancelled" "Closed" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:positionState ],
        [ sh:class common_domain_model:ClosedState ;
            sh:description "Represents the qualification of what led to the trade's closure alongside the dates on which this closure took effect." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:closedState ] ;
    sh:targetClass common_domain_model:State .

common_domain_model:Strike a sh:NodeShape ;
    rdfs:comment "A class describing a single cap or floor rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The party that has sold." ;
            sh:in ( "Payer" "Receiver" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:seller ],
        [ sh:description "The buyer of the option." ;
            sh:in ( "Payer" "Receiver" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:buyer ],
        [ sh:datatype xsd:decimal ;
            sh:description "The rate for a cap or floor." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:strikeRate ] ;
    sh:targetClass common_domain_model:Strike .

common_domain_model:SubstitutedRegime a sh:NodeShape ;
    rdfs:comment "A class to specify each party's election with respect to the Substituted Regimes that will be applicable..." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SubstitutedRegimeTerms ;
            sh:description "Specifies the applicability of the Substituted Regime as denoted in the Substituted Regime Table as part of certain legal agreements, such as the ISDA 2016 and 2018 CSA for Initial Margin." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:regimeTerms ],
        [ sh:description "The applicable regulatory regime, as specified through an enumeration." ;
            sh:in ( "AustraliaMarginRules" "CanadaMarginRules" "CFTC_MarginRules" "EMIR_MarginRules" "HongKongMarginRules" "JapanMarginRules" "US_PrudentialMarginRules" "SEC_MarginRules" "SingaporeMarginRules" "SwitzerlandMarginRules" "BrazilMarginRules" "UnitedKingdomMarginRules" "SouthAfricaMarginRules" "SouthKoreaMarginRules" "HongKongSFCMarginRules" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:regime ],
        [ sh:datatype xsd:string ;
            sh:description "The additional regulatory regime as specified by the parties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalRegime ] ;
    sh:targetClass common_domain_model:SubstitutedRegime .

common_domain_model:TaxonomyValue a sh:NodeShape ;
    rdfs:comment "Defines a taxonomy value as either a simple string or a more granular expression with class names and values for each class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TaxonomyClassification ;
            sh:description "Specifies the taxonomy value as a set of class names and values for each class." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:classification ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the taxonomy value as a simple string, which may be associated to an external scheme." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:name ] ;
    sh:targetClass common_domain_model:TaxonomyValue .

common_domain_model:TerminationCurrencyAmendment a sh:NodeShape ;
    rdfs:comment "A class to specify the Amendment to Termination Currency elections by the parties to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether the Amendment to Termination Currency is deemed applicable by the parties (True) or not (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:class common_domain_model:AmendmentEffectiveDate ;
            sh:description "The effective date of the Amendment to Termination Currency. This date can be specified as either an actual date, a specific date (e.g. the annex date) or as a custom provision." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:class common_domain_model:TerminationCurrencyElection ;
            sh:description "The parties' Amendment Currency election." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:TerminationCurrencyAmendment .

common_domain_model:ThresholdMinimumTransferAmountFixedAmount a sh:NodeShape ;
    rdfs:comment "Defines the Threshold or the Minimum Transfer Amount (MTA) as a fixed amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "Specifies the monetary value of the Threshold or the Minimum Transfer Amount (MTA) applicable to collateral transfer obligations." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:amount ],
        [ sh:description "Specifies the relevant trigger for the Threshold or Minimum Transfer Amount to fall to zero." ;
            sh:in ( "EventOfDefault" "TerminationEvent" "TerminationEventAllAffectedTransactions" "PotentialEventOfDefault" "AdditionalTerminationEvent" "Other" ) ;
            sh:order 2 ;
            sh:path common_domain_model:event ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether a trigger applies for the Threshold or Minimum Transfer Amount to fall to zero. If 'True' then such a trigger exists." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:zeroEvent ] ;
    sh:targetClass common_domain_model:ThresholdMinimumTransferAmountFixedAmount .

common_domain_model:TimeRounding a sh:NodeShape ;
    rdfs:comment "Specifies how a calculated time should be rounded, including both the direction of rounding and the unit to which the time is rounded. Rounding is applied after all offsets have been calculated." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The time unit to which the value should be rounded (e.g., minute, hour, day)." ;
            sh:in ( "Second" "Minute" "Hour" "Day" "Week" "Month" "Year" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:roundToUnit ],
        [ sh:description "The direction in which rounding is performed (e.g., up, down, or to the nearest value)." ;
            sh:in ( "Up" "Down" "Nearest" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:roundingDirection ] ;
    sh:targetClass common_domain_model:TimeRounding .

common_domain_model:TradeLot a sh:NodeShape ;
    rdfs:comment "Specifies the price and quantity of a trade lot, where the same product could be traded multiple times with the same counterparty but in different lots (at a different date, in a different quantity and at a different price). One trade lot combined with a product definition specifies the entire economics of a trade. The lifecycle mechanics of each such trade lot (e.g. cashflow payments) is independent of the other lots." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Identifier ;
            sh:description "Specifies one or more identifiers for the lot, if any." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:lotIdentifier ],
        [ sh:class common_domain_model:PriceQuantity ;
            sh:description "Specifies the settlement characteristics of a trade lot: price, quantity, observable (optionally) and the settlement terms. This attribute has a multiple cardinality to allow to specify the price, quantity and observable of different legs in a single, composite product (e.g. a Swap)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:priceQuantity ] ;
    sh:targetClass common_domain_model:TradeLot .

common_domain_model:Tranche a sh:NodeShape ;
    rdfs:comment "The class to represent a CDS Tranche." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Lower bound percentage of the loss that the Tranche can endure, expressed as a decimal. An attachment point of 5% would be represented as 0.05. The difference between Attachment and Exhaustion points is called the width of the Tranche." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:attachmentPoint ],
        [ sh:datatype xsd:decimal ;
            sh:description "Upper bound percentage of the loss that the Tranche can endure, expressed as a decimal. An exhaustion point of 5% would be represented as 0.05. The difference between Attachment and Exhaustion points is call the width of the Tranche." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:exhaustionPoint ],
        [ sh:datatype xsd:boolean ;
            sh:description "Outstanding Swap Notional Amount is defined at any time on any day, as the greater of: (a) Zero; If Incurred Recovery Amount Applicable: (b) The Original Swap Notional Amount minus the sum of all Incurred Loss Amounts and all Incurred Recovery Amounts (if any) determined under this Confirmation at or prior to such time.Incurred Recovery Amount not populated: (b) The Original Swap Notional Amount minus the sum of all Incurred Loss Amounts determined under this Confirmation at or prior to such time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:incurredRecoveryApplicable ] ;
    sh:targetClass common_domain_model:Tranche .

common_domain_model:TransferState a sh:NodeShape ;
    rdfs:comment "Defines the fundamental financial information associated with a Transfer event. Each TransferState specifies where a Transfer is in its life-cycle. TransferState is a root type and as such, can be created independently to any other CDM data type, but can also be used as part of the CDM Event Model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents the State of the Transfer through its life-cycle." ;
            sh:in ( "Disputed" "Instructed" "Pending" "Settled" "Netted" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:transferStatus ],
        [ sh:class common_domain_model:Transfer ;
            sh:description "Represents the Transfer that has been effected by a business or life-cycle event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:transfer ] ;
    sh:targetClass common_domain_model:TransferState .

common_domain_model:TriggerEvent a sh:NodeShape ;
    rdfs:comment "Observation point for trigger." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:DateList ;
            sh:description "The trigger Dates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:triggerDates ],
        [ sh:class common_domain_model:Trigger ;
            sh:description "The trigger level" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:trigger ],
        [ sh:class common_domain_model:FeaturePayment ;
            sh:description "The feature payment, i.e. the payment made following trigger occurrence." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:featurePayment ],
        [ sh:class common_domain_model:AveragingSchedule ;
            sh:description "A derivative schedule." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:schedule ] ;
    sh:targetClass common_domain_model:TriggerEvent .

common_domain_model:Tx a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Pric ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:pric ],
        [ sh:class common_domain_model:Qty ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:qty ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:tradgCpcty ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:tradVn ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:ctryOfBrnch ],
        [ sh:class common_domain_model:New ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:newTx ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:tradDt ] ;
    sh:targetClass common_domain_model:Tx .

common_domain_model:ValuationAgent a sh:NodeShape ;
    rdfs:comment "Details of the party valuating the collateral to be delivered or returned." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies how the Valuation Agent is determined." ;
            sh:in ( "SoleValuationAgent" "SwitchUponDefault" "SwitchUponFailureToPerform" "FixedPartyForDisputes" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:valuationAgent ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:description "Specification of which party calculating the value of collateral to be delivered or returned." ;
            sh:in ( "Party1" "Party2" "PartyMakingDemand" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:ValuationAgent .

common_domain_model:ValuationDates a sh:NodeShape ;
    rdfs:comment "Defines how and when a performance type option or performance type swap is to be valued, including initial, interim and final valuation dates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PerformanceValuationDates ;
            sh:description "Specifies the final valuation dates of the underlyer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:finalValuationDate ],
        [ sh:class common_domain_model:PerformanceValuationDates ;
            sh:description "Specifies the interim valuation dates of the underlyer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:interimValuationDate ],
        [ sh:class common_domain_model:PerformanceValuationDates ;
            sh:description "Specifies the initial valuation dates of the underlyer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:initialValuationDate ] ;
    sh:targetClass common_domain_model:ValuationDates .

common_domain_model:ValuationTime a sh:NodeShape ;
    rdfs:comment "Specifies the time by which the value of the collateral and obligations to transfer or return collateral are to be calculated relative to the Valuation Date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The day in respect of which the Valuation Time is being specified. If not specified, addional language must be used to define the methodology." ;
            sh:in ( "PreviousLocalBusinessDay" "PreviousLocalBusinessDayMarket" "PreviousLocalBusinessDayCityOfAgent" "ValuationDate" "AsSelected" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:day ],
        [ sh:datatype xsd:string ;
            sh:description "The location relevant to the timezone for the Valuation Time." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:location ],
        [ sh:description "The type of time specified for the Valuation Time." ;
            sh:in ( "CloseOfBusiness" "SpecificTime" "AsSelected" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:time ],
        [ sh:datatype xsd:time ;
            sh:description "A time specified in a 24-hour notation, e.g. 3pm would be represented as 15:00." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:hourminutetime ],
        [ sh:datatype xsd:string ;
            sh:description "Any relevant time zone where specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:timezone ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:ValuationTime .

common_domain_model:VarianceReturnTerms a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specification of the exchange traded contract nearest." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:Asset ] [ sh:class common_domain_model:Basket ] [ sh:class common_domain_model:Index ] ) ;
            sh:order 5 ;
            sh:path common_domain_model:exchangeTradedContractNearest ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the price of shares is adjusted for dividends or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path common_domain_model:sharePriceDividendAdjustment ],
        [ sh:description "In this context, this is AgreedInitialPrice - a specified Initial Index Level." ;
            sh:in ( <http://www.fpml.org/coding-scheme/determination-method-3-4#AgreedInitialPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#AsSpecifiedInMasterConfirmation> <http://www.fpml.org/coding-scheme/determination-method-3-4#CalculationAgent> <http://www.fpml.org/coding-scheme/determination-method-3-4#ClosingPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#DividendCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#ExpiringContractLevel> <http://www.fpml.org/coding-scheme/determination-method-3-4#HedgeExecution> <http://www.fpml.org/coding-scheme/determination-method-3-4#IssuerPaymentCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#NAV> <http://www.fpml.org/coding-scheme/determination-method-3-4#OpenPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#OSPPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#SettlementCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#StrikeDateDetermination> <http://www.fpml.org/coding-scheme/determination-method-3-4#TWAPPrice> "TWAPVE" "TWAPVEExcludingClose" <http://www.fpml.org/coding-scheme/determination-method-3-4#ValuationTime> <http://www.fpml.org/coding-scheme/determination-method-3-4#VWAPPrice> "VWAPVE" "VWAPVEExcludingClose" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path common_domain_model:initialLevelSource ],
        [ sh:class common_domain_model:DividendApplicability ;
            sh:description "The parameters which define whether dividends are applicable" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:dividendApplicability ],
        [ sh:datatype xsd:string ;
            sh:description "Performance calculation, in accordance with Part 1 Section 12 of the 2018 ISDA CDM Equity Confirmation for Security Equity Swap, Para 75. 'Equity Performance'. Cumulative performance is used as a notional multiplier factor on both legs of an Equity Swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path common_domain_model:performance ],
        [ sh:datatype xsd:integer ;
            sh:description "This specifies the numerator of an annualization factor. Frequently this number is equal to the number of observations of prices in a year e.g. 252." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:annualizationFactor ],
        [ sh:datatype xsd:decimal ;
            sh:description "Contract will strike off this initial level. Providing just the initialLevel without initialLevelSource, infers that this is AgreedInitialPrice - a specified Initial Index Level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path common_domain_model:initialLevel ],
        [ sh:datatype xsd:integer ;
            sh:description "Expected number of trading days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path common_domain_model:expectedN ],
        [ sh:class common_domain_model:NonNegativeQuantitySchedule ;
            sh:description "Vega Notional represents the approximate gain/loss at maturity for a 1% difference between RVol (realised vol) and KVol (strike vol). It does not necessarily represent the Vega Risk of the trade." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:vegaNotionalAmount ],
        [ sh:class common_domain_model:VolatilityCapFloor ;
            sh:description "Contains containing volatility-based barriers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:volatilityCapFloor ],
        [ sh:class common_domain_model:Price ;
            sh:description "Variance Strike Price in accordance with the ISDA 2011 Equity Derivatives Definitions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:varianceStrikePrice ],
        [ sh:class common_domain_model:EquityUnderlierProvisions ;
            sh:description "Contains Equity Underlyer provisions regarding jurisdiction and fallbacks." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:equityUnderlierProvisions ],
        [ sh:class common_domain_model:Price ;
            sh:description "Volatility Strike Price in accordance with the ISDA 2011 Equity Derivatives Definitions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:volatilityStrikePrice ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether Mean Adjustment is applicable or not in the calculation of the Realized Volatility, Variance or Correlation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path common_domain_model:meanAdjustment ],
        [ sh:class common_domain_model:ValuationTerms ;
            sh:description "Contains all non-date valuation information." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:valuationTerms ],
        [ sh:class common_domain_model:VarianceCapFloor ;
            sh:description "Contains possible barriers for variance products, both variance-based and underlier price based" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:varianceCapFloor ] ;
    sh:targetClass common_domain_model:VarianceReturnTerms .

common_domain_model:Velocity a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2, or 3. If the period value is T (Term) then period multiplier must contain the value 1." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:description "A time period, e.g. a day, week, month, year or term of the stream." ;
            sh:in ( "Hour" "Minute" "Second" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:period ] ;
    sh:targetClass common_domain_model:Velocity .

common_domain_model:VolatilityCapFloor a sh:NodeShape ;
    rdfs:comment "Contains volatility-based barriers. Volatility Cap needs to be specified in accordance with the ISDA 2011 Equity Derivatives Definitions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Volatility Cap Amount in accordance with the ISDA 2011 Equity Derivatives Definitions. This means the Volatility Cap Amount election is a number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:totalVolatilityCap ],
        [ sh:datatype xsd:decimal ;
            sh:description "Volatility Cap Amount in accordance with the ISDA 2011 Equity Derivatives Definitions. The Calculated VolCapAmt can be optionally provided." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:volatilityCapFactor ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the volatility cap is applicable in accordance with the ISDA 2011 Equity Derivatives Definitions. Setting the element 'applicable' to 'False' - means No Volatility Cap and no 'totalVolatilityCap' or 'volatilityCapFactor' should be provided. Setting the element 'applicable' to 'True' - means Volatility Cap election, then 'totalVolatilityCap' or 'volatilityCapFactor' should be provided, otherwise it defaults to volatilityCapFactor=2.5." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ] ;
    sh:targetClass common_domain_model:VolatilityCapFloor .

