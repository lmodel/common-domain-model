            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:currency ] ;
    sh:targetClass common_domain_model:FloatingRateIndexIdentification .

common_domain_model:FloatingRateIndexMappings a sh:NodeShape ;
    rdfs:comment "This type defines mappings between FROs in different definitional versions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FloatingRateIndexMap ;
            sh:description "The predecessor FRO(s) that this index maps to." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:mapsFrom ],
        [ sh:class common_domain_model:FloatingRateIndexMap ;
            sh:description "The successor FRO that this index maps to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:mapsTo ] ;
    sh:targetClass common_domain_model:FloatingRateIndexMappings .

common_domain_model:FloatingRateProcessingDetails a sh:NodeShape ;
    rdfs:comment "Type for reporting the details of the rate treatment.  This could potentially be replaced by the existing FloatingRateDefinition type , but this is slightly more detailed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The raw or untreated rate, prior to any of the rate treatments." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:rawRate ],
        [ sh:class common_domain_model:FloatingRateProcessingParameters ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:processingParameters ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value of the processed rate without the spread applied, for subsequent compounding, etc." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:spreadExclusiveRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value of the rate after processing." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:processedRate ] ;
    sh:targetClass common_domain_model:FloatingRateProcessingDetails .

common_domain_model:FloatingRateProcessingParameters a sh:NodeShape ;
    rdfs:comment "Type to hold the processing parameters that should be or were used to calculate a floating amount.  These parameters can vary over a schedule so this type holds the acutal values applicable to this calculation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "spread to be added to the floating rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:spread ],
        [ sh:description "How to handle negative interest rates." ;
            sh:in ( "NegativeInterestRateMethod" "ZeroInterestRateMethod" "ZeroInterestRateExcludingSpreadMethod" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:negativeTreatment ],
        [ sh:datatype xsd:decimal ;
            sh:description "floor to be applied to the floating rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:floorRate ],
        [ sh:description "US rate treatment (Bond Equivalent Yield or Money Market Yield, if applicable." ;
            sh:in ( "BondEquivalentYield" "MoneyMarketYield" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:treatment ],
        [ sh:class common_domain_model:Price ;
            sh:description "The rate to be applied for the initial period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:initialRate ],
        [ sh:class common_domain_model:Rounding ;
            sh:description "THe final rate rounding to be applied." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:rounding ],
        [ sh:datatype xsd:decimal ;
            sh:description "floating rate multiplier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:multiplier ],
        [ sh:datatype xsd:decimal ;
            sh:description "capt to be applied to the floating rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:capRate ] ;
    sh:targetClass common_domain_model:FloatingRateProcessingParameters .

common_domain_model:FloatingRateSettingDetails a sh:NodeShape ;
    rdfs:comment "Type for reporting the raw (untreated) observed or calculated rate for a calculation period.  If this is a calculated rate, it allows details of the observations and the resulting rate to be returned." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CalculatedRateDetails ;
            sh:description "Calculated rate details (observation dates, values, and weights)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationDetails ],
        [ sh:datatype xsd:date ;
            sh:description "The day upon which the rate was observed (for term rates)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:observationDate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The resulting rate that was observed or calculated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:floatingRate ],
        [ sh:datatype xsd:date ;
            sh:description "The day for which the rate is needed (e.g. period beginning or end date)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:resetDate ] ;
    sh:targetClass common_domain_model:FloatingRateSettingDetails .

common_domain_model:FloatingRateSpecification a sh:NodeShape ;
    rdfs:comment "A class to specify the floating interest rate by extending the floating rate definition with a set of attributes that specify such rate: the initial value specified as part of the trade, the rounding convention, the averaging method and the negative interest rate treatment." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:inflationLag common_domain_model:mainPublication common_domain_model:interpolationMethod common_domain_model:calculationStyle common_domain_model:finalPrincipalExchangeCalculation rdf:type common_domain_model:indexSource common_domain_model:calculationMethod common_domain_model:initialIndexLevel common_domain_model:fallbackBondApplicable ) ;
    sh:property [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The floor rate or floor rate schedule, if any, which applies to the floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. A floor rate schedule is expressed as explicit floor rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:floorRateSchedule ],
        [ sh:class common_domain_model:RateSchedule ;
            sh:description "A rate multiplier or multiplier schedule to apply to the floating rate. A multiplier schedule is expressed as explicit multipliers and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in the calculationPeriodDatesAdjustments. The multiplier can be a positive or negative decimal. This element should only be included if the multiplier is not equal to 1 (one) for the term of the stream." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:floatingRateMultiplierSchedule ],
        [ sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:FloatingRateIndex ] [ sh:class common_domain_model:InflationIndex ] ) ;
            sh:order 8 ;
            sh:path common_domain_model:rateOption ],
        [ sh:class common_domain_model:FloatingRateCalculationParameters ;
            sh:description "Support for modular calculated rates, such such as lockout compound calculations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:calculationParameters ],
        [ sh:description "If averaging is applicable, this component specifies whether a weighted or unweighted average method of calculation is to be used. The component must only be included when averaging applies." ;
            sh:in ( "Unweighted" "Weighted" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:averagingMethod ],
        [ sh:class common_domain_model:Rounding ;
            sh:description "The rounding convention to apply to the final rate used in determination of a calculation period amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:finalRateRounding ],
        [ sh:class common_domain_model:Price ;
            sh:description "The initial floating rate reset agreed between the principal parties involved in the trade. This is assumed to be the first required reset rate for the first regular calculation period. It should only be included when the rate is not equal to the rate published on the source implied by the floating rate index. An initial rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:initialRate ],
        [ sh:class common_domain_model:FallbackRateParameters ;
            sh:description "Definition of any fallback rate that may be applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:fallbackRate ],
        [ sh:description "The specification of any rate conversion which needs to be applied to the observed rate before being used in any calculations. The two common conversions are for securities quoted on a bank discount basis which will need to be converted to either a Money Market Yield or Bond Equivalent Yield. See the Annex to the 2000 ISDA Definitions, Section 7.3. Certain General Definitions Relating to Floating Rate Options, paragraphs (g) and (h) for definitions of these terms." ;
            sh:in ( "BondEquivalentYield" "MoneyMarketYield" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:rateTreatment ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The cap rate or cap rate schedule, if any, which applies to the floating rate. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain level. A cap rate schedule is expressed as explicit cap rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:capRateSchedule ],
        [ sh:class common_domain_model:SpreadSchedule ;
            sh:description "The ISDA Spread or a Spread schedule expressed as explicit spreads and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:spreadSchedule ],
        [ sh:description "The specification of any provisions for calculating payment obligations when a floating rate is negative (either due to a quoted negative floating rate or by operation of a spread that is subtracted from the floating rate)." ;
            sh:in ( "NegativeInterestRateMethod" "ZeroInterestRateMethod" "ZeroInterestRateExcludingSpreadMethod" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:negativeInterestRateTreatment ] ;
    sh:targetClass common_domain_model:FloatingRateSpecification .

common_domain_model:FrenchLawAddendum a sh:NodeShape ;
    rdfs:comment "A class to specify party specific elections when a Collateral Transfer Agreement is governed by French Law." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FrenchLawAddendumElection ;
            sh:description "The parties French Law Addendum Elections." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:partyElection ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether the French Law Addendum is deemed applicable by the parties (True) or not (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:FrenchLawAddendum .

common_domain_model:FrenchLawAddendumElection a sh:NodeShape ;
    rdfs:comment "A class to specify party specific French Law Addendum language." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The party specific language to be included in the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:addendumLanguage ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether the party elects specific language." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:FrenchLawAddendumElection .

common_domain_model:FroHistory a sh:NodeShape ;
    rdfs:comment "FRO History" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ContractualDefinition ;
            sh:description "The supplement or version the FRO was last updated in the 2006 Definitions or 2021 Floating Rate Matrix. (e.g. FRO-M-V1)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:lastUpdatedIn ],
        [ sh:datatype xsd:date ;
            sh:description "The date the Floating Rate Option was removed from the 2006 Definitions or 2021 Floating Rate Matrix. (e.g. 2014/01/01)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:endDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date the Floating Rate Option was added to the 2006 Definitions or 2021 Floating Rate Matrix. (e.g. 2017/04/06)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:startDate ],
        [ sh:class common_domain_model:ContractualDefinition ;
            sh:description "The supplement or version the FRO was first added to the 2006 Definitions or 2021 Floating Rate Matrix. (e.g. S52)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:firstDefinedIn ],
        [ sh:datatype xsd:date ;
            sh:description "The date the Floating Rate Option was last updated in the 2006 Definitions or 2021 Floating Rate Matrix. (e.g. 2021/06/11)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:updateDate ] ;
    sh:targetClass common_domain_model:FroHistory .

common_domain_model:FutureValueAmount a sh:NodeShape ;
    rdfs:comment "A class defining a currency and a future value date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The currency in which the an amount is denominated. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of days from the adjusted calculation period start date to the adjusted value date, calculated in accordance with the applicable day count fraction." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:calculationPeriodNumberOfDays ],
        [ sh:datatype xsd:date ;
            sh:description "Adjusted value date of the future value amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:valueDate ],
        [ sh:class common_domain_model:NonNegativeQuantitySchedule ;
            sh:description "Specifies quantity amount returned if not the full amount from the TradeState, e.g. partial return" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:quantity ] ;
    sh:targetClass common_domain_model:FutureValueAmount .

common_domain_model:FxAdditionalTerms a sh:NodeShape ;
    rdfs:comment "TransactionAdditionalTerms which apply to the CurrencyPair asset class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FxDisruptionEvents ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:disruptionEvents ],
        [ sh:class common_domain_model:DeterminationRolesAndTerms ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:determinationTerms ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:noFaultTermination ] ;
    sh:targetClass common_domain_model:FxAdditionalTerms .

common_domain_model:FxBenchmarkObligationDefault a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:in ( "LocalAssetSubstituteGross" "LocalAssetSubstituteNet" "LocalCurrencySubstitute" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:localSubstituteProvisionType ],
        [ sh:in ( "OutstandingPrincipalBalance" "StatedPrincipalBalance" "FaceValue" "MarketValue" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:specifiedValue ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:benchmarkObligationDefaultIsApplicable ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:escrowArrangement ] ;
    sh:targetClass common_domain_model:FxBenchmarkObligationDefault .

common_domain_model:FxDisruptionEvents a sh:NodeShape ;
    rdfs:comment "Additional Provisions for a Confirmation of an FX or Currency Option Transaction" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FxPriceSourceDisruption ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:priceSourceDisruption ],
        [ sh:class common_domain_model:FxInconvertibilityOrNonTransferability ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:inconvertibilityOrNonTransferability ],
        [ sh:class common_domain_model:MaterialChangeInCircumstance ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:materialChangeInCircumstance ],
        [ sh:in ( "ToBeTreatedAsDisruptionEvent" "ToBeTreatedAsIllegalityOrImpossibility" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:illegalityOrImpossibility ],
        [ sh:class common_domain_model:Illiquidity ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:illiquidity ],
        [ sh:class common_domain_model:Clause ;
            sh:description "Where parties may optionaly describe any extra bespoke agreements about fallback procedure attached to a particular determination role." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:fallbackLanguageBespokeTerms ],
        [ sh:class common_domain_model:GovernmentalAuthorityDefault ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:governmentalAuthorityDefault ],
        [ sh:class common_domain_model:FxDualExchangeRate ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:dualExchangeRate ],
        [ sh:in ( "ToBeTreatedAsDisruptionEvent" "ToBeTreatedAsForceMajeureOrActOfSState" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:forceMajeureOrActOfSState ],
        [ sh:class common_domain_model:EventCurrency ;
            sh:description "Additional Provisions for a Confirmation of an FX or Currency Option Transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:eventCurrency ],
        [ sh:class common_domain_model:PriceMateriality ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:priceMateriality ],
        [ sh:class common_domain_model:FxBenchmarkObligationDefault ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:benchmarkObligationDefault ],
        [ sh:class common_domain_model:Nationalization ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:nationalization ] ;
    sh:targetClass common_domain_model:FxDisruptionEvents .

common_domain_model:FxDualExchangeRate a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:class common_domain_model:FallbackReferencePrice ;
            sh:description "The method, prioritised by the order it is listed in this element, to get a replacement rate for the disrupted settlement rate option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fallbackReferencePrice ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:dualExchangeRateIsApplicable ] ;
    sh:targetClass common_domain_model:FxDualExchangeRate .

common_domain_model:FxFixingDate a sh:NodeShape ;
    rdfs:comment "Extends the Offset structure to specify an FX fixing date as an offset to dates specified somewhere else in the document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business center(s), specified either explicitly or by reference to those specified somewhere else in the instance document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenters ],
        [ sh:class common_domain_model:DateRelativeToCalculationPeriodDates ;
            sh:description "The calculation period references on which settlements in non-deliverable currency are due and will then have to be converted according to the terms specified through the other parts of the nonDeliverableSettlement structure. Implemented for Brazilian-CDI swaps where it will refer to the termination date of the appropriate leg." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:dateRelativeToCalculationPeriodDates ],
        [ sh:description "In the case of an offset specified as a number of days, this element defines whether consideration is given as to whether a day is a good business day or not. If a day type of business days is specified then non-business days are ignored when calculating the offset. The financial business centers to use for determination of business days are implied by the context in which this element is used. This element must only be included when the offset is specified as a number of days. If the offset is zero days then the dayType element should not be included." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:dayType ],
        [ sh:description "The convention for adjusting a date if it would otherwise fall on a day that is not a business day, as specified by an ISDA convention (e.g. Following, Precedent)." ;
            sh:in ( "FOLLOWING" "FRN" "MODFOLLOWING" "PRECEDING" "MODPRECEDING" "NEAREST" "NONE" "NotApplicable" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:businessDayConvention ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "A reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:businessCentersReference ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "Describes the specific date when a non-deliverable forward or cash-settled option will 'fix' against a particular rate, which will be used to compute the ultimate cash settlement. This element should be omitted where a single, discrete fixing date cannot be identified e.g. on an american option, where fixing may occur at any date on a continuous range.  This attribute was formerly part of 'fxSettlementTerms', which is now being harmonised into a common 'CashSettlementTerms' that includes a 'ValuationDate'." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:fxFixingDate ],
        [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:period ],
        [ sh:class common_domain_model:DateRelativeToPaymentDates ;
            sh:description "The payment date references on which settlements in non-deliverable currency are due and will then have to be converted according to the terms specified through the other parts of the nonDeliverableSettlement structure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:dateRelativeToPaymentDates ],
        [ sh:class common_domain_model:DateRelativeToValuationDates ;
            sh:description "The calculation period references on which settlements in non-deliverable currency are due and will then have to be converted according to the terms specified through the other parts of the nonDeliverableSettlement structure. Implemented for Brazilian-CDI swaps where it will refer to the termination date of the appropriate leg." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:dateRelativeToValuationDates ] ;
    sh:targetClass common_domain_model:FxFixingDate .

common_domain_model:FxInconvertibilityOrNonTransferability a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:GeneralNonTransferability ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:generalNonTransferability ],
        [ sh:class common_domain_model:SpecificInconvertibility ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:specificInconvertibility ],
        [ sh:class common_domain_model:SpecificNonTransferability ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:specificNonTransferability ],
        [ sh:class common_domain_model:GeneralInconvertibility ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:generalInconvertibility ] ;
    sh:targetClass common_domain_model:FxInconvertibilityOrNonTransferability .

common_domain_model:FxInformationSource a sh:NodeShape ;
    rdfs:comment "Information source specific to Foreign Exchange products." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A specific page for the source for obtaining a market data point. In FpML, this is specified as a scheme, rateSourcePageScheme, for which no coding Scheme or URI is specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:sourcePage ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The time that the fixing will be taken along with a business center to define the time zone." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:fixingTime ],
        [ sh:datatype xsd:string ;
            sh:description "The heading for the source on a given source page." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:sourcePageHeading ],
        [ sh:description "An information source for obtaining a market data point. For example Bloomberg, Reuters, Telerate, etc." ;
            sh:in ( <http://www.fpml.org/coding-scheme/information-provider-2-4#AssocBanksSingapore> <http://www.fpml.org/coding-scheme/information-provider-2-4#BancoCentralChile> <http://www.fpml.org/coding-scheme/information-provider-2-4#BankOfCanada> <http://www.fpml.org/coding-scheme/information-provider-2-4#BankOfEngland> <http://www.fpml.org/coding-scheme/information-provider-2-4#BankOfJapan> <http://www.fpml.org/coding-scheme/information-provider-2-4#Bloomberg> <http://www.fpml.org/coding-scheme/information-provider-2-4#EuroCentralBank> <http://www.fpml.org/coding-scheme/information-provider-2-4#FederalReserve> <http://www.fpml.org/coding-scheme/information-provider-2-4#FHLBSF> <http://www.fpml.org/coding-scheme/information-provider-2-4#ICESWAP> <http://www.fpml.org/coding-scheme/information-provider-2-4#ISDA> <http://www.fpml.org/coding-scheme/information-provider-2-4#Refinitiv> <http://www.fpml.org/coding-scheme/information-provider-2-4#ReserveBankAustralia> <http://www.fpml.org/coding-scheme/information-provider-2-4#ReserveBankNewZealand> <http://www.fpml.org/coding-scheme/information-provider-2-4#Reuters> <http://www.fpml.org/coding-scheme/information-provider-2-4#SAFEX> <http://www.fpml.org/coding-scheme/information-provider-2-4#Telerate> <http://www.fpml.org/coding-scheme/information-provider-2-4#TOKYOSWAP> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:sourceProvider ] ;
    sh:targetClass common_domain_model:FxInformationSource .

common_domain_model:FxLinkedNotionalAmount a sh:NodeShape ;
    rdfs:comment "A data to:  describe the cashflow representation for FX linked notionals." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date on which the FX spot rate is observed. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedFxSpotFixingDate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The calculation period notional amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:notionalAmount ],
        [ sh:datatype xsd:decimal ;
            sh:description "The actual observed FX spot rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:observedFxSpotRate ],
        [ sh:datatype xsd:date ;
            sh:description "The reset date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:resetDate ] ;
    sh:targetClass common_domain_model:FxLinkedNotionalAmount .

common_domain_model:FxLinkedNotionalSchedule a sh:NodeShape ;
    rdfs:comment "A data to:  describe a notional schedule where each notional that applies to a calculation period is calculated with reference to a notional amount or notional amount schedule in a different currency by means of a spot currency exchange rate which is normally observed at the beginning of each period." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The dates on which spot currency exchange rates are observed for purposes of determining the varying notional currency amount that will apply to a calculation period." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:varyingNotionalFixingDates ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The time at which the spot currency exchange rate will be observed. It is specified as a time in a business day calendar location, e.g. 11:00am London time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fixingTime ],
        [ sh:class common_domain_model:FxSpotRateSource ;
            sh:description "The information source and time at which the spot currency exchange rate will be observed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:fxSpotRateSource ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The dates on which interim exchanges of notional are paid. Interim exchanges will arise as a result of changes in the spot currency exchange amount or changes in the constant notional schedule (e.g. amortisation)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:varyingNotionalInterimExchangePaymentDates ],
        [ sh:datatype xsd:string ;
            sh:description "The currency of the varying notional amount, i.e. the notional amount being determined periodically based on observation of a spot currency exchange rate. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:varyingNotionalCurrency ] ;
    sh:targetClass common_domain_model:FxLinkedNotionalSchedule .

common_domain_model:FxPriceSourceDisruption a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SettlementRateOption ;
            sh:description "The method, prioritised by the order it is listed in this element, to get a replacement rate for the disrupted settlement rate option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fallbackReferencePrice ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:priceSourceDisruptionIsApplicable ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:escrowArrangement ] ;
    sh:targetClass common_domain_model:FxPriceSourceDisruption .

common_domain_model:FxRate a sh:NodeShape ;
    rdfs:comment "A class describing the rate of a currency conversion: pair of currency, quotation mode and exchange rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The rate of exchange between the two currencies of the leg of a deal. Must be specified with a quote basis." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:rate ],
        [ sh:class common_domain_model:QuotedCurrencyPair ;
            sh:description "Defines the two currencies for an FX trade and the quotation relationship between the two currencies." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:quotedCurrencyPair ] ;
    sh:targetClass common_domain_model:FxRate .

common_domain_model:FxSettlementRateSource a sh:NodeShape ;
    rdfs:comment "The source of the Foreign Exchange settlement rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Indicates that an officially defined rate settlement rate option will be the used for the fixing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:settlementRateOption ],
        [ sh:class common_domain_model:FxInformationSource ;
            sh:description "Indicates that a non-standard rate source will be used for the fixing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:nonstandardSettlementRate ] ;
    sh:targetClass common_domain_model:FxSettlementRateSource .

common_domain_model:GeneralInconvertibility a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:generalInconvertibilityIsApplicable ],
        [ sh:in ( "LocalAssetSubstituteGross" "LocalAssetSubstituteNet" "LocalCurrencySubstitute" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:localSubstituteProvisionType ],
        [ sh:class common_domain_model:NonDeliverableSubstitute ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:nonDeliverableSubstitute ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:description "Refers to the segregation deposit procedure parties may want to commmit into during the time a Disruption Event is effective" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:class common_domain_model:ValuationPostponement ;
            sh:description "Specifies how long to wait to get a quote from a settlement rate option upon a price source disruption." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:maximumDaysOfDisruption ] ;
    sh:targetClass common_domain_model:GeneralInconvertibility .

common_domain_model:GeneralNonTransferability a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NonDeliverableSubstitute ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:nonDeliverableSubstitute ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:description "Refers to the segregation deposit procedure parties may want to commmit into during the time a Disruption Event is effective" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:class common_domain_model:ValuationPostponement ;
            sh:description "Specifies how long to wait to get a quote from a settlement rate option upon a price source disruption." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:maximumDaysOfDisruption ],
        [ sh:in ( "LocalAssetSubstituteGross" "LocalAssetSubstituteNet" "LocalCurrencySubstitute" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:localSubstituteProvisionType ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:generalNonTransferabilityIsApplicable ] ;
    sh:targetClass common_domain_model:GeneralNonTransferability .

common_domain_model:GeneralTerms a sh:NodeShape ;
    rdfs:comment " A class specifying a set of non-monetary terms for the Credit Derivative Transaction, including the buyer and seller and selected items from the ISDA 2014 Credit Definition article II, such as the reference obligation and related terms. The CDM GeneralTerms class corresponds to the FpML GeneralTerms complex type, except that the effectiveDate and scheduledTerminationDate have been positioned as part of the InterestRatePayout class in the CDM instead of in GeneralTerms." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BasketReferenceInformation ;
            sh:description "This attribute contains all the terms relevant to defining the Credit Default Swap Basket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:basketReferenceInformation ],
        [ sh:class common_domain_model:CreditIndex ;
            sh:description "This attribute contains all the terms relevant to the underlying Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:indexReferenceInformation ],
        [ sh:datatype xsd:boolean ;
            sh:description "Value of this attribute set to 'true' indicates that modified equity delivery is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:modifiedEquityDelivery ],
        [ sh:datatype xsd:string ;
            sh:description "This attribute is used for representing information contained in the Additional Terms field of the 2003 Master Credit Derivatives confirm." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:additionalTerm ],
        [ sh:datatype xsd:boolean ;
            sh:description "Value of this attribute set to 'true' indicates that substitution is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:substitution ],
        [ sh:class common_domain_model:ReferenceInformation ;
            sh:description "This attribute contains all the terms relevant to defining the reference entity and reference obligation(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:referenceInformation ] ;
    sh:targetClass common_domain_model:GeneralTerms .

common_domain_model:GovernmentalAuthorityDefault a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:governmentalAuthorityDefaultIsApplicable ],
        [ sh:class common_domain_model:ValuationPostponement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:maximumDaysOfDisruption ],
        [ sh:in ( "OutstandingPrincipalBalance" "StatedPrincipalBalance" "FaceValue" "MarketValue" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:specifiedValue ],
        [ sh:in ( "LocalAssetSubstituteGross" "LocalAssetSubstituteNet" "LocalCurrencySubstitute" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:localSubstituteProvisionType ] ;
    sh:targetClass common_domain_model:GovernmentalAuthorityDefault .

common_domain_model:GracePeriodExtension a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the grace period extension provision is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ],
        [ sh:class common_domain_model:Offset ;
            sh:description "The number of calendar or business days after any due date that the reference entity has to fulfil its obligations before a failure to pay credit event is deemed to have occurred. ISDA 2003 Term: Grace Period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:gracePeriod ] ;
    sh:targetClass common_domain_model:GracePeriodExtension .

common_domain_model:HoldingAndUsingPostedCollateralElection a sh:NodeShape ;
    rdfs:comment "Specifies the parties' elections related to the holding and using of posted collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the party has the right to reuse, rehypothecate, or otherwise make use of the posted collateral. 'True' if the party has the right,'False' if the party does not have the right." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:useOfPostedCollateral ],
        [ sh:class common_domain_model:EligibilityToHoldCollateral ;
            sh:description "The specification of the conditions under which a party and its custodian(s) are entitled to hold posted collateral." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:eligibilityToHoldCollateral ],
        [ sh:description "The party to which the elections apply." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:HoldingAndUsingPostedCollateralElection .

common_domain_model:Id a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:lei ] ;
    sh:targetClass common_domain_model:Id .

common_domain_model:Illiquidity a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:class common_domain_model:SettlementRateOption ;
            sh:description "The method, prioritised by the order it is listed in this element, to get a replacement rate for the disrupted settlement rate option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fallbackReferencePrice ],
        [ sh:class common_domain_model:Quantity ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:minimumAmount ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:illiquidityIsApplicable ],
        [ sh:class common_domain_model:AdjustedRelativeDateOffset ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:illiquidityValuationDate ] ;
    sh:targetClass common_domain_model:Illiquidity .

common_domain_model:IndependentAmount a sh:NodeShape ;
    rdfs:comment "A class specifying the Independent Amount as the combination of a payer/receiver, a payment amount, a payment date and an associated payment calculation rule." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PaymentDetail ;
            sh:description "An attribute that specifies a payment as the combination of a payment amount, a payment date and an associated payment calculation rule." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:paymentDetail ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party responsible for making the payments defined by this structure." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:payerPartyReference ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party that receives the payments corresponding to this structure." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:receiverPartyReference ],
        [ sh:class common_domain_model:Account ;
            sh:description "A reference to the account responsible for making the payments defined by this structure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:payerAccountReference ],
        [ sh:class common_domain_model:Account ;
            sh:description "A reference to the account that receives the payments corresponding to this structure." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:receiverAccountReference ] ;
    sh:targetClass common_domain_model:IndependentAmount .

common_domain_model:IndexAdjustmentEvents a sh:NodeShape ;
    rdfs:comment "Defines the specification of the consequences of Index Events" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Consequence of index cancellation." ;
            sh:in ( "CalculationAgentAdjustment" "NegotiatedCloseOut" "CancellationAndPayment" "RelatedExchange" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:indexCancellation ],
        [ sh:description "Consequence of index disruption." ;
            sh:in ( "CalculationAgentAdjustment" "NegotiatedCloseOut" "CancellationAndPayment" "RelatedExchange" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:indexDisruption ],
        [ sh:description "Consequence of index modification." ;
            sh:in ( "CalculationAgentAdjustment" "NegotiatedCloseOut" "CancellationAndPayment" "RelatedExchange" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:indexModification ] ;
    sh:targetClass common_domain_model:IndexAdjustmentEvents .

common_domain_model:IndexTransitionInstruction a sh:NodeShape ;
    rdfs:comment "Defines the information needed to create a Index Transition Business Event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceQuantity ;
            sh:description "Specifies both new floating rate index and spread adjustment for each leg to be updated.  The spread adjustment accounts for the difference between the old floating rate index relative to the new one. This spread amount is added to the existing spread to determine the new spread, which is applied from the specified effective date forward. In the case of the IBOR Fallback Rate Adjustments, the adjustment spread (also known as the Fallback Adjustment) accounts for two distinctions: i) the fact that the replacement Risk-Free Rate is an overnight rate while IBORs have term structures (e.g., 1, 3, 6-month LIBOR); and (ii) the historical spread differential between IBORs and their term equivalent Overnight Risk-Free Rate compounded rates." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the effective date of the index transition event. This is first date on which the floating rate calculation will use the new floating rate index and adjusted spread in the floating rate calculation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:description "Specifies the cash transfer that can optionally be tied to an index transition event." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:ScheduledTransfer ] [ sh:class common_domain_model:UnscheduledTransfer ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:cashTransfer ] ;
    sh:targetClass common_domain_model:IndexTransitionInstruction .

common_domain_model:Indx a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Nm ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:nm ] ;
    sh:targetClass common_domain_model:Indx .

common_domain_model:IneligibleCreditSupport a sh:NodeShape ;
    rdfs:comment "Identifies collateral that has been designated as not meeting the eligibility criteria set out in the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies the date from which all credit support provided by a party is treated as ineligible under the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:totalIneligibilityDate ],
        [ sh:description "Identifies a party designated in the agreement for the purpose of applying particular rights, obligations, or elections." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:order 2 ;
            sh:path common_domain_model:specifiedParty ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the date from which the transfer of credit support by a party is treated as ineligible under the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:transferIneligibilityDate ] ;
    sh:targetClass common_domain_model:IneligibleCreditSupport .

common_domain_model:InflationRateSpecification a sh:NodeShape ;
    rdfs:comment "A data to:  specify the inflation rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FloatingRateCalculationParameters ;
            sh:description "Support for modular calculated rates, such such as lockout compound calculations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path common_domain_model:calculationParameters ],
        [ sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:FloatingRateIndex ] [ sh:class common_domain_model:InflationIndex ] ) ;
            sh:order 17 ;
            sh:path common_domain_model:rateOption ],
        [ sh:description "To be specified only for products that embed a redemption payment." ;
            sh:in ( "Floored" "NonFloored" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:finalPrincipalExchangeCalculation ],
        [ sh:datatype xsd:string ;
            sh:description "The current main publication source such as relevant web site or a government body. FpML specifies mainPublication to be of type mainPublicationSource, but without specifying actual values." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:mainPublication ],
        [ sh:datatype xsd:decimal ;
            sh:description "Initial known index level for the first calculation period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:initialIndexLevel ],
        [ sh:datatype xsd:string ;
            sh:description "The reference source such as Reuters or Bloomberg. FpML specifies indexSource to be of type rateSourcePageScheme, but without specifying actual values." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:indexSource ],
        [ sh:class common_domain_model:Rounding ;
            sh:description "The rounding convention to apply to the final rate used in determination of a calculation period amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:finalRateRounding ],
        [ sh:datatype xsd:boolean ;
            sh:description "The applicability of a fallback bond as defined in the 2006 ISDA Inflation Derivatives Definitions, sections 1.3 and 1.8." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:fallbackBondApplicable ],
        [ sh:description "Indicates the style of how the inflation index calculates the payment (e.g. YearOnYear, ZeroCoupon)." ;
            sh:in ( "YearOnYear" "ZeroCoupon" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:calculationStyle ],
        [ sh:class common_domain_model:Price ;
            sh:description "The initial floating rate reset agreed between the principal parties involved in the trade. This is assumed to be the first required reset rate for the first regular calculation period. It should only be included when the rate is not equal to the rate published on the source implied by the floating rate index. An initial rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:initialRate ],
        [ sh:class common_domain_model:FallbackRateParameters ;
            sh:description "Definition of any fallback rate that may be applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path common_domain_model:fallbackRate ],
        [ sh:description "Indicates how to use the inflation index to calculate the payment (e.g. Ratio, Return, Spread). Added for Inflation Asset Swap" ;
            sh:in ( "Ratio" "Return" "Spread" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:calculationMethod ],
        [ sh:description "The specification of any rate conversion which needs to be applied to the observed rate before being used in any calculations. The two common conversions are for securities quoted on a bank discount basis which will need to be converted to either a Money Market Yield or Bond Equivalent Yield. See the Annex to the 2000 ISDA Definitions, Section 7.3. Certain General Definitions Relating to Floating Rate Options, paragraphs (g) and (h) for definitions of these terms." ;
            sh:in ( "BondEquivalentYield" "MoneyMarketYield" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path common_domain_model:rateTreatment ],
        [ sh:class common_domain_model:RateSchedule ;
            sh:description "A rate multiplier or multiplier schedule to apply to the floating rate. A multiplier schedule is expressed as explicit multipliers and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in the calculationPeriodDatesAdjustments. The multiplier can be a positive or negative decimal. This element should only be included if the multiplier is not equal to 1 (one) for the term of the stream." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:floatingRateMultiplierSchedule ],
        [ sh:description "The method used when calculating the Inflation Index Level from multiple points. The most common is Linear." ;
            sh:in ( <http://www.fpml.org/coding-scheme/interpolation-method-1-2#Linear> <http://www.fpml.org/coding-scheme/interpolation-method-1-2#LinearZeroYield> <http://www.fpml.org/coding-scheme/interpolation-method-1-2#None> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:interpolationMethod ],
        [ sh:class common_domain_model:Offset ;
            sh:description "An off-setting period from the payment date which determines the reference period for which the inflation index is observed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:inflationLag ],
        [ sh:description "The specification of any provisions for calculating payment obligations when a floating rate is negative (either due to a quoted negative floating rate or by operation of a spread that is subtracted from the floating rate)." ;
            sh:in ( "NegativeInterestRateMethod" "ZeroInterestRateMethod" "ZeroInterestRateExcludingSpreadMethod" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path common_domain_model:negativeInterestRateTreatment ],
        [ sh:class common_domain_model:SpreadSchedule ;
            sh:description "The ISDA Spread or a Spread schedule expressed as explicit spreads and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path common_domain_model:spreadSchedule ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The floor rate or floor rate schedule, if any, which applies to the floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. A floor rate schedule is expressed as explicit floor rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path common_domain_model:floorRateSchedule ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The cap rate or cap rate schedule, if any, which applies to the floating rate. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain level. A cap rate schedule is expressed as explicit cap rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path common_domain_model:capRateSchedule ],
        [ sh:description "If averaging is applicable, this component specifies whether a weighted or unweighted average method of calculation is to be used. The component must only be included when averaging applies." ;
            sh:in ( "Unweighted" "Weighted" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path common_domain_model:averagingMethod ] ;
    sh:targetClass common_domain_model:InflationRateSpecification .

common_domain_model:InitialFixingDate a sh:NodeShape ;
    rdfs:comment "A CDM class which purpose is to specify the initial fixing date either alongside the FpML interest rate specification as an offset of another date, or alongside the credit derivative specification as an unadjusted date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The initial fixing date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:initialFixingDate ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:relativeDateOffset ] ;
    sh:targetClass common_domain_model:InitialFixingDate .

common_domain_model:InterestAdjustmentPeriodicity a sh:NodeShape ;
    rdfs:comment "A class to specify the Interest Adjustment periodicity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The Interest Adjustment periodicity when specified through a standardized election." ;
            sh:in ( "LastLocalBusinessDayOfMonth" "EachDay" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:standardElection ],
        [ sh:datatype xsd:string ;
            sh:description "The Interest Adjustment periodicity when specified through a custom election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customElection ] ;
    sh:targetClass common_domain_model:InterestAdjustmentPeriodicity .

common_domain_model:InterestAmountApplication a sh:NodeShape ;
    rdfs:comment "A class to specify the application of Interest Amount with respect to the Delivery Amount and the Return Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:DeliveryAmount ;
            sh:description "The application of Interest Amount with respect the Delivery Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:deliveryAmount ],
        [ sh:class common_domain_model:ReturnAmount ;
            sh:description "The application of Interest Amount with respect the Return Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:returnAmount ] ;
    sh:targetClass common_domain_model:InterestAmountApplication .

