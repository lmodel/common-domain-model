            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:floatingRateIndex ],
        [ sh:class common_domain_model:SpreadSchedule ;
            sh:description "The ISDA Spread or a Spread schedule expressed as explicit spreads and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:spreadSchedule ],
        [ sh:class common_domain_model:Period ;
            sh:description "The ISDA Designated Maturity, i.e. the tenor of the floating rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:indexTenor ] ;
    sh:targetClass common_domain_model:StubFloatingRate .

common_domain_model:StubPeriod a sh:NodeShape ;
    rdfs:comment " A class defining how the initial or final stub calculation period amounts is calculated. For example, the rate to be applied to the initial or final stub calculation period may be the linear interpolation of two different tenors for the floating rate index specified in the calculation period amount component, e.g. A two month stub period may used the linear interpolation of a one month and three month floating rate. The different rate tenors would be specified in this component. Note that a maximum of two rate tenors can be specified. If a stub period uses a single index tenor and this is the same as that specified in the calculation period amount component then the initial stub or final stub component, as the case may be, must not be included." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:StubValue ;
            sh:description "Specifies how the initial stub amount is calculated. A single floating rate tenor different to that used for the regular part of the calculation periods schedule may be specified, or two floating tenors may be specified. If two floating rate tenors are specified then Linear Interpolation (in accordance with the 2000 ISDA Definitions, Section 8.3. Interpolation) is assumed to apply. Alternatively, an actual known stub rate or stub amount may be specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:initialStub ],
        [ sh:class common_domain_model:StubValue ;
            sh:description "Specifies how the final stub amount is calculated. A single floating rate tenor different to that used for the regular part of the calculation periods schedule may be specified, or two floating tenors may be specified. If two floating rate tenors are specified then Linear Interpolation (in accordance with the 2000 ISDA Definitions, Section 8.3. Interpolation) is assumed to apply. Alternatively, an actual known stub rate or stub amount may be specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:finalStub ],
        [ sh:class common_domain_model:CalculationPeriodDates ;
            sh:description "A pointer style reference to the associated calculation period dates component defined elsewhere in the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationPeriodDatesReference ] ;
    sh:targetClass common_domain_model:StubPeriod .

common_domain_model:SubstitutedRegimeTerms a sh:NodeShape ;
    rdfs:comment "Specifies the applicability of the Substituted Regime as denoted in the Substituted Regime Table as part of certain legal agreements, such as such as the ISDA 2016 and 2018 CSA for Initial Margin." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The specification of whether the regime is elected as applicable to the party when acting as collateral taker." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:description "The party for which the regime terms are being specified when acting as collateral taker." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:SubstitutedRegimeTerms .

common_domain_model:SubstitutionPartyElection a sh:NodeShape ;
    rdfs:comment "Party specific elections for substitution of posted collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The process for substituting/exchanging one form of collateral held by a party for a different form of collateral, used with legacy agreements." ;
            sh:in ( "ConsentRequired" "NoConsent" "ConsentRequiredNoDelay" "TimesAdjusted" "NoticeConditions" "CostsApportioned" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:legacyConsent ],
        [ sh:datatype xsd:boolean ;
            sh:description "The election as to whether the Pledgor/Obligor/Chargor/Security Provider must obtain the Secured Partys consent for any collateral substitution." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:needsConsent ],
        [ sh:description "The party that is acting as the Pledgor/Obligor/Chargor/Security Provider." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "Specific consent language might be specified by the parties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:specificConsentLanguage ],
        [ sh:datatype xsd:string ;
            sh:description "Substitution Date has the meaning specified in Paragraph4(d)(ii), unless otherwise specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:substitutionDateLanguage ] ;
    sh:targetClass common_domain_model:SubstitutionPartyElection .

common_domain_model:SubstitutionProvisions a sh:NodeShape ;
    rdfs:comment "Defines collateral substitution provisions such as how many and with how much notice are substitutions allowed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Period ;
            sh:description "Defines the min period for notify of a substitution." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:noticeDeadlinePeriod ],
        [ sh:datatype xsd:dateTime ;
            sh:description "A specific date and time for the notice deadline" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:noticeDeadlineDateTime ],
        [ sh:datatype xsd:integer ;
            sh:description "Specifies if 1 or more substitutions are allowed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:numberOfSubstitutionsAllowed ] ;
    sh:targetClass common_domain_model:SubstitutionProvisions .

common_domain_model:SwapCurveValuation a sh:NodeShape ;
    rdfs:comment "A class to specify a valuation swap curve, which is used as part of the strike construct for the bond and convertible bond options." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:earlyCallDate rdf:type common_domain_model:interpolationMethod ) ;
    sh:property [ sh:description "The side (bid/mid/ask) of the measure." ;
            sh:in ( "Afternoon" "Ask" "Bid" "Closing" "High" "Index" "MeanOfBidAndAsk" "LocationalMarginal" "Low" "MarginalHourly" "MarketClearing" "MeanOfHighAndLow" "Morning" "Official" "Opening" "OSP" "Settlement" "Spot" "Mid" "NationalSingle" "WeightedAverage" "UnWeightedAverage" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:side ],
        [ sh:class common_domain_model:Period ;
            sh:description "The ISDA Designated Maturity, i.e. the tenor of the floating rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:indexTenor ],
