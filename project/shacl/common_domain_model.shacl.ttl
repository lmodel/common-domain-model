common_domain_model:InventoryRecord a sh:NodeShape ;
    rdfs:comment "An individual piece of inventory. This represents a single security." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:expirationDateTime common_domain_model:collateral rdf:type common_domain_model:comment common_domain_model:dividendTerms common_domain_model:interestRate common_domain_model:quantity common_domain_model:partyRole ) ;
    sh:property [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "Unique identifier for this record. This can be used to uniquely identify a specific piece of inventory." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifer ],
        [ sh:class common_domain_model:Security ;
            sh:description "The security details." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:security ] ;
    sh:targetClass common_domain_model:InventoryRecord .

common_domain_model:InvstmtDcsnPrsn a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Prsn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:prsn ] ;
    sh:targetClass common_domain_model:InvstmtDcsnPrsn .

common_domain_model:JapaneseSecuritiesProvisions a sh:NodeShape ;
    rdfs:comment "A class to specify Japanese Securities Provision elections." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Recommended Japanese Securities Provisions are applicable when True, additional Provisions are specified when False." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:relevantProvisionsElection ],
        [ sh:datatype xsd:boolean ;
            sh:description "Japanese Securities Provisions are applicable when True and Not Applicable when False." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:datatype xsd:string ;
            sh:description "Specific terms applicable to Recommended Japanese Securities Provisions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:relevantProvisionsTerms ],
        [ sh:datatype xsd:string ;
            sh:description "Specific terms applicable to Additional Amendments to Japanese Securities Provisions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:amendmentsToJapaneseProvisionsTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "Additional Amendments to Japanese Securities Provisions are specified when True, and not specified when False." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:amendmentsToJapaneseProvisions ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specification of whether Clearstream Event amendment language is included (true) or excluded (false)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:clearstreamAmendmentToJapaneseProvisions ] ;
    sh:targetClass common_domain_model:JapaneseSecuritiesProvisions .

common_domain_model:Lag a sh:NodeShape ;
    rdfs:comment "The pricing period per calculation period if the pricing days do not wholly fall within the respective calculation period." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Offset ;
            sh:description "Defines the offset of the series of pricing dates relative to the calculation period." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:lagDuration ],
        [ sh:class common_domain_model:Offset ;
            sh:description "Defines the offset of the series of pricing dates relative to the calculation period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:firstObservationDateOffset ] ;
    sh:targetClass common_domain_model:Lag .

common_domain_model:LegacyExposureScopeElection a sh:NodeShape ;
    rdfs:comment "Specification of amendments to the calculation of Exposure in terms of the Transactions and Products covered." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:ExcludedProducts ;
            sh:description "Description of the relevant derivative transactions excluded from the calculation of exposure." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:excludedProducts ],
        [ sh:datatype xsd:boolean ;
            sh:description "A boolean flag to represent whether any transactions are excluded (ie True) or not (ie False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:excludedTransactions ],
        [ sh:datatype xsd:string ;
            sh:description "The bespoke/additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:LegacyExposureScopeElection .

common_domain_model:LegacyIndependentAmount a sh:NodeShape ;
    rdfs:comment "Sets out the additional amount of collateral that is required to be delivered by that party irrespective of the mark-to-market exposure under the related Transactions. It may take the form of a fixed amount, or be determined using credit ratings." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:class common_domain_model:LegacyIndependentAmountParty ;
            sh:description "The party specific elections for the Independent Amount clause." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:LegacyIndependentAmount .

common_domain_model:LegacyIndependentAmountParty a sh:NodeShape ;
    rdfs:comment "The party specific elections for the Independent Amount clause." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "Indicates the Independent Amount is specified as a fixed amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:fixedAmount ],
        [ sh:class common_domain_model:LegacyIndependentAmountRatingsXExposure ;
            sh:description "Indicates the Independent Amount is determined using both credit rating and exposure metrics." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:ratingsXExposure ],
        [ sh:class common_domain_model:LegacyIndependentAmountRatingsBased ;
            sh:description "Indicates the Independent Amount is determined using a credit rating." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:ratingsBased ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether Independent Amount is applicable to the elected party. If applicable, 'True', and if not applicable then 'False'." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:description "Identifies the Party making the election." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:LegacyIndependentAmountParty .

common_domain_model:LegacyIndependentAmountRatingsBased a sh:NodeShape ;
    rdfs:comment "Specifies that the Independent Amount is determined using a credit rating." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the party to whom the rating agency rating applies to for the purposes of determining the Independent Amount." ;
            sh:in ( "Party" "CreditSupportProvider" "NamedEntity" "PartyOrCreditSupportProvider" "NamedAffiliate" "AllAffiliates" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:ratedParty ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Details the Named Entity where the Rated Party is Named Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:namedEntity ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Details the Named Affiliate where the Rated Party is Named Affiliate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:namedAffiliate ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the currency applicable to the relevant Independent Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:currency ],
        [ sh:description "The relevant rating type." ;
            sh:in ( "LongTerm" "ShortTerm" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:ratingType ],
        [ sh:class common_domain_model:RatingAgencyAmount ;
            sh:description "A logical container designed to hold a defined set of related data. In this case the collation of Rating Information and an associated Independent Amount." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:variableSet ],
        [ sh:description "Specifies how multiple credit ratings are compared when determining the applicable Independent Amount, and whether that measure is highest, lowest, or a comparison of either." ;
            sh:in ( "Compare" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:compare ] ;
    sh:targetClass common_domain_model:LegacyIndependentAmountRatingsBased .

common_domain_model:LegacyIndependentAmountRatingsXExposure a sh:NodeShape ;
    rdfs:comment "Specifies that the Independent Amount is determined using both credit rating and exposure metrics." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the party to whom the rating agency rating applies to for the purposes of determining the Independent Amount." ;
            sh:in ( "Party" "CreditSupportProvider" "NamedEntity" "PartyOrCreditSupportProvider" "NamedAffiliate" "AllAffiliates" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:ratedParty ],
        [ sh:description "Specifies how multiple credit ratings are compared when determining the applicable Independent Amount, and whether that measure is highest, lowest, or a comparison of either." ;
            sh:in ( "Compare" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:compare ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Details the Named Entity where the Rated Party is Named Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:namedEntity ],
        [ sh:description "The relevant rating type." ;
            sh:in ( "LongTerm" "ShortTerm" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:ratingType ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Details the Named Affiliate where the Rated Party is Named Affiliate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:namedAffiliate ],
        [ sh:class common_domain_model:RatingMultiplier ;
            sh:description "A logical container to hold a defined set of related data. In this case the collation of Ratings Information and associated exposure multiplier where highest or lowest of the associated credit ratings are used when determining the applicable Independent Amount." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:highestLowestVariableSet ],
        [ sh:class common_domain_model:DirectionRatingMultiplier ;
            sh:description "A logical container to hold a defined set of related data. In this case the collation of Ratings Information and associated exposure multiplier where multiple credit ratings are compared when determining the applicable Independent Amount." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:compareVariableSet ] ;
    sh:targetClass common_domain_model:LegacyIndependentAmountRatingsXExposure .

common_domain_model:LegacyResolutionAlternative a sh:NodeShape ;
    rdfs:comment "Alternative procedures to those in the pre-print for resolving collateral related disputes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Details of the alternative dispute resolution procedure (if any)." ;
            sh:in ( "NoAlternative" "SplitDifference" "AdditionalConditions" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:resolutionAlternative ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:class common_domain_model:Money ;
            sh:description "The maximum amount to which the difference between the calculations by the valuation agent and disputing party can be split, where Split the Difference is elected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:amount ] ;
    sh:targetClass common_domain_model:LegacyResolutionAlternative .

common_domain_model:LimitApplicableExtended a sh:NodeShape ;
    rdfs:comment "A class to represent the CDM attributes that are not part of the FpML standard. Once broader usage is confirmed, it is expected that those two classes can be collapsed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The currency in which the applicable limit is denominated. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:decimal ;
            sh:description "The limit utilized by this specific trade. While the attribute is of type integer in the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:limitImpactDueToTrade ],
        [ sh:datatype xsd:decimal ;
            sh:description "The limit utilised by all the cleared trades for the limit level and limit type. While the attribute is of type integer in FpML and the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:amountUtilized ],
        [ sh:description "Standard code to indicate which type of credit line is being referred to - i.e. IM, DV01, PV01, CS01, Notional, Clip Size, Notional, maximumOrderQuantity." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#CS01> <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#DV01> <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#IM> <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#Notional> "NPV" <http://www.fpml.org/coding-scheme/credit-limit-type-1-1#PV01> ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:limitType ],
        [ sh:class common_domain_model:CreditLimitUtilisation ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:utilization ],
        [ sh:class common_domain_model:Velocity ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:velocity ],
        [ sh:datatype xsd:integer ;
            sh:description "This element is required in FpML, optional in CDM for the purpose of accommodating the CME data representation while making reference to the FpML one." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:clipSize ],
        [ sh:description "The level at which the limit is set: customer business, proprietary business or account level. This attribute is specified as a string as part of the CME clearing confirmation specification." ;
            sh:in ( "Account" "Customer" "House" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:limitLevel ],
        [ sh:datatype xsd:decimal ;
            sh:description "The limit remaining for the limit level and limit type. This does not take into account any pending trades. While the attribute is of type integer in FpML and the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:amountRemaining ],
        [ sh:datatype xsd:decimal ;
            sh:description "The total limit available for the limit level and limit type. While the attribute is of type integer in the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:limitAmount ] ;
    sh:targetClass common_domain_model:LimitApplicableExtended .

common_domain_model:Loan a sh:NodeShape ;
    rdfs:comment "Identifies a loan by referencing an asset identifier and through an optional set of attributes." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the type of loan facility (letter of credit, revolving, ...)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:facilityType ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:identifier ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the credit agreement date is the closing date (the date where the agreement has been signed) for the loans in the credit agreement. Funding of the facilities occurs on (or sometimes a little after) the Credit Agreement date. This underlier attribute is used to help identify which of the company's outstanding loans are being referenced by knowing to which credit agreement it belongs. ISDA Standards Terms Supplement term: Date of Original Credit Agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:creditAgreementDate ],
        [ sh:datatype xsd:string ;
            sh:description "Denotes the loan tranche that is subject to the derivative transaction. It will typically be referenced as the Bloomberg tranche number. ISDA Standards Terms Supplement term: Bloomberg Tranche Number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:tranche ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:exchange ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Specifies the borrower. There can be more than one borrower. It is meant to be used in the event that there is no Bloomberg Id or the Secured List isn't applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:borrower ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the seniority level of the lien." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:lien ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:assetType ] ;
    sh:targetClass common_domain_model:Loan .

common_domain_model:LocationIdentifier a sh:NodeShape ;
    rdfs:comment "Specifies a location identifier. An issuer and an identifier type can be associated with the actual identifier value as a way to properly qualify it." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The identifier issuer, when specified explicitly alongside the identifier value (instead of being specified by reference to a party)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:issuer ],
        [ sh:description "Specifies the nature of a location identifier." ;
            sh:in ( "DeliveryPoint" "EntryPoint" "InterconnectionPoint" "WithdrawalPoint" "DeliveryZone" "BuyerHub" "SellerHub" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:locationIdentifierType ],
        [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "The identifier value. This level of indirection between the issuer and the identifier and its version provides the ability to associate multiple identifiers to one issuer, consistently with the FpML PartyTradeIdentifier." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:assignedIdentifier ],
        [ sh:class common_domain_model:Party ;
            sh:description "The identifier issuer, when specified by reference to a party specified as part of the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:issuerReference ] ;
    sh:targetClass common_domain_model:LocationIdentifier .

common_domain_model:MakeWholeAmount a sh:NodeShape ;
    rdfs:comment "A class to specify the amount to be paid by the buyer of the option if the option is exercised prior to the Early Call Date (typically applicable to the convertible bond options)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Spread in basis points over the floating rate index." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:spread ],
        [ sh:class common_domain_model:Period ;
            sh:description "The ISDA Designated Maturity, i.e. the tenor of the floating rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:indexTenor ],
        [ sh:datatype xsd:date ;
            sh:description "Date prior to which the option buyer will have to pay a Make Whole Amount to the option seller if he/she exercises the option." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:earlyCallDate ],
        [ sh:description "The type of interpolation method that the calculation agent reserves the right to use." ;
            sh:in ( <http://www.fpml.org/coding-scheme/interpolation-method-1-2#Linear> <http://www.fpml.org/coding-scheme/interpolation-method-1-2#LinearZeroYield> <http://www.fpml.org/coding-scheme/interpolation-method-1-2#None> ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:interpolationMethod ],
        [ sh:description "The reference index that is used to specify the floating interest rate." ;
            sh:in ( "AED_EBOR_Reuters" "AED_EIBOR" "AUD_AONIA" "AUD_AONIA_OIS_Compound_1" "AUD_AONIA_OIS_COMPOUND" "AUD_AONIA_OIS_COMPOUND_SwapMarker" "AUD_BBR_AUBBSW" "AUD_BBR_BBSW" "AUD_BBR_BBSW_Bloomberg" "AUD_BBR_BBSY__BID_" "AUD_BBR_ISDC" "AUD_BBSW" "AUD_BBSW_Quarterly_Swap_Rate_ICAP" "AUD_BBSW_Semi_Annual_Swap_Rate_ICAP" "AUD_BBSY_Bid" "AUD_LIBOR_BBA" "AUD_LIBOR_BBA_Bloomberg" "AUD_LIBOR_Reference_Banks" "AUD_Quarterly_Swap_Rate_ICAP" "AUD_Quarterly_Swap_Rate_ICAP_Reference_Banks" "AUD_Semi_Annual_Swap_Rate_11_00_BGCANTOR" "AUD_Semi_Annual_Swap_Rate_BGCANTOR_Reference_Banks" "AUD_Semi_annual_Swap_Rate_ICAP" "AUD_Semi_Annual_Swap_Rate_ICAP_Reference_Banks" "AUD_Swap_Rate_Reuters" "BRL_CDI" "CAD_BA_CDOR" "CAD_BA_CDOR_Bloomberg" "CAD_BA_ISDD" "CAD_BA_Reference_Banks" "CAD_BA_Reuters" "CAD_BA_Telerate" "CAD_CDOR" "CAD_CORRA" "CAD_CORRA_CanDeal_TMX_Term" "CAD_CORRA_Compounded_Index" "CAD_CORRA_OIS_Compound_1" "CAD_CORRA_OIS_COMPOUND" "CAD_ISDA_Swap_Rate" "CAD_LIBOR_BBA" "CAD_LIBOR_BBA_Bloomberg" "CAD_LIBOR_BBA_SwapMarker" "CAD_LIBOR_Reference_Banks" "CAD_REPO_CORRA" "CAD_TBILL_ISDD" "CAD_TBILL_Reference_Banks" "CAD_TBILL_Reuters" "CAD_TBILL_Telerate" "CHF_3M_LIBOR_SWAP_CME_vs_LCH_ICAP" "CHF_3M_LIBOR_SWAP_CME_vs_LCH_ICAP_Bloomberg" "CHF_3M_LIBOR_SWAP_EUREX_vs_LCH_ICAP" "CHF_3M_LIBOR_SWAP_EUREX_vs_LCH_ICAP_Bloomberg" "CHF_6M_LIBOR_SWAP_CME_vs_LCH_ICAP" "CHF_6M_LIBORSWAP_CME_vs_LCH_ICAP_Bloomberg" "CHF_6M_LIBOR_SWAP_EUREX_vs_LCH_ICAP" "CHF_6M_LIBOR_SWAP_EUREX_vs_LCH_ICAP_Bloomberg" "CHF_Annual_Swap_Rate" "CHF_Annual_Swap_Rate_11_00_ICAP" "CHF_Annual_Swap_Rate_Reference_Banks" "CHF_Basis_Swap_3m_vs_6m_LIBOR_11_00_ICAP" "CHF_ISDAFIX_Swap_Rate" "CHF_LIBOR" "CHF_LIBOR_BBA" "CHF_LIBOR_BBA_Bloomberg" "CHF_LIBOR_ISDA" "CHF_LIBOR_Reference_Banks" "CHF_OIS_11_00_ICAP" "CHF_SARON" "CHF_SARON_Average_12M" "CHF_SARON_Average_1M" "CHF_SARON_Average_1W" "CHF_SARON_Average_2M" "CHF_SARON_Average_3M" "CHF_SARON_Average_6M" "CHF_SARON_Average_9M" "CHF_SARON_Compounded_Index" "CHF_SARO