common_domain_model:InterestShortFall a sh:NodeShape ;
    rdfs:comment "A class to specify the interest shortfall floating rate payment event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the nature of the interest Shortfall cap (i.e. Fixed Cap or Variable Cap) in the case where it is applicable. ISDA 2003 Term: Interest Shortfall Cap." ;
            sh:in ( "Fixed" "Variable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
