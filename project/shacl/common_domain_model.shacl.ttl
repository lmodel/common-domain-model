            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:side ] ;
    sh:targetClass common_domain_model:MakeWholeAmount .

common_domain_model:MandatoryEarlyTermination a sh:NodeShape ;
    rdfs:comment "A data to:  define an early termination provision for which exercise is mandatory." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SettlementTerms ;
            sh:description "If specified, this means that cash settlement is applicable to the transaction and defines the parameters associated with the cash settlement procedure. If not specified, then physical settlement is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:cashSettlement ],
        [ sh:class common_domain_model:CalculationAgent ;
            sh:description "The ISDA Calculation Agent responsible for performing duties associated with an optional early termination." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:calculationAgent ],
        [ sh:class common_domain_model:AdjustableDate ;
            sh:description "The early termination date associated with a mandatory early termination of a swap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:mandatoryEarlyTerminationDate ],
        [ sh:class common_domain_model:MandatoryEarlyTerminationAdjustedDates ;
            sh:description "The adjusted dates associated with a mandatory early termination provision. These dates have been adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:mandatoryEarlyTerminationAdjustedDates ] ;
    sh:targetClass common_domain_model:MandatoryEarlyTermination .

common_domain_model:MandatoryEarlyTerminationAdjustedDates a sh:NodeShape ;
    rdfs:comment "A data defining:  the adjusted dates associated with a mandatory early termination provision." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date by which the cash settlement amount must be agreed. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedCashSettlementValuationDate ],
        [ sh:datatype xsd:date ;
            sh:description "The early termination date that is applicable if an early termination provision is exercised. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:adjustedEarlyTerminationDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the cash settlement amount is paid. This date should already be adjusted for any applicable business date convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:adjustedCashSettlementPaymentDate ] ;
    sh:targetClass common_domain_model:MandatoryEarlyTerminationAdjustedDates .

common_domain_model:ManualExercise a sh:NodeShape ;
    rdfs:comment "A class defining manual exercise, i.e. that the option buyer counterparty must give notice to the option seller of exercise." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ExerciseNotice ;
            sh:description "Definition of the party to whom notice of exercise should be given." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:exerciseNotice ],
        [ sh:datatype xsd:boolean ;
            sh:description "If fallback exercise is specified then the notional amount of the underlying swap, not previously exercised under the swaption, will be automatically exercised at the expiration time on the expiration date if at such time the buyer is in-the-money, provided that the difference between the settlement rate and the fixed rate under the relevant underlying swap is not less than one tenth of a percentage point (0.10% or 0.001). The term in-the-money is assumed to have the meaning defined in the 2000 ISDA Definitions, Section 17.4. In-the-money." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:fallbackExercise ] ;
    sh:targetClass common_domain_model:ManualExercise .

common_domain_model:MarginCallResponseAction a sh:NodeShape ;
    rdfs:comment "Specifies the margin call action details, including collateral to be moved and its direction." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the margin call action details, specified as either Delivery or Return." ;
            sh:in ( "Delivery" "Return" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:marginCallAction ],
        [ sh:class common_domain_model:CollateralPosition ;
            sh:description "Specifies the collateral to be moved and its direction." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:collateralPositionComponent ] ;
    sh:targetClass common_domain_model:MarginCallResponseAction .

common_domain_model:MasterAgreementClause a sh:NodeShape ;
    rdfs:comment "Defines clauses that make up a Master Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MasterAgreementClauseVariant ;
            sh:description "Allows multiple variants to be defined for a clause. This needs to be an array as some clauses can specify different variants for different parties. At least one variant must be specified for a clause." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:variant ],
        [ sh:datatype xsd:string ;
            sh:description "Optional textual description of the clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:name ],
        [ sh:description "Optional party. This can be required for umbrella agreements where a clause may need to be assigned to a specific party who may or may not be on the agreement." ;
            sh:in ( <http://www.fpml.org/coding-scheme/party-role-4-0#Accountant> "AgentLender" <http://www.fpml.org/coding-scheme/party-role-4-0#AllocationAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ArrangingBroker> "BarrierDeterminationAgent" "BeneficialOwner" <http://www.fpml.org/coding-scheme/party-role-4-0#Beneficiary> <http://www.fpml.org/coding-scheme/party-role-4-0#BookingParty> "Borrower" <http://www.fpml.org/coding-scheme/party-role-4-0#Buyer> <http://www.fpml.org/coding-scheme/party-role-4-0#BuyerDecisionMaker> "Chargor" <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingClient> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingExceptionParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingFirm> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingOrganization> <http://www.fpml.org/coding-scheme/party-role-4-0#Client> <http://www.fpml.org/coding-scheme/party-role-4-0#ClientDecisionMaker> <http://www.fpml.org/coding-scheme/party-role-4-0#ConfirmationPlatform> <http://www.fpml.org/coding-scheme/party-role-4-0#ContractualParty> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Counterparty> <http://www.fpml.org/coding-scheme/party-role-4-0#CreditSupportProvider> <http://www.fpml.org/coding-scheme/party-role-4-0#Custodian> <http://www.fpml.org/coding-scheme/party-role-4-0#DataSubmitter> "DeterminingParty" <http://www.fpml.org/coding-scheme/party-role-4-0#DisputingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#DocumentRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingEntity> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionFacility> <http://www.fpml.org/coding-scheme/party-role-4-0#Guarantor> "HedgingParty" "Lender" "MarginAffiliate" <http://www.fpml.org/coding-scheme/party-role-4-0#OrderTransmitter> "Pledgor" <http://www.fpml.org/coding-scheme/party-role-4-0#PrimeBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#PriorTradeRepository> "PTRRServiceProvider" <http://www.fpml.org/coding-scheme/party-role-4-0#PublicationVenue> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Seller> <http://www.fpml.org/coding-scheme/party-role-4-0#SellerDecisionMaker> "SecuredParty" <http://www.fpml.org/coding-scheme/party-role-4-0#SettlementAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeSource> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingManager> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingPartner> "TripartyAgent" "ThirdPartyCustodian" ) ;
            sh:order 3 ;
            sh:path common_domain_model:otherParty ],
        [ sh:description "Optional counterparty role. This can be used where a clause needs to be assigned to a specific party on the agreement based upon their role i.e. Party A or Party B." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:order 2 ;
            sh:path common_domain_model:counterparty ],
        [ sh:description "Unique identifier for the clause." ;
            sh:in ( "ISLA_GMSLA_001" "ISLA_GMSLA_002" "ISLA_GMSLA_003" "ISLA_GMSLA_004" "ISLA_GMSLA_005" "ISLA_GMSLA_006" "ISLA_GMSLA_007" "ISLA_GMSLA_008" "ISLA_GMSLA_009" "ISLA_GMSLA_010" "ISLA_GMSLA_011" "ISLA_GMSLA_012" "ISLA_GMSLA_013" "ISLA_GMSLA_014" "ISLA_GMSLA_015" "ISLA_GMSLA_016" "ISLA_GMSLA_017" "ISLA_GMSLA_018" "ISLA_GMSLA_019" "ISLA_GMSLA_020" "ISLA_GMSLA_021" "ISLA_GMSLA_022" "ISLA_GMSLA_023" "ISLA_GMSLA_024" "ISLA_GMSLA_025" "ISLA_GMSLA_026" "ISLA_GMSLA_027" "ISLA_GMSLA_028" "ISLA_GMSLA_029" "ISLA_GMSLA_030" "ISLA_GMSLA_031" "ISLA_GMSLA_032" "ISLA_GMSLA_033" "ISLA_GMSLA_034" "ISLA_GMSLA_035" "ISLA_GMSLA_036" "ISLA_GMSLA_037" "ISLA_GMSLA_038" "ISLA_GMSLA_039" "ISLA_GMSLA_040" "ISLA_GMSLA_041" "ISLA_GMSLA_042" "ISLA_GMSLA_043" "ISLA_GMSLA_044" "ISLA_GMSLA_045" "ISLA_GMSLA_046" "ISLA_GMSLA_047" "ISLA_GMSLA_048" "ISLA_GMSLA_049" "ISLA_GMSLA_050" "ISLA_GMSLA_051" "ISLA_GMSLA_052" "ISLA_GMSLA_053" "ISLA_GMSLA_054" "ISLA_GMSLA_055" "ISLA_GMSLA_056" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:identifer ] ;
    sh:targetClass common_domain_model:MasterAgreementClause .

common_domain_model:MasterAgreementClauseVariant a sh:NodeShape ;
    rdfs:comment "Sets the details for a specific variant associated to a clause in a Master Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Optional party. This can be used where a clause needs to assign different variants to different parties who may or may not be on the agreement." ;
            sh:in ( <http://www.fpml.org/coding-scheme/party-role-4-0#Accountant> "AgentLender" <http://www.fpml.org/coding-scheme/party-role-4-0#AllocationAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ArrangingBroker> "BarrierDeterminationAgent" "BeneficialOwner" <http://www.fpml.org/coding-scheme/party-role-4-0#Beneficiary> <http://www.fpml.org/coding-scheme/party-role-4-0#BookingParty> "Borrower" <http://www.fpml.org/coding-scheme/party-role-4-0#Buyer> <http://www.fpml.org/coding-scheme/party-role-4-0#BuyerDecisionMaker> "Chargor" <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingClient> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingExceptionParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingFirm> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingOrganization> <http://www.fpml.org/coding-scheme/party-role-4-0#Client> <http://www.fpml.org/coding-scheme/party-role-4-0#ClientDecisionMaker> <http://www.fpml.org/coding-scheme/party-role-4-0#ConfirmationPlatform> <http://www.fpml.org/coding-scheme/party-role-4-0#ContractualParty> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Counterparty> <http://www.fpml.org/coding-scheme/party-role-4-0#CreditSupportProvider> <http://www.fpml.org/coding-scheme/party-role-4-0#Custodian> <http://www.fpml.org/coding-scheme/party-role-4-0#DataSubmitter> "DeterminingParty" <http://www.fpml.org/coding-scheme/party-role-4-0#DisputingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#DocumentRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingEntity> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionFacility> <http://www.fpml.org/coding-scheme/party-role-4-0#Guarantor> "HedgingParty" "Lender" "MarginAffiliate" <http://www.fpml.org/coding-scheme/party-role-4-0#OrderTransmitter> "Pledgor" <http://www.fpml.org/coding-scheme/party-role-4-0#PrimeBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#PriorTradeRepository> "PTRRServiceProvider" <http://www.fpml.org/coding-scheme/party-role-4-0#PublicationVenue> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Seller> <http://www.fpml.org/coding-scheme/party-role-4-0#SellerDecisionMaker> "SecuredParty" <http://www.fpml.org/coding-scheme/party-role-4-0#SettlementAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeSource> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingManager> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingPartner> "TripartyAgent" "ThirdPartyCustodian" ) ;
            sh:order 3 ;
            sh:path common_domain_model:otherParty ],
        [ sh:description "Optional counterparty role. This can be used where a clause needs to assign a different variant to the different parties on the agreement based upon their role i.e. Party A or Party B." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:order 2 ;
            sh:path common_domain_model:counterparty ],
        [ sh:datatype xsd:string ;
            sh:description "Optional textual description of the variant." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:name ],
        [ sh:description "Unique identifier for this variant." ;
            sh:in ( "ISLA_GMSLA_001_01" "ISLA_GMSLA_001_02" "ISLA_GMSLA_002_01" "ISLA_GMSLA_002_02" "ISLA_GMSLA_002_03" "ISLA_GMSLA_003_01" "ISLA_GMSLA_003_02" "ISLA_GMSLA_004_01" "ISLA_GMSLA_004_02" "ISLA_GMSLA_004_03" "ISLA_GMSLA_005_01" "ISLA_GMSLA_005_02" "ISLA_GMSLA_006_01" "ISLA_GMSLA_006_02" "ISLA_GMSLA_006_03" "ISLA_GMSLA_006_04" "ISLA_GMSLA_006_05" "ISLA_GMSLA_007_01" "ISLA_GMSLA_007_02" "ISLA_GMSLA_008_01" "ISLA_GMSLA_008_02" "ISLA_GMSLA_008_03" "ISLA_GMSLA_008_04" "ISLA_GMSLA_009_01" "ISLA_GMSLA_009_02" "ISLA_GMSLA_009_03" "ISLA_GMSLA_009_04" "ISLA_GMSLA_010_01" "ISLA_GMSLA_010_02" "ISLA_GMSLA_011_01" "ISLA_GMSLA_011_02" "ISLA_GMSLA_011_03" "ISLA_GMSLA_012_01" "ISLA_GMSLA_012_02" "ISLA_GMSLA_012_03" "ISLA_GMSLA_013_01" "ISLA_GMSLA_013_02" "ISLA_GMSLA_013_03" "ISLA_GMSLA_013_04" "ISLA_GMSLA_013_05" "ISLA_GMSLA_013_06" "ISLA_GMSLA_014_01" "ISLA_GMSLA_014_02" "ISLA_GMSLA_014_03" "ISLA_GMSLA_014_04" "ISLA_GMSLA_014_05" "ISLA_GMSLA_015_01" "ISLA_GMSLA_015_02" "ISLA_GMSLA_016_01" "ISLA_GMSLA_016_02" "ISLA_GMSLA_016_03" "ISLA_GMSLA_016_04" "ISLA_GMSLA_016_05" "ISLA_GMSLA_016_06" "ISLA_GMSLA_017_01" "ISLA_GMSLA_017_02" "ISLA_GMSLA_017_03" "ISLA_GMSLA_018_01" "ISLA_GMSLA_018_02" "ISLA_GMSLA_018_03" "ISLA_GMSLA_019_01" "ISLA_GMSLA_019_02" "ISLA_GMSLA_019_03" "ISLA_GMSLA_020_01" "ISLA_GMSLA_020_02" "ISLA_GMSLA_021_01" "ISLA_GMSLA_021_02" "ISLA_GMSLA_021_03" "ISLA_GMSLA_021_04" "ISLA_GMSLA_021_05" "ISLA_GMSLA_022_01" "ISLA_GMSLA_022_02" "ISLA_GMSLA_023_01" "ISLA_GMSLA_023_02" "ISLA_GMSLA_024_01" "ISLA_GMSLA_024_02" "ISLA_GMSLA_024_03" "ISLA_GMSLA_025_01" "ISLA_GMSLA_025_02" "ISLA_GMSLA_025_03" "ISLA_GMSLA_025_04" "ISLA_GMSLA_026_01" "ISLA_GMSLA_026_02" "ISLA_GMSLA_026_03" "ISLA_GMSLA_027_01" "ISLA_GMSLA_027_02" "ISLA_GMSLA_028_01" "ISLA_GMSLA_028_02" "ISLA_GMSLA_028_03" "ISLA_GMSLA_028_04" "ISLA_GMSLA_028_05" "ISLA_GMSLA_029_01" "ISLA_GMSLA_029_02" "ISLA_GMSLA_029_03" "ISLA_GMSLA_030_01" "ISLA_GMSLA_030_02" "ISLA_GMSLA_030_03" "ISLA_GMSLA_030_04" "ISLA_GMSLA_031_01" "ISLA_GMSLA_031_02" "ISLA_GMSLA_031_03" "ISLA_GMSLA_031_04" "ISLA_GMSLA_031_05" "ISLA_GMSLA_032_01" "ISLA_GMSLA_032_02" "ISLA_GMSLA_032_03" "ISLA_GMSLA_033_01" "ISLA_GMSLA_033_02" "ISLA_GMSLA_033_03" "ISLA_GMSLA_034_01" "ISLA_GMSLA_034_02" "ISLA_GMSLA_034_03" "ISLA_GMSLA_034_04" "ISLA_GMSLA_035_01" "ISLA_GMSLA_035_02" "ISLA_GMSLA_036_01" "ISLA_GMSLA_036_02" "ISLA_GMSLA_036_03" "ISLA_GMSLA_036_04" "ISLA_GMSLA_037_01" "ISLA_GMSLA_037_02" "ISLA_GMSLA_037_03" "ISLA_GMSLA_038_01" "ISLA_GMSLA_038_02" "ISLA_GMSLA_038_03" "ISLA_GMSLA_038_04" "ISLA_GMSLA_039_01" "ISLA_GMSLA_039_02" "ISLA_GMSLA_039_03" "ISLA_GMSLA_040_01" "ISLA_GMSLA_040_02" "ISLA_GMSLA_040_03" "ISLA_GMSLA_041_01" "ISLA_GMSLA_041_02" "ISLA_GMSLA_041_03" "ISLA_GMSLA_042_01" "ISLA_GMSLA_042_02" "ISLA_GMSLA_042_03" "ISLA_GMSLA_043_01" "ISLA_GMSLA_043_02" "ISLA_GMSLA_044_01" "ISLA_GMSLA_044_02" "ISLA_GMSLA_044_03" "ISLA_GMSLA_044_04" "ISLA_GMSLA_045_01" "ISLA_GMSLA_045_02" "ISLA_GMSLA_045_03" "ISLA_GMSLA_045_04" "ISLA_GMSLA_046_01" "ISLA_GMSLA_046_02" "ISLA_GMSLA_047_01" "ISLA_GMSLA_047_02" "ISLA_GMSLA_048_01" "ISLA_GMSLA_048_02" "ISLA_GMSLA_049_01" "ISLA_GMSLA_049_02" "ISLA_GMSLA_050_01" "ISLA_GMSLA_050_02" "ISLA_GMSLA_051_01" "ISLA_GMSLA_051_02" "ISLA_GMSLA_051_03" "ISLA_GMSLA_052_01" "ISLA_GMSLA_052_02" "ISLA_GMSLA_053_01" "ISLA_GMSLA_053_02" "ISLA_GMSLA_054_01" "ISLA_GMSLA_054_02" "ISLA_GMSLA_054_03" "ISLA_GMSLA_054_04" "ISLA_GMSLA_055_01" "ISLA_GMSLA_056_01" "ISLA_GMSLA_056_02" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:MasterAgreementVariableSet ;
            sh:description "For some variants of some clauses additional details are required to work out what has been elected. This array can be used to define the name and value of these variables. Please refer to the agreement documentation for more details of the variables that are available for any clause." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:variableSet ] ;
    sh:targetClass common_domain_model:MasterAgreementClauseVariant .

common_domain_model:MasterAgreementElections a sh:NodeShape ;
    rdfs:comment "A representation of a master agreement extended from a base agreement of shared elections." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:MasterAgreementElections .

common_domain_model:MasterAgreementSchedule a sh:NodeShape ;
    rdfs:comment "The set of elections which specify a Master Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MasterAgreementClause ;
            sh:description "Clauses that have had elections made against them in this Master Agreement. There must be at least one clause defined in the agreement." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:clause ] ;
    sh:targetClass common_domain_model:MasterAgreementSchedule .

common_domain_model:MaterialChangeInCircumstance a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationPostponement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:maximumDaysOfDisruption ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:materialChangeInCircumstanceIsApplicable ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:escrowArrangement ] ;
    sh:targetClass common_domain_model:MaterialChangeInCircumstance .

common_domain_model:Merger a sh:NodeShape ;
    rdfs:comment "Defines the underlier for both the Purchaser Company and the Acquired Compagny involved in Merger corporate action, as well as th respective price observation for each." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Security ;
            sh:description "Defines the underlier for the Acquired Company involved in Merger corporate action." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:acquiredSecurity ],
        [ sh:class common_domain_model:Security ;
            sh:description "Defines the underlier for the Purchaser Company involved in Merger corporate action." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:purchaserSecurity ],
        [ sh:class common_domain_model:Price ;
            sh:description "The price observation that relates to underlier for the Acquired Company." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:acquiredSecurityPrice ],
        [ sh:class common_domain_model:Price ;
            sh:description "The price observation that relates to underlier for the Purchaser Company." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:purchaserSecurityPrice ] ;
    sh:targetClass common_domain_model:Merger .

common_domain_model:MinimumTransferAmountElection a sh:NodeShape ;
    rdfs:comment "Specifies the method by which the minimum transfer amount is defined, such as a fixed amount, ratings based, or an alternative basis set out in the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MinimumTransferAmountRatingsBased ;
            sh:description "Defines that the Minimum Transfer Amount (MTA) is based on a Ratings condition(s)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:ratingsBased ],
        [ sh:datatype xsd:string ;
            sh:description "Utilised where the clause data structure is not able to capture a material aspect of the clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:other ],
        [ sh:description "The party to which the minimum transfer amount applies." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:ThresholdMinimumTransferAmountFixedAmount ;
            sh:description "Defines that the Minimum Transfer Amount (MTA) is a Fixed Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fixedAmount ] ;
    sh:targetClass common_domain_model:MinimumTransferAmountElection .

common_domain_model:MinimumTransferAmountRatingsBased a sh:NodeShape ;
    rdfs:comment "Defines that the Minimum Transfer Amount (MTA) is based on a Ratings condition(s)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The minimum transfer amount currency code." ;
            sh:in ( "AED" "AFN" "ALL" "AMD" "AOA" "ARS" "AUD" "AWG" "AZN" "BAM" "BBD" "BDT" "BHD" "BIF" "BMD" "BND" "BOB" "BOV" "BRL" "BSD" "BTN" "BWP" "BYN" "BZD" "CAD" "CDF" "CHE" "CHF" "CHW" "CLF" "CLP" "CNY" "COP" "COU" "CRC" "CUP" "CVE" "CZK" "DJF" "DKK" "DOP" "DZD" "EGP" "ERN" "ETB" "EUR" "FJD" "FKP" "GBP" "GEL" "GHS" "GIP" "GMD" "GNF" "GTQ" "GYD" "HKD" "HNL" "HTG" "HUF" "IDR" "ILS" "INR" "IQD" "IRR" "ISK" "JMD" "JOD" "JPY" "KES" "KGS" "KHR" "KMF" "KPW" "KRW" "KWD" "KYD" "KZT" "LAK" "LBP" "LKR" "LRD" "LSL" "LYD" "MAD" "MDL" "MGA" "MKD" "MMK" "MNT" "MOP" "MRU" "MUR" "MVR" "MWK" "MXN" "MXV" "MYR" "MZN" "NAD" "NGN" "NIO" "NOK" "NPR" "NZD" "OMR" "PAB" "PEN" "PGK" "PHP" "PKR" "PLN" "PYG" "QAR" "RON" "RSD" "RUB" "RWF" "SAR" "SBD" "SCR" "SDG" "SEK" "SGD" "SHP" "SLE" "SOS" "SRD" "SSP" "STN" "SVC" "SYP" "SZL" "THB" "TJS" "TMT" "TND" "TOP" "TRY" "TTD" "TWD" "TZS" "UAH" "UGX" "USD" "USN" "UYI" "UYU" "UYW" "UZS" "VED" "VES" "VND" "VUV" "WST" "XAD" "XAF" "XAG" "XAU" "XBA" "XBB" "XBC" "XBD" "XCD" "XCG" "XDR" "XOF" "XPD" "XPF" "XPT" "XSU" "XTS" "XUA" "XXX" "YER" "ZAR" "ZMW" "ZWG" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:currency ],
        [ sh:description "Defines where conditions apply if no Rating where ratings may not exist." ;
            sh:in ( "All" "One" "Two" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:notRatedBy ],
        [ sh:description "Specifies the relevant trigger for the Threshold or Minimum Transfer Amount to fall to zero." ;
            sh:in ( "EventOfDefault" "TerminationEvent" "TerminationEventAllAffectedTransactions" "PotentialEventOfDefault" "AdditionalTerminationEvent" "Other" ) ;
            sh:order 11 ;
            sh:path common_domain_model:event ],
        [ sh:datatype xsd:string ;
            sh:description "Details the Named Affiliate where the Rated Party is Named Affiliate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:namedAffiliate ],
        [ sh:description "Where two ratings are specified whether the higher or lower rating prevails." ;
            sh:in ( "Lowest" "Highest" "ReferenceAgency" "Average" "SecondBest" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:compare ],
        [ sh:description "The party to which a rating applies." ;
            sh:in ( "Party" "CreditSupportProvider" "NamedEntity" "PartyOrCreditSupportProvider" "NamedAffiliate" "AllAffiliates" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:ratedParty ],
        [ sh:description "The relevant rating type." ;
            sh:in ( "LongTerm" "ShortTerm" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:ratingType ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether a trigger applies for the Threshold or Minimum Transfer Amount to fall to zero. If 'True' then such a trigger exists." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path common_domain_model:zeroEvent ],
        [ sh:datatype xsd:string ;
            sh:description "Details the Named Entity where the Rated Party is Named Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:namedEntity ],
        [ sh:description "Defines the number of Rating Agencies that the Party must be rated by." ;
            sh:in ( "All" "AnyOne" "AnyTwo" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:numberOfRatingAgencies ],
        [ sh:datatype xsd:boolean ;
            sh:description "What conditions apply where a party has no rating." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:noRating ],
        [ sh:class common_domain_model:CSAMinimumTransferAmountVariableSet ;
            sh:description "Defines a combination of Rating Agency, Rating Value, amount and Currency code." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:variableSet ] ;
    sh:targetClass common_domain_model:MinimumTransferAmountRatingsBased .

common_domain_model:MoneyRange a sh:NodeShape ;
    rdfs:comment "The money range defined as either a lower and upper money bound, or both." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MoneyBound ;
            sh:description "The upper bound of a money range, e.g. less than 10,000 USD." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:upperBound ],
        [ sh:class common_domain_model:MoneyBound ;
            sh:description "The lower bound of a money range, e.g. greater than or equal to 1,000 USD." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:lowerBound ] ;
    sh:targetClass common_domain_model:MoneyRange .

common_domain_model:MultipleCreditNotations a sh:NodeShape ;
    rdfs:comment "Represetns a class to specify multiple credit notations alongside a conditional 'any' or 'all' qualifier." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:in ( "Lowest" "Highest" "ReferenceAgency" "Average" "SecondBest" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:mismatchResolution ],
        [ sh:description "An enumerated element, to qualify whether All or Any credit notation applies." ;
            sh:in ( "All" "Any" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:condition ],
        [ sh:class common_domain_model:CreditNotation ;
            sh:description "At least two credit notations much be specified." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:creditNotation ],
        [ sh:in ( <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#AMBest> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#CBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#DBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Fitch> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Japanagency> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Moodys> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors> ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:referenceAgency ] ;
    sh:targetClass common_domain_model:MultipleCreditNotations .

common_domain_model:MultipleDebtTypes a sh:NodeShape ;
    rdfs:comment "Represents a class to specify multiple credit debt types alongside a conditional 'any' or 'all' qualifier." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The type of debt, e.g. long term debt, deposit, ... FpML doesn't specific a scheme value, hence no enumeration is specified as part of the CDM. At least two debt types much be specified." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:debtType ],
        [ sh:description "An enumerated attribute, to qualify whether All or Any debt type applies." ;
            sh:in ( "All" "Any" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:condition ] ;
    sh:targetClass common_domain_model:MultipleDebtTypes .

common_domain_model:MultipleExercise a sh:NodeShape ;
    rdfs:comment "A class defining multiple exercises. As defined in the 2000 ISDA Definitions, Section 12.4. Multiple Exercise, the buyer of the option has the right to exercise all or less than all the unexercised notional amount of the underlying swap on one or more days in the exercise period, but on any such day may not exercise less than the minimum notional amount or more than the maximum notional amount, and if an integral multiple amount is specified, the notional exercised must be equal to or, be an integral multiple of, the integral multiple amount. In FpML, MultipleExercise is built upon the PartialExercise.model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "A pointer style reference to the associated notional schedule defined elsewhere in the document. This element has been made optional as part of its integration in the OptionBaseExtended, because not required for the options on securities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:notionalReference ],
        [ sh:datatype xsd:decimal ;
            sh:description "A notional amount which restricts the amount of notional that can be exercised when partial exercise or multiple exercise is applicable. The integral multiple amount defines a lower limit of notional that can be exercised and also defines a unit multiple of notional that can be exercised, i.e. only integer multiples of this amount can be exercised." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:integralMultipleAmount ],
        [ sh:datatype xsd:integer ;
            sh:description "The maximum number of options that can be exercised on a given exercise date. If the number is not specified, it means that the maximum number of options corresponds to the remaining unexercised options." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:maximumNumberOfOptions ],
        [ sh:datatype xsd:decimal ;
            sh:description "The minimum notional amount that can be exercised on a given exercise date. See multipleExercise." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:minimumNotionalAmount ],
        [ sh:datatype xsd:integer ;
            sh:description "The minimum number of options that can be exercised on a given exercise date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:minimumNumberOfOptions ],
        [ sh:datatype xsd:decimal ;
            sh:description "The maximum notional amount that can be exercised on a given exercise date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:maximumNotionalAmount ] ;
    sh:targetClass common_domain_model:MultipleExercise .

common_domain_model:MultipleValuationDates a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Where multiple valuation dates are specified as being applicable for cash settlement, this element specifies (a) the number of applicable valuation dates, and (b) the number of business days after satisfaction of all conditions to settlement when the first such valuation date occurs, and (c) the number of business days thereafter of each successive valuation date. ISDA 2003 Term: Multiple Valuation Dates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:numberValuationDates ],
        [ sh:datatype xsd:integer ;
            sh:description "A number of business days. Its precise meaning is dependant on the context in which this element is used. ISDA 2003 Term: Business Day." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:businessDays ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of business days between successive valuation dates when multiple valuation dates are applicable for cash settlement. ISDA 2003 Term: Business Days thereafter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:businessDaysThereafter ] ;
    sh:targetClass common_domain_model:MultipleValuationDates .

common_domain_model:Nationalization a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationPostponement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:maximumDaysOfDisruption ],
        [ sh:class common_domain_model:AncillaryEntity ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:relevantAffiliate ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:nationalizationIsApplicable ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:assignmentOfClaim ] ;
    sh:targetClass common_domain_model:Nationalization .

common_domain_model:NaturalPersonRole a sh:NodeShape ;
    rdfs:comment "A class to specify the role(s) that natural person(s) may have in relation to the contract." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NaturalPerson ;
            sh:description "A reference to the natural person to whom the role refers to." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:personReference ],
        [ sh:description "FpML specifies a person role that is distinct from the party role." ;
            sh:in ( "Broker" "Buyer" "DecisionMaker" "ExecutionWithinFirm" "InvestmentDecisionMaker" "Seller" "Trader" ) ;
            sh:order 1 ;
            sh:path common_domain_model:role ] ;
    sh:targetClass common_domain_model:NaturalPersonRole .

common_domain_model:New a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Tx ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:tx ],
        [ sh:class common_domain_model:OrdrTrnsmssn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:ordrTrnsmssn ],
        [ sh:class common_domain_model:AddtlAttrbts ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:addtlAttrbts ],
        [ sh:class common_domain_model:Sellr ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:sellr ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:exctgPty ],
        [ sh:class common_domain_model:FinInstrm ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:finInstrm ],
        [ sh:class common_domain_model:InvstmtDcsnPrsn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:invstmtDcsnPrsn ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:submitgPty ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:txId ],
        [ sh:class common_domain_model:Buyr ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:buyr ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:invstmtPtyInd ],
        [ sh:class common_domain_model:ExctgPrsn ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:exctgPrsn ] ;
    sh:targetClass common_domain_model:New .

common_domain_model:Nm a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RefRate ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:refRate ],
        [ sh:class common_domain_model:Term ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:term ] ;
    sh:targetClass common_domain_model:Nm .

common_domain_model:NonLegalEntity a sh:NodeShape ;
    rdfs:comment "Specifies a non-legal entity that exists in the agreement with a defined relationship to a Legal entity to the agreement" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies the unique identifier value for a non-legal entity such as a sleeve, or sub account, that is a party to the agreement and has a relationship with a legal entity defined on the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the Identifier type for a non-Legal entity to the agreement, for example the use of an alert code to uniquely identify a non-Legal entity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:identifierType ] ;
    sh:targetClass common_domain_model:NonLegalEntity .

common_domain_model:NoticeContactInformation a sh:NodeShape ;
    rdfs:comment "Specifies notice information including address and, optionally, an associated person. This type also supports the ISDA CSA representation as a single string, through the address attribute in Contact Information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TelephoneNumber ;
            sh:description "The telephone number." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:telephone ],
        [ sh:class common_domain_model:Address ;
            sh:description "The street/postal address." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:address ],
        [ sh:datatype xsd:string ;
            sh:description "The email address." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:email ],
        [ sh:datatype xsd:string ;
            sh:description "The web page. This attribute is not specified as part of the FpML ContactInformation complex type." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:webPage ],
        [ sh:class common_domain_model:NaturalPerson ;
            sh:description "Optional information about people involved in a transaction or business process." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:naturalPerson ],
        [ sh:datatype xsd:string ;
            sh:description "Additional information on the recipient." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalInformation ] ;
    sh:targetClass common_domain_model:NoticeContactInformation .

common_domain_model:NoticeInformationElection a sh:NodeShape ;
    rdfs:comment "Specifies the party reference and the associated notice and contact information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NoticeContactInformation ;
            sh:description "Additional notice/address information of the party." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:additionalContactInformation ],
        [ sh:description "The party to which the election and details apply." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:partyReference ],
        [ sh:class common_domain_model:ContactInformation ;
            sh:description "The main notice/address information of the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:primaryContactInformation ] ;
    sh:targetClass common_domain_model:NoticeInformationElection .

common_domain_model:NotificationTimeElection a sh:NodeShape ;
    rdfs:comment "A class to specify the notification time election by the respective parties to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether the Notification Time is precluded on the day being a local business day." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:localBusinessDay ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The Notification Time as a time that is qualified as a standard business center." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:notificationTime ],
        [ sh:datatype xsd:string ;
            sh:description "The Notification Time as a bespoke election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:customNotification ] ;
    sh:targetClass common_domain_model:NotificationTimeElection .

common_domain_model:Obligations a sh:NodeShape ;
    rdfs:comment "A class to specify the underlying obligations of the reference entity on which protection is purchased or sold through the Credit Default Swap." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SpecifiedCurrency ;
            sh:description "An obligation and deliverable obligation characteristic. The currency or currencies in which an obligation or deliverable obligation must be payable. ISDA 2003 Term: Specified Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:specifiedCurrency ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published additional provisions for U.S. Municipal as Reference Entity. ISDA 2003 Term: Revenue Obligation Liability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path common_domain_model:revenueObligationLiability ],
        [ sh:datatype xsd:boolean ;
            sh:description "OTE: Only allowed as an obligation characteristic under ISDA Credit 1999. In essence Not Contingent means the repayment of principal cannot be dependent on a formula/index, i.e. to prevent the risk of being delivered an instrument that may never pay any element of principal, and to ensure that the obligation is interest bearing (on a regular schedule). ISDA 2003 Term: Not Contingent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path common_domain_model:notContingent ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published Standard Terms Supplement for use with CDS Transactions on Leveraged Loans. ISDA 2003 Term: Continuity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path common_domain_model:continuity ],
        [ sh:datatype xsd:string ;
            sh:description "A free format string to specify any excluded obligations or deliverable obligations, as the case may be, of the reference entity or excluded types of obligations or deliverable obligations. ISDA 2003 Term: Excluded Obligations/Excluded Deliverable Obligations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path common_domain_model:excluded ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Indicates whether or not the obligation is quoted, listed or ordinarily purchased and sold on an exchange. ISDA 2003 Term: Listed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:listed ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published additional provisions for U.S. Municipal as Reference Entity. ISDA 2003 Term: Full Faith and Credit Obligation Liability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:fullFaithAndCreditObLiability ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Any obligation that is not primarily (majority) owed to a Sovereign or Supranational Organisation. ISDA 2003 Term: Not Sovereign Lender." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:notSovereignLender ],
        [ sh:class common_domain_model:NotDomesticCurrency ;
            sh:description "An obligation and deliverable obligation characteristic. Any obligation that is payable in any currency other than the domestic currency. Domestic currency is either the currency so specified or, if no currency is specified, the currency of (a) the reference entity, if the reference entity is a sovereign, or (b) the jurisdiction in which the relevant reference entity is organised, if the reference entity is not a sovereign. ISDA 2003 Term: Not Domestic Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:notDomesticCurrency ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. If the reference entity is a Sovereign, this means any obligation that is not subject to the laws of the reference entity. If the reference entity is not a sovereign, this means any obligation that is not subject to the laws of the jurisdiction of the reference entity. ISDA 2003 Term: Not Domestic Law." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:notDomesticLaw ],
        [ sh:datatype xsd:string ;
            sh:description "Applies to Loan CDS, to indicate what lien level is appropriate for a deliverable obligation. Applies to European Loan CDS, to indicate the Ranking of the obligation. Example: a 2nd lien Loan CDS would imply that the deliverable obligations are 1st or 2nd lien loans." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path common_domain_model:designatedPriority ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published Standard Terms Supplement for use with CDS Transactions on Leveraged Loans. ISDA 2003 Term: Cash Settlement Only." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path common_domain_model:cashSettlementOnly ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published additional provisions for U.S. Municipal as Reference Entity. ISDA 2003 Term: General Fund Obligation Liability." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:generalFundObligationLiability ],
        [ sh:datatype xsd:string ;
            sh:description "This element is used to specify any other obligations of a reference entity in both obligations and deliverable obligations. The obligations can be specified free-form. ISDA 2003 Term: Other Obligations of a Reference Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path common_domain_model:othReferenceEntityObligations ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Defined in the ISDA published Standard Terms Supplement for use with CDS Transactions on Leveraged Loans. ISDA 2003 Term: Delivery of Commitments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path common_domain_model:deliveryOfCommitments ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. An obligation that ranks at least equal with the most senior Reference Obligation in priority of payment or, if no Reference Obligation is specified in the related Confirmation, the obligations of the Reference Entity that are senior. ISDA 2003 Term: Not Subordinated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:notSubordinated ],
        [ sh:datatype xsd:boolean ;
            sh:description "An obligation and deliverable obligation characteristic. Any obligation other than an obligation that was intended to be offered for sale primarily in the domestic market of the relevant Reference Entity. This specifies that the obligation must be an internationally recognised bond. ISDA 2003 Term: Not Domestic Issuance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:notDomesticIssuance ],
        [ sh:description "Used in both obligations and deliverable obligations to represent a class or type of securities which apply. ISDA 2003 Term: Obligation Category/Deliverable Obligation Category." ;
            sh:in ( "Payment" "BorrowedMoney" "ReferenceObligationsOnly" "Bond" "Loan" "BondOrLoan" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:category ] ;
    sh:targetClass common_domain_model:Obligations .

common_domain_model:ObservationDate a sh:NodeShape ;
    rdfs:comment "Specifies a single date on which market observations take place and specifies optional associated weighting." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies an identification key for the market observation. This attribute can be used as a reference to assign weights to a series of dates defined in a parametricSchedule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:observationReference ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the degree of importance of the observation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:weight ],
        [ sh:datatype xsd:date ;
            sh:description "A date subject to adjustment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unadjustedDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedDate ] ;
    sh:targetClass common_domain_model:ObservationDate .

common_domain_model:ObservationDates a sh:NodeShape ;
    rdfs:comment "Describes date details for a set of observation dates in parametric or non-parametric form." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ParametricDates ;
            sh:description "Specifies parametric terms to determine which days within a given calculation period the price would be observed. Typically associated with Commodities. " ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:parametricDates ],
        [ sh:class common_domain_model:PeriodicDates ;
            sh:description "Specifies the date range and frequency on which market observations take place.  Weights can be assigned to dates in the schedule by assigning the weight and corresponding observationReference in the observationSchedule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:periodicSchedule ],
        [ sh:class common_domain_model:ObservationSchedule ;
            sh:description "Specifies a schedule of dates (non-parametric) on which market observations take place, and allows for the optional definition of weights where applicable.  When no weight is specified, then weight of each date is assumed to be 1.0" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:observationSchedule ] ;
    sh:targetClass common_domain_model:ObservationDates .

common_domain_model:ObservationIdentifier a sh:NodeShape ;
    rdfs:comment "Defines the parameters needed to uniquely identify a piece of data among the population of all available market data." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InformationSource ;
            sh:description "Represents where the market data published and should be observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:informationSource ],
        [ sh:description "Represents the asset or rate to which the observation relates." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Asset ] [ sh:class common_domain_model:Basket ] [ sh:class common_domain_model:Index ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:observable ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "Represents the time and time-zone." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:observationTime ],
        [ sh:class common_domain_model:DeterminationMethodology ;
            sh:description "Specifies the method according to which an amount or a date is determined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:determinationMethodology ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date value to use when resolving the market data." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:observationDate ] ;
    sh:targetClass common_domain_model:ObservationIdentifier .

common_domain_model:ObservationInstruction a sh:NodeShape ;
    rdfs:comment "Specifies inputs needed to process an observation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ObservationEvent ;
            sh:description "Contains all information related to an observation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:observationEvent ] ;
    sh:targetClass common_domain_model:ObservationInstruction .

common_domain_model:ObservationParameters a sh:NodeShape ;
    rdfs:comment "Parameters on daily observed computed rates, specifically daily caps and floors. This type is used to represent modular computed rates in interestRatePayouts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "A daily observation floor rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:observationFloorRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "A daily observation cap rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:observationCapRate ] ;
    sh:targetClass common_domain_model:ObservationParameters .

common_domain_model:ObservationSchedule a sh:NodeShape ;
    rdfs:comment "Specifies a single date on which market observations take place and specifies optional associated weighting." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ObservationDate ;
            sh:description "Specifies an adjusted or unadjusted date for a market observation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:observationDate ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The business day convention and financial business centers used for adjusting the date if it would otherwise fall on a day that is not a business date in the specified business centers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:dateAdjustments ] ;
    sh:targetClass common_domain_model:ObservationSchedule .

common_domain_model:ObservationShiftCalculation a sh:NodeShape ;
    rdfs:comment "Parameters to describe the observation shift for a daily compounded or averaged floating rate. This type is used to represent modular computed rates in interestRatePayouts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Whether the rate is calculated in advance, in arrears, or relative to a reset date." ;
            sh:in ( "SetInAdvance" "Standard" "FixingDate" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:calculationBase ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of days of observation shift." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:offsetDays ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "Any additional business days that be applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:additionalBusinessDays ] ;
    sh:targetClass common_domain_model:ObservationShiftCalculation .

common_domain_model:OptionFeature a sh:NodeShape ;
    rdfs:comment "Defines additional optional features that can be included in an option contract." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:StrategyFeature ;
            sh:description "Defines a simple strategy feature." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:strategyFeature ],
        [ sh:class common_domain_model:AveragingFeature ;
            sh:description "Defines an option feature in which an average market observation price is determined on valuation and compared to the strike to determine a settlement amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:averagingFeature ],
        [ sh:class common_domain_model:FxFeature ;
            sh:description "Describes a quanto or composite FX feature." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:fxFeature ],
        [ sh:class common_domain_model:Barrier ;
            sh:description "Specifies a barrier feature." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:barrier ],
        [ sh:class common_domain_model:PassThrough ;
            sh:description "Specifies the rules for pass-through payments from the underlier, such as dividends." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:passThrough ] ;
    sh:targetClass common_domain_model:OptionFeature .

common_domain_model:OptionalEarlyTermination a sh:NodeShape ;
    rdfs:comment "A data defining:  an early termination provision where either or both parties have the right to exercise." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:OptionalEarlyTerminationAdjustedDates ;
            sh:description "An early termination provision to terminate the trade at fair value where one or both parties have the right to decide on termination." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:optionalEarlyTerminationAdjustedDates ],
        [ sh:class common_domain_model:CalculationAgent ;
            sh:description "The ISDA Calculation Agent responsible for performing duties associated with an optional early termination." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:calculationAgent ],
        [ sh:class common_domain_model:BuyerSeller ;
            sh:description "If optional early termination is not available to both parties then this component specifies the buyer and seller of the option. In FpML, this attribute is of type SinglePsrtyOption, which actually consists of the BuyerSeller.model." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:singlePartyOption ],
        [ sh:class common_domain_model:ExerciseTerms ;
            sh:description "The exercise terms associated with the optional early termination, including details such as exercise style, exercise fees, and any other relevant conditions or terms." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:exerciseTerms ],
        [ sh:class common_domain_model:ExerciseNotice ;
            sh:description "Definition of the party to whom notice of exercise should be given." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:exerciseNotice ],
        [ sh:datatype xsd:boolean ;
            sh:description "Used for specifying whether the Mutual Early Termination Right that is detailed in the Master Confirmation will apply." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:mutualEarlyTermination ],
        [ sh:datatype xsd:boolean ;
            sh:description "A flag to indicate whether follow-up confirmation of exercise (written or electronic) is required following telephonic notice by the buyer to the seller or seller's agent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:followUpConfirmation ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "If specified, this means that cash settlement is applicable to the transaction and defines the parameters associated with the cash settlement procedure. If not specified, then physical settlement is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:cashSettlement ] ;
    sh:targetClass common_domain_model:OptionalEarlyTermination .

common_domain_model:OptionalEarlyTerminationAdjustedDates a sh:NodeShape ;
    rdfs:comment "A data defining:  the adjusted dates associated with an optional early termination provision." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EarlyTerminationEvent ;
            sh:description "The adjusted dates associated with an individual early termination date." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:earlyTerminationEvent ] ;
    sh:targetClass common_domain_model:OptionalEarlyTerminationAdjustedDates .

common_domain_model:OrdrTrnsmssn a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:trnsmssnInd ] ;
    sh:targetClass common_domain_model:OrdrTrnsmssn .

common_domain_model:PartialExercise a sh:NodeShape ;
    rdfs:comment "A class defining partial exercise. As defined in the 2000 ISDA Definitions, Section 12.3 Partial Exercise, the buyer of the option may exercise all or less than all the notional amount of the underlying swap but may not be less than the minimum notional amount (if specified) and must be an integral multiple of the integral multiple amount if specified." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:maximumNotionalAmount rdf:type common_domain_model:maximumNumberOfOptions ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The minimum number of options that can be exercised on a given exercise date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:minimumNumberOfOptions ],
        [ sh:class common_domain_model:Money ;
            sh:description "A pointer style reference to the associated notional schedule defined elsewhere in the document. This element has been made optional as part of its integration in the OptionBaseExtended, because not required for the options on securities." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:notionalReference ],
        [ sh:datatype xsd:decimal ;
            sh:description "A notional amount which restricts the amount of notional that can be exercised when partial exercise or multiple exercise is applicable. The integral multiple amount defines a lower limit of notional that can be exercised and also defines a unit multiple of notional that can be exercised, i.e. only integer multiples of this amount can be exercised." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:integralMultipleAmount ],
        [ sh:datatype xsd:decimal ;
            sh:description "The minimum notional amount that can be exercised on a given exercise date. See multipleExercise." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:minimumNotionalAmount ] ;
    sh:targetClass common_domain_model:PartialExercise .

common_domain_model:PartyChangeInstruction a sh:NodeShape ;
    rdfs:comment "Specifies instruction to change the party on a trade. This primitive instruction is used in a number of scenarios including: clearing, allocation and novation. The instrution must include a trade identifier, because a change of party effectively results in a different trade." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PartyRole ;
            sh:description "Specifies an additional party roles to be added on to the new transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyRole ],
        [ sh:class common_domain_model:Counterparty ;
            sh:description "The new counterparty who is stepping into the trade. The stepping out counterparty is inferred based on the counterparty role that is being updated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:counterparty ],
        [ sh:class common_domain_model:AncillaryParty ;
            sh:description "Specifies an ancillary party to be added onto the new transaction, e.g. the original executing party in an allocation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:ancillaryParty ],
        [ sh:class common_domain_model:TradeIdentifier ;
            sh:description "The identifier to be assigned to the new trade post change of party." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:tradeId ] ;
    sh:targetClass common_domain_model:PartyChangeInstruction .

common_domain_model:PartyCustomisedWorkflow a sh:NodeShape ;
    rdfs:comment "A class to specify a party-related, non-standardized data in a generic form." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The party name to which the workflow pertains to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:partyName ],
        [ sh:class common_domain_model:CustomisedWorkflow ;
            sh:description "Non-standardized data in a generic form." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:customisedWorkflow ],
        [ sh:class common_domain_model:Party ;
            sh:description "Reference to the party to which the workflow pertains to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyReference ] ;
    sh:targetClass common_domain_model:PartyCustomisedWorkflow .

common_domain_model:PartyIdentifier a sh:NodeShape ;
    rdfs:comment "Comprises an identifier and a source. The associated metadata key denotes the ability to associate a hash value to the PartyIdentifier instantiations for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Provides an identifier associated with a party. The identifier is unique within the public source specified in the source attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:description "Defines the source of the identifier." ;
            sh:in ( "BIC" "LEI" "MIC" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:identifierType ] ;
    sh:targetClass common_domain_model:PartyIdentifier .

common_domain_model:PartyOptionTerminationCurrency a sh:NodeShape ;
    rdfs:comment "Specifies mechanism for Termination currency to be selected by the Non-defaulting Party/party which is not the Affected Party." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies termination currency where there are two Affected Parties and they cannot agree on the termination currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:bothAffectedTermCurrencyOption ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies alternative conditions for selection of the termination currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:terminationCurrencySpecifiedCondition ],
        [ sh:description "Specifies the enumerated conditions for selection of the termination currency." ;
            sh:in ( "PaymentsDue" "FreelyAvailable" "PaymentsDueAndFreelyAvailable" "Specified" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:terminationCurrencyCondition ] ;
    sh:targetClass common_domain_model:PartyOptionTerminationCurrency .

common_domain_model:PartyTerminationCurrencySelection a sh:NodeShape ;
    rdfs:comment "Specifies the termination currency to be used by a party when it is the Non-Defaulting Party or the Party which is not the Affected Party." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "The elective party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies termination Currency." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:statedPartyCurrency ] ;
    sh:targetClass common_domain_model:PartyTerminationCurrencySelection .

common_domain_model:PassThrough a sh:NodeShape ;
    rdfs:comment "Type which contains pass through payments." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PassThroughItem ;
            sh:description "One to many pass through payment items." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:passThroughItem ] ;
    sh:targetClass common_domain_model:PassThrough .

common_domain_model:PassThroughItem a sh:NodeShape ;
    rdfs:comment "Class to represent a single pass through payment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Percentage of payments from the underlier which are passed through." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:passThroughPercentage ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "This attribute doesn't exists in the FpML construct, which makes use of the PayerReceiver.model group." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:payerReceiver ] ;
    sh:targetClass common_domain_model:PassThroughItem .

common_domain_model:PaymentCalculationPeriod a sh:NodeShape ;
    rdfs:comment "A data defining:  the adjusted payment date and associated calculation period parameters required to calculate the actual or projected payment amount. This data forms:  part of the cashflow representation of a swap stream." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The adjusted payment date. This date should already be adjusted for any applicable business day convention. This component is not intended for use in trade confirmation but may be specified to allow the fee structure to also serve as a cashflow type component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedPaymentDate ],
        [ sh:class common_domain_model:Money ;
            sh:description "A known fixed payment amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fixedPaymentAmount ],
        [ sh:datatype xsd:decimal ;
            sh:description "A decimal value representing the discount factor used to calculate the present value of cash flow." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:discountFactor ],
        [ sh:class common_domain_model:Money ;
            sh:description "A monetary amount representing the present value of the forecast payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:presentValueAmount ],
        [ sh:class common_domain_model:CalculationPeriod ;
            sh:description "The parameters used in the calculation of a fixed or floating rate calculation period amount. A list of calculation period elements may be ordered in the document by ascending start date. An FpML document which contains an unordered list of calculation periods is still regarded as a conformant document." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:calculationPeriod ],
        [ sh:datatype xsd:date ;
            sh:description "The unadjusted payment date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unadjustedPaymentDate ],
        [ sh:class common_domain_model:Money ;
            sh:description "A monetary amount representing the forecast of the future value of the payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:forecastPaymentAmount ] ;
    sh:targetClass common_domain_model:PaymentCalculationPeriod .

common_domain_model:PaymentDateSchedule a sh:NodeShape ;
    rdfs:comment "The payment dates when specified as relative to a set of dates specified somewhere else in the instance document/transaction, e.g. the valuation dates as typically the case for equity swaps, or when specified as a calculation period schedule." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The last payment when specified as an adjustable or relative date, as in the FpML total return construct." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:finalPaymentDate ],
        [ sh:class common_domain_model:AdjustableRelativeOrPeriodicDates ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:interimPaymentDates ] ;
    sh:targetClass common_domain_model:PaymentDateSchedule .

common_domain_model:PaymentDetail a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "A fixed payment amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:paymentAmount ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The feature payment date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:paymentDate ],
        [ sh:class common_domain_model:PaymentRule ;
            sh:description "The calculation rule." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:paymentRule ] ;
    sh:targetClass common_domain_model:PaymentDetail .

common_domain_model:PaymentRule a sh:NodeShape ;
    rdfs:comment "A class defining the payment calculation rule. As of FpML 5.10, percentage rule is the only calculation rule that has been specified as part of the standard." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PercentageRule ;
            sh:description "This attribute is not present as part of the FpML construct, as the payment rule is specialised by means of runtime type extension through the xsi:type." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:percentageRule ] ;
    sh:targetClass common_domain_model:PaymentRule .

common_domain_model:PercentageRule a sh:NodeShape ;
    rdfs:comment "A class defining a content model for a calculation rule defined as percentage of the notional amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "A reference to the notional amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:notionalAmountReference ],
        [ sh:datatype xsd:decimal ;
            sh:description "A percentage of the notional amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:paymentPercent ] ;
    sh:targetClass common_domain_model:PercentageRule .

common_domain_model:PeriodRange a sh:NodeShape ;
    rdfs:comment "Indicates The period range defined as either a lower and upper period bound, or both." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PeriodBound ;
            sh:description "Specifies the lower bound of a period range, e.g. greater than or equal to 5Y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:lowerBound ],
        [ sh:class common_domain_model:PeriodBound ;
            sh:description "Specifies the upper bound of a period range, e.g. less than to 10Y." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:upperBound ] ;
    sh:targetClass common_domain_model:PeriodRange .

common_domain_model:PersonIdentifier a sh:NodeShape ;
    rdfs:comment "Comprises an identifier and a source. The associated metadata key denotes the ability to associate a hash value to the PersonIdentifier instantiations for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Provides an identifier associated with a person. The identifier is unique within the public source specified in the source attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "The ISO 3166 standard code for the country issuing the identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:country ],
        [ sh:description "Defines the source of the identifier." ;
            sh:in ( "ARNU" "CCPT" "CUST" "DRLC" "EMPL" "NIDN" "SOSE" "TXID" "NPID" "PLID" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:identifierType ] ;
    sh:targetClass common_domain_model:PersonIdentifier .

common_domain_model:PhysicalSettlementPeriod a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "A number of business days. Its precise meaning is dependant on the context in which this element is used. ISDA 2003 Term: Business Day." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:businessDays ],
        [ sh:datatype xsd:integer ;
            sh:description "A maximum number of business days. Its precise meaning is dependant on the context in which this element is used. Intended to be used to limit a particular ISDA fallback provision." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:maximumBusinessDays ],
        [ sh:datatype xsd:boolean ;
            sh:description "An explicit indication that a number of business days are not specified and therefore ISDA fallback provisions should apply." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:businessDaysNotSpecified ] ;
    sh:targetClass common_domain_model:PhysicalSettlementPeriod .

common_domain_model:PledgeeRepresentativeRider a sh:NodeShape ;
    rdfs:comment "The terms of the Rider for the ISDA Euroclear 2019 Collateral Transfer Agreement with respect to the use of a Pledgee Representative attached to this Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CustomisableOffset ;
            sh:description "The definition of representative end date in relation to a representative event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:representativeEndDate ],
        [ sh:datatype xsd:string ;
            sh:description "The specific representative event terms applicable when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:representativeEventTerms ],
        [ sh:datatype xsd:string ;
            sh:description "The specific representative terms applicable when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:representativeTerms ],
        [ sh:description "Identification of the represented party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:boolean ;
            sh:description "Identification of whether the representative CTA provisions are applicable (True) or not applicable (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:description "The specification of whether the representative event terms are applicable." ;
            sh:in ( "Applicable" "NotApplicable" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:representativeEvent ] ;
    sh:targetClass common_domain_model:PledgeeRepresentativeRider .

common_domain_model:PortfolioReturnTerms a sh:NodeShape ;
    rdfs:comment "Specifies an individual type of return of a Performance Payout, when such individual return is part of an aggregation of multiple similar returns, at Performance Payout level." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NonNegativeQuantitySchedule ;
            sh:description "Specifies a quantity schedule for the underlier, which applies to each individual return leg." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "2018 ISDA CDM Equity Confirmation for Security Equity Swap: Final Price | Specifies the final valuation price of the underlier. This price can be expressed either as an actual amount/currency, as a determination method, or by reference to another value specified in the swap document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:finalValuationPrice ],
        [ sh:class common_domain_model:DividendReturnTerms ;
            sh:description "Return terms based upon dividend payments associated to the underlier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:dividendReturnTerms ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies the initial valuation price(s) of the underlier. This price can be expressed either as an actual amount/currency, as a determination method, or by reference to another value specified in the swap document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:interimValuationPrice ],
        [ sh:class common_domain_model:VarianceReturnTerms ;
            sh:description "Return terms based upon the observed variance of the underlier's price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:varianceReturnTerms ],
        [ sh:class common_domain_model:VolatilityReturnTerms ;
            sh:description "Return terms based upon the observed volatility of the underlier's price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:volatilityReturnTerms ],
        [ sh:class common_domain_model:PriceReturnTerms ;
            sh:description "Return terms based upon the underlier's observed price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:priceReturnTerms ],
        [ sh:class common_domain_model:CorrelationReturnTerms ;
            sh:description "Return terms based upon the observed correlation between the components of the underlying basket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:correlationReturnTerms ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each individual return leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies the initial valuation price(s) of the underlier. This price can be expressed either as an actual amount/currency, as a determination method, or by reference to another value specified in the swap document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:initialValuationPrice ],
        [ sh:description "Defines the product that is the subject of a tradable product definition, an underlying product definition, a physical exercise, a position, or other purposes." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Observable ] [ sh:class common_domain_model:Product ] ) ;
            sh:order 1 ;
            sh:path common_domain_model:underlier ] ;
    sh:targetClass common_domain_model:PortfolioReturnTerms .

common_domain_model:Position a sh:NodeShape ;
    rdfs:comment "A Position describes how much of a given Product is being held and constitutes the atomic element of a Portfolio." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceQuantity ;
            sh:description "Position with many price quantities." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "Reference to the Contract, in case product is contractual and the contract has been formed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:tradeReference ],
        [ sh:description "The asset that underlies the position." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:asset ],
        [ sh:class common_domain_model:Money ;
            sh:description "The aggregate cost of proceeds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:cashBalance ],
        [ sh:class common_domain_model:Product ;
            sh:description "The product underlying the position." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:product ] ;
    sh:targetClass common_domain_model:Position .

common_domain_model:PositionIdentifier a sh:NodeShape ;
    rdfs:comment "Defines a position identifier as a special case of the generic identifier type, that also includes the position identifier class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "The identifier issuer, when specified by reference to a party specified as part of the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:issuerReference ],
        [ sh:description "The enumerated classification of the identifier. Optional as a position identifier may be party-specific, in which case it may not correspond to any established classification." ;
            sh:in ( "UniqueTransactionIdentifier" "UniqueSwapIdentifier" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:identifierType ],
        [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "The identifier value. This level of indirection between the issuer and the identifier and its version provides the ability to associate multiple identifiers to one issuer, consistently with the FpML PartyTradeIdentifier." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:assignedIdentifier ],
        [ sh:datatype xsd:string ;
            sh:description "The identifier issuer, when specified explicitly alongside the identifier value (instead of being specified by reference to a party)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:issuer ] ;
    sh:targetClass common_domain_model:PositionIdentifier .

common_domain_model:PostingObligationsElection a sh:NodeShape ;
    rdfs:comment "Specifies the collateral posting obligations for the security provider party(ies)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:otherEligibleSupport ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The excluded collateral as specified in relation to the pledgor/chargor/obligor(s) posting obligation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:excludedCollateral ],
        [ sh:class common_domain_model:EligibleCollateralCriteria ;
            sh:description "The eligible collateral as specified in relation to the pledgor/chargor/obligor(s) posting obligation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:eligibleCollateral ],
        [ sh:datatype xsd:boolean ;
            sh:description "If set to True, the Control Agreement is a Credit Support Document with respect to the party(ies)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:asPermitted ],
        [ sh:description "Specifies the party providing the security." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:PostingObligationsElection .

common_domain_model:PriceMateriality a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SettlementRateOption ;
            sh:description "The method, prioritised by the order it is listed in this element, to get a replacement rate for the disrupted settlement rate option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:fallbackReferencePrice ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:priceMaterialityIsApplicable ] ;
    sh:targetClass common_domain_model:PriceMateriality .

common_domain_model:PriceSource a sh:NodeShape ;
    rdfs:comment "Specifies a publication that provides the commodity price, including, where applicable, the details of where in the publication the price is published." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:time ;
            sh:description "Specifies the time at which the price should be observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:priceSourceTime ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the heading or field name for the price  on a given page or screen, where applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:priceSourceHeading ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the location of the price which may be a specific page, electornic screen name, or a code (e.g. a RIC code) where the price can be found." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:priceSourceLocation ],
        [ sh:datatype xsd:string ;
            sh:description "Defines a publication in which the price can be found. (e.g Gas Daily, Platts Bloomberg. Commodity publishers can be found at this URL:  http://www.fpml.org/coding-scheme/commodity-information-provider>" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:pricePublisher ] ;
    sh:targetClass common_domain_model:PriceSource .

common_domain_model:PriceSourceDisruption a sh:NodeShape ;
    rdfs:comment "A data defining:  the parameters used to get a price quote to replace the settlement rate option that is disrupted." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FallbackReferencePrice ;
            sh:description "The method, prioritised by the order it is listed in this element, to get a replacement rate for the disrupted settlement rate option." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:fallbackReferencePrice ] ;
    sh:targetClass common_domain_model:PriceSourceDisruption .

common_domain_model:PricingDates a sh:NodeShape ;
    rdfs:comment "Specifies specific dates or parametric rules for the dates on which the price will be determined" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ParametricDates ;
            sh:description "Defines rules for the dates on which the price will be determined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:parametricDates ],
        [ sh:class common_domain_model:AdjustableDates ;
            sh:description "Defines specified dates on which the price will be determined." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:specifiedDates ] ;
    sh:targetClass common_domain_model:PricingDates .

common_domain_model:PrincipalPaymentSchedule a sh:NodeShape ;
    rdfs:comment "Describe dates schedules for Principal Exchanges and related role of the parties when known." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PrincipalPayment ;
            sh:description "Principal Payment at Trade maturity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:finalPrincipalPayment ],
        [ sh:class common_domain_model:AdjustableRelativeOrPeriodicDates ;
            sh:description "Principal Payment as part of the Trade lifecycle e.g. as part of notional reset adjustements in a Cross Currency Swap with a varying notional leg." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:intermediatePrincipalPayment ],
        [ sh:class common_domain_model:PrincipalPayment ;
            sh:description "Principal Payment made at Trade inception." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:initialPrincipalPayment ] ;
    sh:targetClass common_domain_model:PrincipalPaymentSchedule .

common_domain_model:ProcessAgentElection a sh:NodeShape ;
    rdfs:comment "Specifies the parties' respective elections with respect to the Process Agent." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "Specification of the process agent entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:entity ],
        [ sh:datatype xsd:string ;
            sh:description "Additional information relating to the Process Agent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalInformation ],
        [ sh:class common_domain_model:ContactInformation ;
            sh:description "The main notice/address information of the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:primaryContactInformation ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether the Process Agent is applicable (True) or not applicable (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:description "The party to which the election and details apply." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:partyReference ] ;
    sh:targetClass common_domain_model:ProcessAgentElection .

common_domain_model:ProductIdentifier a sh:NodeShape ;
    rdfs:comment "Comprises an identifier and a source. The associated metadata key denotes the ability to associate a hash value to the ProductIdentifier instantiations for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Provides an identifier associated with a specific product.  The identifier is unique within the public source specified in the source attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:description "Defines the source of the identifier." ;
            sh:in ( "BBGID" "BBGTICKER" "CUSIP" "FIGI" "ISDACRP" "ISIN" "Name" "REDID" "RIC" "Other" "Sicovam" "SEDOL" "UPI" "Valoren" "Wertpapier" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:source ] ;
    sh:targetClass common_domain_model:ProductIdentifier .

common_domain_model:PubliclyAvailableInformation a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "If this element is specified and set to 'true', indicates that ISDA defined Standard Public Sources are applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:standardPublicSources ],
        [ sh:datatype xsd:string ;
            sh:description "A public information source, e.g. a particular newspaper or electronic news service, that may publish relevant information used in the determination of whether or not a credit event has occurred. ISDA 2003 Term: Public Source." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:publicSource ],
        [ sh:datatype xsd:integer ;
            sh:description "The minimum number of the specified public information sources that must publish information that reasonably confirms that a credit event has occurred. The market convention is two. ISDA 2003 Term: Specified Number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:specifiedNumber ] ;
    sh:targetClass common_domain_model:PubliclyAvailableInformation .

common_domain_model:Qty a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unit ] ;
    sh:targetClass common_domain_model:Qty .

common_domain_model:QuantityChangeInstruction a sh:NodeShape ;
    rdfs:comment "Instructions required to create a Quantity Change Primitive Event, which can be either an increase, a decrease or a replacement. An increase adds a new trade lot to the original trade, whereas a decrease subtracts from an existing trade lot's quantity. A replacement updates the quantity of an existing trade lot to the new value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Direction of the quantity change specified as either an increase, decrease or replacement." ;
            sh:in ( "Increase" "Decrease" "Replace" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:direction ],
        [ sh:class common_domain_model:PriceQuantity ;
            sh:description "Quantity by which the trade is being increased, decreased or replaced, and the price at which such quantity change is agreed. The quantity change should always be specified as a positive number, with the direction (increase/decrease/replacement) being specified by the direction enumeration. A fee can also be associated to the quantity change by specifying a Price component of type CashPrice, including the corresponding settlement date and direction." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:change ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Identifier for the new lot (in case of increase) or for the existing lot to be changed(in case of decrease or replacement). This optional attribute is mandatory in case of a decrease or replacement if the initial trade state contains multiple trade lots." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:lotIdentifier ] ;
    sh:targetClass common_domain_model:QuantityChangeInstruction .

common_domain_model:QuantityMultiplier a sh:NodeShape ;
    rdfs:comment " Class to specify a mechanism for a quantity to be set as a multiplier to another (reference) quantity, based on a price observation. At the moment this class only supports FX or Equity-linked notional and re-uses existing building blocks for those 2 cases, until such time when component can be made more generic. This captures the case of resetting cross-currency swaps and resetting equity swaps." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FxLinkedNotionalSchedule ;
            sh:description "Multiplier specified as an FX-linked schedule, e.g. for a resetting cross-currency swap.." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:fxLinkedNotionalSchedule ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:multiplierValue ] ;
    sh:targetClass common_domain_model:QuantityMultiplier .

common_domain_model:Quanto a sh:NodeShape ;
    rdfs:comment "Determines the currency rate that the seller of the equity amounts will apply at each valuation date for converting the respective amounts into a currency that is different from the currency denomination of the underlier." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The time at which the spot currency exchange rate will be observed. It is specified as a time in a business day calendar location, e.g. 11:00am London time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:fixingTime ],
        [ sh:class common_domain_model:FxSpotRateSource ;
            sh:description "Specifies the methodology (reference source and, optionally, fixing time) to be used for determining a currency conversion rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fxSpotRateSource ],
        [ sh:class common_domain_model:FxRate ;
            sh:description "Specifies a currency conversion rate." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:fxRate ] ;
    sh:targetClass common_domain_model:Quanto .

common_domain_model:QuasiGovernmentIssuerType a sh:NodeShape ;
    rdfs:comment "Represents a class to allow specification of different types of Quasi Government collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Applies to non-sovereign entity (e.g. separate legal personality from sovereign).  True if entity has recourse to sovereign (e.g. debt guaranteed by government).  False if entity does not have recourse to sovereign." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:sovereignRecourse ],
        [ sh:datatype xsd:boolean ;
            sh:description "True if sovereign entity (e.g. not separate legal personality from sovereign) or false if non-sovereign entity (e.g. separate legal personality from sovereign)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:sovereignEntity ] ;
    sh:targetClass common_domain_model:QuasiGovernmentIssuerType .

common_domain_model:RatingAgencyAmount a sh:NodeShape ;
    rdfs:comment "A logical container to hold a defined set of related data. In this case the collation of Rating Information and an associated Independent Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Specifies the notional or collateral Independent Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:amount ],
        [ sh:class common_domain_model:CreditNotation ;
            sh:description "Allows a grouping of Rating agencies and Rating values." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:ratingVariableSet ] ;
    sh:targetClass common_domain_model:RatingAgencyAmount .

common_domain_model:RatingMultiplier a sh:NodeShape ;
    rdfs:comment "A logical container to hold a defined set of related data. In this case the collation of Ratings Information and associated exposure multiplier." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CreditNotation ;
            sh:description "Allows a grouping of Rating agencies and Rating values." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:ratingVariableSet ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the multiplier applied to exposure based on the credit rating of the rated party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:exposureMultiplier ] ;
    sh:targetClass common_domain_model:RatingMultiplier .

common_domain_model:RecalculationOfValue a sh:NodeShape ;
    rdfs:comment "A class to specify terms for Recalculation of the Market Value of Posted Collateral when a dispute has been failed to be resolved by Resolution Time." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RecalculationOfValueElection ;
            sh:description "The parties' Recalculation of Value terms." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:RecalculationOfValue .

common_domain_model:RecalculationOfValueElection a sh:NodeShape ;
    rdfs:comment "A class to specify Recalculation of Value terms that will be applicable." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The procedure for Recalculation of Value." ;
            sh:in ( "ConsulationProcedure" "OtherRegulatoryCSAProcedure" "NotApplicable" "Specified" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:recalculationOfValueElection ],
        [ sh:datatype xsd:string ;
            sh:description "Additional Recalculation of Value terms when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:recalculationOfValueTerms ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:RecalculationOfValueElection .

common_domain_model:RecallProvision a sh:NodeShape ;
    rdfs:comment "Defines the additional features that allow securities to be recalled by the lender before the term of the loan. A recall is not the same as an early termination, but may result in the early termination of a loan." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether the securities on loan can be recalled by the lender." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isRecallable ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "The operational deadline on T+0 before which a recall must be requested. For the UK, best practice recommends that this would be 30 minutes before market close i.e. 16:00:00 GMT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:issuanceCutoffTime ],
        [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The intended settlement date of the recall, expressed as an offset against a relative date e.g. T+1. The best practice is that the borrower must make their best efforts to settle on T+1." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:intendedSettlementDate ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "The time on the day of intended settlement by which the borrower must notify the lender that they will be returning the requested security. For the UK, best practice recommends that this would be 30 minutes before the CREST DVP cut-off time i.e. 15:15:00 GMT" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:notificationTime ] ;
    sh:targetClass common_domain_model:RecallProvision .

common_domain_model:RefRate a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:indx ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:nm ] ;
    sh:targetClass common_domain_model:RefRate .

common_domain_model:ReferenceBank a sh:NodeShape ;
    rdfs:comment "A class to describe an institution (party) identified by means of a coding scheme and an optional name." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "An institution (party) identifier, e.g. a bank identifier code (BIC). FpML specifies a referenceBankIdScheme." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:referenceBankId ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the institution (party). A free format string. FpML does not define usage rules for the element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:referenceBankName ] ;
    sh:targetClass common_domain_model:ReferenceBank .

common_domain_model:ReferenceBanks a sh:NodeShape ;
    rdfs:comment "A class defining the list of reference institutions polled for relevant rates or prices when determining the cash settlement amount for a product where cash settlement is applicable." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ReferenceBank ;
            sh:description "An institution (party) identified by means of a coding scheme and an optional name." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:referenceBank ] ;
    sh:targetClass common_domain_model:ReferenceBanks .

common_domain_model:ReferencePair a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ReferenceObligation ;
            sh:description "The Reference Obligation is a financial instrument that is either issued or guaranteed by the reference entity. It serves to clarify the precise reference entity protection is being offered upon, and its legal position with regard to other related firms (parents/subsidiaries). Furthermore the Reference Obligation is ALWAYS deliverable and establishes the Pari Passu ranking (as the deliverable bonds must rank equal to the reference obligation). ISDA 2003 Term: Reference Obligation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:referenceObligation ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The corporate or sovereign entity on which you are buying or selling protection and any successor that assumes all or substantially all of its contractual and other obligations. It is vital to use the correct legal name of the entity and to be careful not to choose a subsidiary if you really want to trade protection on a parent company. Please note, Reference Entities cannot be senior or subordinated. It is the obligations of the Reference Entities that can be senior or subordinated. ISDA 2003 Term: Reference Entity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:referenceEntity ],
        [ sh:description "Defines the reference entity types corresponding to a list of types in the ISDA First to Default documentation." ;
            sh:in ( <http://www.fpml.org/coding-scheme/entity-type-1-0#Asian> <http://www.fpml.org/coding-scheme/entity-type-1-0#AustralianAndNewZealand> <http://www.fpml.org/coding-scheme/entity-type-1-0#EuropeanEmergingMarkets> <http://www.fpml.org/coding-scheme/entity-type-1-0#Japanese> <http://www.fpml.org/coding-scheme/entity-type-1-0#NorthAmericanHighYield> <http://www.fpml.org/coding-scheme/entity-type-1-0#NorthAmericanInsurance> <http://www.fpml.org/coding-scheme/entity-type-1-0#NorthAmericanInvestmentGrade> <http://www.fpml.org/coding-scheme/entity-type-1-0#Singaporean> <http://www.fpml.org/coding-scheme/entity-type-1-0#WesternEuropean> <http://www.fpml.org/coding-scheme/entity-type-1-0#WesternEuropeanInsurance> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:entityType ],
        [ sh:datatype xsd:boolean ;
            sh:description "Used to indicate that there is no Reference Obligation associated with this Credit Default Swap and that there will never be one." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:noReferenceObligation ] ;
    sh:targetClass common_domain_model:ReferencePair .

common_domain_model:ReferencePool a sh:NodeShape ;
    rdfs:comment "This type contains all the reference pool items to define the reference entity and reference obligation(s) in the basket." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ReferencePoolItem ;
            sh:description "This type contains all the constituent weight and reference information." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:referencePoolItem ] ;
    sh:targetClass common_domain_model:ReferencePool .

common_domain_model:ReferencePoolItem a sh:NodeShape ;
    rdfs:comment "This type contains all the constituent weight and reference information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ProtectionTerms ;
            sh:description "Reference to the documentation terms applicable to this item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:protectionTermsReference ],
        [ sh:class common_domain_model:ConstituentWeight ;
            sh:description "Describes the weight of each of the constituents within the basket. If not provided, it is assumed to be equal weighted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:constituentWeight ],
        [ sh:class common_domain_model:CashSettlementTerms ;
            sh:description "Reference to the cash settlement terms applicable to this item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:cashSettlementTermsReference ],
        [ sh:class common_domain_model:ReferencePair ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:referencePair ],
        [ sh:class common_domain_model:PhysicalSettlementTerms ;
            sh:description "Reference to the physical settlement terms applicable to this item." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:physicalSettlementTermsReference ] ;
    sh:targetClass common_domain_model:ReferencePoolItem .

common_domain_model:ReferenceSwapCurve a sh:NodeShape ;
    rdfs:comment "A complex type used to specify the option and convertible bond option strike when expressed in reference to a swap curve." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MakeWholeAmount ;
            sh:description "Amount to be paid by the buyer of the option if the option is exercised prior to the Early Call Date. (The market practice in the convertible bond option space being that the buyer should be penalised if he/she exercises the option early on.)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:makeWholeAmount ],
        [ sh:class common_domain_model:SwapCurveValuation ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:swapUnwindValue ] ;
    sh:targetClass common_domain_model:ReferenceSwapCurve .

common_domain_model:RegimeTerms a sh:NodeShape ;
    rdfs:comment "A class that is used by the ApplicableRegime and the AdditionalRegime classes to specify the regulatory regime terms." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SimmException ;
            sh:description "The election for SIMM exception to the regulatory regime clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:simmException ],
        [ sh:description "The party for which the regime terms are being specified when acting as collateral taker." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The bespoke party specific Regime term elections applicable when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:asSpecified ],
        [ sh:description "The specification of whether the regime is elected as applicable to the party when acting as collateral taker." ;
            sh:in ( "Applicable" "NotApplicable" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:class common_domain_model:RetrospectiveEffect ;
            sh:description "Specifies the retrospective effect exception to the regulatory regime clause of Initial Margin documents as either a normalized value specified as part of an enumeration or a customized value specified of type string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:retrospectiveEffect ] ;
    sh:targetClass common_domain_model:RegimeTerms .

common_domain_model:RegionalGovernmentIssuerType a sh:NodeShape ;
    rdfs:comment "Represents a class to allow specification of different type of Regional government collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Applies to regional governments, local authorities or municipals.  True if entity has recourse to sovereign (e.g. debt guaranteed by government).  False if entity does not have recourse to sovereign." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:sovereignRecourse ] ;
    sh:targetClass common_domain_model:RegionalGovernmentIssuerType .

common_domain_model:RelativeTime a sh:NodeShape ;
    rdfs:comment "Defines a time value calculated relative to a reference time. The final value is derived by applying any offset and rounding rules inherited from RelativeTimeOffset to the reference time." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TimeZone ;
            sh:description "The reference time zone or base time from which the relative time is calculated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:timeRelativeTo ],
        [ sh:datatype xsd:integer ;
            sh:description "A time offset multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying a negative offset, e.g. -2 hours." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:offsetMultiplier ],
        [ sh:class common_domain_model:TimeRounding ;
            sh:description "Optional rules that define how the calculated time should be rounded after the offset has been applied." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:rounding ],
        [ sh:description "The unit of time for the offset (e.g., seconds, minutes, hours, days). " ;
            sh:in ( "Second" "Minute" "Hour" "Day" "Week" "Month" "Year" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:offsetTimeUnit ] ;
    sh:targetClass common_domain_model:RelativeTime .

common_domain_model:Representations a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "If present and true, then index disclaimer is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:indexDisclaimer ],
        [ sh:class common_domain_model:Clause ;
            sh:description "Any additional terms that might be specified applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:additionalBespokeTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, then non reliance is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:nonReliance ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, then additional acknowledgements are applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:additionalAcknowledgements ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, then agreements regarding hedging are applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:agreementsRegardingHedging ] ;
    sh:targetClass common_domain_model:Representations .

common_domain_model:ResetDates a sh:NodeShape ;
    rdfs:comment "A data defining:  the parameters used to generate the reset dates schedule and associated fixing dates. The reset dates are the dates on which the new index value (which is observed on the fixing date) is applied for each period and on which the interest rate hence begins to accrue." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RelativeDateOffset ;
            sh:description "The fixing dates are the dates on which the index values are observed. The fixing dates are specified by reference to the reset date through business days offset and an associated set of financial business centers. Normally these offset calculation rules will be those specified in the ISDA definition for the relevant floating rate index (ISDA's Floating Rate Option). However, non-standard offset calculation rules may apply for a trade if mutually agreed by the principal parties to the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:fixingDates ],
        [ sh:class common_domain_model:ResetFrequency ;
            sh:description "The frequency at which the reset dates occur. In the case of a weekly reset frequency, also specifies the day of the week that the reset occurs. If the reset frequency is greater than the calculation period frequency then this implies that more than one reset is established for each calculation period and some form of rate averaging is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:resetFrequency ],
        [ sh:class common_domain_model:CalculationPeriodDates ;
            sh:description "A pointer style reference to the associated calculation period dates component defined elsewhere in the document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationPeriodDatesReference ],
        [ sh:class common_domain_model:AdjustableDate ;
            sh:description "This attribute is not part of the FpML ResetDate, and has been added as part of the CDM to support the credit derivatives final fixing date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:finalFixingDate ],
        [ sh:class common_domain_model:InitialFixingDate ;
            sh:description "The initial fixing date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:initialFixingDate ],
        [ sh:class common_domain_model:Offset ;
            sh:description "Specifies the number of business days before the period end date when the rate cut-off date is assumed to apply. The financial business centers associated with determining the rate cut-off date are those specified in the reset dates adjustments. The rate cut-off number of days must be a negative integer (a value of zero would imply no rate cut off applies in which case the rateCutOffDaysOffset element should not be included). The relevant rate for each reset date in the period from, and including, a rate cut-off date to, but excluding, the next applicable period end date (or, in the case of the last calculation period, the termination date) will (solely for purposes of calculating the floating amount payable on the next applicable payment date) be deemed to be the relevant rate in effect on that rate cut-off date. For example, if rate cut-off days for a daily averaging deal is -2 business days, then the refix rate applied on (period end date - 2 days) will also be applied as the reset on (period end date - 1 day), i.e. the actual number of reset dates remains the same but from the rate cut-off date until the period end date, the same refix rate is applied. Note that in the case of several calculation periods contributing to a single payment, the rate cut-off is assumed only to apply to the final calculation period contributing to that payment. The day type associated with the offset must imply a business days offset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:rateCutOffDaysOffset ],
        [ sh:description "Specifies whether the reset dates are determined with respect to each adjusted calculation period start date or adjusted calculation period end date. If the reset frequency is specified as daily this element must not be included." ;
            sh:in ( "CalculationPeriodStartDate" "CalculationPeriodEndDate" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:resetRelativeTo ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The definition of the business day convention and financial business centers used for adjusting the reset date if it would otherwise fall on a day that is not a business day in the specified business center." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:resetDatesAdjustments ] ;
    sh:targetClass common_domain_model:ResetDates .

common_domain_model:ResetFrequency a sh:NodeShape ;
    rdfs:comment "A class defining the reset frequency. In the case of a weekly reset, also specifies the day of the week that the reset occurs. If the reset frequency is greater than the calculation period frequency the this implies that more or more reset dates is established for each calculation period and some form of rate averaging is applicable. The specific averaging method of calculation is specified in FloatingRateCalculation. In case the reset frequency is of value T (term), the period is defined by the swap/swapStream/calculationPerioDates/effectiveDate and the swap/swapStream/calculationPerioDates/terminationDate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2, or 3. If the period value is T (Term) then period multiplier must contain the value 1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:description "The day of the week on which a weekly reset date occurs. This element must be included if the reset frequency is defined as weekly and not otherwise." ;
            sh:in ( "TBILL" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:weeklyRollConvention ],
        [ sh:description "A time period, e.g. a day, week, month, year or term of the stream." ;
            sh:in ( "H" "D" "W" "M" "Y" "T" "C" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:period ] ;
    sh:targetClass common_domain_model:ResetFrequency .

common_domain_model:ResetInstruction a sh:NodeShape ;
    rdfs:comment "Defines the information needed to create a Reset Business Event. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AssetPayout ] [ sh:class common_domain_model:CommodityPayout ] [ sh:class common_domain_model:CreditDefaultPayout ] [ sh:class common_domain_model:FixedPricePayout ] [ sh:class common_domain_model:InterestRatePayout ] [ sh:class common_domain_model:OptionPayout ] [ sh:class common_domain_model:PerformancePayout ] [ sh:class common_domain_model:SettlementPayout ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:payout ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the 'Rate Record Day' for a Fallback rate.  Fallback rate fixing processes typically set the fixing rate in arrears, i.e., the Fallback Rate corresponding to a Rate Record Date is set at the end of the interest accural period.  When this applies, Reset->resetDate occurs at the end of the interest period, and the Reset->rateRecordDate occurs near the start of the interest period.  The Reset->rateRecordDate and Reset->observations->observationIdentifier->observationDate will differ if a Fallback rate is unavailable on the Rate Record Date, and the latest previous available rate is used as the observation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:rateRecordDate ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date on which the reset is occuring." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:resetDate ] ;
    sh:targetClass common_domain_model:ResetInstruction .

common_domain_model:ResolutionValue a sh:NodeShape ;
    rdfs:comment "Methodology for resolving disputes in respect of the determination of the value of collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:description "Details of how securities collateral is valued when resolving disputes." ;
            sh:in ( "BidPricePercentage" "BidPricePercentageLessHaircut" "MidPricePercentage" "MidPricePercentageLessHaircut" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:securities ],
        [ sh:datatype xsd:boolean ;
            sh:description "Represents whether a fallback calculation method is applicable. 'True' if fallback calculation method is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fallback ],
        [ sh:description "Details of how cash collateral is valued when resolving disputes." ;
            sh:in ( "CashAmount" "CashPercentage" "CashPercentageLessHaircut" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:cash ] ;
    sh:targetClass common_domain_model:ResolutionValue .

common_domain_model:ResourceLength a sh:NodeShape ;
    rdfs:comment "A class to indicate the length of the resource." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The length value of the resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:lengthValue ],
        [ sh:description "The length unit of the resource. For example, pages (pdf, text documents) or time (audio, video files)." ;
            sh:in ( "Pages" "TimeUnit" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:lengthUnit ] ;
    sh:targetClass common_domain_model:ResourceLength .

common_domain_model:Restructuring a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "In relation to a restructuring credit event, unless multiple holder obligation is not specified restructurings are limited to multiple holder obligations. A multiple holder obligation means an obligation that is held by more than three holders that are not affiliates of each other and where at least two thirds of the holders must agree to the event that constitutes the restructuring credit event. ISDA 2003 Term: Multiple Holder Obligation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:multipleHolderObligation ],
        [ sh:datatype xsd:boolean ;
            sh:description "Presence of this element and value set to 'true' indicates that Section 3.9 of the 2003 Credit Derivatives Definitions shall apply. Absence of this element indicates that Section 3.9 shall not apply. NOTE: Not allowed under ISDA Credit 1999." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:multipleCreditEventNotices ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the restructuring provision is applicable." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ],
        [ sh:description "Specifies the type of restructuring that is applicable." ;
            sh:in ( <http://www.fpml.org/coding-scheme/restructuring-1-1#ModModR> <http://www.fpml.org/coding-scheme/restructuring-1-1#ModR> <http://www.fpml.org/coding-scheme/restructuring-1-1#R> ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:restructuringType ] ;
    sh:targetClass common_domain_model:Restructuring .

common_domain_model:RetrospectiveEffect a sh:NodeShape ;
    rdfs:comment "A class to specify the retrospective effect exception to the regulatory regime clause of Initial Margin documents as either a normalized value specified as part of an enumeration or a customized value specified of type string." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The Standard Initial Margin Model exception when specified by the party according to one of the enumerated values." ;
            sh:in ( "Applicable" "NotApplicable" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:standardisedException ],
        [ sh:datatype xsd:string ;
            sh:description "The Standard Initial Margin Model exception when specified as a customized approach by the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:asSpecified ] ;
    sh:targetClass common_domain_model:RetrospectiveEffect .

common_domain_model:ReturnTerms a sh:NodeShape ;
    rdfs:comment "Specifies the type of return of a performance payout." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:interimValuationPrice rdf:type common_domain_model:underlier common_domain_model:initialValuationPrice common_domain_model:quantity common_domain_model:finalValuationPrice common_domain_model:payerReceiver ) ;
    sh:property [ sh:class common_domain_model:VolatilityReturnTerms ;
            sh:description "Return terms based upon the observed volatility of the underlier's price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:volatilityReturnTerms ],
        [ sh:class common_domain_model:PriceReturnTerms ;
            sh:description "Return terms based upon the underlier's observed price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:priceReturnTerms ],
        [ sh:class common_domain_model:VarianceReturnTerms ;
            sh:description "Return terms based upon the observed variance of the underlier's price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:varianceReturnTerms ],
        [ sh:class common_domain_model:DividendReturnTerms ;
            sh:description "Return terms based upon dividend payments associated to the underlier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:dividendReturnTerms ],
        [ sh:class common_domain_model:CorrelationReturnTerms ;
            sh:description "Return terms based upon the observed correlation between the components of the underlying basket." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:correlationReturnTerms ] ;
    sh:targetClass common_domain_model:ReturnTerms .

common_domain_model:RollFeature a sh:NodeShape ;
    rdfs:comment "Used in conjunction with an exchange-based pricing source. Identifies a way in which the futures contracts referenced will roll between periods. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Used in conjunction with an exchange-based pricing source. Identifies a date source calendar from which the pricing dates and thus roll to the next contract will be based off (e.g. pricing is based on the NYMEX WTI First Nearby Futures Contract, if Future is chosen, the pricing will roll to the next futures contract on expiration, if ListedOption is chosen, the pricing will roll to the next futures contract on the Option expiration date which is three business days before the expiration of the NYMEX WTI futures contract.) Omitting this element will result in the default behavior expected with the pricing source described within the commodity element." ;
            sh:in ( "ListedOption" "Future" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:rollSourceCalendar ],
        [ sh:class common_domain_model:Offset ;
            sh:description "Specifies, for a Commodity Transaction that references a delivery date for a listed future, the day on which the specified future will roll to the next nearby month prior to the expiration of the referenced future. If the future will not roll at all - i.e. the price will be taken from the expiring contract, 0 should be specified here. If the future will roll to the next nearby on the last trading day - i.e. the price will be taken from the next nearby on the last trading day, then 1 should be specified and so on." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:deliveryDateRollConvention ] ;
    sh:targetClass common_domain_model:RollFeature .

common_domain_model:SchedulePeriod a sh:NodeShape ;
    rdfs:comment "A class that defines the period of a schedule. The period contains a set of start and end dates, quantities, fixing, and pricing data." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Adjusted payment date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:paymentDate ],
        [ sh:class common_domain_model:DateRange ;
            sh:description "Period over which the underlying price is observed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:fixingPeriod ],
        [ sh:class common_domain_model:DateRange ;
            sh:description "Period for which the payment is generated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationPeriod ],
        [ sh:class common_domain_model:CalculationScheduleDeliveryPeriods ;
            sh:description "Period and time profile over which the delivery takes place." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:deliveryPeriod ] ;
    sh:targetClass common_domain_model:SchedulePeriod .

common_domain_model:SchmeNm a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:prtry ] ;
    sh:targetClass common_domain_model:SchmeNm .

common_domain_model:SecuredDebt a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the type of secured debt product." ;
            sh:in ( "AssetBacked" "CollateralizedObligation" "CoveredBonds" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:securedType ],
        [ sh:description "Specifies the type of Asset Backed Security." ;
            sh:in ( "HomeEquity" "AutoLoan" "StudentLoan" "CreditCard" "Property" "Mortgage" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:assetBacked ],
        [ sh:description "Specifies the type of Collateralized Obligation." ;
            sh:in ( "CDO" "CMO" "CLO" "CBO" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:collateralizedObligation ],
        [ sh:description "Specifies the type of property when the security is linked to a property asset." ;
            sh:in ( "Commercial" "Residential" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:propertyType ],
        [ sh:description "Specifies the type of Covered Bond." ;
            sh:in ( "Pfandbriefe" "JumboPfandbriefe" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:coveredBond ] ;
    sh:targetClass common_domain_model:SecuredDebt .

common_domain_model:SecuredPartyRightsEvent a sh:NodeShape ;
    rdfs:comment "A class to specify Secured Party Rights Event language." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A boolean attribute to specify whether Failure to Pay Early Termination language in the agreement is deemed applicable or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:failureToPayEarlyTermination ],
        [ sh:class common_domain_model:SecuredPartyRightsEventElection ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:securedPartyRightsEventElection ],
        [ sh:datatype xsd:boolean ;
            sh:description "A boolean attribute to specify whether Failure to Pay Early Termination language is included (True) or excluded (False) from the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:earlyTerminationDateOptionalLanguage ] ;
    sh:targetClass common_domain_model:SecuredPartyRightsEvent .

common_domain_model:SecuredPartyRightsEventElection a sh:NodeShape ;
    rdfs:comment "A class to specify party specific Secured Party Rights Event language." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:boolean ;
            sh:description "A boolean attribute to specify whether a Secured Party Rights Event will only occur upon the occurrence of one or more of the event specified in a Control Agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:rightsEvent ] ;
    sh:targetClass common_domain_model:SecuredPartyRightsEventElection .

common_domain_model:SecurityAgreementElections a sh:NodeShape ;
    rdfs:comment "The set of elections which specify a Security Agremeent." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Full Discharge condition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:fullDischarge ],
        [ sh:class common_domain_model:ExecutionTerms ;
            sh:description "The location and language of execution to determine duty to be paid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:executionTerms ],
        [ sh:datatype xsd:string ;
            sh:description "Any additional terms that might be specified applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:additionalBespokeTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "Delivery In Lieu rights." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:deliveryInLieuRight ],
        [ sh:class common_domain_model:ProcessAgent ;
            sh:description "The Process Agent that might be appointed by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:processAgent ],
        [ sh:class common_domain_model:AppropriatedCollateralValuation ;
            sh:description "The election for the Valuation of Appropriate Collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:appropriatedCollateralValuation ],
        [ sh:class common_domain_model:Account ;
            sh:description "The pledged account associated with the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:pledgedAccount ],
        [ sh:class common_domain_model:JurisdictionRelatedTerms ;
            sh:description "The jurisdiction specific terms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:jurisdictionRelatedTerms ],
        [ sh:datatype xsd:string ;
            sh:description "Any additional amendments that might be specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:additionalAmendments ],
        [ sh:class common_domain_model:EnforcementEvent ;
            sh:description "Enforcement Events specific to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:enforcementEvent ] ;
    sh:targetClass common_domain_model:SecurityAgreementElections .

common_domain_model:SecurityProviderRightsEvent a sh:NodeShape ;
    rdfs:comment "A class to specify the Pledgor/Obligor/Chargor Rights Event election." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The Automatic Set-Off provision applies when the value is set to True." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:automaticSetOff ],
        [ sh:class common_domain_model:SecurityProviderRightsEventElection ;
            sh:description "A qualification as to whether the Additional Representation is applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ],
        [ sh:datatype xsd:boolean ;
            sh:description "The Pledgor/Obligor/Chargor Rights Event election includes cooling off language when the attribute is set of True." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:includeCoolingOffLanguage ],
        [ sh:datatype xsd:string ;
            sh:description "A custom Pledgor/Obligor/Chargor Rights Event election might be specified by the parties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:customElection ],
        [ sh:datatype xsd:boolean ;
            sh:description "If specified as applicable here, a Pledgor/Obligor/Chargor Rights Event will not occur unless the Pledgor/Obligor/Chargor (A) has provided a statement to the Secured Party in respect of such Early Termination Date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fullDischarge ] ;
    sh:targetClass common_domain_model:SecurityProviderRightsEvent .

common_domain_model:SecurityProviderRightsEventElection a sh:NodeShape ;
    rdfs:comment "A class to specify party specific Secured Party Rights Event language." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:boolean ;
            sh:description "If True, the Rights Event language applies for the specified Party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:rightsEvent ] ;
    sh:targetClass common_domain_model:SecurityProviderRightsEventElection .

common_domain_model:Sellr a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AcctOwnr ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:acctOwnr ] ;
    sh:targetClass common_domain_model:Sellr .

common_domain_model:SensitivityMethodologiesPartyElection a sh:NodeShape ;
    rdfs:comment "A class to specificy methodologies to compute sensitivities specific to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SensitivityToEquity ;
            sh:description "The methodology to compute sensitivities to equity indices, funds and ETFs for the purpose of Initial Margin agreements." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:sensitivityToEquity ],
        [ sh:description "The party to which the election applies." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:SensitivityMethodology ;
            sh:description "The methodology to compute sensitivities to commodity indices for the purpose of Initial Margin agreements." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:sensitivityToCommodity ] ;
    sh:targetClass common_domain_model:SensitivityMethodologiesPartyElection .

common_domain_model:SensitivityToEquity a sh:NodeShape ;
    rdfs:comment "Represents risk sensitivity calculated with respect to the value of an individual equity instrument." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SensitivityMethodology ;
            sh:description "Represents risk sensitivity calculated with respect to the level of an equity or market index." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:sensitivityToIndices ],
        [ sh:class common_domain_model:SensitivityMethodology ;
            sh:description "Represents risk sensitivity calculated with respect to the value of a fund, such as a mutual fund or collective investment vehicle." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:sensitivityToFunds ],
        [ sh:class common_domain_model:SensitivityMethodology ;
            sh:description "Represents risk sensitivity calculated with respect to the value of an exchange-traded fund (ETF)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:sensitivityToETFs ] ;
    sh:targetClass common_domain_model:SensitivityToEquity .

common_domain_model:SettledEntityMatrix a sh:NodeShape ;
    rdfs:comment "A class to specify the Relevant Settled Entity Matrix." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Specifies the publication date of the applicable version of the matrix. When this element is omitted, the Standard Terms Supplement defines rules for which version of the matrix is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:publicationDate ],
        [ sh:description "Relevant settled entity matrix source." ;
            sh:in ( <http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#ConfirmationAnnex> <http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#NotApplicable> <http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#Publisher> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:matrixSource ] ;
    sh:targetClass common_domain_model:SettledEntityMatrix .

common_domain_model:ShapingProvision a sh:NodeShape ;
    rdfs:comment "Defines the applicable settlement limits that may require a settlement to be 'shaped', i.e. broken-down into smaller amounts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "Defines applicable settlement limits in each currency." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:shapeSchedule ] ;
    sh:targetClass common_domain_model:ShapingProvision .

common_domain_model:SimmCalculationCurrency a sh:NodeShape ;
    rdfs:comment "A class to specify the SIMM Calculation Currency elections by each party to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CalculationCurrencyElection ;
            sh:description "The parties' SIMM Calculation Currency election." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:SimmCalculationCurrency .

common_domain_model:SimmException a sh:NodeShape ;
    rdfs:comment "A class to specify the SIMM exception to the regulatory regime clause." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The Standard Initial Margin Model exception when specified by the party according to one of the enumerated values." ;
            sh:in ( "Applicable" "NotApplicable" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:standardisedException ],
        [ sh:description "The Standard Initial Margin model exception approach applicable when specified by the party according to one of the enumerated values." ;
            sh:in ( "FallBackToMandatoryMethod" "MandatoryMethod" "OtherMethod" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:simmExceptionApplicable ],
        [ sh:datatype xsd:string ;
            sh:description "The Standard Initial Margin Model exception when specified as a customized approach by the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:asSpecified ] ;
    sh:targetClass common_domain_model:SimmException .

common_domain_model:SimmVersion a sh:NodeShape ;
    rdfs:comment "A class to specify the ISDA SIMM version that applies to the ISDA 2018 CSA for Initial Margin." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The party which the specified SIMM version applies to." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:partyVersion ],
        [ sh:datatype xsd:string ;
            sh:description "The SIMM version exception when specified as a customized approach by the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:asSpecified ],
        [ sh:datatype xsd:boolean ;
            sh:description "A boolean attribute to determine whether the SIMM version is specified for the purpose of the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isSpecified ] ;
    sh:targetClass common_domain_model:SimmVersion .

common_domain_model:SinglePostingParty a sh:NodeShape ;
    rdfs:comment "Where only a single  party is explicitly designated to post collateral, the party which is specified as the sole poster of collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Utilised where the clause data structure is not able to capture a material aspect of the clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:other ],
        [ sh:description "The party acting as the Single Posting Party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:SinglePostingParty .

common_domain_model:SingleValuationDate a sh:NodeShape ;
    rdfs:comment "A class to specify the number of business days after satisfaction of all conditions to settlement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:numberValuationDates common_domain_model:businessDaysThereafter ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "A number of business days. Its precise meaning is dependant on the context in which this element is used. ISDA 2003 Term: Business Day." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:businessDays ] ;
    sh:targetClass common_domain_model:SingleValuationDate .

common_domain_model:SpecialPurposeVehicleIssuerType a sh:NodeShape ;
    rdfs:comment "Represents a class to allow specification of different types of special purpose vehicle (SPV) collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Indicates tranched or untranched credit risk." ;
            sh:in ( "TranchedCreditRisk" "UntranchedCreditRisk" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:creditRisk ] ;
    sh:targetClass common_domain_model:SpecialPurposeVehicleIssuerType .

common_domain_model:SpecificInconvertibility a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:specificInconvertibilityIsApplicable ],
        [ sh:class common_domain_model:Quantity ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:minimumAmount ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:description "Refers to the segregation deposit procedure parties may want to commmit into during the time a Disruption Event is effective" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:escrowArrangement ],
        [ sh:datatype xsd:string ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:relevantClass ],
        [ sh:class common_domain_model:NonDeliverableSubstitute ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:nonDeliverableSubstitute ],
        [ sh:in ( "LocalAssetSubstituteGross" "LocalAssetSubstituteNet" "LocalCurrencySubstitute" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:localSubstituteProvisionType ],
        [ sh:class common_domain_model:ValuationPostponement ;
            sh:description "Specifies how long to wait to get a quote from a settlement rate option upon a price source disruption." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:maximumDaysOfDisruption ] ;
    sh:targetClass common_domain_model:SpecificInconvertibility .

common_domain_model:SpecificNonTransferability a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationPostponement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:maximumDaysOfDisruption ],
        [ sh:class common_domain_model:NonDeliverableSubstitute ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:nonDeliverableSubstitute ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:specificNonTransferabilityIsApplicable ],
        [ sh:datatype xsd:string ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:relevantClass ],
        [ sh:in ( "LocalAssetSubstituteGross" "LocalAssetSubstituteNet" "LocalCurrencySubstitute" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:localSubstituteProvisionType ],
        [ sh:class common_domain_model:EscrowArrangement ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:escrowArrangement ] ;
    sh:targetClass common_domain_model:SpecificNonTransferability .

common_domain_model:SpecifiedConditionOrAccessCondition a sh:NodeShape ;
    rdfs:comment "Specifies the events elected by the parties that are deemed an Access Condition (for Initial Margin CSA) or a Specified Condition (for Variation Margin and Legacy CSA), which, if triggered, may temporarily or permanently suspend rights to rehypothecate, transfer, or substitute collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SpecifiedOrAccessConditionPartyElection ;
            sh:description "The party specific elections." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:partyElection ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether events that could temporarily or permanently suspend rights to rehypothecate, transfer or substitute collateral are applicable. If applicable,'True'. If not applicable,'False'." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:SpecifiedConditionOrAccessCondition .

common_domain_model:SpecifiedEntities a sh:NodeShape ;
    rdfs:comment "A provision that allows each party to specify its Specified Entities for certain Events of Default and Termination Events." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The Event of Default or Termination event for which Specified Entities terms are being defined." ;
            sh:in ( "DefaultUnderSpecifiedTransaction" "CrossDefault" "Bankruptcy" "CreditEventUponMerger" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:specifiedEntityClause ],
        [ sh:class common_domain_model:SpecifiedEntity ;
            sh:description "The party specific election of Specified Entities for the Event of Default or Termination Event specified." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:specifiedEntity ] ;
    sh:targetClass common_domain_model:SpecifiedEntities .

common_domain_model:SpecifiedEntity a sh:NodeShape ;
    rdfs:comment "The party specific election of Specified Entities for the Event of Default or Termination Event specified." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The non standard terms for the Event of Default or Termination Event specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:otherSpecifiedEntityTerms ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The specified entities for the Event of Default or Termination Event specified." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:specifiedEntity ],
        [ sh:description "The specified entity terms for the Event of Default or Termination Event specified." ;
            sh:in ( "None" "AnyAffiliate" "NamedSpecifiedEntity" "MaterialSubsidiary" "OtherSpecifiedEntity" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:specifiedEntityTerms ],
        [ sh:datatype xsd:string ;
            sh:description "The meaning of Material Subsidiary for the Event of Default or Termination Event specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:materialSubsidiaryTerms ],
        [ sh:class common_domain_model:Party ;
            sh:description "The elective party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:SpecifiedEntity .

common_domain_model:SpecifiedOrAccessConditionPartyElection a sh:NodeShape ;
    rdfs:comment "The party specific elections in respect to the Specified Condition and Access Condition clause." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies events that may lead to the early termination of the Master Agreement, including suspension of the affected party's rights to rehypothecate, transfer, or substitute collateral." ;
            sh:in ( "FailureToNotifyNAV" "InvestmentAdvisor" "KeyPersons" "NAVDeclineTrigger" "NAVFloor" "OperativeDocs" "RatingsDowngradeOrWithdrawalParty1" "RatingsDowngradeOrWithdrawalParty2" "AsApplicable" "AsSpecified" ) ;
            sh:order 2 ;
            sh:path common_domain_model:additionalTerminationEvent ],
        [ sh:description "Specifies events that may temporarily or permanently suspend a partys rights to rehypothecate, transfer, or substitute collateral." ;
            sh:in ( "Illegality" "TaxEvent" "TaxEventUponMerger" "CreditEventUponMerger" "AdditionalTerminationEvents" "ForceMajeureEvent" "PotentialTerminationEvents" ) ;
            sh:order 1 ;
            sh:path common_domain_model:specifiedOrAccessCondition ],
        [ sh:description "Identifies the party making the election." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies any bespoke Additional Termination Event(s) that are set out in the related Specified Condition clause." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:specifiedAdditionalTerminationEvent ] ;
    sh:targetClass common_domain_model:SpecifiedOrAccessConditionPartyElection .

common_domain_model:SpinOff a sh:NodeShape ;
    rdfs:comment "Defines the underlier for both the Parent Company and the Child Compagny involved in Spin Off corporate action, as well as th respective price observation for each." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Price ;
            sh:description "The price observation that relates to underlier for the Child Company." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:childSecurityPrice ],
        [ sh:class common_domain_model:Price ;
            sh:description "The price observation that relates to underlier for the Parent Company." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:parentSecurityPrice ],
        [ sh:class common_domain_model:Security ;
            sh:description "Defines the underlier for the Child Company involved in Spin Off corporate action." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:childSecurity ],
        [ sh:class common_domain_model:Security ;
            sh:description "Defines the underlier for the Parent Company involved in Spin Off corporate action." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:parentSecurity ] ;
    sh:targetClass common_domain_model:SpinOff .

common_domain_model:SplitInstruction a sh:NodeShape ;
    rdfs:comment "Specifies instructions for a split, consisting of a breakdown of instructions to be applied to each branch of the split. This instruction can be used to duplicate a trade, as in a clearing scenario, or to split a trade into smaller quantities (in which case each breakdown instruction needs to include a quantity change), as in an allocation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PrimitiveInstruction ;
            sh:description "Each split breakdown specifies the set of primitive instructions to be applied to a single branch of that split. N split breakdowns result in N output trades, which include the original trade. Instructions for how to handle the original trade (e.g. if it must be closed) must be specified in one of the breakdowns." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:breakdown ] ;
    sh:targetClass common_domain_model:SplitInstruction .

common_domain_model:StandardizedScheduleTradeInfo a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:markToMarketValue ],
        [ sh:in ( "Swap" "CrossCurrencySwap" "Swaption" "SwaptionStraddle" "SwapWithCallableBermudanRightToEnterExitSwaps" "IRExoticSwapWithAnExoticCouponAgainstAFloatingLeg" "Option" "ForwardRateAgreement" "SingleNameCreditDefaultSwap" "IndexCDS" "IndexTranche" "CreditNthToDefault" "CreditTotalReturnSwapOnABond" "DeliverableSwap" "NonDeliverableCrossCurrencySwap" "DeliverableForward" "NonDeliverableForward" "DeliverableOption" "NonDeliverableOption" "VarianceSwap" "VolatilitySwap" "CorrelationSwap" "Forward" "DividendSwap" "DeliverableOptionF" "ContractForDifference" "SwapsAndPortfolioSwaps" "FixedFloatSwap" "BasisSwap" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:productClass ],
        [ sh:class common_domain_model:Money ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:grossInitialMargin ],
        [ sh:in ( "InterestRates" "Credit" "ForeignExchange" "Equity" "Commodity" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:assetClass ] ;
    sh:targetClass common_domain_model:StandardizedScheduleTradeInfo .

common_domain_model:StockSplitInstruction a sh:NodeShape ;
    rdfs:comment "Data required to perform a stock split business event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The number that denotes the cumulative quantity of post-split shares issued to shareholders versus the quantity of pre-split shares previously issued to shareholders.  This number will be multiplied by existing shares in an equity derivative contract or other positions to determine the post-split number of shares.  With regard to any reference to price, the pre-split reference price will be divided by this number to determine the post-split reference price." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:adjustmentRatio ],
        [ sh:datatype xsd:date ;
            sh:description "The effective date of the stock split, also known as the ex-date. This is the date on which the additional shares are paid to the shareholders, or in the case of a reverse stock split, the number shares held by each shareholder is proportionally reduced.  Equity derivative transactions can be amended in firms' internal systems on such date.   In most markets, the listed stock price is reduced (or increased for a reverse stock split) to account for the split on the same date, but in some markets the price adjustment occurs on a later date.  In either case, equity derivative transactions should be amended on the date that the stocks are paid to the shareholders (or consolidated)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:effectiveDate ] ;
    sh:targetClass common_domain_model:StockSplitInstruction .

common_domain_model:StrategyFeature a sh:NodeShape ;
    rdfs:comment "A class for defining option strategy features." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:StrikeSpread ;
            sh:description "Definition of the upper strike in a strike spread." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:strikeSpread ],
        [ sh:class common_domain_model:CalendarSpread ;
            sh:description "Definition of the later expiration date in a calendar spread." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:calendarSpread ] ;
    sh:targetClass common_domain_model:StrategyFeature .

common_domain_model:StrikeSpread a sh:NodeShape ;
    rdfs:comment "A class for defining a strike spread feature." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:OptionStrike ;
            sh:description "Upper strike in a strike spread." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:upperStrike ],
        [ sh:datatype xsd:decimal ;
            sh:description "Number of options at the upper strike price in a strike spread." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:upperStrikeNumberOfOptions ] ;
    sh:targetClass common_domain_model:StrikeSpread .

common_domain_model:StubFloatingRate a sh:NodeShape ;
    rdfs:comment "A class defining a floating rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Schedule ;
            sh:description "A rate multiplier or multiplier schedule to apply to the floating rate. A multiplier schedule is expressed as explicit multipliers and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in the calculationPeriodDatesAdjustments. The multiplier can be a positive or negative decimal. This element should only be included if the multiplier is not equal to 1 (one) for the term of the stream." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:floatingRateMultiplierSchedule ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The floor rate or floor rate schedule, if any, which applies to the floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. A floor rate schedule is expressed as explicit floor rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:floorRateSchedule ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The cap rate or cap rate schedule, if any, which applies to the floating rate. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain level. A cap rate schedule is expressed as explicit cap rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:capRateSchedule ],
        [ sh:description "The specification of any rate conversion which needs to be applied to the observed rate before being used in any calculations. The two common conversions are for securities quoted on a bank discount basis which will need to be converted to either a Money Market Yield or Bond Equivalent Yield. See the Annex to the 2000 ISDA Definitions, Section 7.3. Certain General Definitions Relating to Floating Rate Options, paragraphs (g) and (h) for definitions of these terms." ;
            sh:in ( "BondEquivalentYield" "MoneyMarketYield" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:rateTreatment ],
