common_domain_model:TransferBase a sh:NodeShape ;
    rdfs:comment "Defines the movement of an Asset (eg cash, securities or commodities) between two parties on a date." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:payoutReference rdf:type common_domain_model:transferType common_domain_model:corporateActionTransferType ) ;
    sh:property [ sh:class common_domain_model:Identifier ;
            sh:description "Represents a unique reference to the transfer." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:NonNegativeQuantity ;
            sh:description "Represents the amount of the asset to be transferred. The cashflow amount is always a positive number, as the cashflow direction is implied by the payer/receiver attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:PartyReferencePayerReceiver ;
            sh:description "Represents the parties to the transfer and their role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:AdjustableOrAdjustedOrRelativeDate ;
            sh:description "Represents the date on which the transfer to due." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:class common_domain_model:PaymentDiscounting ;
            sh:description "FpML specifies the FpML PaymentDiscounting.model group for representing the discounting elements that can be associated with a payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:paymentDiscounting ],
        [ sh:description "Represents the object that is subject to the transfer, it could be an asset or a reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 3 ;
            sh:path common_domain_model:asset ] ;
    sh:targetClass common_domain_model:TransferBase .

common_domain_model:TransferContactInformation a sh:NodeShape ;
    rdfs:comment "Specifies transfer information including address and, optionally, an associated account. This type also supports the ISDA CSA representation as a single string, through the address attribute in Contact Information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Address ;
            sh:description "The street/postal address." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:address ],
        [ sh:datatype xsd:string ;
            sh:description "The email address." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:email ],
        [ sh:datatype xsd:string ;
            sh:description "The web page. This attribute is not specified as part of the FpML ContactInformation complex type." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:webPage ],
        [ sh:class common_domain_model:Account ;
            sh:description "Specifies the account infomation for transfers to a party." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:account ],
        [ sh:class common_domain_model:TelephoneNumber ;
            sh:description "The telephone number." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:telephone ],
        [ sh:datatype xsd:string ;
            sh:description "Additional transfer information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalInformation ] ;
    sh:targetClass common_domain_model:TransferContactInformation .

common_domain_model:TransferableProduct a sh:NodeShape ;
    rdfs:comment "A TransferableProduct is a type of financial product which can be held or transferred, represented as an Asset with the addition of specific EconomicTerms." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EconomicTerms ;
            sh:description "The price forming features, including payouts and provisions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:economicTerms ] ;
    sh:targetClass common_domain_model:TransferableProduct .

common_domain_model:Underlier a sh:NodeShape ;
    rdfs:comment "The underlying financial product that will be physically or cash settled, which can be of any type, eg an asset such as cash or a security, a product, or the cash settlement of an index rate.  Conditions are usually applied when used in a data type, such as a payout, to ensure this aligns with the use case." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:Underlier .

common_domain_model:Workflow a sh:NodeShape ;
    rdfs:comment "A collection of workflow steps which together make up an entire workflow sequence." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:WorkflowStep ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:steps ] ;
    sh:targetClass common_domain_model:Workflow .

common_domain_model:AccrualFactor a sh:NodeShape ;
    rdfs:comment "The accrual rate and related terms, to adjust the price of an underlier impacted by a Corporate Action when economic impact consists in freezing the underlier price to the last fixing then applying accruals per each remaining underlier price fixing date required i.e. for each fixing date, adjustedPrice = lastFixingPrice x accrualFactor, where: accrualFactor = (1 + accrualRateValue x DCF)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AccrualFactorCalculationTerms ;
            sh:description "Describes the input terms involved in the calculation of the accrual factor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:calculationTerms ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "The rate to be applied to the last fixing price, for price accrual calculation purposes. DatedValue may be used for the purpose of representing Price series if such calculation is required for multiple dates." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:AccrualFactor .

common_domain_model:AccrualFactorCalculationTerms a sh:NodeShape ;
    rdfs:comment "Describes the input terms involved in the calculation of the accrual factor. Optionnally, long and short stub interpolation rates can be specified." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The duration between last fixing date and the payment date of accruals, calculated in accordance with the appropriate DayCountFraction." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:tenorTillMaturity ],
        [ sh:description "The enumerated values to specify the day count fraction." ;
            sh:in ( "ACT_360" "ACT_365L" "ACT_364" "ACT_365_FIXED" "ACT_ACT_AFB" "ACT_ACT_ICMA" "ACT_ACT_ISDA" "ACT_ACT_ISMA" "CAL_252" "_1_1" "_30E_360" "_30E_360_ISDA" "_30_360" "RBA_BOND_BASIS" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:dayCountFraction ],
        [ sh:class common_domain_model:StubValue ;
            sh:description "Describes the rate, tenor, period duration for the short and long stubs, when the accrualRate optionnaly results from an interpolation method." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:interpolationTerms ] ;
    sh:targetClass common_domain_model:AccrualFactorCalculationTerms .

common_domain_model:AdditionalDisruptionEvents a sh:NodeShape ;
    rdfs:comment "A type for defining the Additional Disruption Events." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:hedgingDisruption ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:increasedCostOfHedging ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the maximum stock loan rate for Loss of Stock Borrow. A percentage of 5% is represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:maximumStockLoanRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the initial stock loan per ISDA Def. A percentage of 5% is represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:initialStockLoanRate ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:lossOfStockBorrow ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:foreignOwnershipEvent ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:insolvencyFiling ],
        [ sh:class common_domain_model:Clause ;
            sh:description "Where parties may optionnaly describe any extra bespoke agreements, in regards of the standardized Extraordinary Events." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:additionalBespokeTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "If true, failure to deliver is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:failureToDeliver ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:increasedCostOfStockBorrow ],
        [ sh:description "Specifies the party which determines additional disruption events." ;
            sh:in ( "DisruptionEventsDeterminingParty" "ExtraordinaryDividendsParty" "PredeterminedClearingOrganizationParty" "ExerciseNoticeReceiverPartyManual" "ExerciseNoticeReceiverPartyOptionalEarlyTermination" "ExerciseNoticeReceiverPartyCancelableProvision" "ExerciseNoticeReceiverPartyExtendibleProvision" "CalculationAgentIndependent" "CalculationAgentOptionalEarlyTermination" "CalculationAgentMandatoryEarlyTermination" "CalculationAgentFallback" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:determiningParty ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:changeInLaw ] ;
    sh:targetClass common_domain_model:AdditionalDisruptionEvents .

common_domain_model:AdditionalFixedPayments a sh:NodeShape ;
    rdfs:comment "A class to specify the events that will give rise to the payment additional fixed payments." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "An Additional Fixed Payment. Corresponds to the payment by or on behalf of the issuer of an amount in respect to the reference obligation in reduction of the prior writedowns. ISDA 2003 Term: Writedown Reimbursement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:writedownReimbursement ],
        [ sh:datatype xsd:boolean ;
            sh:description "An additional Fixed Payment Event. Corresponds to the payment by or on behalf of the Issuer of an actual interest amount in respect to the reference obligation that is greater than the expected interest amount. ISDA 2003 Term: Interest Shortfall Reimbursement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:interestShortfallReimbursement ],
        [ sh:datatype xsd:boolean ;
            sh:description "An additional Fixed Payment Event. Corresponds to the payment by or on behalf of the Issuer of an actual principal amount in respect to the reference obligation that is greater than the expected principal amount. ISDA 2003 Term: Principal Shortfall Reimbursement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:principalShortfallReimbursement ] ;
    sh:targetClass common_domain_model:AdditionalFixedPayments .

common_domain_model:AdditionalObligations a sh:NodeShape ;
    rdfs:comment "The election of party specific additional obligations applicable to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The party that the additional obligations apply to." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:string ;
            sh:description "The party specific additional obligations applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalObligations ] ;
    sh:targetClass common_domain_model:AdditionalObligations .

common_domain_model:AdditionalRepresentation a sh:NodeShape ;
    rdfs:comment "A class to specify the Additional Representation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A supplemental custom election that might be specified by the parties for the purpose of specifying the Additional Representation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customElection ],
        [ sh:class common_domain_model:AdditionalRepresentationElection ;
            sh:description "A qualification as to whether the Additional Representation is applicable." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:AdditionalRepresentation .

common_domain_model:AdditionalRepresentationElection a sh:NodeShape ;
    rdfs:comment "A class to specify the parties' Additional Representation(s) election." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:boolean ;
            sh:description "The Additional Representation is applicable when True, and not applicable when False." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:datatype xsd:string ;
            sh:description "Details of any Additional Representations given by the relevant parties in relation to the collateral arrangement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:AdditionalRepresentationElection .

common_domain_model:AdditionalRightsEvent a sh:NodeShape ;
    rdfs:comment "A class to specify the Pledgor/Obligor/Chargor Additional Rights Event election." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The qualification of the Pledgor Additional Rights Event election, when specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:qualification ],
        [ sh:datatype xsd:boolean ;
            sh:description "The Pledgor Additional Rights Event election is applicable when True, and not applicable when False." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:AdditionalRightsEvent .

common_domain_model:AddtlAttrbts a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:sctiesFincgTxInd ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:rskRdcgTx ] ;
    sh:targetClass common_domain_model:AddtlAttrbts .

common_domain_model:AdjustableOrAdjustedDate a sh:NodeShape ;
    rdfs:comment "A class for defining a date that shall be subject to adjustment if it would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The business day convention and financial business centers used for adjusting the date if it would otherwise fall on a day that is not a business date in the specified business centers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:dateAdjustments ],
        [ sh:datatype xsd:date ;
            sh:description "The date once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:adjustedDate ],
        [ sh:datatype xsd:date ;
            sh:description "A date subject to adjustment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unadjustedDate ] ;
    sh:targetClass common_domain_model:AdjustableOrAdjustedDate .

common_domain_model:AdjustmentFactor a sh:NodeShape ;
    rdfs:comment "Describes the terms involved for adjusting the price of the underlier impacted by a Corporate Action." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The multiplier value applied to the price of the underlier impacted by a Corporate Action." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:value ],
        [ sh:class common_domain_model:AdjustmentFactorCalculationTerms ;
            sh:description "Describes the input terms involved in the calculation of the adjustment factor applied to the price of the underlier impacted by a Corporate Action." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:calculationTerms ] ;
    sh:targetClass common_domain_model:AdjustmentFactor .

common_domain_model:AdjustmentFactorCalculationTerms a sh:NodeShape ;
    rdfs:comment "Describes the input terms involved in the calculation of the adjustment factor applied to the price of the underlier impacted by a Corporate Action." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SpinOff ;
            sh:description "Defines the underlier for both the Parent Company and the Child Compagny involved in Spin Off corporate action, as well as the respective price observation for each." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:spinOff ],
        [ sh:datatype xsd:string ;
            sh:description "To describe the formula used to calculate the Adjustment Factor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:bespokeCalculationFormula ],
        [ sh:class common_domain_model:AccrualFactor ;
            sh:description "The accrual rate and related terms, to adjust the price of an underlier impacted by a Corporate Action when economic impact consists in freezing the underlier price to last fixing and applying accruals for each remaining underlier price fixing date required i.e. for each, adjustedPrice = lastFixingPrice x (1 + accrualRate x DCF)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:accrualFactor ],
        [ sh:class common_domain_model:Merger ;
            sh:description "Defines the underlier for both the Purchaser Company and the Acquired Compagny involved in Spin Off corporate action, as well as the respective price observation for each." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:merger ],
        [ sh:datatype xsd:decimal ;
            sh:description "Multiple value, say 'M/N' where 'M' is the number of shares after the event and 'N' is the number of shares prior to the event. " ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:shareForShareRatio ],
        [ sh:datatype xsd:decimal ;
            sh:description "Multiple value, say 'M/N' where 'M' is the number of rights after the event, and 'N' of shares prior to the event. " ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:shareForRightsRatio ],
        [ sh:datatype xsd:decimal ;
            sh:description "Multiplier value (e.g. 85 %, etc.) to calculate net dividend amount, given gross amount before taking into account the relevant fiscal features." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:dividendRatio ],
        [ sh:class common_domain_model:Price ;
            sh:description "The price to pay per each right." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:rightsSubscriptionPrice ],
        [ sh:class common_domain_model:Price ;
            sh:description "The last fixing price of the Underlier affected by the CorporateAction, before any adjustment with regards to the CorporateAction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:lastFixingPriceBeforeAdjustment ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "To record observations of dividends." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:dividendObservation ] ;
    sh:targetClass common_domain_model:AdjustmentFactorCalculationTerms .

common_domain_model:Aggregation a sh:NodeShape ;
    rdfs:comment "The definitions for whether aggregation applies to the GMSLA, and if so how it applies." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Any specfic elections that are not captured by the above options, such as grouping information." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:otherDetails ],
        [ sh:datatype xsd:boolean ;
            sh:description "The mark to market can be defined separately for different groups of loans." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:loansCanBeGrouped ],
        [ sh:description "How is the mark to market value determined?" ;
            sh:in ( "Aggregated" "LoanByLoan" "AggregatedAndLoanByLoan" "NotSpecified" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:aggregationType ] ;
    sh:targetClass common_domain_model:Aggregation .

common_domain_model:AggregationParameters a sh:NodeShape ;
    rdfs:comment " Parameters to be used to filter events that are relevant to a given portfolio in order to calculate the state of this portfolio. The attributes correspond to all the possible aggregation criteria that can be used and these criteria can be combined. All the attributes are optional." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "To aggregate as of a particular date" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:dateTime ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether to calculate total position to given date, or only daily position for the given date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:totalPosition ],
        [ sh:class common_domain_model:Party ;
            sh:description "To aggregate based on a selection of party(ies) / legal entity(ies)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:party ],
        [ sh:description "To aggregate based on position status (EXECUTED, SETTLED etc)" ;
            sh:in ( "Executed" "Formed" "Settled" "Cancelled" "Closed" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:positionStatus ],
        [ sh:class common_domain_model:NonTransferableProduct ;
            sh:description "To aggregate based on a selection of products." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:product ],
        [ sh:class common_domain_model:Trade ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:tradeReference ],
        [ sh:datatype xsd:string ;
            sh:description "To aggregate based on a selection of product type(s)." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:productQualifier ] ;
    sh:targetClass common_domain_model:AggregationParameters .

common_domain_model:AgreementTerms a sh:NodeShape ;
    rdfs:comment "Specification of the content of a legal agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Specification of whether the agreement terms have been negotiated using the clause library methodology." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:clauseLibrary ],
        [ sh:class common_domain_model:Counterparty ;
            sh:description "Specification of the roles of the counterparties to the agreement." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:counterparty ],
        [ sh:class common_domain_model:Agreement ;
            sh:description "Specification of the standard set of terms that define a legal agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:agreement ] ;
    sh:targetClass common_domain_model:AgreementTerms .

common_domain_model:AmountSchedule a sh:NodeShape ;
    rdfs:comment "A class to specify a currency amount or a currency amount schedule." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The currency in which the amount schedule is denominated. The currency is specified outside of the actual schedule in order to be applied uniformly to it. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:currency ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "The schedule of step date and value pairs. On each step date the associated step value becomes effective. A list of steps may be ordered in the document by ascending step date. An FpML document containing an unordered list of steps is still regarded as a conformant document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:datedValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "The initial rate or amount, as the case may be. An initial rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:AmountSchedule .

common_domain_model:ApplicableRegime a sh:NodeShape ;
    rdfs:comment "A class to specify the applicable regulatory regime(s) that parties to a legal agreement, such as the ISDA 2016 and 2018 CSA for Initial Margin, might be subject to." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RegimeTerms ;
            sh:description "A class that is used by the ApplicableRegime and the AdditionalRegime classes to specify the terms that are specific to each party and regime which are referred to in the Regime Table as part of certain legal agreements, such as the ISDA 2016 and 2018 CSA for Initial Margin." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:regimeTerms ],
        [ sh:datatype xsd:string ;
            sh:description "The additional regulatory regime as specified by the parties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalRegime ],
        [ sh:datatype xsd:string ;
            sh:description "The bespoke Additional Type for the purposes of Covered Transactions (IM)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:additionalTerms ],
        [ sh:description "The applicable regulatory regime, as specified through an enumeration." ;
            sh:in ( "AustraliaMarginRules" "CanadaMarginRules" "CFTC_MarginRules" "EMIR_MarginRules" "HongKongMarginRules" "JapanMarginRules" "US_PrudentialMarginRules" "SEC_MarginRules" "SingaporeMarginRules" "SwitzerlandMarginRules" "BrazilMarginRules" "UnitedKingdomMarginRules" "SouthAfricaMarginRules" "SouthKoreaMarginRules" "HongKongSFCMarginRules" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:regime ],
        [ sh:in ( "NotApplicable" "EquityOptionOrIndexOption" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:additionalType ] ;
    sh:targetClass common_domain_model:ApplicableRegime .

common_domain_model:AssetDeliveryPeriods a sh:NodeShape ;
    rdfs:comment "Defines the periods of delivery, including the delivery profile." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:deliveryCapacity rdf:type common_domain_model:priceTimeIntervalQuantity ) ;
    sh:property [ sh:class common_domain_model:AssetDeliveryProfile ;
            sh:description "Defines the delivery profile of the asset, including the load type and the delivery intervals." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:profile ],
        [ sh:datatype xsd:date ;
            sh:description "Delivery start date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:startDate ],
        [ sh:datatype xsd:date ;
            sh:description "Delivery end date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:endDate ] ;
    sh:targetClass common_domain_model:AssetDeliveryPeriods .

common_domain_model:AssetDeliveryProfileBlock a sh:NodeShape ;
    rdfs:comment "Defines a delivery profile block, including start and end time, days of the week, duration, delivery capacity and price time interval quantity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:time ;
            sh:description "The start time of the delivery interval for each block or shape." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:startTime ],
        [ sh:class common_domain_model:Price ;
            sh:description "Price per quantity per delivery time interval." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:priceTimeIntervalQuantity ],
        [ sh:description "The days of the week of the delivery." ;
            sh:in ( "MON" "TUE" "WED" "THU" "FRI" "SAT" "SUN" ) ;
            sh:order 2 ;
            sh:path common_domain_model:dayOfWeek ],
        [ sh:datatype xsd:time ;
            sh:description "The end time of the delivery interval for each block or shape." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:endTime ],
        [ sh:class common_domain_model:Quantity ;
            sh:description "The number of units included in the transaction for each delivery interval" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:deliveryCapacity ] ;
    sh:targetClass common_domain_model:AssetDeliveryProfileBlock .

common_domain_model:AssetLeg a sh:NodeShape ;
    rdfs:comment "Defines each asset movement of an asset payout." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "Specifies the settlement date of securities.  In a repo transaction the purchase date would always be the effective date as specified under Economic Terms, the repurchase date would always be the termination date as specified under Economic Terms." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:description "Specifies a delivery method for the security transaction." ;
            sh:in ( <http://www.fpml.org/coding-scheme/delivery-method-1-0#DeliveryVersusPayment> <http://www.fpml.org/coding-scheme/delivery-method-1-0#FreeOfPayment> <http://www.fpml.org/coding-scheme/delivery-method-1-0#PreDelivery> <http://www.fpml.org/coding-scheme/delivery-method-1-0#PrePayment> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:deliveryMethod ] ;
    sh:targetClass common_domain_model:AssetLeg .

common_domain_model:AutomaticEarlyTermination a sh:NodeShape ;
    rdfs:comment "A class to specify the Automatic Early Termination provision applicable to a Master Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether automatic termination applies in the event of certain bankruptcy events." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:fallbackAET ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether indemnity applies in the event AET is applicable to one or both of the parties." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:indemnity ],
        [ sh:class common_domain_model:AutomaticEarlyTerminationElection ;
            sh:description "The party election specific to the Automatic Early Termination Clause." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:AutomaticEarlyTermination .

common_domain_model:AutomaticEarlyTerminationElection a sh:NodeShape ;
    rdfs:comment "A class to specify the party elections specific to the Automatic Early Termination Clause." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A boolean election to specify whether the Automatic Early Termination provisions of Section 6(a) are applicable (True) or not applicable (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party for which the Automatic Early Termination provisions are being specified." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:AutomaticEarlyTerminationElection .

common_domain_model:AutomaticExercise a sh:NodeShape ;
    rdfs:comment "A type to define automatic exercise of a swaption. With automatic exercise the option is deemed to have exercised if it is in the money by more than the threshold amount on the exercise date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "A threshold rate. The threshold of 0.10% would be represented as 0.001" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:thresholdRate ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean that indicates if it has an automaticExercise" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:AutomaticExercise .

common_domain_model:AverageTradingVolume a sh:NodeShape ;
    rdfs:comment "Represents the average trading volume of an Equity product upon an exchange or set of exchanges." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Indicates the type of equity average trading volume being stated (single) the highest amount on one exchange, or (consolidated) volumes across multiple exchanges." ;
            sh:in ( "Single" "Consolidated" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:methodology ],
        [ sh:class common_domain_model:Period ;
            sh:description "Represents the period of the equities average trading volume on the exchange/s." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:period ] ;
    sh:targetClass common_domain_model:AverageTradingVolume .

common_domain_model:AveragingCalculationMethod a sh:NodeShape ;
    rdfs:comment "Defines the ways in which multiple values can be aggregated into a single value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Identifies whether the average values will be weighted or unweighted." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isWeighted ],
        [ sh:description "Identifies which of the Pythagorean means is being used to compute an average value." ;
            sh:in ( "Arithmetic" "Geometric" "Harmonic" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:calculationMethod ] ;
    sh:targetClass common_domain_model:AveragingCalculationMethod .

common_domain_model:AveragingFeature a sh:NodeShape ;
    rdfs:comment "As per ISDA 2002 Definitions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AveragingCalculation ;
            sh:description "Defines parameters for use in cases when a valuation or other term is based on an average of market observations." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:averagingCalculation ],
        [ sh:class common_domain_model:AveragingPeriod ;
            sh:description "The averaging in period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:averagingPeriodIn ],
        [ sh:class common_domain_model:AveragingPeriod ;
            sh:description "The averaging out period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:averagingPeriodOut ],
        [ sh:in ( "In" "Out" "Both" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:averagingInOut ],
        [ sh:datatype xsd:decimal ;
            sh:description "The factor of strike." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:strikeFactor ] ;
    sh:targetClass common_domain_model:AveragingFeature .

common_domain_model:AveragingObservationList a sh:NodeShape ;
    rdfs:comment "An unordered list of weighted averaging observations." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:WeightedAveragingObservation ;
            sh:description "A single weighted averaging observation." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:averagingObservation ] ;
    sh:targetClass common_domain_model:AveragingObservationList .

common_domain_model:AveragingStrikeFeature a sh:NodeShape ;
    rdfs:comment "Defines the terms required to calculate the average observations associated with an averaging strike." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AveragingCalculation ;
            sh:description "Defines parameters for use in cases when a valuation or other term is based on an average of market observations." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:averagingCalculation ],
        [ sh:class common_domain_model:ObservationTerms ;
            sh:description "Class containing terms that are associated with observing a price/benchmark/index across either single or multple observations. " ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:observationTerms ] ;
    sh:targetClass common_domain_model:AveragingStrikeFeature .

common_domain_model:Barrier a sh:NodeShape ;
    rdfs:comment "As per ISDA 2002 Definitions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TriggerEvent ;
            sh:description "The option only becomes active when a predetermined trigger level is breached." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:knockIn ],
        [ sh:class common_domain_model:TriggerEvent ;
            sh:description "The option becomes null and void when a predetermined trigger level is breached." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:knockOut ] ;
    sh:targetClass common_domain_model:Barrier .

common_domain_model:BaseCurrency a sh:NodeShape ;
    rdfs:comment "The definitions regarding base currency determinations relating to the GMSLA." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The base currency that is defined must be freely convertible." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:baseCurrencyMustBeFreelyConvertible ],
        [ sh:description "If the base currency is not freely convertible, the fallback currency can be defined here." ;
            sh:in ( "CNH" "CNT" "GGP" "IMP" "JEP" "KID" "MCF" "SML" "VAL" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:baseCurrencyIfOriginalNotFreelyConvertible ],
        [ sh:description "The base currency as defined in the GMSLA." ;
            sh:in ( "CNH" "CNT" "GGP" "IMP" "JEP" "KID" "MCF" "SML" "VAL" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:baseCurrency ] ;
    sh:targetClass common_domain_model:BaseCurrency .

common_domain_model:BasketReferenceInformation a sh:NodeShape ;
    rdfs:comment "CDS Basket Reference Information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The name of the basket expressed as a free format string. FpML does not define usage rules for this element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:basketName ],
        [ sh:datatype xsd:integer ;
            sh:description "N th reference obligation to default triggers payout." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:nthToDefault ],
        [ sh:class common_domain_model:ReferencePool ;
            sh:description "This element contains all the reference pool items to define the reference entity and reference obligation(s) in the basket." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:referencePool ],
        [ sh:datatype xsd:string ;
            sh:description "A CDS basket identifier." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:basketId ],
        [ sh:class common_domain_model:Tranche ;
            sh:description "This element contains CDS tranche terms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:tranche ],
        [ sh:datatype xsd:integer ;
            sh:description "M th reference obligation to default to allow representation of N th to M th defaults." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:mthToDefault ] ;
    sh:targetClass common_domain_model:BasketReferenceInformation .

common_domain_model:BillingRecord a sh:NodeShape ;
    rdfs:comment "Specifies individual records within a billing invoice." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The starting date of the period described by this record" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:recordStartDate ],
        [ sh:datatype xsd:date ;
            sh:description "The ending date of the period described by this record" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:recordEndDate ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "The trade for the individual billing record." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tradeState ],
        [ sh:class common_domain_model:Money ;
            sh:description "Indicates the minimum fee amount applied to the billing record, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:minimumFee ],
        [ sh:description "The settlement terms for the billing record" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:ScheduledTransfer ] [ sh:class common_domain_model:UnscheduledTransfer ] ) ;
            sh:order 1 ;
            sh:path common_domain_model:recordTransfer ] ;
    sh:targetClass common_domain_model:BillingRecord .

common_domain_model:BillingRecordInstruction a sh:NodeShape ;
    rdfs:comment "Specifies the instructions for creation of a billing record." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Observation ;
            sh:description "The observations used to calculate the billing amount." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:observation ],
        [ sh:datatype xsd:date ;
            sh:description "The starting date of the period described by this record" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:recordStartDate ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "The trade for the individual billing record." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tradeState ],
        [ sh:datatype xsd:date ;
            sh:description "The ending date of the period described by this record" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:recordEndDate ],
        [ sh:datatype xsd:date ;
            sh:description "The date for settlement of the transfer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:settlementDate ] ;
    sh:targetClass common_domain_model:BillingRecordInstruction .

common_domain_model:BillingSummary a sh:NodeShape ;
    rdfs:comment "Specifies individual summaries within a billing invoice." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The settlement terms for the billing summary" ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:ScheduledTransfer ] [ sh:class common_domain_model:UnscheduledTransfer ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:summaryTransfer ],
        [ sh:description "The account level for the billing summary." ;
            sh:in ( "AccountTotal" "GrandTotal" "ParentTotal" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:summaryAmountType ] ;
    sh:targetClass common_domain_model:BillingSummary .

common_domain_model:BillingSummaryInstruction a sh:NodeShape ;
    rdfs:comment "Specifies the instructions for creation of a billing summary." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The account level for the billing summary." ;
            sh:in ( "AccountTotal" "GrandTotal" "ParentTotal" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:summaryAmountType ] ;
    sh:targetClass common_domain_model:BillingSummaryInstruction .

common_domain_model:BondReference a sh:NodeShape ;
    rdfs:comment "Reference to a bond underlier to represent an asset swap or Condition Precedent Bond." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Security ;
            sh:description "Reference to a bond underlier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:bond ],
        [ sh:datatype xsd:boolean ;
            sh:description "To indicate whether the Discrepancy Clause is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:discrepancyClause ],
        [ sh:class common_domain_model:FixedRateSpecification ;
            sh:description "Specifies the coupon rate (expressed in percentage) of a fixed income security or convertible bond." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:couponRate ],
        [ sh:datatype xsd:boolean ;
            sh:description "To indicate whether the Condition Precedent Bond is applicable. The swap contract is only valid if the bond is issued and if there is any dispute over the terms of fixed stream then the bond terms would be used." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:conditionPrecedentBond ] ;
    sh:targetClass common_domain_model:BondReference .

common_domain_model:BoundedVariance a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "All observations below this price level will be excluded from the variance calculation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:lowerBarrier ],
        [ sh:datatype xsd:decimal ;
            sh:description "All observations above this price level will be excluded from the variance calculation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:upperBarrier ],
        [ sh:datatype xsd:boolean ;
            sh:description "The contract specifies whether the notional should be scaled by the Number of Days in Range divided by the Expected N. The number of Days in Ranges refers to the number of returns that contribute to the realized volatility." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:daysInRangeAdjustment ],
        [ sh:description "The contract specifies which price must satisfy the boundary condition." ;
            sh:in ( "Previous" "Last" "Both" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:realisedVarianceMethod ] ;
    sh:targetClass common_domain_model:BoundedVariance .

common_domain_model:BusinessDateRange a sh:NodeShape ;
    rdfs:comment "A class defining a range of contiguous business days by defining an unadjusted first date, an unadjusted last date and a business day convention and business centers for adjusting the first and last dates if they would otherwise fall on a non business day in the specified business centers. The days between the first and last date must also be good business days in the specified centers to be counted in the range." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The convention for adjusting a date if it would otherwise fall on a day that is not a business day, as specified by an ISDA convention (e.g. Following, Precedent)." ;
            sh:in ( "FOLLOWING" "FRN" "MODFOLLOWING" "PRECEDING" "MODPRECEDING" "NEAREST" "NONE" "NotApplicable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:businessDayConvention ],
        [ sh:datatype xsd:date ;
            sh:description "The last date of a date range." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:endDate ],
        [ sh:datatype xsd:date ;
            sh:description "The first date of a date range." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:startDate ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business center(s), specified either explicitly or by reference to those specified somewhere else in the instance document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenters ] ;
    sh:targetClass common_domain_model:BusinessDateRange .

common_domain_model:BusinessDayOffset a sh:NodeShape ;
    rdfs:comment "This allows an offset to be specified as, for instance, N business days, with a business centers specified as included." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:designatedMaturity ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:datatype xsd:string ;
            sh:description "Fixing Offset Reason" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fixingOffsetReason ],
        [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:period ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business centers for the offset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:businessCenters ],
        [ sh:datatype xsd:string ;
            sh:description "Legal text that underlies the Fixing Offset. ISDA Fixing Offset Definition. (e.g. One day that is either a Sydney Business Day or a Melbourne Business Day following the Reset Date)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:fixingOffsetDefinition ] ;
    sh:targetClass common_domain_model:BusinessDayOffset .

common_domain_model:BusinessEvent a sh:NodeShape ;
    rdfs:comment "A business event represents a life cycle event of a trade. The combination of the state changes results in a qualifiable life cycle event. An example of a Business Event is a PartialTermination which is a defined by a quantity change primitive event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Instruction ;
            sh:description "Specifies the instructions to create the Business Event." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:instruction ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the event contractually takes effect, when different from the event date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "The time and zone of the date in which the event contractually takes effect." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:effectiveTime ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "Specifies the after trade state(s) created." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:after ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "The time and zone of the date in which the event is taking place." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:eventTime ],
        [ sh:class common_domain_model:IdentifiedList ;
            sh:description "Specifies the package information in case the business event represents several trades executed as a package (hence this attribute is optional). The package information is only instantiated once at the business event level to preserve referential integrity, whereas individual trades make reference to it to identify that they are part of a package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:packageInformation ],
        [ sh:description "The intent attribute is meant to be specified when the event qualification cannot be programmatically inferred from the event features. As a result it is only associated with those primitives that can give way to such ambiguity, the quantityChange being one of those. An example of such is a reduction in the trade notional, which could be interpreted as either a trade correction (unless a maximum period of time post-event is specified as part of the qualification), a partial termination or a portfolio rebalancing in the case of an equity swap. On the other hand, an event such as the exercise is not expected to have an associated intent as there should not be ambiguity." ;
            sh:in ( "Allocation" "CashFlow" "Clearing" "Compression" "ContractFormation" "ContractTermsAmendment" "CorporateActionAdjustment" "CreditEvent" "Decrease" "EarlyTerminationProvision" "Increase" "IndexTransition" "NotionalReset" "NotionalStep" "Novation" "ObservationRecord" "OptionExercise" "OptionalExtension" "OptionalCancellation" "PortfolioRebalancing" "PrincipalExchange" "Reallocation" "Repurchase" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:intent ],
        [ sh:datatype xsd:string ;
            sh:description "The CDM event qualifier, which corresponds to the outcome of the isEvent qualification logic which qualifies the lifecycle event as a function of its features (e.g. PartialTermination, ClearingSubmission, Novation, ...)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:eventQualifier ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date on which the event is taking place. This date is equal to the trade date in the case of a simple execution.  However it can be different from the trade date, for example in the case of a partial termination." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:eventDate ],
        [ sh:description "The intent of a corporate action on the position." ;
            sh:in ( "CashDividend" "StockDividend" "StockSplit" "ReverseStockSplit" "SpinOff" "Merger" "Delisting" "StockNameChange" "StockIdentifierChange" "RightsIssue" "Takeover" "StockReclassification" "BonusIssue" "ClassAction" "EarlyRedemption" "Liquidation" "BankruptcyOrInsolvency" "IssuerNationalization" "Relisting" "BespokeEvent" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:corporateActionIntent ] ;
    sh:targetClass common_domain_model:BusinessEvent .

common_domain_model:BusinessUnit a sh:NodeShape ;
    rdfs:comment "A class to specify an organizational unit." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Identifier ;
            sh:description "An identifier used to uniquely identify the organizational unit" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "A name used to describe the organizational unit" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:name ],
        [ sh:class common_domain_model:ContactInformation ;
            sh:description "The contact information for such business unit, when different from the contact information associated with the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:contactInformation ] ;
    sh:targetClass common_domain_model:BusinessUnit .

common_domain_model:Buyr a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AcctOwnr ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:acctOwnr ] ;
    sh:targetClass common_domain_model:Buyr .

common_domain_model:CSAMinimumTransferAmountVariableSet a sh:NodeShape ;
    rdfs:comment "Defines a combination of Rating Agency, Rating Value, amount and Currency code." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A flag that defines the Minimum Transfer Amount (MTA) as Infinity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:amountIsInfinity ],
        [ sh:datatype xsd:integer ;
            sh:description "The Minimum Transfer Amount (MTA) applicable to the Rating." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:amount ],
        [ sh:description "The name of the Rating Agency." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#AMBest> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#CBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#DBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Fitch> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Japanagency> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Moodys> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors> ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:name ],
        [ sh:datatype xsd:string ;
            sh:description "The value assigned to the rating." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:CSAMinimumTransferAmountVariableSet .

common_domain_model:CSAThresholdVariableSet a sh:NodeShape ;
    rdfs:comment "Defines a combination of Rating Agency, Rating Value, Threshold amount and Currency code." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The relevant rating agency." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#AMBest> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#CBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#DBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Fitch> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Japanagency> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Moodys> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors> ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:name ],
        [ sh:datatype xsd:integer ;
            sh:description "The amount value applicable to the Threshold." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:amount ],
        [ sh:datatype xsd:string ;
            sh:description "Rating applicable to the party from a given rating agency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:CSAThresholdVariableSet .

common_domain_model:CalculatedRateDetails a sh:NodeShape ;
    rdfs:comment "Type for reporting details of calculated rates, including the observations that went into the final reported rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The resulting calculated weight." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:calculatedRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The daily growth factors, showing the weighted rates divided by the day count basis plus one, giving how much the value grows for each step in the calculation." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:growthFactor ],
        [ sh:datatype xsd:decimal ;
            sh:description "The total sum or product of all the individual terms that went into the calculated rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:aggregateValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "The compounding curve, showing how the initial value grew during the calculation period." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:compoundedGrowth ],
        [ sh:datatype xsd:decimal ;
            sh:description "The total weight of all the terms that went into the calculated rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:aggregateWeight ],
        [ sh:datatype xsd:decimal ;
            sh:description "The weighted value of each observation." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:weightedRates ],
        [ sh:class common_domain_model:CalculatedRateObservations ;
            sh:description "The observation dates and weights for each observation date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:observations ] ;
    sh:targetClass common_domain_model:CalculatedRateDetails .

common_domain_model:CalculatedRateObservations a sh:NodeShape ;
    rdfs:comment "Type for reporting observations that went into the final reported rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The corresponding weight for each date." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:weights ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value observed for that date" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:observedRates ],
        [ sh:datatype xsd:date ;
            sh:description "The observation date upon which the rate is observed." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:observationDates ],
        [ sh:datatype xsd:decimal ;
            sh:description "The value after any processing, such as application of caps or floors." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:processedRates ] ;
    sh:targetClass common_domain_model:CalculatedRateObservations .

common_domain_model:CalculationAndTimingCollateralTransferAgreement a sh:NodeShape ;
    rdfs:comment "Specification of the Calculation, Valuation and Timing terms specific to the Initial Margin Credit Support Annex." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:securitiesSettlementDay ],
        [ sh:class common_domain_model:CalculationAgentTerms ;
            sh:description "Details of the party calculating the value of collateral to be delivered or returned." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationAgentTerms ],
        [ sh:class common_domain_model:ValuationCalculationDateLocation ;
            sh:description "The specified location where the credit exposure will be calculated by the respective parties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:calculationDateLocation ],
        [ sh:class common_domain_model:BespokeCalculationTime ;
            sh:description "Bespoke terms to describe the time as of which such party (or the Calculation Agent (IM) (if applicale)) computes its end of day valuations of derivatives transactions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:bespokeCalculationTime ],
        [ sh:class common_domain_model:NotificationTime ;
            sh:description "The time by which a demand for the Transfer of Eligible Credit Support (IM) or Posted Credit Support (IM) needs to be made in order for the transfer to take place in accordance with the Transfer Timing provisions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:notificationTime ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:cashSettlementDay ],
        [ sh:class common_domain_model:BespokeCalculationDate ;
            sh:description "The specification of bespoke Calculation Date terms for the purposes of Initial or Variation Margin by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:bespokeCalculationDate ] ;
    sh:targetClass common_domain_model:CalculationAndTimingCollateralTransferAgreement .

common_domain_model:CalculationAndTimingInitialMargin a sh:NodeShape ;
    rdfs:comment "Specification of the Calculation, Valuation and Timing terms specific to the Initial Margin Credit Support Annex." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationCalculationDateLocation ;
            sh:description "The specified location where the credit exposure will be calculated by the respective parties." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:calculationDateLocation ],
        [ sh:class common_domain_model:NotificationTime ;
            sh:description "The time by which a demand for the Transfer of Eligible Credit Support (IM) or Posted Credit Support (IM) needs to be made in order for the transfer to take place in accordance with the Transfer Timing provisions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:notificationTime ],
        [ sh:class common_domain_model:CalculationAgentTerms ;
            sh:description "Details of the party calculating the value of collateral to be delivered or returned." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationAgentTerms ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:cashSettlementDay ],
        [ sh:class common_domain_model:BespokeCalculationTime ;
            sh:description "Bespoke terms to describe the time as of which such party (or the Calculation Agent (IM) (if applicale)) computes its end of day valuations of derivatives transactions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:bespokeCalculationTime ],
        [ sh:class common_domain_model:BespokeCalculationDate ;
            sh:description "The specification of bespoke Calculation Date terms for the purposes of Initial or Variation Margin by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:bespokeCalculationDate ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:securitiesSettlementDay ] ;
    sh:targetClass common_domain_model:CalculationAndTimingInitialMargin .

common_domain_model:CalculationAndTimingLegacy a sh:NodeShape ;
    rdfs:comment "Specification of the Calculation, Valuation and Timing terms specific to the Legacy (1994/95) Credit Support Annex." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationTime ;
            sh:description "Specifies the time on which the value of collateral or exposure are calculated in accordance with the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:valuationTime ],
        [ sh:class common_domain_model:CSAValuationDate ;
            sh:description "Details of the days on which calculations are to be made to determine the Delivery Amount and/or Return Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuationDate ],
        [ sh:class common_domain_model:NotificationTime ;
            sh:description "The time by which a demand for the Transfer of Eligible Credit Support (IM) or Posted Credit Support (IM) needs to be made in order for the transfer to take place in accordance with the Transfer Timing provisions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:notificationTime ],
        [ sh:class common_domain_model:ValuationAgent ;
            sh:description "Details of the party calculating the value of collateral to be delivered or returned." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:valuationAgent ] ;
    sh:targetClass common_domain_model:CalculationAndTimingLegacy .

common_domain_model:CalculationAndTimingVariationMargin a sh:NodeShape ;
    rdfs:comment "Specification of the Calculation, Valuation and Timing terms specific to the Variation Margin Credit Support Annex." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationAgent ;
            sh:description "Details of the party valuating the collateral to be delivered or returned." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:valuationAgent ],
        [ sh:class common_domain_model:ValuationTime ;
            sh:description "Specifies the time on which the value of collateral or exposure are calculated in accordance with the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:valuationTime ],
        [ sh:class common_domain_model:CSAValuationDate ;
            sh:description "Details of the days on which calculations are to be made to determine the Delivery Amount and/or Return Amount." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuationDate ],
        [ sh:class common_domain_model:ValuationCalculationDateLocation ;
            sh:description "The specified location where the credit exposure will be calculated by the respective parties." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:valuationDateLocation ],
        [ sh:class common_domain_model:NotificationTime ;
            sh:description "The time by which a demand for the Transfer of Eligible Credit Support (IM) or Posted Credit Support (IM) needs to be made in order for the transfer to take place in accordance with the Transfer Timing provisions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:notificationTime ] ;
    sh:targetClass common_domain_model:CalculationAndTimingVariationMargin .

common_domain_model:CalculationCurrencyElection a sh:NodeShape ;
    rdfs:comment "A class to specify the ISDA SIMM Calculation Currency." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The currency in which the ISDA SIMM Calculation is denominated, when different from the Base Currency. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:boolean ;
            sh:description "The SIMM Calculation Currency (also known as SIMM Reporting Currency) means the Base Currency when True. It means a different currency when False. In that latter case, the SIMM Calculation Currency is specified as part of the currency attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:isBaseCurrency ],
        [ sh:description "The party which the SIMM Calculation Currency qualification applies to." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:CalculationCurrencyElection .

common_domain_model:CalculationFrequency a sh:NodeShape ;
    rdfs:comment "Represents the parameters for describing how often something (such as collateral interest) is to be calculated." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Period ;
            sh:description "Specifies the time period at which calculation is performed, e.g. 1 month." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:period ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the day of the month if used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:dayOfMonth ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the week of the month if used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:weekOfMonth ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies how many days from the trigger event should the payment occur." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:offsetDays ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the month of the year if used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:monthOfYear ],
        [ sh:description "Specifies the day of the week if used." ;
            sh:in ( "MON" "TUE" "WED" "THU" "FRI" "SAT" "SUN" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:dayOfWeek ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the business center for adjustment of calculation period." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:businessCenter ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "Specifies where is the time measured." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:dateLocation ] ;
    sh:targetClass common_domain_model:CalculationFrequency .

common_domain_model:CalculationPeriod a sh:NodeShape ;
    rdfs:comment "A data defining:  the parameters used in the calculation of a fixed or floating rate calculation period amount. This data forms:  part of cashflows representation of a swap stream." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "The amount representing the forecast of the accrued value of the calculation period. An intermediate value used to generate the forecastPaymentAmount in the PaymentCalculationPeriod." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:forecastAmount ],
        [ sh:class common_domain_model:FxLinkedNotionalAmount ;
            sh:description "The amount that a cashflow will accrue interest on. This is the calculated amount of the FX linked - i.e. the other currency notional amount multiplied by the appropriate FX spot rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:fxLinkedNotionalAmount ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of days from the adjusted effective / start date to the adjusted termination / end date calculated in accordance with the applicable day count fraction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:calculationPeriodNumberOfDays ],
        [ sh:class common_domain_model:FloatingRateDefinition ;
            sh:description "The floating rate reset information for the calculation period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:floatingRateDefinition ],
        [ sh:datatype xsd:decimal ;
            sh:description "The year fraction value of the calculation period, result of applying the ISDA rules for day count fraction defined in the ISDA Annex." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:dayCountYearFraction ],
        [ sh:datatype xsd:date ;
            sh:description "The calculation period end date, adjusted according to any relevant business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path common_domain_model:adjustedEndDate ],
        [ sh:datatype xsd:date ;
            sh:description "The calculation period start date, adjusted according to any relevant business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path common_domain_model:adjustedStartDate ],
        [ sh:datatype xsd:date ;
            sh:description "The calculation start date, unadjusted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unadjustedStartDate ],
        [ sh:datatype xsd:date ;
            sh:description "The calculation end date, unadjusted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:unadjustedEndDate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The amount that a cashflow will accrue interest on." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:notionalAmount ],
        [ sh:datatype xsd:decimal ;
            sh:description "The calculation period fixed rate. A per annum rate, expressed as a decimal. A fixed rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:fixedRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "A value representing the forecast rate used to calculate the forecast future value of the accrual period. This is a calculated rate determined based on averaging the rates in the rateObservation elements, and incorporates all of the rate treatment and averaging rules. A value of 1% should be represented as 0.01." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:forecastRate ] ;
    sh:targetClass common_domain_model:CalculationPeriod .

common_domain_model:CalculationScheduleDeliveryPeriods a sh:NodeShape ;
    rdfs:comment "Period and time profile over which the delivery takes place." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Price ;
            sh:description "Price per quantity per delivery time interval." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:priceTimeIntervalQuantity ],
        [ sh:datatype xsd:date ;
            sh:description "Delivery end date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:endDate ],
        [ sh:class common_domain_model:Quantity ;
            sh:description "The number of units included in the transaction for each delivery interval" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:deliveryCapacity ],
        [ sh:class common_domain_model:AssetDeliveryProfile ;
            sh:description "Defines the delivery profile of the asset, including the load type and the delivery intervals." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:profile ],
        [ sh:datatype xsd:date ;
            sh:description "Delivery start date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:startDate ] ;
    sh:targetClass common_domain_model:CalculationScheduleDeliveryPeriods .

common_domain_model:CalendarSpread a sh:NodeShape ;
    rdfs:comment "A type for defining a calendar spread feature." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:expirationDateTwo ] ;
    sh:targetClass common_domain_model:CalendarSpread .

common_domain_model:CancelableProvision a sh:NodeShape ;
    rdfs:comment "A data defining:  the right of a party to cancel a swap transaction on the specified exercise dates. The provision is for 'walk-away' cancellation (i.e. the fair value of the swap is not paid). A fee payable on exercise can be specified. As a difference from the FpML construct, the canonical model extends the BuyerSeller class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The earliest time in a business day that notice of cancelation can be given." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:earliestCancellationTime ],
        [ sh:class common_domain_model:ExerciseNotice ;
            sh:description "Definition of the party to whom notice of exercise should be given." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:exerciseNotice ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The latest time at which notice of cancelation can be given." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:latestCancelationTime ],
        [ sh:class common_domain_model:ExerciseTerms ;
            sh:description "The exercise terms associated with the cancelable provision, including details such as exercise style, exercise fees, and any other relevant conditions or terms governing the cancellation of the swap transaction." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:exerciseTerms ],
        [ sh:description "Seller party that can be resolved as one of the two principal parties to the transaction. The party that sells ('writes') this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. ISDA 2002 Equity Definitions section 1.19: `Seller` means the party specified as such in the related Confirmation. | ISDA 2006 Definitions article 12.1 (a)(i) relating to a Swaption: 'Seller' means the party the party specified as such or as writer in the related Confirmation | ISDA 2006 Definitions article 12.1 (a)(ii) relating to Swap Transactions with applicable Early Termination: the party specified as such or as writer in the related Confirmation or, if neither party is specified as such, the Non-exercising Party | ISDA 2006 Definitions article 12.1 (a)(iii) relating to any other Option Transaction: the party specified as such in the related Confirmation. | ISDA 2014 Credit Definition article 1.4: `Seller` means the Floating Rate Payer." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 14 ;
            sh:path common_domain_model:seller ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The first day when cancelation is permitted to take effect. A party may give notice prior to this date and taken together with the effective period would be necessary to cancel on this date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:earliestDate ],
        [ sh:description "Buyer party that can be resolved as one of the two principal parties to the transaction. The party that buys this instrument, i.e. pays for this instrument and receives the rights defined by it. ISDA 2002 Equity Definitions section 1.18: `Buyer` means the party specified as such in the related Confirmation. | ISDA 2006 Definitions article 12.1 (b)(i) relating to a Swaption: 'Buyer' means the party that will, on each Premium Payment Date, pay to Seller the Premium | ISDA 2006 Definitions article 12.1 (b)(ii) relating to Swap Transactions with applicable Early Termination: the party specified as such in the related Confirmation, or the Exercising Party if neither party is specified | ISDA 2006 Definitions article 12.1 (b)(iii) relating to any other Option Transaction: the party specified as such in the related Confirmation. | ISDA 2014 Credit Definition article 1.4: `Buyer` means the Fixed Rate Payer." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 13 ;
            sh:path common_domain_model:buyer ],
        [ sh:class common_domain_model:AdjustableOrRelativeDates ;
            sh:description "The effective date if cancelation is invoked otherwise the cancellation period defines the cancellation date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:description "The party with right to exercise a cancellation. Allows for buyer, seller or either." ;
            sh:in ( "InitialBuyer" "InitialSeller" "Either" "AsDefinedInMasterAgreement" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:callingParty ],
        [ sh:class common_domain_model:FinalCalculationPeriodDateAdjustment ;
            sh:description "Business date convention adjustment to final payment period per leg (swapStream) upon exercise event. The adjustments can be made in-line with leg level BDC's or they can be specified separately." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:finalCalculationPeriodDateAdjustment ],
        [ sh:datatype xsd:boolean ;
            sh:description "A flag to indicate whether follow-up confirmation of exercise (written or electronic) is required following telephonic notice by the buyer to the seller or seller's agent." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:followUpConfirmation ],
        [ sh:description "An initial fee for the cancelable option." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:ScheduledTransfer ] [ sh:class common_domain_model:UnscheduledTransfer ] ) ;
            sh:order 4 ;
            sh:path common_domain_model:initialFee ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The last day within the term of the contract that cancelation is allowed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:expirationDate ],
        [ sh:class common_domain_model:CancelableProvisionAdjustedDates ;
            sh:description "The adjusted dates associated with a cancelable provision. These dates have been adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:cancelableProvisionAdjustedDates ],
        [ sh:class common_domain_model:Period ;
            sh:description "Effective period for cancelation when notice is given. This is the period after notice is given that cancellation becomes effecticve." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:effectivePeriod ] ;
    sh:targetClass common_domain_model:CancelableProvision .

common_domain_model:CancelableProvisionAdjustedDates a sh:NodeShape ;
    rdfs:comment "A data to:  define the adjusted dates for a cancelable provision on a swap transaction." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CancellationEvent ;
            sh:description "The adjusted dates for an individual cancellation date." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:cancellationEvent ] ;
    sh:targetClass common_domain_model:CancelableProvisionAdjustedDates .

common_domain_model:CancellationEvent a sh:NodeShape ;
    rdfs:comment "The adjusted dates for a specific cancellation date, including the adjusted exercise date and adjusted termination date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date on which option exercise takes place. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:adjustedExerciseDate ],
        [ sh:datatype xsd:date ;
            sh:description "The early termination date that is applicable if an early termination provision is exercised. This date should already be adjusted for any applicable business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:adjustedEarlyTerminationDate ] ;
    sh:targetClass common_domain_model:CancellationEvent .

common_domain_model:CashCollateralValuationMethod a sh:NodeShape ;
    rdfs:comment "This type is a generic structure that can represent the parameters of several mid-market valuation and replacement value methods described in the 2021 ISDA Definitions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "This may be used to specify what type of CSA (credit support annex/agreement) is to be used for cash settlement purposes." ;
            sh:in ( "NoCSA" "ExistingCSA" "ReferenceVMCSA" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:applicableCsa ],
        [ sh:datatype xsd:string ;
            sh:description "This may be used to indicate the interest rate to be used for cash collateral for cash settlement purposes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:cashCollateralInterestRate ],
        [ sh:datatype xsd:string ;
            sh:description "This may be used to indicate the currency of cash collateral for cash settlement purposes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:cashCollateralCurrency ],
        [ sh:datatype xsd:boolean ;
            sh:description "This may be used to indicate that 'prescribed documentation adjustment' is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:prescribedDocumentationAdjustment ],
        [ sh:description "This may be used to specify which party is protected (e.g. under Replacement Value cash settlement methods)." ;
            sh:in ( "ExercisingParty" "NonExercisingParty" "AsSpecifiedInMasterAgreement" "AsSpecifiedInStandardTermsSupplement" "Both" ) ;
            sh:order 4 ;
            sh:path common_domain_model:protectedParty ],
        [ sh:datatype xsd:string ;
            sh:description "This may be used to indicate the discount rate to be used for cash collateral for cash settlement purposes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:agreedDiscountRate ] ;
    sh:targetClass common_domain_model:CashCollateralValuationMethod .

common_domain_model:CashflowRepresentation a sh:NodeShape ;
    rdfs:comment "A data defining:  the cashflow representation of a swap trade." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A true/false flag to indicate whether the cashflows match the parametric definition of the stream, i.e. whether the cashflows could be regenerated from the parameters without loss of information." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:cashflowsMatchParameters ],
        [ sh:class common_domain_model:PaymentCalculationPeriod ;
            sh:description "The adjusted payment date and associated calculation period parameters required to calculate the actual or projected payment amount. A list of payment calculation period elements may be ordered in the document by ascending adjusted payment date. An FpML document containing an unordered list of payment calculation periods is still regarded as a conformant document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:paymentCalculationPeriod ] ;
    sh:targetClass common_domain_model:CashflowRepresentation .

common_domain_model:ClosedState a sh:NodeShape ;
    rdfs:comment " A class to qualify the closed state of an execution or a contract through the combination or a state (e.g. terminated, novated) and a set of dates: activity date, effective date and, when relevant, last payment date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date associated with the last payment in relation to the artefact (e.g. contract) to which this closed state applies. As an example, in the case of an early termination event, it would be the settlement date of the associated fee, if applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:lastPaymentDate ],
        [ sh:description "The qualification of what gave way to the contract or execution closure, e.g. allocation, termination, ..." ;
            sh:in ( "Allocated" "Cancelled" "Exercised" "Expired" "Matured" "Novated" "Terminated" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:state ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the closing event contractually takes effect, when different from the activity date. When an explicit event effective date attribute is associated with the closing event, it will be that date. In the case of a cancellation event, it will be the date on which the cancelled event took place." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:datatype xsd:date ;
            sh:description "The activity date on which the closing state took place, i.e. either the event date of the closing event (e.g. option exercise, contract early termination) or the contractual termination date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:activityDate ] ;
    sh:targetClass common_domain_model:ClosedState .

common_domain_model:CodeListIdentification a sh:NodeShape ;
    rdfs:comment "A type to identify the version of a codelist" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The the most recent version of the codelist, eg. 9-1" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:version ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the code list, e.g. business-center" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:codeShortId ],
        [ sh:datatype xsd:string ;
            sh:description "Canonical URI which uniquely identifies a specific version of the referenced code list. Must be an absolute URI. Must not be used as a de facto location URI." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:canonicalVersionUri ],
        [ sh:datatype xsd:string ;
            sh:description "A short name (without whitespace) for the code list, e.g. businessCenterScheme" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:shortName ],
        [ sh:datatype xsd:string ;
            sh:description "The most recent date the code list was published, e.g. 2021-10-05" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:publicationDate ],
        [ sh:datatype xsd:string ;
            sh:description "Suggested retrieval location for this version, in genericode format. An application must signal an error to the user if a document retrieved using a LocationUri is not in genericode format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:locationUri ],
        [ sh:datatype xsd:string ;
            sh:description "Canonical URI which uniquely identifies all versions (collectively) of the referenced code list. Must be an absolute URI. Must not be used as a de facto location URI." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:canonicalUri ],
        [ sh:datatype xsd:string ;
            sh:description "A description  of the code list, e.g. A list of codes identifying business centers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:description ] ;
    sh:targetClass common_domain_model:CodeListIdentification .

common_domain_model:CodeValue a sh:NodeShape ;
    rdfs:comment "A type to hold the value of the code in a codelist" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Where the code was defined,e.g. ISDA, FpML, Bloomberg" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:source ],
        [ sh:datatype xsd:date ;
            sh:description "When the code ceased to be valid for new uses" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:deprecatedDate ],
        [ sh:datatype xsd:string ;
            sh:description "The value of the code, e.g. USNY" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:value ],
        [ sh:datatype xsd:date ;
            sh:description "When the code became/becomes effective" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the meaning of the code, e.g. New York City, USA" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:description ] ;
    sh:targetClass common_domain_model:CodeValue .

common_domain_model:CollateralAccessBreach a sh:NodeShape ;
    rdfs:comment "A class to specify Collateral Access Breach language." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Determination of whether the Collateral Access Breach end date is a number of days (True) or specified (False)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:cabEndDateElection ],
        [ sh:datatype xsd:decimal ;
            sh:description "The business days following the related Collateral Access Breach when the additional terms end." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:cabEndDate ],
        [ sh:datatype xsd:boolean ;
            sh:description "Collateral Access Breach terms are applicable when True and not applicable when False." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ],
        [ sh:datatype xsd:string ;
            sh:description "Specific terms for when Collateral Access Breach terms end." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:cabEndDateTerms ] ;
    sh:targetClass common_domain_model:CollateralAccessBreach .

common_domain_model:CollateralAgreementFloatingRate a sh:NodeShape ;
    rdfs:comment "Represents the parameters needed to calculate the floating rate paid on collateral holdings." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The floor rate or floor rate schedule, if any, which applies to the floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. A floor rate schedule is expressed as explicit floor rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:floorRateSchedule ],
        [ sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:FloatingRateIndex ] [ sh:class common_domain_model:InflationIndex ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:rateOption ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies how spreads should be applied in a low/negative rate environment.  If true, spread is applied only if rate is positive." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:compressibleSpread ],
        [ sh:class common_domain_model:SpreadSchedule ;
            sh:description "The ISDA Spread or a Spread schedule expressed as explicit spreads and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The spread is a per annum rate, expressed as a decimal. For purposes of determining a calculation period amount, if positive the spread will be added to the floating rate and if negative the spread will be subtracted from the floating rate. A positive 10 basis point (0.1%) spread would be represented as 0.001." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:spreadSchedule ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies how negative rates should be applied.  If rates go negative, should the payment be reversed (true) or zeroed out (false)?" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:negativeInterest ],
        [ sh:class common_domain_model:StrikeSchedule ;
            sh:description "The cap rate or cap rate schedule, if any, which applies to the floating rate. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain level. A cap rate schedule is expressed as explicit cap rates and dates and the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:capRateSchedule ] ;
    sh:targetClass common_domain_model:CollateralAgreementFloatingRate .

common_domain_model:CollateralInterestCalculationParameters a sh:NodeShape ;
    rdfs:comment "Represents parameters for calculating the amount the floating interest calculation, e.g.  for a single currency or defaults for all currencies." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CollateralAgreementFloatingRate ;
            sh:description "Specifies the floating interest rate to be used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:floatingRate ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the applicable fixed rate  if used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:fixedRate ],
        [ sh:class common_domain_model:Rounding ;
            sh:description "Specifies the rounding rules for settling in that currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:rounding ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the withholding tax rate if a withholding tax is applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:withholdingTaxRate ],
        [ sh:description "Specifies the day count fraction to use for that currency." ;
            sh:in ( "ACT_360" "ACT_365L" "ACT_364" "ACT_365_FIXED" "ACT_ACT_AFB" "ACT_ACT_ICMA" "ACT_ACT_ISDA" "ACT_ACT_ISMA" "CAL_252" "_1_1" "_30E_360" "_30E_360_ISDA" "_30_360" "RBA_BOND_BASIS" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:dayCountFraction ],
        [ sh:datatype xsd:boolean ;
            sh:description "If True, specifies that the interest transfers should be converted to base currency equivalent, or if False specifies that the transfer should be in the currency of the collateral." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:inBaseCurrency ],
        [ sh:description "Specifies the type of compounding to be applied (None, Business, Calendar)." ;
            sh:in ( "None" "Business" "Calendar" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:compoundingType ],
        [ sh:description "Specifies when/how often is rounding applied?" ;
            sh:in ( "Daily" "PeriodEnd" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:roundingFrequency ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the applicable business centers for compounding." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:compoundingBusinessCenter ] ;
    sh:targetClass common_domain_model:CollateralInterestCalculationParameters .

common_domain_model:CollateralInterestHandlingParameters a sh:NodeShape ;
    rdfs:comment "Represents parameters that describe how calculated interest amounts are handled, i.e. are they transferred/distributed, or is the collateral balance adjusted, is netting done, and any other special handling." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates the option that accrued interest should be calculated and distributed when a partial return collateral occurs." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:onPartialReturn ],
        [ sh:description "Specifies the alternative to interest amounts." ;
            sh:in ( "Standard" "ActualAmountReceived" "TransferIfDeliveryAmountBelowMTA" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path common_domain_model:alternativeToInterestAmount ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether or not to include the open interest accrual in the margin calculation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:includeAccrualInMarginCalc ],
        [ sh:class common_domain_model:NumberBound ;
            sh:description "Specifies the level below which the interest will be rolled over." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:interestRolloverLimit ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies applicable business centers for payments." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:paymentBusinessCenter ],
        [ sh:class common_domain_model:InterestAmountApplication ;
            sh:description "The application of Interest Amount with respect to the Delivery Amount and the Return Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:interestAmountApplication ],
        [ sh:class common_domain_model:CollateralInterestNotification ;
            sh:description "Specifies the terms describing notification requirements." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path common_domain_model:notification ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether to net Held and Posted Interest Payments (i.e. whether interest payable for a period can be netted with interest receivable)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:netPostedAndHeldInterest ],
        [ sh:description "Specifies how the collateral interest is to be handled." ;
            sh:in ( "Transfer" "Adjust" "Transfer_or_Adjust" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:interestPaymentHandling ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies an alternative to interest amount, when the alternative provision clause is specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path common_domain_model:alternativeProvision ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the interest amount may be offset against any margin call deliver or return amounts?   (aka 'net payments' indicator)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:netInterestWithMarginCalls ],
        [ sh:datatype xsd:time ;
            sh:description "Specifies the time of day that interest needs to be confirmed by." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path common_domain_model:cutoffTime ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether interest accruing on unsettled interest amount is included (continues to be accrued) in the following period." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:accrueInterestOnUnsettledInterest ],
        [ sh:class common_domain_model:NumberBound ;
            sh:description "Specifies the level below which the interest will be written off; if omitted write-off is not applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:writeoffLimit ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates the option that accrued interest should be calculated and distributed when a full return of collateral occurs." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:onFullReturn ] ;
    sh:targetClass common_domain_model:CollateralInterestHandlingParameters .

common_domain_model:CollateralInterestNotification a sh:NodeShape ;
    rdfs:comment "Represents the parameters describing when notifications should be made for required collateral interest transfers." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Specifies the number of days before (negative) or after (positive) the trigger event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:offset ],
        [ sh:description "The type of days on which notification should occur." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:notificationDayType ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies what triggers notification (should be enum) Interest Statement Frequency, Period End Date." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:trigger ],
        [ sh:datatype xsd:time ;
            sh:description "Specifies the time of day that the notification should occur." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:notificationTime ] ;
    sh:targetClass common_domain_model:CollateralInterestNotification .

common_domain_model:CollateralInterestParameters a sh:NodeShape ;
    rdfs:comment "Represents the floating interest calculation and distribution parameters for a single currency." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents the party to which these parameters apply (the applicable party).  In other words, if the parameters are different depending on which party is posting/holding the collateral, for which party to the Collateral Agreement (Party 1 or Party 2) that is posting the collateral do these parameters apply?" ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:postingParty ],
        [ sh:class common_domain_model:CollateralInterestCalculationParameters ;
            sh:description "Represents the basic interest calculation parameters." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:interestCalculationParameters ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the currency for which the parameters are captured." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:currency ],
        [ sh:class common_domain_model:CollateralInterestHandlingParameters ;
            sh:description "Represents the parameters describing how and when interest transfer occurs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:interestHandlingParameters ],
        [ sh:class common_domain_model:CalculationFrequency ;
            sh:description "Represents how often and when interest is calculated." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:interestCalculationFrequency ],
        [ sh:description "Specifies the type of margin for which interest is being calculated, if the parameters are different depending on type of margin (initial or variation)." ;
            sh:in ( "VariationMargin" "InitialMargin" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:marginType ] ;
    sh:targetClass common_domain_model:CollateralInterestParameters .

common_domain_model:CollateralManagementAgreement a sh:NodeShape ;
    rdfs:comment "A class to specify the Collateral Management Agreement election." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CollateralManagementAgreementElection ;
            sh:description "The parties' Collateral Management Agreement election." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:CollateralManagementAgreement .

common_domain_model:CollateralManagementAgreementElection a sh:NodeShape ;
    rdfs:comment "A class to specify the Collateral Management Agreement election." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The designated Collateral Management Agreement with respect to the elective party as the Obligee." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:collateralManagementAgreement ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:CollateralManagementAgreementElection .

common_domain_model:CollateralSpecification a sh:NodeShape ;
    rdfs:comment "The definitions regarding collateral relating to the GMSLA." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Aggregation ;
            sh:description "How does paragraph 5.4 (aggregation) apply to the GMSLA?" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:aggregation ],
        [ sh:description "Does paragraph 6.4 (indemnity for failure to redeliver Equivalent Non-Cash Collateral) apply to the GMSLA?" ;
            sh:in ( "Applicable" "NotApplicable" "NotSpecified" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:failureToDevliverIndemnityApplies ],
        [ sh:datatype xsd:string ;
            sh:description "If the definition of 'Market Value' is non standard, it can be specified here." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:definitionOfMarketValueNonStandard ],
        [ sh:description "Does paragraph 5.6 (netting of obligations to deliver Collateral and redeliver Equivalent Collateral) apply to the GMSLA?" ;
            sh:in ( "Applicable" "NotApplicable" "NotSpecified" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:nettingObligationsApply ],
        [ sh:datatype xsd:boolean ;
            sh:description "Is the standard definition of 'Market Value' used in the GMSLA?" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:standardDefinitionOfMarketValueUsed ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "What is the notification time of the GMSLA?" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:notificationTime ] ;
    sh:targetClass common_domain_model:CollateralSpecification .

common_domain_model:CollateralTaxonomyValue a sh:NodeShape ;
    rdfs:comment "Specifies the collateral taxonomy value, either as a specified enumeration or as a string." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identifies United Kingdom Eligible Collateral Assets classification categories based on UK Onshored EMIR Uncleared Margin Rules Eligible Collateral asset classes for both initial margin (IM) and variation margin (VM) posted and collected between specified entities. Please note: UK EMIR regulation will detail which eligible collateral assets classes apply to each type of entity pairing (counterparty) and which apply to posting of IM and VM." ;
            sh:in ( "UK_EMIRTypeA" "UK_EMIRTypeB" "UK_EMIRTypeC" "UK_EMIRTypeD" "UK_EMIRTypeE" "UK_EMIRTypeF" "UK_EMIRTypeG" "UK_EMIRTypeH" "UK_EMIRTypeI" "UK_EMIRTypeJ" "UK_EMIRTypeK" "UK_EMIRTypeL" "UK_EMIRTypeM" "UK_EMIRTypeN" "UK_EMIRTypeO" "UK_EMIRTypeP" "UK_EMIRTypeQ" "UK_EMIRTypeR" ) ;
            sh:order 1 ;
            sh:path common_domain_model:uk_EMIR_EligibleCollateral ],
        [ sh:description "Identifies US Eligible Collateral Assets classification categories based on Uncleared Margin Rules published by the CFTC and the US Prudential Regulator. Note: While the same basic categories exist in the CFTC and US Prudential Regulators’ margin rules, the precise definitions or application of those rules could differ between the two rules." ;
            sh:in ( "US_CFTC_PRType1" "US_CFTC_PRType2" "US_CFTC_PRType3" "US_CFTC_PRType4" "US_CFTC_PRType5A" "US_CFTC_PRType5B" "US_CFTC_PRType6" "US_CFTC_PRType7" "US_CFTC_PRType8A" "US_CFTC_PRType8B" "US_CFTC_PRType8C" "US_CFTC_PRType9" "US_CTFC_PRType10" ) ;
            sh:order 2 ;
            sh:path common_domain_model:us_CFTC_PR_EligibleCollateral ],
        [ sh:datatype xsd:string ;
            sh:description "Identifies the taxonomy value when not specified as an enumeration." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:nonEnumeratedTaxonomyValue ],
        [ sh:description "Identifies European Union Eligible Collateral Assets classification categories based on EMIR Uncleared Margin Rules. Eligible Collateral asset classes for both initial margin (IM) and variation margin (VM) posted and collected between specified entities. Please note: EMIR regulation will detail which eligible collateral assets classes apply to each type of entity pairing (counterparty) and which apply to posting of IM and VM" ;
            sh:in ( "EU_EMIRTypeA" "EU_EMIRTypeB" "EU_EMIRTypeC" "EU_EMIRTypeD" "EU_EMIRTypeE" "EU_EMIRTypeF" "EU_EMIRTypeG" "EU_EMIRTypeH" "EU_EMIRTypeI" "EU_EMIRTypeJ" "EU_EMIRTypeK" "EU_EMIRTypeL" "EU_EMIRTypeM" "EU_EMIRTypeN" "EU_EMIRTypeO" "EU_EMIRTypeP" "EU_EMIRTypeQ" "EU_EMIRTypeR" ) ;
            sh:order 0 ;
            sh:path common_domain_model:eu_EMIR_EligibleCollateral ] ;
    sh:targetClass common_domain_model:CollateralTaxonomyValue .

common_domain_model:CollateralTransferAgreementElections a sh:NodeShape ;
    rdfs:comment "The set of elections which specify a Collateral Transfer Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Any additional amendments that might be specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path common_domain_model:additionalAmendments ],
        [ sh:class common_domain_model:DemandsAndNotices ;
            sh:description "The optional specification of address where the demands, specifications and notices will be communicated to for each of the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path common_domain_model:demandsAndNotices ],
        [ sh:class common_domain_model:CalculationAndTimingCollateralTransferAgreement ;
            sh:description "The set of elections for determining Valuation and Timing terms specific to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:calculationAndTiming ],
        [ sh:class common_domain_model:ConditionsPrecedent ;
            sh:description "The set of elections that may overwrite the default Condition Precedent provision, and the set of provisions that are deemed Access Condition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:conditionsPrecedent ],
        [ sh:datatype xsd:string ;
            sh:description "Any additional terms that might be specified applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path common_domain_model:additionalBespokeTerms ],
        [ sh:class common_domain_model:JurisdictionRelatedTerms ;
            sh:description "The jurisdiction specific terms relevant to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path common_domain_model:jurisdictionRelatedTerms ],
        [ sh:class common_domain_model:GeneralSimmElections ;
            sh:description "The specification of the ISDA SIMM Method for all Covered Transactions with respect to all Regimes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:generalSimmElections ],
        [ sh:class common_domain_model:RightsEvents ;
            sh:description "The bespoke provisions that might be specified by the parties to the agreement to specify the rights of Security Taker and/or Security Provider when an Early Termination or Access Condition event has occurred." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path common_domain_model:rightsEvents ],
        [ sh:class common_domain_model:BaseAndEligibleCurrency ;
            sh:description "The base and eligible currency(ies) for the document as specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:baseAndEligibleCurrency ],
        [ sh:class common_domain_model:OtherAgreements ;
            sh:description "The bespoke definition of other agreement terms as specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path common_domain_model:otherAgreements ],
        [ sh:class common_domain_model:CustodyArrangements ;
            sh:description "The Custodian and Segregated Account details in respect of each party to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path common_domain_model:custodyArrangements ],
        [ sh:class common_domain_model:FinalReturns ;
            sh:description "A clause providing that final return collateral is to be provided without consideration of any Minimum Transfer Amount and collateral haircut." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path common_domain_model:finalReturns ],
        [ sh:class common_domain_model:PostingObligations ;
            sh:description "The security providers posting obligations." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:postingObligations ],
        [ sh:class common_domain_model:ProcessAgent ;
            sh:description "The Process Agent that might be appointed by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path common_domain_model:processAgent ],
        [ sh:class common_domain_model:FxHaircutCurrency ;
            sh:description "The reference currency for the purpose of specifying the FX Haircut relating to a posting obligation, as being either the Termination Currency or an FX Designated Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:fxHaircutCurrency ],
        [ sh:class common_domain_model:Regime ;
            sh:description "The Regime Table provision , which determines the regulatory regime(s) applicable to each of the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:regime ],
        [ sh:class common_domain_model:Substitution ;
            sh:description "The conditions under which the Security Provider can substitute posted collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:substitution ],
        [ sh:class common_domain_model:AddressesForTransfer ;
            sh:description "The optional specification of address for transfer as specified by the respective parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path common_domain_model:addressesForTransfer ],
        [ sh:class common_domain_model:TerminationCurrencyAmendment ;
            sh:description "The bespoke provision that might be specified by the parties to the agreement applicable to Termination Currency.  Unless specified the definition of Termination Currency has the meaning specified in the Schedule to the ISDA Master Agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path common_domain_model:terminationCurrencyAmendment ],
        [ sh:class common_domain_model:AdditionalRepresentations ;
            sh:description "The specification Additional Representations that may be applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path common_domain_model:additionalRepresentations ],
        [ sh:class common_domain_model:SensitivityMethodologies ;
            sh:description "The specification of methodologies to compute sensitivities specific to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:sensitivityMethodologies ],
        [ sh:datatype xsd:string ;
            sh:description "The bespoke provision that might be specified by the parties to the agreement applicable to Interpretations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path common_domain_model:interpretationTerms ],
        [ sh:class common_domain_model:DisputeResolution ;
            sh:description "The election terms under which a party disputes (i) the Calculation Agents calculation of a Delivery Amount or a Return Amount, or (ii) the Value of any Transfer of Eligible Credit Support or Posted Credit Support." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:disputeResolution ],
        [ sh:class common_domain_model:OneWayProvisions ;
            sh:description "The determination of whether the One Way Provisions are applicable (true) or not applicable (false)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:oneWayProvisions ],
        [ sh:class common_domain_model:CreditSupportObligationsCollateralTransferAgreement ;
            sh:description "The Credit Support Obligations applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:creditSupportObligations ],
        [ sh:class common_domain_model:PledgeeRepresentativeRider ;
            sh:description "The terms of the Rider for the ISDA Euroclear 2019 Collateral Transfer Agreement with respect to the use of a Pledgee Representative attached to this Agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path common_domain_model:pledgeeRepresentativeRider ],
        [ sh:class common_domain_model:SubstitutedRegime ;
            sh:description "The specification of Additional regimes for purposes of determining whether a Regulatory Event has occurred." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:substitutedRegime ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether cross-currency swaps need to be identified in the Confirmation so that the obligations to exchange principal be disregarded for the purpose of determining the Delivery Amount or Return Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:identifiedCrossCurrencySwap ],
        [ sh:class common_domain_model:MinimumTransferAmountAmendment ;
            sh:description "The bespoke provision that might be specified by the parties to the agreement applicable to Minimum Transfer Amount.  Unless specified the definition of Minimum Transfer Amount in any Other Regulatory CSA has the meaning specified in such Other Regulatory CSA." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path common_domain_model:minimumTransferAmountAmendment ] ;
    sh:targetClass common_domain_model:CollateralTransferAgreementElections .

common_domain_model:CollateralTransferTimingDefinition a sh:NodeShape ;
    rdfs:comment "Bespoke language removing the pre-print requirement to transfer legal title of securities collateral through written instructions to the relevant depository institution or other securities intermediaries solely for the purposes of the 1994 New York Law Credit Support Annex." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:datatype xsd:boolean ;
            sh:description "A boolean flag to represent bespoke amendment to the pre-print definition of Transfer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:CollateralTransferTimingDefinition .

common_domain_model:CollateralValuationTreatment a sh:NodeShape ;
    rdfs:comment "Specification of the valuation treatment for the specified collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Specifies a haircut percentage to be applied to the value of asset and used as a discount factor to the value of the collateral asset,expressed as a percentage in decimal terms. As an example a 0.5% haircut would be represented as a decimal number 0.005." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:haircutPercentage ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies a percentage value of transaction needing to be posted as collateral expressed as a valuation. As an example a 104% requirement would be represented as a decimal number 1.04." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:marginPercentage ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies an FX haircut applied to a specific asset which is agreed between the parties (for example, if pledgor eligible collateral is not denominated in the termination currency or under other specified cases in collateral support documents both for initial margin and variation margin).The percentage value is expressed as the discount haircut to the value of the collateral- as an example an 8% FX haircut would be expressed as 0.08." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fxHaircutPercentage ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies a percentage value of any additional haircut to be applied to a collateral asset,the percentage value is expressed as the discount haircut to the value of the collateral- as an example a 5% haircut would be expressed as 0.05. " ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:additionalHaircutPercentage ] ;
    sh:targetClass common_domain_model:CollateralValuationTreatment .

common_domain_model:CollateralValueMethod a sh:NodeShape ;
    rdfs:comment "Details how particular types of collateral are valued (other than in respect of a default)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Details of how securities collateral is valued." ;
            sh:in ( "BidPricePercentage" "BidPricePercentageLessHaircut" "MidPricePercentage" "MidPricePercentageLessHaircut" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:securitiesCollateral ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:description "Details of how cash collateral is valued." ;
            sh:in ( "CashAmount" "CashPercentage" "CashPercentageLessHaircut" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:cashCollateral ] ;
    sh:targetClass common_domain_model:CollateralValueMethod .

common_domain_model:CommodityPriceReturnTerms a sh:NodeShape ;
    rdfs:comment "Defines parameters in which the commodity price is assessed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Rounding ;
            sh:description "Defines rounding rules and precision to be used in the rounding of a number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:rounding ],
        [ sh:class common_domain_model:SpreadSchedule ;
            sh:description "Defines a spread value for one or more defined dates." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:spread ],
        [ sh:datatype xsd:decimal ;
            sh:description "Defines the conversion applied if the quantity unit on contract is different from unit on referenced underlier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:conversionFactor ],
        [ sh:class common_domain_model:RollFeature ;
            sh:description "Used in conjunction with an exchange-based pricing source. Identifies a way in which the futures contracts referenced will roll between periods. " ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:rollFeature ] ;
    sh:targetClass common_domain_model:CommodityPriceReturnTerms .

common_domain_model:CommodityProductDefinition a sh:NodeShape ;
    rdfs:comment "Specifies the commodity underlier in the event that no ISDA Commodity Reference Price exists." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceSource ;
            sh:description "Specifies a publication that provides the commodity price, including, where applicable the details of where in the publication the price is published.  Applicable when the commodity reference price is not a futures contract" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:priceSource ],
        [ sh:description "Specifies the publication where the commodity prices can be found." ;
            sh:in ( "Argus" "ArgusMcCloskeys" "ArgusAmericasCrudeReport" "ArgusBiofuelReport" "ArgusCrudeReport" "ArgusEuropeanProductsReport" "ArgusFMB" "ArgusInternationalLPGReport" "ArgusLPG" "ArgusNatGas" "AssocBanksSingapore" "BandD" "BalticExchange" "BankOfCanada" "BankOfEngland" "BankOfJapan" "Bloomberg" "BLUENEXT" "CAISO" "CanadianGasPriceReporter" "CanadianGasReporter" "ChemicalMarketsAssociation" "CMAIAromaticsMarketReport" "CMAIWeeklyMethanolMarketReport" "CRUSteelLongProductMonitor" "CRUSteelSheetProductsMonitor" "DowJonesEnergyService" "DowJonesEnergyServiceScreen" "DowJonesNatGas" "EEX" "ERCOT" "EuroCentralBank" "EURONEXMATIF" "FederalReserve" "FERTECON" "FertilizerWeek" "FHLBSF" "GasDaily" "GasDailyPriceGuide" "GlobalCoale" "GME" "HerenReport" "ICE" "ICE10XDailyNaturalGas" "ICE10XDailyPower" "ICE10XMonthly" "ICEDayAheadIndex" "ICEECX" "ICIS" "InsideFERC" "IPE" "ISDA" "ISONewEngland" "JAPANMOFTSRR" "LEBA" "LondonBullionMarketAssociation" "LONDONPLATINUMPALLADIUMMARKET" "MegawattDaily" "MetalBulletin" "MISO" "NaturalGasWeek" "NGIBidweekSurvey" "NYISO" "OBM" "OMEL" "OPIS" "PaperTrader" "PIX" "PJM" "PlattsAsiaPacific" "PlattsAsiaPacificArabMarketscan" "PlattsCleanTankerwire" "PlattsCoalTrader" "PlattsCrudeOilMarketwire" "PlattsDirtyTakerwire" "PlattsENGR" "PlattsEuropean" "PlattsEuropeanMarketscan" "PlattsGasDaily" "PlattsGasDailyPriceGuide" "PlattsInsideFERC" "PlattsLPG" "PlattsMarketwire" "PlattsMegawattDaily" "PlattsMetalsAlert" "PlattsOilgram" "PlattsOilgramBunkerwire" "PlattsPolymerscan" "PlattsTSIIronOre" "TSIScrap" "TSISteel" "PlattsUS" "PlattsUSMarketscan" "PPM" "PPMEurope" "PPW" "ReserveBankAustralia" "ReserveBankNewZealand" "Reuters" "ReutersScreen" "RIMIntelligenceProducts" "SeaPac" "Telerate" "TelerateScreen" "UXWEEKLY" "WorldCrudeReport" "WorldPulpMonthly" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:commodityInfoPublisher ],
        [ sh:datatype xsd:string ;
            sh:description " Identifies the exchange from which the reference price should be sourced, using the scheme at the following url: http://www.fpml.org/coding-scheme/external/exchange-id-MIC-1-0" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:exchangeId ],
        [ sh:class common_domain_model:CommodityReferenceFramework ;
            sh:description "Specifies the type of commodity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:referenceFramework ] ;
    sh:targetClass common_domain_model:CommodityProductDefinition .

common_domain_model:CommodityReferenceFramework a sh:NodeShape ;
    rdfs:comment "Specifies the type of commodity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Provides an enumerated value for a capacity unit, generally used in the context of defining quantities for commodities." ;
            sh:in ( "ALW" "BBL" "BCF" "BDFT" "CBM" "CER" "CRT" "DAG" "DAY" "DMTU" "ENVCRD" "ENVOFST" "FEU" "G" "GBBSH" "GBBTU" "GBCWT" "GBGAL" "GBMBTU" "GBMMBTU" "GBT" "GBTHM" "GJ" "GW" "GWH" "HL" "HOGB" "ISOBTU" "ISOMBTU" "ISOMMBTU" "ISOTHM" "J" "KG" "KL" "KW" "KWD" "KWH" "KWM" "KWMIN" "KWY" "L" "LB" "MB" "MBF" "MJ" "MMBF" "MMBBL" "MSF" "MT" "MW" "MWD" "MWH" "MWM" "MWMIN" "MWY" "OZT" "SGB" "TEU" "USBSH" "USBTU" "USCWT" "USGAL" "USMBTU" "USMMBTU" "UST" "USTHM" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:capacityUnit ],
        [ sh:description "Provides an enumerated values for a weather unit, generally used in the context of defining quantities for commodities." ;
            sh:in ( "CDD" "CPD" "HDD" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:weatherUnit ],
        [ sh:datatype xsd:string ;
            sh:description "Defines the currency in which the commodity is priced." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:currency ],
        [ sh:datatype xsd:string ;
            sh:description "Identifies the commodity more specifically. Where possible, this should follow the naming convention used in the 2005 ISDA Commodity Definitions SubAnnex A, including the subCommodity and additional qualifiers, but should be limited to 256 characters or less." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:commodityName ] ;
    sh:targetClass common_domain_model:CommodityReferenceFramework .

common_domain_model:ConcentrationLimit a sh:NodeShape ;
    rdfs:comment "Represents a class to describe concentration limits that may be applicable to eligible collateral criteria." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NumberRange ;
            sh:description "Specifies the perecentage of collateral limit represented as a decimal number - example 25% is 0.25." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:percentageLimit ],
        [ sh:class common_domain_model:ConcentrationLimitCriteria ;
            sh:description "Specifies a set of criteria to describe the assets that the concentration limits apply to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:concentrationLimitCriteria ],
        [ sh:class common_domain_model:MoneyRange ;
            sh:description "Specifies the value of collateral limit represented as a range." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:valueLimit ] ;
    sh:targetClass common_domain_model:ConcentrationLimit .

common_domain_model:ConcentrationLimitCriteria a sh:NodeShape ;
    rdfs:comment "Respresents a class to describe a set of criteria to describe specific assets that the concentration limits apply to." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the type of concentration limit to be applied." ;
            sh:in ( "Asset" "BaseCurrencyEquivalent" "Issuer" "PrimaryExchange" "IndustrySector" "UltimateParentInstitution" "IssueOutstandingAmount" "MarketCapitalisation" "OutstandingBalance" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:concentrationLimitType ],
        [ sh:description "Restrict the criteria to only apply to a specific type of margin, ie IM or VM." ;
            sh:in ( "VariationMargin" "InitialMargin" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:restrictTo ],
        [ sh:description "Denotes which Criteria has priority if more than one agency rating applies." ;
            sh:in ( "Issuer" "Asset" "Lowest" "Highest" "Average" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path common_domain_model:ratingPriorityResolution ],
        [ sh:description "The specific criteria that applies. It can be created using AND, OR and NOT logic, and both asset and issuer characteristics." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllCriteria ] [ sh:class common_domain_model:AnyCriteria ] [ sh:class common_domain_model:NegativeCriteria ] [ sh:class common_domain_model:CollateralIssuerType ] [ sh:class common_domain_model:CollateralGuarantorType ] [ sh:class common_domain_model:AssetType ] [ sh:class common_domain_model:IssuerCountryOfOrigin ] [ sh:class common_domain_model:AssetCountryOfOrigin ] [ sh:in ( "CNH" "CNT" "GGP" "IMP" "JEP" "KID" "MCF" "SML" "VAL" ) ] [ sh:class common_domain_model:IssuerName ] [ sh:class common_domain_model:IssuerAgencyRating ] [ sh:class common_domain_model:SovereignAgencyRating ] [ sh:class common_domain_model:AssetAgencyRating ] [ sh:class common_domain_model:AssetMaturity ] [ sh:class common_domain_model:SpecificAsset ] [ sh:class common_domain_model:CollateralTaxonomy ] [ sh:class common_domain_model:ListingExchange ] [ sh:class common_domain_model:ListingSector ] [ sh:class common_domain_model:IndexType ] [ sh:class common_domain_model:CounterpartyOwnIssuePermitted ] [ sh:class common_domain_model:DomesticCurrencyIssued ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:collateralCriteria ],
        [ sh:class common_domain_model:AverageTradingVolume ;
            sh:description "Specifies an average trading volume on an exchange in relation to Equity products." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:averageTradingVolume ],
        [ sh:description "Specifies which of the two counterparties the criteria applies to (either one or both counterparties). This attribute is optional, in case the applicable party is already specified elsewhere within a party election." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:order 3 ;
            sh:path common_domain_model:appliesTo ] ;
    sh:targetClass common_domain_model:ConcentrationLimitCriteria .

common_domain_model:ConstituentWeight a sh:NodeShape ;
    rdfs:comment "A class describing the weight of each of the underlier constituent within the basket, either in absolute or relative terms." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The number of units (index or securities) that constitute the underlier of the swap. In the case of a basket swap, this element is used to reference both the number of basket units, and the number of each asset components of the basket when these are expressed in absolute terms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:openUnits ],
        [ sh:datatype xsd:decimal ;
            sh:description "The relative weight of each respective basket constituent, expressed in percentage. A basket percentage of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:basketPercentage ] ;
    sh:targetClass common_domain_model:ConstituentWeight .

common_domain_model:ContractFormationInstruction a sh:NodeShape ;
    rdfs:comment "Specifies instructions to create a fully formed contract, with optional legal agreements." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalAgreement ;
            sh:description "Optional legal agreements associated to the contract being formed, for instance a master agreement." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:legalAgreement ] ;
    sh:targetClass common_domain_model:ContractFormationInstruction .

common_domain_model:ContractualMatrix a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identifies the form of applicable matrix." ;
            sh:in ( <http://www.fpml.org/coding-scheme/matrix-type-1-1#CreditDerivativesPhysicalSettlementMatrix> <http://www.fpml.org/coding-scheme/matrix-type-1-1#EquityDerivativesMatrix> <http://www.fpml.org/coding-scheme/matrix-type-1-1#SettlementMatrix> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:matrixType ],
        [ sh:description "Defines any applicable key into the relevant matrix. For example, the Transaction Type would be the single term required for the Credit Derivatives Physical Settlement Matrix. This element should be omitted in the case of the 2000 ISDA Definitions Settlement Matrix for Early Termination and Swaptions." ;
            sh:in ( "AsiaCorporate" "AsiaFinancialCorporate" "AsiaSovereign" "AustraliaCorporate" "AustraliaFinancialCorporate" "AustraliaSovereign" "EmergingEuropeanAndMiddleEasternSovereign" "EmergingEuropeanCorporate" "EmergingEuropeanCorporateLPN" "EmergingEuropeanFinancialCorporate" "EmergingEuropeanFinancialCorporateLPN" "EuropeanCoCoFinancialCorporate" "EuropeanCorporate" "EuropeanFinancialCorporate" "EuropeanSeniorNonPreferredFinancialCorporate" <http://www.fpml.org/coding-scheme/equity-matrix-transaction-type-1-0#IVS1OpenMarkets> "JapanCorporate" "JapanFinancialCorporate" "JapanSovereign" "LatinAmericaCorporate" "LatinAmericaCorporateBond" "LatinAmericaCorporateBondOrLoan" "LatinAmericaFinancialCorporateBond" "LatinAmericaFinancialCorporateBondOrLoan" "LatinAmericaSovereign" "NewZealandCorporate" "NewZealandFinancialCorporate" "NewZealandSovereign" "NorthAmericanCorporate" "NorthAmericanFinancialCorporate" "SingaporeCorporate" "SingaporeFinancialCorporate" "SingaporeSovereign" "StandardAsiaCorporate" "StandardAsiaFinancialCorporate" "StandardAsiaSovereign" "StandardAustraliaCorporate" "StandardAustraliaFinancialCorporate" "StandardAustraliaSovereign" "StandardEmergingEuropeanAndMiddleEasternSovereign" "StandardEmergingEuropeanCorporate" "StandardEmergingEuropeanCorporateLPN" "StandardEmergingEuropeanFinancialCorporate" "StandardEmergingEuropeanFinancialCorporateLPN" "StandardEuropeanCoCoFinancialCorporate" "StandardEuropeanCorporate" "StandardEuropeanFinancialCorporate" "StandardEuropeanSeniorNonPreferredFinancialCorporate" "StandardJapanCorporate" "StandardJapanFinancialCorporate" "StandardJapanSovereign" "StandardLatinAmericaCorporateBond" "StandardLatinAmericaCorporateBondOrLoan" "StandardLatinAmericaFinancialCorporateBond" "StandardLatinAmericaFinancialCorporateBondOrLoan" "StandardLatinAmericaSovereign" "StandardNewZealandCorporate" "StandardNewZealandFinancialCorporate" "StandardNewZealandSovereign" "StandardNorthAmericanCorporate" "StandardNorthAmericanFinancialCorporate" "StandardSingaporeCorporate" "StandardSingaporeFinancialCorporate" "StandardSingaporeSovereign" "StandardSubordinatedEuropeanInsuranceCorporate" "StandardSukukFinancialCorporate" "StandardUSMunicipalFullFaithAndCredit" "StandardUSMunicipalGeneralFund" "StandardUSMunicipalRevenue" "StandardWesternEuropeanSovereign" "SubordinatedEuropeanInsuranceCorporate" "SukukCorporate" "SukukFinancialCorporate" "SukukSovereign" "USMunicipalFullFaithAndCredit" "USMunicipalGeneralFund" "USMunicipalRevenue" "WesternEuropeanSovereign" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:matrixTerm ] ;
    sh:targetClass common_domain_model:ContractualMatrix .

common_domain_model:ContractualTermsSupplement a sh:NodeShape ;
    rdfs:comment "A contractual supplement (such as those published by ISDA) and its publication date that will apply to the trade." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Specifies the publication date of the applicable version of the contractual supplement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:publicationDate ],
        [ sh:description "Identifies the form of applicable contractual supplement." ;
            sh:in ( "ABX" "ABXTranche" "CDSonLeveragedLoans" "CDSonMBS" "CDX" "CDXEmergingMarkets" "CDXEmergingMarketsDiversified" "CDXSwaption" "CDXTranche" "CMBX" "EuropeanCMBS" "EuropeanRMBS" "IOS" "ISDA1999CreditConvertibleExchangeableAccretingObligations" "ISDA1999CreditRestructuring" "ISDA1999CreditSuccessorAndCreditEvents" "ISDA2003AdditionalProvisionsLPN" "ISDA2003ContingentCreditSpreadTransaction" "ISDA2003Credit2005MatrixSupplement" "ISDA2003CreditArgentineRepublic" "ISDA2003CreditAuctionSupplement" "ISDA2003CreditMay2003" "ISDA2003CreditMonolineInsurers" "ISDA2003CreditMonolineInsurers2005" "ISDA2003CreditRepublicOfHungary" "ISDA2003CreditRepublicOfHungary2005" "ISDA2003CreditRussianFederation" "ISDA2003CreditUSMunicipals" "ISDA2003STMicroelectronicsNV" "ISDA2007FullLookthroughDepositoryReceiptSupplement" "ISDA2007PartialLookthroughDepositoryReceiptSupplement" "ISDACreditMonolineInsurers" "ISDADeliveryRestrictions" "ISDAFixedRecovery" "ISDALPNReferenceEntities" "ISDAMarch2004EquityCanadianSupplement" "ISDARecoveryLock" "ISDASecuredDeliverableObligationCharacteristic" "LCDX" "LCDXTranche" "MBX" "MCDX" "PO" "PrimeX" "StandardCDXTranche" "StandardLCDS" "StandardLCDSBullet" "StandardLCDXBullet" "StandardLCDXBulletTranche" "StandardiTraxxEuropeTranche" "SyndicatedSecuredLoanCDS" "TRX" "TRX_II" "iTraxxAsiaExJapan" "iTraxxAsiaExJapanSwaption" "iTraxxAsiaExJapanTranche" "iTraxxAustralia" "iTraxxAustraliaSwaption" "iTraxxAustraliaTranche" "iTraxxCJ" "iTraxxCJTranche" "iTraxxEurope" "iTraxxEuropeDealer" "iTraxxEuropeNonDealer" "iTraxxEuropeSwaption" "iTraxxEuropeTranche" "iTraxxJapan" "iTraxxJapanSwaption" "iTraxxJapanTranche" "iTraxxLevX" "iTraxxSDI75Dealer" "iTraxxSDI75NonDealer" "iTraxxSovX" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:contractualTermsSupplementType ] ;
    sh:targetClass common_domain_model:ContractualTermsSupplement .

common_domain_model:ControlAgreement a sh:NodeShape ;
    rdfs:comment "A class to specify the relationship between the Control Agreement and the Credit Support Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ControlAgreementElections ;
            sh:description "The party specific elections." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:ControlAgreement .

common_domain_model:ControlAgreementElections a sh:NodeShape ;
    rdfs:comment "A class to specify the Control Agreement election sby each party to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ],
        [ sh:datatype xsd:boolean ;
            sh:description "Unless specified as inapplicable in the event of any inconsistency between this Deed and the Control Agreement, this Deed will prevail over the Control Agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:consistencyWithControlAgreement ],
        [ sh:datatype xsd:boolean ;
            sh:description "Unless specified as inapplicable the parties recognise that the Control Agreement is a means by which the parties can perform their obligations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:relationshipWithControlAgreement ],
        [ sh:datatype xsd:boolean ;
            sh:description "The identification of whether the Control Agreement is a Credit Support Document with respect to each party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:controlAgreementAsCsd ] ;
    sh:targetClass common_domain_model:ControlAgreementElections .

common_domain_model:ControlAgreementNecEvent a sh:NodeShape ;
    rdfs:comment "A class to specify Control Agreement language related to delivery of a Notice of Exclusive Control." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ControlAgreementNecEventElection ;
            sh:description "Indicates party specific Control Agreement language related to delivery of a Notice of Exclusive Control." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:controlAgreementNecEventElection ] ;
    sh:targetClass common_domain_model:ControlAgreementNecEvent .

common_domain_model:ControlAgreementNecEventElection a sh:NodeShape ;
    rdfs:comment "A class to specify party specific Control Agreement language related to delivery of a Notice of Exclusive Control." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates Control Agreement language related to delivery of a Notice of Exclusive Control." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:necEvent ],
        [ sh:description "The elective party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:ControlAgreementNecEventElection .

common_domain_model:CorporateAction a sh:NodeShape ;
    rdfs:comment "Specifies the relevant data regarding a corporate action" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:InformationSource ;
            sh:description "A class defining the source of data used in an Observation for any purposes. The data is either sourced from a Provider, or from a Party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:informationSource ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the account phyical balance and related underlier ownership is recorded by the custodian." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:recordDate ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "To record observations of dividends." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:dividendObservation ],
        [ sh:description "The underlier impacted by the corporate action." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Observable ] [ sh:class common_domain_model:Product ] ) ;
            sh:order 5 ;
            sh:path common_domain_model:underlier ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the corporate action is announced by the issuer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:announcementDate ],
        [ sh:description "The type of corporate action taking place." ;
            sh:in ( "CashDividend" "StockDividend" "StockSplit" "ReverseStockSplit" "SpinOff" "Merger" "Delisting" "StockNameChange" "StockIdentifierChange" "RightsIssue" "Takeover" "StockReclassification" "BonusIssue" "ClassAction" "EarlyRedemption" "Liquidation" "BankruptcyOrInsolvency" "IssuerNationalization" "Relisting" "BespokeEvent" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:corporateActionType ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which resulting from the corporate action are delivered." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:payDate ],
        [ sh:datatype xsd:string ;
            sh:description "Corporate action triggered by the occurrence of an event which description is seperatly agreed between the parties and/or described in any referenced agreement (for instance bespoke term described in any string type objects present in most root attributes of Agreement type)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:bespokeEventDescription ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the corporate action is known to have taken place." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:exDate ],
        [ sh:class common_domain_model:AdjustmentFactor ;
            sh:description "Specifies any additional details e.g. further descriptions depending on the particular type of Corporate Action, adjustmentFactor, calculations" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:adjustmentFactor ] ;
    sh:targetClass common_domain_model:CorporateAction .

common_domain_model:CounterpartyPosition a sh:NodeShape ;
    rdfs:comment "A Position describes the accumulated effect of a set of securities or financial transactions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ContractDetails ;
            sh:description "Represents information specific to trades or positions involving contractual products." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:contractDetails ],
        [ sh:class common_domain_model:Collateral ;
            sh:description "Represents the collateral obligations of a party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:collateral ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The date and time when the position was opened." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:openDateTime ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "Reference to all the trades that constitute the position." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:tradeReference ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Represents the role each specified party takes in the position." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:partyRole ],
        [ sh:class common_domain_model:PositionIdentifier ;
            sh:description "Represents the identifier(s) that uniquely identify a position for an identity issuer. A position can include multiple identifiers, for example an internal position identifer and a UTI (Unique Trade Identifier)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:positionIdentifier ],
        [ sh:class common_domain_model:TradableProduct ;
            sh:description "Encapsulates the core constituents that characterize a position." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:positionBase ],
        [ sh:class common_domain_model:Party ;
            sh:description "The parties involved in the position, including the Clearing Organization." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:ExecutionDetails ;
            sh:description "Defines specific attributes that relate to trade or position executions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:executionDetails ] ;
    sh:targetClass common_domain_model:CounterpartyPosition .

common_domain_model:CounterpartyPositionBusinessEvent a sh:NodeShape ;
    rdfs:comment "A business event represents a life cycle event of a position. The combination of the state changes results in a qualifiable life cycle event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:IdentifiedList ;
            sh:description "Specifies the package information in case the business event represents several trades executed as a package (hence this attribute is optional). The package information is only instantiated once at the business event level to preserve referential integrity, whereas individual trades make reference to it to identify that they are part of a package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:packageInformation ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date on which the event is taking place. This date is equal to the trade date in the case of a simple execution.  However it can be different from the trade date, for example in the case of a partial termination." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:eventDate ],
        [ sh:description "The intent of a corporate action on the position." ;
            sh:in ( "CashDividend" "StockDividend" "StockSplit" "ReverseStockSplit" "SpinOff" "Merger" "Delisting" "StockNameChange" "StockIdentifierChange" "RightsIssue" "Takeover" "StockReclassification" "BonusIssue" "ClassAction" "EarlyRedemption" "Liquidation" "BankruptcyOrInsolvency" "IssuerNationalization" "Relisting" "BespokeEvent" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:corporateActionIntent ],
        [ sh:description "The intent attribute is meant to be specified when the event qualification cannot be programmatically inferred from the event features. As a result it is only associated with those primitives that can give way to such ambiguity, the quantityChange being one of those." ;
            sh:in ( "PositionCreation" "CorporateActionAdjustment" "Decrease" "Increase" "Transfer" "OptionExercise" "Valuation" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:intent ],
        [ sh:class common_domain_model:CounterpartyPositionState ;
            sh:description "Specifies the after position state(s) created." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:after ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the event contractually takes effect, when different from the event date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:effectiveDate ] ;
    sh:targetClass common_domain_model:CounterpartyPositionBusinessEvent .

common_domain_model:CounterpartyPositionState a sh:NodeShape ;
    rdfs:comment "Defines the fundamental financial information that can be changed by a Primitive Event and by extension any business or life-cycle event. Each PositionState specifies where a Position is in its life-cycle. PositionState is a root type and as such, can be created independently to any other CDM data type, but can also be used as part of the CDM Event Model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ObservationEvent ;
            sh:description "Represents the observed events related to a particular product or process, such as credit events or corporate actions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:observationHistory ],
        [ sh:class common_domain_model:CounterpartyPosition ;
            sh:description "Represents the Position that has been effected by a business or life-cycle event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:counterpartyPosition ],
        [ sh:class common_domain_model:Valuation ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:valuationHistory ],
        [ sh:class common_domain_model:State ;
            sh:description "Represents the State of the Position through its life-cycle." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:state ] ;
    sh:targetClass common_domain_model:CounterpartyPositionState .

common_domain_model:CreditEvent a sh:NodeShape ;
    rdfs:comment "Specifies the relevant data regarding a credit event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The type of credit event taking place." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-event-type-1-0#Bankruptcy> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#DistressedRatingsDowngrade> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#FailureToPay> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#FailureToPayInterest> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#FailureToPayPrincipal> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#GovernmentalIntervention> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#ImpliedWritedown> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#MaturityExtension> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#ObligationAcceleration> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#ObligationDefault> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#RepudiationMoratorium> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#Restructuring> <http://www.fpml.org/coding-scheme/credit-event-type-1-0#Writedown> ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:creditEventType ],
        [ sh:class common_domain_model:ReferenceInformation ;
            sh:description "The reference entity, part of a credit basket, impacted by the credit event." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:referenceInformation ],
        [ sh:class common_domain_model:Resource ;
            sh:description "A public information source, e.g. a particular newspaper or electronic news service, that may publish relevant information used in the determination of whether or not a credit event has occurred." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:publiclyAvailableInformation ],
        [ sh:datatype xsd:date ;
            sh:description "The date in which the credit event is determined by the Credit Derivatives Determinations Comitee." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:eventDeterminationDate ],
        [ sh:class common_domain_model:Price ;
            sh:description "The final price resulting from the auction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:finalPrice ],
        [ sh:datatype xsd:decimal ;
            sh:description "The percentage of the original value of the asset affected by the credit event that can be recovered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:recoveryPercent ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the auction is scheduled to occur." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:auctionDate ] ;
    sh:targetClass common_domain_model:CreditEvent .

common_domain_model:CreditEventNotice a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The notifying party is the party that notifies the other party when a credit event has occurred by means of a credit event notice. If more than one party is referenced as being the notifying party then either party may notify the other of a credit event occurring. ISDA 2003 Term: Notifying Party." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:notifyingParty ],
        [ sh:datatype xsd:string ;
            sh:description "Inclusion of this business center element implies that Greenwich Mean Time in Section 3.3 of the 2003 ISDA Credit Derivatives Definitions is replaced by the local time of the city indicated by the businessCenter element value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:businessCenter ],
        [ sh:class common_domain_model:PubliclyAvailableInformation ;
            sh:description "A specified condition to settlement. Publicly available information means information that reasonably confirms any of the facts relevant to determining that a credit event or potential repudiation/moratorium, as applicable, has occurred. The ISDA defined list (2003) is the market standard and is considered comprehensive, and a minimum of two differing public sources must have published the relevant information, to declare a Credit Event. ISDA 2003 Term: Notice of Publicly Available Information Applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:publiclyAvailableInformation ] ;
    sh:targetClass common_domain_model:CreditEventNotice .

common_domain_model:CreditIndex a sh:NodeShape ;
    rdfs:comment "Specification of an index based on credit risk, typically composed using corporate debt instruments in a region or industry sector, e.g. the iTraxx indices." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The Asset Class of the Index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path common_domain_model:assetClass ],
        [ sh:class common_domain_model:ReferenceInformation ;
            sh:description "Excluded reference entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:excludedReferenceEntity ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:description "Seniority of debt instruments comprising the index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-seniority-2-3#Other> <http://www.fpml.org/coding-scheme/credit-seniority-2-3#SeniorLossAbsorbingCapacity> <http://www.fpml.org/coding-scheme/credit-seniority-2-3#SeniorSec> <http://www.fpml.org/coding-scheme/credit-seniority-2-3#SeniorUnSec> <http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubLowerTier2> <http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubTier1> <http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubTier3> <http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubUpperTier2> ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:seniority ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path common_domain_model:exchange ],
        [ sh:datatype xsd:integer ;
            sh:description "A CDS index series version identifier, e.g. 1, 2, 3 etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:indexAnnexVersion ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The organisation that creates or maintains the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:provider ],
        [ sh:datatype xsd:date ;
            sh:description "A CDS index series annex date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:indexAnnexDate ],
        [ sh:datatype xsd:decimal ;
            sh:description "Index Factor is the index version factor or percent, expressed as an absolute decimal value between 0 and 1, that multiplied by the original notional amount yields the notional amount covered by the seller of protection." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:indexFactor ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 17 ;
            sh:path common_domain_model:assetType ],
        [ sh:class common_domain_model:Tranche ;
            sh:description "This element contains CDS tranche terms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:tranche ],
        [ sh:class common_domain_model:SettledEntityMatrix ;
            sh:description "Used to specify the Relevant Settled Entity Matrix when there are settled entities at the time of the trade." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:settledEntityMatrix ],
        [ sh:datatype xsd:integer ;
            sh:description "A CDS index series identifier, e.g. 1, 2, 3 etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:indexSeries ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:name ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:description "A CDS index series annex source." ;
            sh:in ( <http://www.fpml.org/coding-scheme/cdx-index-annex-source-1-0#MasterConfirmation> <http://www.fpml.org/coding-scheme/cdx-index-annex-source-1-0#Publisher> ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:indexAnnexSource ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:identifier ] ;
    sh:targetClass common_domain_model:CreditIndex .

common_domain_model:CreditLimitInformation a sh:NodeShape ;
    rdfs:comment "A class to represent the credit limit utilisation information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LimitApplicableExtended ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:limitApplicable ] ;
    sh:targetClass common_domain_model:CreditLimitInformation .

common_domain_model:CreditSupportAgreementInitialMarginElections a sh:NodeShape ;
    rdfs:comment "The set of elections which specify an Initial Margin Credit Support Annex or Deed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SensitivityMethodologies ;
            sh:description "The specification of methodologies to compute sensitivities specific to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:sensitivityMethodologies ],
        [ sh:class common_domain_model:ProcessAgent ;
            sh:description "The Process Agent that might be appointed by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path common_domain_model:processAgent ],
        [ sh:class common_domain_model:AdditionalRepresentations ;
            sh:description "The specification Additional Representations that may be applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path common_domain_model:additionalRepresentations ],
        [ sh:datatype xsd:string ;
            sh:description "Any additional amendments that might be specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path common_domain_model:additionalAmendments ],
        [ sh:class common_domain_model:OtherEligibleAndPostedSupport ;
            sh:description "The Other Eligible Support elections associated with margin agreements." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path common_domain_model:otherEligibleAndPostedSupport ],
        [ sh:class common_domain_model:TerminationCurrencyAmendment ;
            sh:description "The bespoke provision that might be specified by the parties to the agreement applicable to Termination Currency.  Unless specified the definition of Termination Currency has the meaning specified in the Schedule to the ISDA Master Agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:terminationCurrencyAmendment ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether cross-currency swaps need to be identified in the Confirmation so that the obligations to exchange principal be disregarded for the purpose of determining the Delivery Amount or Return Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:identifiedCrossCurrencySwap ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether Trust Scheme Addendum is applicable (True) or not applicable (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path common_domain_model:trustSchemeAddendum ],
        [ sh:class common_domain_model:DemandsAndNotices ;
            sh:description "The optional specification of address where the demands, specifications and notices will be communicated to for each of the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path common_domain_model:demandsAndNotices ],
        [ sh:class common_domain_model:FxHaircutCurrency ;
            sh:description "The reference currency for the purpose of specifying the FX Haircut relating to a posting obligation, as being either the Termination Currency or an FX Designated Currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:fxHaircutCurrency ],
        [ sh:class common_domain_model:DisputeResolution ;
            sh:description "The election terms under which a party disputes (i) the Calculation Agents calculation of a Delivery Amount or a Return Amount, or (ii) the Value of any Transfer of Eligible Credit Support or Posted Credit Support." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path common_domain_model:disputeResolution ],
        [ sh:class common_domain_model:DistributionAndInterestPayment ;
            sh:description "The Distributions and Interest Payment terms specified as part of the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path common_domain_model:distributionAndInterestPayment ],
        [ sh:class common_domain_model:AppropriatedCollateralValuation ;
            sh:description "The election for the Valuation of Appropriate Collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path common_domain_model:appropriatedCollateralValuation ],
        [ sh:class common_domain_model:Regime ;
            sh:description "The Regime Table provision , which determines the regulatory regime(s) applicable to each of the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:regime ],
        [ sh:class common_domain_model:MasterAgreementDatedAsOfDate ;
            sh:description "Defines the dates agreed by the parties as the date of the Credit Support Annex or Credit Support Deed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path common_domain_model:masterAgreementDatedAsOfDate ],
        [ sh:class common_domain_model:OtherAgreements ;
            sh:description "The bespoke definition of other agreement terms as specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:otherAgreements ],
        [ sh:class common_domain_model:RightsEvents ;
            sh:description "The bespoke provisions that might be specified by the parties to the agreement to specify the rights of Security Taker and/or Security Provider when an Early Termination or Access Condition event has occurred." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:rightsEvents ],
        [ sh:class common_domain_model:JurisdictionRelatedTerms ;
            sh:description "The jurisdiction specific terms relevant to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path common_domain_model:jurisdictionRelatedTerms ],
        [ sh:class common_domain_model:BaseAndEligibleCurrency ;
            sh:description "The base and eligible currency(ies) for the document as specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path common_domain_model:baseAndEligibleCurrency ],
        [ sh:datatype xsd:string ;
            sh:description "Any additional terms that might be specified applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path common_domain_model:additionalBespokeTerms ],
        [ sh:class common_domain_model:FinalReturns ;
            sh:description "A clause providing that final return collateral is to be provided without consideration of any Minimum Transfer Amount and collateral haircut." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path common_domain_model:finalReturns ],
        [ sh:datatype xsd:string ;
            sh:description "Details of language relating to Client Asset and Money Rules (CASS)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path common_domain_model:clientAssetSourcebookAdditionalLanguage ],
        [ sh:class common_domain_model:CalculationAndTimingInitialMargin ;
            sh:description "The set of elections for determining Valuation and Timing terms specific to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path common_domain_model:calculationAndTiming ],
        [ sh:class common_domain_model:HoldingAndUsingPostedCollateral ;
            sh:description "The elections for the holding and using of posted collateral by the respective parties to the Credit Support Annex for Variation Margin." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path common_domain_model:holdingAndUsingPostedCollateral ],
        [ sh:class common_domain_model:CreditSupportObligationsInitialMargin ;
            sh:description "The Credit Support Obligations applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path common_domain_model:creditSupportObligations ],
        [ sh:class common_domain_model:MinimumTransferAmountAmendment ;
            sh:description "The bespoke provision that might be specified by the parties to the agreement applicable to Minimum Transfer Amount.  Unless specified the definition of Minimum Transfer Amount in any Other Regulatory CSA has the meaning specified in such Other Regulatory CSA." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:minimumTransferAmountAmendment ],
        [ sh:class common_domain_model:CoveredTransactions ;
            sh:description "The specification of transactions covered by the terms of the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:coveredTransactions ],
        [ sh:class common_domain_model:SubstitutedRegime ;
            sh:description "The specification of Additional regimes for purposes of determining whether a Regulatory Event has occurred." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:substitutedRegime ],
        [ sh:datatype xsd:string ;
            sh:description "The bespoke provision that might be specified by the parties to the agreement applicable to Interpretations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path common_domain_model:interpretationTerms ],
        [ sh:class common_domain_model:OneWayProvisions ;
            sh:description "The determination of whether the One Way Provisions are applicable (true) or not applicable (false)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:oneWayProvisions ],
        [ sh:class common_domain_model:PostingObligations ;
            sh:description "The security providers posting obligations." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:postingObligations ],
        [ sh:class common_domain_model:CustodyArrangements ;
            sh:description "The Custodian and Segregated Account details in respect of each party to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:custodyArrangements ],
        [ sh:class common_domain_model:Substitution ;
            sh:description "The conditions under which the Security Provider can substitute posted collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path common_domain_model:substitution ],
        [ sh:class common_domain_model:ConditionsPrecedent ;
            sh:description "The set of elections that may overwrite the default Condition Precedent provision, and the set of provisions that are deemed Access Condition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path common_domain_model:conditionsPrecedent ],
        [ sh:class common_domain_model:GeneralSimmElections ;
            sh:description "The specification of the ISDA SIMM Method for all Covered Transactions with respect to all Regimes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:generalSimmElections ] ;
    sh:targetClass common_domain_model:CreditSupportAgreementInitialMarginElections .

common_domain_model:CreditSupportAgreementLegacyElections a sh:NodeShape ;
    rdfs:comment "The set of elections which specify a Legacy (1994 or 1995) Credit Support Annex or Deed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ConditionsPrecedent ;
            sh:description "The set of elections that may overwrite the default Condition Precedent provision, and the set of provisions that are deemed Access Condition." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:conditionsPrecedent ],
        [ sh:class common_domain_model:AdditionalRepresentations ;
            sh:description "The specification Additional Representations that may be applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path common_domain_model:additionalRepresentations ],
        [ sh:class common_domain_model:FinalReturns ;
            sh:description "A clause providing that final return collateral is to be provided without consideration of any Minimum Transfer Amount and collateral haircut." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path common_domain_model:finalReturns ],
        [ sh:datatype xsd:string ;
            sh:description "The bespoke exchange date terms that might be specified by the parties to the agreement." ;
