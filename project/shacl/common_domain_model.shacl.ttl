            sh:order 8 ;
            sh:path common_domain_model:agreementMinimumTransferAmount ],
        [ sh:class common_domain_model:EligibleCollateralCriteria ;
            sh:description "Specifies the details to describe or identify non-cash collateral eligible assets for recall purposes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:recallNonCashCollateralDescription ],
        [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral legal agreement threshold amount in base currency." ;
