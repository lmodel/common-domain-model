common_domain_model:MasterAgreement a sh:NodeShape ;
    rdfs:comment "The set of elections that define an ISDA Master Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CreditSupportDocument ;
            sh:description "Identification of party specific Credit Support Documents applicable to the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:creditSupportDocument ],
        [ sh:class common_domain_model:DemandsAndNotices ;
            sh:description "Specification of the address and other details for notices." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:addressForNotices ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specification of whether the Governing Law clause extends to Non-Contractual Obligations (True) or does not extend to Non-Contractual Obligations (False)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:nonContractualObligations ],
        [ sh:class common_domain_model:SpecifiedEntities ;
            sh:description "A provision that allows each party to specify its Specified Entities for certain Events of Default and Termination Events." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:specifiedEntities ],
        [ sh:class common_domain_model:AutomaticEarlyTermination ;
            sh:description "The specification of whether there is an automatic occurrence of an Early Termination Date in respect of Transactions upon the occurrence of certain bankruptcy / insolvency related events." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:automaticEarlyTermination ],
        [ sh:class common_domain_model:TerminationCurrency ;
            sh:description "Specification of the currency in which the termination payment is made (including the process by which such currency is determined)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:terminationCurrency ],
        [ sh:class common_domain_model:CreditSupportProvider ;
            sh:description "Identification of party specific Credit Support Providers applicable to the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:creditSupportProvider ] ;
    sh:targetClass common_domain_model:MasterAgreement .

common_domain_model:MasterAgreementBase a sh:NodeShape ;
    rdfs:comment "A set of elections that can be shared across master agreement types - this should be built upon for specific contracts." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:specifiedEntities common_domain_model:collateral common_domain_model:eventsOfDefault rdf:type common_domain_model:creditSupportProvider common_domain_model:automaticEarlyTermination common_domain_model:addressForNotices common_domain_model:creditSupportDocument common_domain_model:nonContractualObligations common_domain_model:baseCurrency common_domain_model:terminationCurrency ) ;
    sh:targetClass common_domain_model:MasterAgreementBase .

common_domain_model:MasterConfirmationBase a sh:NodeShape ;
    rdfs:comment "Legal agreement specification for General Terms and Elections that are applicable across multiple confirmations and are referenced by these confirmations." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:linearInterpolationElection common_domain_model:typeOfSwapElection common_domain_model:equityCashSettlementDates common_domain_model:settlementTerms rdf:type common_domain_model:pricingMethodElection common_domain_model:valuationDates ) ;
    sh:targetClass common_domain_model:MasterConfirmationBase .

common_domain_model:MeasureBase a sh:NodeShape ;
    rdfs:comment "Provides an abstract type to define a measure as a number associated to a unit. This type is abstract because all its attributes are optional. The types that extend it can specify further existence constraints." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:datedValue common_domain_model:priceExpression common_domain_model:priceType common_domain_model:arithmeticOperator common_domain_model:multiplier common_domain_model:composite rdf:type common_domain_model:frequency common_domain_model:priceSubType common_domain_model:perUnitOf common_domain_model:premiumType ) ;
    sh:property [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:unit ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:MeasureBase .

common_domain_model:MeasureSchedule a sh:NodeShape ;
    rdfs:comment "A set of measures, all in the same unit, where the values are defined through a schedule of steps. The initial value may be defined either as part of the steps, or using the single amount attribute." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:priceExpression common_domain_model:priceType common_domain_model:arithmeticOperator common_domain_model:multiplier common_domain_model:composite rdf:type common_domain_model:frequency common_domain_model:priceSubType common_domain_model:perUnitOf common_domain_model:premiumType ) ;
    sh:property [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:unit ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:datedValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:MeasureSchedule .

common_domain_model:NonNegativeStep a sh:NodeShape ;
    rdfs:comment "A class defining a step date and non-negative step value pair. This step definitions are used to define varying rate or amount schedules, e.g. a notional amortisation or a step-up coupon schedule." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date on which the associated stepValue becomes effective. This day may be subject to adjustment in accordance with a business day convention." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:stepDate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The non-negative rate or amount which becomes effective on the associated stepDate. A rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:stepValue ] ;
    sh:targetClass common_domain_model:NonNegativeStep .

common_domain_model:OtherAgreement a sh:NodeShape ;
    rdfs:comment "A class for defining an agreement executed between parties." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The agreement executed between the parties and intended to govern product-specific derivatives transactions between those parties." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:otherAgreementType ],
        [ sh:datatype xsd:string ;
            sh:description "An identifier that has been created to identify the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:datatype xsd:date ;
            sh:description "The date on which the agreement was signed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:date ],
        [ sh:datatype xsd:string ;
            sh:description "The version of the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:version ] ;
    sh:targetClass common_domain_model:OtherAgreement .

common_domain_model:OtherIndex a sh:NodeShape ;
    rdfs:comment "Specification of a user-defined index that does not meet the criteria of other Index data types." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path common_domain_model:assetType ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:exchange ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:name ],
        [ sh:description "The Asset Class of the Index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:assetClass ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The organisation that creates or maintains the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:provider ],
        [ sh:datatype xsd:string ;
            sh:description "A description that defines the OtherIndex." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:description ] ;
    sh:targetClass common_domain_model:OtherIndex .

common_domain_model:PartyAgreementIdentifier a sh:NodeShape ;
    rdfs:comment "A class defining a legal agreement identifier issued by the indicated party." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "Party that issued the document identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyReference ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "While FpML specifies the document identifier with a value and an associated scheme, the CDM makes use of the Identifier, which has an explicit issuer. The issuer of this identifier is not necessarily the same as the party reference." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:documentIdentifier ] ;
    sh:targetClass common_domain_model:PartyAgreementIdentifier .

common_domain_model:Payout a sh:NodeShape ;
    rdfs:comment "Represents the set of future cashflow methodologies in the form of specific payout data type(s) which result from the financial product.  Examples: a trade in a cash asset will use only a settlement payout; for derivatives, two interest rate payouts can be combined to specify an interest rate swap; one interest rate payout can be combined with a credit default payout to specify a credit default swap." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:Payout .

common_domain_model:PayoutBase a sh:NodeShape ;
    rdfs:comment "A data type that contains the common attributes (e.g. payer and receiver parties) and validation conditions that apply across all payout types" ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:compoundingMethod common_domain_model:bondReference common_domain_model:interimValuationPrice common_domain_model:schedule rdf:type common_domain_model:calculationPeriodDates common_domain_model:fxFeature common_domain_model:portfolioReturnTerms common_domain_model:fixedAmount common_domain_model:minimumFee common_domain_model:returnTerms common_domain_model:assetLeg common_domain_model:transactedPrice common_domain_model:deliveryTerm common_domain_model:tradeType common_domain_model:resetDates common_domain_model:optionType common_domain_model:dividendTerms common_domain_model:protectionTerms common_domain_model:exerciseTerms common_domain_model:buyerSeller common_domain_model:generalTerms common_domain_model:cashflowRepresentation common_domain_model:paymentDates common_domain_model:spreadCalculationMethod common_domain_model:pricingDates common_domain_model:averagingFeature common_domain_model:floatingAmount common_domain_model:underlier common_domain_model:dayCountFraction common_domain_model:delivery common_domain_model:initialValuationPrice common_domain_model:strike common_domain_model:feature common_domain_model:paymentDate common_domain_model:valuationDates common_domain_model:commodityPriceReturnTerms common_domain_model:paymentDelay common_domain_model:rateSpecification common_domain_model:finalValuationPrice common_domain_model:discountingMethod common_domain_model:observationTerms common_domain_model:stubPeriod common_domain_model:fixedPrice ) ;
    sh:property [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:principalPayment ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:payerReceiver ] ;
    sh:targetClass common_domain_model:PayoutBase .

common_domain_model:Portfolio a sh:NodeShape ;
    rdfs:comment " A Portfolio represents an aggregation of multiple Positions, by describing the parameters that this Portfolio should be aggregated based on. The resulting PortfolioState is calculated using these aggregation parameters as inputs, by aggregating all the Events that are relevant to this Portfolio. The concept of Portfolio works at all levels in the model: from the highest for a given LegalEntity for instance, to the lowest to account for security substitutions in a secutity financing transaction. As such, Portfolio can be used either above or below the Contract level." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PortfolioState ;
            sh:description "Describes the state of the Portfolio as a list of Positions resulting from the aggregation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:portfolioState ],
        [ sh:class common_domain_model:AggregationParameters ;
            sh:description "Describes the portfolio by describing how to aggregate all its relevant Events." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:aggregationParameters ] ;
    sh:targetClass common_domain_model:Portfolio .

common_domain_model:PositionBase a sh:NodeShape ;
    rdfs:comment "Base class to describe a Position, which could be a group of products (e.g. trade portfolio) or a group of assets (e.g. collateral portfolio)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:collateralPositionStatus common_domain_model:treatment ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "The aggregate cost of proceeds." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:cashBalance ],
        [ sh:class common_domain_model:TradeState ;
            sh:description "Reference to the Contract, in case product is contractual and the contract has been formed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:tradeReference ],
        [ sh:class common_domain_model:PriceQuantity ;
            sh:description "Position with many price quantities." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:description "The asset that underlies the position." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:asset ],
        [ sh:class common_domain_model:Product ;
            sh:description "The product underlying the position." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:product ] ;
    sh:targetClass common_domain_model:PositionBase .

common_domain_model:PostedCreditSupportItem a sh:NodeShape ;
    rdfs:comment "Posted Credit Support item with corresponding Valuation Percentage, FX Haircut Percentage and any related disputed Posted Credit Support valuation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "FX Haircut Percentage means, for any item of Eligible Collateral (IM), the percentage specified in accordance with Paragraph 13." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:fxHaircutPercentage ],
        [ sh:class common_domain_model:Money ;
            sh:description "The Base Currency Equivalent of Cash or Security." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:cashOrSecurityValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "Valuation Percentage means, for any item of Eligible Collateral (IM), the percentage specified in accordance with Paragraph 13." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:haircutPercentage ],
        [ sh:class common_domain_model:Money ;
            sh:description "Paragraph 5. If a party (a 'Disputing Party') disputes the Value of any Posted Credit Support (IM)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:disputedCashOrSecurityValue ],
        [ sh:datatype xsd:decimal ;
            sh:description "Percentage value of any additional haircut to be applied to a collateral asset,the percentage value is expressed as the discount haircut to the value of the collateral- as an example a 5% haircut would be expressed as 0.05." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:additionalHaircutPercentage ] ;
    sh:targetClass common_domain_model:PostedCreditSupportItem .

common_domain_model:QuantitySchedule a sh:NodeShape ;
    rdfs:comment "Specifies a quantity schedule to be associated to a financial product to represent a trade amount. This data type extends MeasureSchedule with several unit or multiplier attributes that are used to define financial quantities. This data type is generically based on a schedule and can also be used to represent a quantity as a single value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Specifies the value of the measure as a number. Optional because in a measure vector or schedule, this single value may be omitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:value ],
        [ sh:class common_domain_model:Frequency ;
            sh:description "Defines the frequency to be used when defining a quantity. For example a quantity may be specified as a number of barrels of oil per day, which needs multiplying by the number of days in the relevant period to get the total quantity as a number of barrels." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:frequency ],
        [ sh:class common_domain_model:UnitType ;
            sh:description "Qualifies the unit by which the amount is measured. Optional because a measure may be unit-less (e.g. when representing a ratio between amounts in the same unit)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:unit ],
        [ sh:class common_domain_model:DatedValue ;
            sh:description "A schedule of step date and value pairs. On each step date the associated step value becomes effective. The step dates are used to order the steps by ascending order. This attribute is optional so the data type may be used to define a schedule with a single value." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:datedValue ],
        [ sh:class common_domain_model:Measure ;
            sh:description "Defines an optional number that the quantity should be multiplied by to derive a total quantity. This number is associated to a unit. For example in the case of the Coal (API2) CIF ARA (ARGUS-McCloskey) Futures Contract on the CME, where the unit would be contracts, the multiplier value would 1,000 and the mulitiplier unit would be 1,000 MT (Metric Tons)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:multiplier ] ;
    sh:targetClass common_domain_model:QuantitySchedule .

common_domain_model:RateSpecification a sh:NodeShape ;
    rdfs:comment " A data type to specify the fixed interest rate, floating interest rate or inflation rate." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:RateSpecification .

common_domain_model:RelatedParty a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Party ;
            sh:description "Reference to a party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyReference ],
        [ sh:description "The category of the relationship. The related party performs the role specified in this field for the base party. For example, if the role is ,Guarantor, the related party acts as a guarantor for the base party." ;
            sh:in ( <http://www.fpml.org/coding-scheme/party-role-4-0#Accountant> "AgentLender" <http://www.fpml.org/coding-scheme/party-role-4-0#AllocationAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ArrangingBroker> "BarrierDeterminationAgent" "BeneficialOwner" <http://www.fpml.org/coding-scheme/party-role-4-0#Beneficiary> <http://www.fpml.org/coding-scheme/party-role-4-0#BookingParty> "Borrower" <http://www.fpml.org/coding-scheme/party-role-4-0#Buyer> <http://www.fpml.org/coding-scheme/party-role-4-0#BuyerDecisionMaker> "Chargor" <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingClient> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingExceptionParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingFirm> <http://www.fpml.org/coding-scheme/party-role-4-0#ClearingOrganization> <http://www.fpml.org/coding-scheme/party-role-4-0#Client> <http://www.fpml.org/coding-scheme/party-role-4-0#ClientDecisionMaker> <http://www.fpml.org/coding-scheme/party-role-4-0#ConfirmationPlatform> <http://www.fpml.org/coding-scheme/party-role-4-0#ContractualParty> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#CounterPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Counterparty> <http://www.fpml.org/coding-scheme/party-role-4-0#CreditSupportProvider> <http://www.fpml.org/coding-scheme/party-role-4-0#Custodian> <http://www.fpml.org/coding-scheme/party-role-4-0#DataSubmitter> "DeterminingParty" <http://www.fpml.org/coding-scheme/party-role-4-0#DisputingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#DocumentRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutingEntity> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#ExecutionFacility> <http://www.fpml.org/coding-scheme/party-role-4-0#Guarantor> "HedgingParty" "Lender" "MarginAffiliate" <http://www.fpml.org/coding-scheme/party-role-4-0#OrderTransmitter> "Pledgor" <http://www.fpml.org/coding-scheme/party-role-4-0#PrimeBroker> <http://www.fpml.org/coding-scheme/party-role-4-0#PriorTradeRepository> "PTRRServiceProvider" <http://www.fpml.org/coding-scheme/party-role-4-0#PublicationVenue> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingParty> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyAffiliate> <http://www.fpml.org/coding-scheme/party-role-4-0#ReportingPartyUltimateParent> <http://www.fpml.org/coding-scheme/party-role-4-0#Seller> <http://www.fpml.org/coding-scheme/party-role-4-0#SellerDecisionMaker> "SecuredParty" <http://www.fpml.org/coding-scheme/party-role-4-0#SettlementAgent> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeRepository> <http://www.fpml.org/coding-scheme/party-role-4-0#TradeSource> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingManager> <http://www.fpml.org/coding-scheme/party-role-4-0#TradingPartner> "TripartyAgent" "ThirdPartyCustodian" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:role ],
        [ sh:class common_domain_model:Account ;
            sh:description "Reference to an account." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:accountReference ] ;
    sh:targetClass common_domain_model:RelatedParty .

common_domain_model:RelativeTimeOffset a sh:NodeShape ;
    rdfs:comment "Describes how a time is offset from a reference point, including the unit, magnitude, and rounding behavior." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:timeRelativeTo rdf:type ) ;
    sh:property [ sh:class common_domain_model:TimeRounding ;
            sh:description "Optional rules that define how the calculated time should be rounded after the offset has been applied." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:rounding ],
        [ sh:datatype xsd:integer ;
            sh:description "A time offset multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying a negative offset, e.g. -2 hours." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:offsetMultiplier ],
        [ sh:description "The unit of time for the offset (e.g., seconds, minutes, hours, days). " ;
            sh:in ( "Second" "Minute" "Hour" "Day" "Week" "Month" "Year" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:offsetTimeUnit ] ;
    sh:targetClass common_domain_model:RelativeTimeOffset .

common_domain_model:ReturnInstruction a sh:NodeShape ;
    rdfs:comment "Specifies the information required to create the return of a Security Finance Transaction." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Quantity ;
            sh:description "Specifies the quantity of shares and cash to be returned in a partial return event." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:quantity ] ;
    sh:targetClass common_domain_model:ReturnInstruction .

common_domain_model:ReturnTermsBase a sh:NodeShape ;
    rdfs:comment "Contains all common elements in variance, volatility and correlation return Terms." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:vegaNotionalAmount common_domain_model:exchangeTradedContractNearest common_domain_model:varianceCapFloor common_domain_model:correlationStrikePrice common_domain_model:boundedCorrelation common_domain_model:varianceStrikePrice rdf:type common_domain_model:volatilityStrikePrice common_domain_model:numberOfDataSeries common_domain_model:volatilityCapFloor ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Expected number of trading days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:expectedN ],
        [ sh:class common_domain_model:EquityUnderlierProvisions ;
            sh:description "Contains Equity Underlyer provisions regarding jurisdiction and fallbacks." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:equityUnderlierProvisions ],
        [ sh:description "In this context, this is AgreedInitialPrice - a specified Initial Index Level." ;
            sh:in ( <http://www.fpml.org/coding-scheme/determination-method-3-4#AgreedInitialPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#AsSpecifiedInMasterConfirmation> <http://www.fpml.org/coding-scheme/determination-method-3-4#CalculationAgent> <http://www.fpml.org/coding-scheme/determination-method-3-4#ClosingPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#DividendCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#ExpiringContractLevel> <http://www.fpml.org/coding-scheme/determination-method-3-4#HedgeExecution> <http://www.fpml.org/coding-scheme/determination-method-3-4#IssuerPaymentCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#NAV> <http://www.fpml.org/coding-scheme/determination-method-3-4#OpenPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#OSPPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#SettlementCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#StrikeDateDetermination> <http://www.fpml.org/coding-scheme/determination-method-3-4#TWAPPrice> "TWAPVE" "TWAPVEExcludingClose" <http://www.fpml.org/coding-scheme/determination-method-3-4#ValuationTime> <http://www.fpml.org/coding-scheme/determination-method-3-4#VWAPPrice> "VWAPVE" "VWAPVEExcludingClose" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:initialLevelSource ],
        [ sh:datatype xsd:integer ;
            sh:description "This specifies the numerator of an annualization factor. Frequently this number is equal to the number of observations of prices in a year e.g. 252." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:annualizationFactor ],
        [ sh:datatype xsd:decimal ;
            sh:description "Contract will strike off this initial level. Providing just the initialLevel without initialLevelSource, infers that this is AgreedInitialPrice - a specified Initial Index Level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:initialLevel ],
        [ sh:class common_domain_model:ValuationTerms ;
            sh:description "Contains all non-date valuation information." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:valuationTerms ],
        [ sh:datatype xsd:string ;
            sh:description "Performance calculation, in accordance with Part 1 Section 12 of the 2018 ISDA CDM Equity Confirmation for Security Equity Swap, Para 75. 'Equity Performance'. Cumulative performance is used as a notional multiplier factor on both legs of an Equity Swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:performance ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether the price of shares is adjusted for dividends or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:sharePriceDividendAdjustment ],
        [ sh:datatype xsd:boolean ;
            sh:description "Specifies whether Mean Adjustment is applicable or not in the calculation of the Realized Volatility, Variance or Correlation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:meanAdjustment ],
        [ sh:class common_domain_model:DividendApplicability ;
            sh:description "The parameters which define whether dividends are applicable" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:dividendApplicability ] ;
    sh:targetClass common_domain_model:ReturnTermsBase .

common_domain_model:SecurityLendingInvoice a sh:NodeShape ;
    rdfs:comment "Specifies the information required for inclusion in a securities lending billing invoice." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The starting date of the period described by this invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:billingStartDate ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party receiving the invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:receivingParty ],
        [ sh:class common_domain_model:BillingSummary ;
            sh:description "The billing summaries contained within the invoice" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:billingSummary ],
        [ sh:datatype xsd:date ;
            sh:description "The ending date of the period described by this invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:billingEndDate ],
        [ sh:class common_domain_model:Party ;
            sh:description "The party issuing the invoice" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:sendingParty ],
        [ sh:class common_domain_model:BillingRecord ;
            sh:description "The billing records contained within the invoice" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:billingRecord ] ;
    sh:targetClass common_domain_model:SecurityLendingInvoice .

common_domain_model:SecurityLocate a sh:NodeShape ;
    rdfs:comment "A locate is an approval from a broker that needs to be obtained prior to effecting a short sale in an equity security. Similar to security availability, a borrower can request a single or multiple securities, but at least one must be requested." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MessageInformation ;
            sh:description "Allows details related to the availability messaging use case to be defined" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:messageInformation ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Defines the role(s) that party(ies) may have in relation to the inventory." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:partyRole ],
        [ sh:class common_domain_model:Party ;
            sh:description "Defines all parties involved for the list of inventory records in this set of inventory. For example, when used to describe securities lending availability, this could hold the sender of the availability, the intended recipient, the beneficial owner(s), the lender (which may differ from the sender as the lender may have the same piece of availability going through multiple agents), an agent or a venue." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:party ],
        [ sh:description "Defines the purpose of this inventory." ;
            sh:in ( "AvailableToLend" "RequestToBorrow" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:availableInventoryType ],
        [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "Unique identifier for this group. This can be used to uniquely identify a group of inventory records." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:identifer ],
        [ sh:class common_domain_model:AvailableInventoryRecord ;
            sh:description "An array holding the list of inventory being described. Each element in the inventoryRecord array represents an individual piece of inventory i.e. a security." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:availableInventoryRecord ],
        [ sh:datatype xsd:string ;
            sh:description "Optional comments for this group of inventory records." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:comment ] ;
    sh:targetClass common_domain_model:SecurityLocate .

common_domain_model:SettlementBase a sh:NodeShape ;
    rdfs:comment "A base class to be extended by the SettlementTerms class." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:physicalSettlementTerms rdf:type common_domain_model:cashSettlementTerms ) ;
    sh:property [ sh:description "Optional settlement centre as an enumerated list: Euroclear, Clearstream." ;
            sh:in ( "EuroclearBank" "ClearstreamBankingLuxembourg" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:settlementCentre ],
        [ sh:description "Whether the settlement will be cash, physical, by election, ..." ;
            sh:in ( "Cash" "Physical" "Election" "CashOrPhysical" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:settlementType ],
        [ sh:datatype xsd:string ;
            sh:description "The settlement currency is to be specified when the Settlement Amount cannot be known in advance. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:settlementCurrency ],
        [ sh:description "Settlement Style." ;
            sh:in ( "Standard" "Net" "StandardAndNet" "PairAndNet" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:standardSettlementStyle ],
        [ sh:class common_domain_model:SettlementDate ;
            sh:description "The date on which the settlement amount will be paid, subject to adjustment in accordance with any applicable business day convention. This component would not be present for a mandatory early termination provision where the cash settlement payment date is the mandatory early termination date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:class common_domain_model:SettlementProvision ;
            sh:description "Optionally defines the parameters that regulate a settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:settlementProvision ],
        [ sh:description "The qualification as to how the transfer will settle, e.g. a DvP settlement." ;
            sh:in ( "DeliveryVersusDelivery" "DeliveryVersusPayment" "PaymentVersusPayment" "NotCentralSettlement" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:transferSettlementType ] ;
    sh:targetClass common_domain_model:SettlementBase .

common_domain_model:StandardizedSchedule a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:durationInYears ],
        [ sh:in ( "Swap" "CrossCurrencySwap" "Swaption" "SwaptionStraddle" "SwapWithCallableBermudanRightToEnterExitSwaps" "IRExoticSwapWithAnExoticCouponAgainstAFloatingLeg" "Option" "ForwardRateAgreement" "SingleNameCreditDefaultSwap" "IndexCDS" "IndexTranche" "CreditNthToDefault" "CreditTotalReturnSwapOnABond" "DeliverableSwap" "NonDeliverableCrossCurrencySwap" "DeliverableForward" "NonDeliverableForward" "DeliverableOption" "NonDeliverableOption" "VarianceSwap" "VolatilitySwap" "CorrelationSwap" "Forward" "DividendSwap" "DeliverableOptionF" "ContractForDifference" "SwapsAndPortfolioSwaps" "FixedFloatSwap" "BasisSwap" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:productClass ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:notionalCurrency ],
        [ sh:in ( "InterestRates" "Credit" "ForeignExchange" "Equity" "Commodity" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:assetClass ],
        [ sh:datatype xsd:decimal ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:notional ] ;
    sh:targetClass common_domain_model:StandardizedSchedule .

common_domain_model:StandardizedScheduleInitialMargin a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:netInitialMargin ],
        [ sh:class common_domain_model:StandardizedScheduleTradeInfo ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tradeInfo ] ;
    sh:targetClass common_domain_model:StandardizedScheduleInitialMargin .

common_domain_model:StubCalculationPeriodAmount a sh:NodeShape ;
    rdfs:comment "A data defining:  how the initial or final stub calculation period amounts is calculated. For example, the rate to be applied to the initial or final stub calculation period may be the linear interpolation of two different tenors for the floating rate index specified in the calculation period amount component, e.g. A two month stub period may used the linear interpolation of a one month and three month floating rate. The different rate tenors would be specified in this component. Note that a maximum of two rate tenors can be specified. If a stub period uses a single index tenor and this is the same as that specified in the calculation period amount component then the initial stub or final stub component, as the case may be, must not be included." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:StubValue ;
            sh:description "Specifies how the initial stub amount is calculated. A single floating rate tenor different to that used for the regular part of the calculation periods schedule may be specified, or two floating tenors may be specified. If two floating rate tenors are specified then Linear Interpolation (in accordance with the 2000 ISDA Definitions, Section 8.3. Interpolation) is assumed to apply. Alternatively, an actual known stub rate or stub amount may be specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:initialStub ],
        [ sh:class common_domain_model:StubValue ;
            sh:description "Specifies how the final stub amount is calculated. A single floating rate tenor different to that used for the regular part of the calculation periods schedule may be specified, or two floating tenors may be specified. If two floating rate tenors are specified then Linear Interpolation (in accordance with the 2000 ISDA Definitions, Section 8.3. Interpolation) is assumed to apply. Alternatively, an actual known stub rate or stub amount may be specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:finalStub ],
        [ sh:class common_domain_model:CalculationPeriodDates ;
            sh:description "A pointer style reference to the associated calculation period dates component defined elsewhere in the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:calculationPeriodDatesReference ] ;
    sh:targetClass common_domain_model:StubCalculationPeriodAmount .

common_domain_model:ThresholdMinimumTransferAmountBase a sh:NodeShape ;
    rdfs:comment "A logical container designed to hold a set of related data. In this case, designed to hold a set of information required to specify conditions under which Threshold or Minimum Transfer Amount can fall to zero." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:ratingType common_domain_model:namedEntity common_domain_model:currency common_domain_model:amount common_domain_model:compare rdf:type common_domain_model:numberOfRatingAgencies common_domain_model:variableSet common_domain_model:notRatedBy common_domain_model:noRating common_domain_model:ratedParty common_domain_model:namedAffiliate ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether a trigger applies for the Threshold or Minimum Transfer Amount to fall to zero. If 'True' then such a trigger exists." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:zeroEvent ],
        [ sh:description "Specifies the relevant trigger for the Threshold or Minimum Transfer Amount to fall to zero." ;
            sh:in ( "EventOfDefault" "TerminationEvent" "TerminationEventAllAffectedTransactions" "PotentialEventOfDefault" "AdditionalTerminationEvent" "Other" ) ;
            sh:order 1 ;
            sh:path common_domain_model:event ] ;
    sh:targetClass common_domain_model:ThresholdMinimumTransferAmountBase .

common_domain_model:TradePricingReport a sh:NodeShape ;
    rdfs:comment "The attributes that are specific for consensus based pricing reporting." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TimeZone ;
            sh:description "The regional exchange close time for the underlying contract,including time zone, at which the trades should be priced. This provides an indication for which regional snapshot should be used for pricing primarily for Global markets where there are multiple regional close times." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
