        [ sh:datatype xsd:date ;
            sh:description "The date the fallback rate takes effect." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:effectiveDate ],
        [ sh:datatype xsd:decimal ;
            sh:description "The economic spread applied to the underlying fallback rate to replicate the original risky rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:spreadAdjustment ],
        [ sh:class common_domain_model:FloatingRateCalculationParameters ;
            sh:description "Support for modular calculated rates, such such as lockout compound calculations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:calculationParameters ] ;
    sh:targetClass common_domain_model:FallbackRateParameters .

common_domain_model:FixedRateSpecification a sh:NodeShape ;
    rdfs:comment "Type defining the specification for a fixed rate." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:RateSchedule ;
            sh:description "The fixed rate or fixed rate schedule expressed as explicit fixed rates and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:rateSchedule ] ;
    sh:targetClass common_domain_model:FixedRateSpecification .

common_domain_model:FxFeature a sh:NodeShape ;
    rdfs:comment "A type for defining FX Features." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Specifies the reference currency of the trade." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:referenceCurrency ],
        [ sh:class common_domain_model:Composite ;
            sh:description "If 'Composite' is specified as the Settlement Type in the relevant Transaction Supplement, an amount in the Settlement Currency, determined by the Calculation Agent as being equal to the number of Options exercised or deemed exercised, multiplied by: (Settlement Price – Strike Price) / (Strike Price – Settlement Price) x Multiplier provided that if the above is equal to a negative amount the Option Cash Settlement Amount shall be deemed to be zero." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:composite ],
        [ sh:class common_domain_model:Composite ;
            sh:description "If 'Cross-Currency' is specified as the Settlement Type in the relevant Transaction Supplement, an amount in the Settlement Currency, determined by the Calculation Agent as being equal to the number of Options exercised or deemed exercised, multiplied by: (Settlement Price – Strike Price) / (Strike Price – Settlement Price) x Multiplier x one unit of the Reference Currency converted into an amount in the Settlement Currency using the rate of exchange of the Settlement Currency as quoted on the Reference Price Source on the Valuation Date, provided that if the above is equal to a negative amount the Option Cash Settlement Amount shall be deemed to be zero." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:crossCurrency ],
        [ sh:class common_domain_model:Quanto ;
            sh:description "If 'Quanto' is specified as the Settlement Type in the relevant Transaction Supplement, an amount, as determined by the Calculation Agent in accordance with the Section 8.2 of the Equity Definitions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:quanto ] ;
    sh:targetClass common_domain_model:FxFeature .

common_domain_model:FxHaircutCurrency a sh:NodeShape ;
    rdfs:comment "A class to specify the reference currency for the purpose of specifying the FX Haircut relating to a posting obligation, as being either the Termination Currency or an FX Designated Currency." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The reference currency for the purpose of specifying the FX Haircut relating to a posting obligation is the Termination Currency when the Boolean value is set to True." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isTerminationCurrency ],
        [ sh:datatype xsd:string ;
            sh:description "When specified, the reference currency for the purpose of specifying the FX Haircut relating to a posting obligation. The list of valid currencies is not presently positioned as an enumeration as part of the CDM because that scope is limited to the values specified by ISDA and FpML. As a result, implementers have to make reference to the relevant standard, such as the ISO 4217 standard for currency codes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:fxDesignatedCurrency ] ;
    sh:targetClass common_domain_model:FxHaircutCurrency .

common_domain_model:JurisdictionRelatedTerms a sh:NodeShape ;
    rdfs:comment "A class to specify terms jurisdiction related terms." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FrenchLawAddendum ;
            sh:description "The French Law Addendum Provisions specific to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:frenchLawAddendum ],
        [ sh:datatype xsd:boolean ;
            sh:description "Classification of optional exclusive jurisdiction terms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:exclusiveJurisdiction ],
        [ sh:datatype xsd:boolean ;
            sh:description "The Jury Waiver conditions specific to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:juryWaiver ],
        [ sh:class common_domain_model:JapaneseSecuritiesProvisions ;
            sh:description "The Japanese Securities Provisions election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:japaneseSecuritiesProvisions ],
        [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether the Belgian Law Security Agreement Addendum is deemed applicable by the parties (True) or not (False)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:belgianLawSecurityAgreement ] ;
    sh:targetClass common_domain_model:JurisdictionRelatedTerms .

common_domain_model:LegalAgreementIdentification a sh:NodeShape ;
    rdfs:comment "Specifies the type of legal agreement, identified via a set of composable attributes: agreementName, publisher, governing law and version, e.g. ISDA 2013 Standard Credit Support Annex English Law." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The legal agreement publisher, e.g. ISDA." ;
            sh:in ( "AFB" "BNYM" "ISDAClearstream" "EMTA" "TheFXCommittee" "ISDAEuroclear" "ISDA" "ISLA" "JPMorgan" "ICMA" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:publisher ],
        [ sh:description "The law governing the legal agreement, e.g. English Law, New York Law or Japanese Law." ;
            sh:in ( <http://www.fpml.org/coding-scheme/governing-law-1-2#AsSpecifiedInMasterAgreement> "BE" <http://www.fpml.org/coding-scheme/governing-law-1-2#CAAB> <http://www.fpml.org/coding-scheme/governing-law-1-2#CABC> <http://www.fpml.org/coding-scheme/governing-law-1-2#CAMN> <http://www.fpml.org/coding-scheme/governing-law-1-2#CAON> <http://www.fpml.org/coding-scheme/governing-law-1-2#CAQC> <http://www.fpml.org/coding-scheme/governing-law-1-2#DE> <http://www.fpml.org/coding-scheme/governing-law-1-2#FR> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBEN> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBGY> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBIM> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBJY> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBSC> "IE" <http://www.fpml.org/coding-scheme/governing-law-1-2#JP> "LU" "RelatedMasterAgreement" <http://www.fpml.org/coding-scheme/governing-law-1-2#USCA> <http://www.fpml.org/coding-scheme/governing-law-1-2#USDE> <http://www.fpml.org/coding-scheme/governing-law-1-2#USIL> <http://www.fpml.org/coding-scheme/governing-law-1-2#USNY> ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:governingLaw ],
        [ sh:datatype xsd:integer ;
            sh:description "In the case where successive definitions of the legal agreement have been developed, the vintage identification. This is typically (but not necessarily) done by referencing the year, e.g. 2013 in the case of the ISDA 2013 Standard Credit Support Annex." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:vintage ],
        [ sh:class common_domain_model:AgreementName ;
            sh:description "The legal agreement name, e.g. Credit Support Annex for Variation Margin." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:agreementName ] ;
    sh:targetClass common_domain_model:LegalAgreementIdentification .

common_domain_model:MessageInformation a sh:NodeShape ;
    rdfs:comment "This class corresponds to the components of the FpML MessageHeader.model." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The identifier(s) for the recipient(s) of a message instance." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:sentTo ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier (within the specified coding scheme) giving the details of some party to whom a copy of this message will be sent for reference." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:copyTo ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier assigned to the message." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:messageId ],
        [ sh:datatype xsd:string ;
            sh:description "The identifier for the originator of a message instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:sentBy ] ;
    sh:targetClass common_domain_model:MessageInformation .

common_domain_model:NaturalPerson a sh:NodeShape ;
    rdfs:comment "A class to represent the attributes that are specific to a natural person." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The natural person's surname." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:surname ],
        [ sh:class common_domain_model:PersonIdentifier ;
            sh:description "The identifier associated with a person, e.g. the internal identification code." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:personId ],
        [ sh:datatype xsd:string ;
            sh:description "The natural person's first name. It is optional in FpML." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:firstName ],
        [ sh:class common_domain_model:ContactInformation ;
            sh:description "The contact information for such person, when different from the contact information associated with the party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:contactInformation ],
        [ sh:datatype xsd:string ;
            sh:description "An honorific title, such as Mr., Ms., Dr. etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:honorific ],
        [ sh:datatype xsd:string ;
            sh:description "The natural person's middle initial(s). If a middle initial is provided then a name should be absent." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:initial ],
        [ sh:datatype xsd:date ;
            sh:description "The natural person's date of birth." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:dateOfBirth ],
        [ sh:datatype xsd:string ;
            sh:description "Name suffix, such as Jr., III, etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:suffix ],
        [ sh:datatype xsd:string ;
            sh:description "The natural person's middle name(s). If a middle name is provided then an initial should be absent." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:middleName ] ;
    sh:targetClass common_domain_model:NaturalPerson .

common_domain_model:ObservationEvent a sh:NodeShape ;
    rdfs:comment "Specifies the necessary information to create any observation event." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CreditEvent ;
            sh:description "Specifies the necessary information to create a credit event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:creditEvent ],
        [ sh:class common_domain_model:CorporateAction ;
            sh:description "Specifies the necessary information to create a corporate action." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:corporateAction ] ;
    sh:targetClass common_domain_model:ObservationEvent .

common_domain_model:ObservationTerms a sh:NodeShape ;
    rdfs:comment "Class containing terms that are associated with observing a price/benchmark/index across either single or multiple observations. " ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ObservationDates ;
            sh:description "Describes date details for a set of observation dates in parametric or non-parametric form." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:observationDates ],
        [ sh:description "The enumerated values to specify points in the day when option exercise and valuation can occur." ;
            sh:in ( "Close" "Open" "OSP" "SpecificTime" "XETRA" "DerivativesClose" "AsSpecifiedInMasterConfirmation" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:observationTimeType ],
        [ sh:class common_domain_model:FxSpotRateSource ;
            sh:description "The information source where a published or displayed market rate will be obtained, e.g. Telerate Page 3750." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:informationSource ],
        [ sh:class common_domain_model:CalculationPeriodDates ;
            sh:description "Defines parameters used to generate the calculation period dates schedule, including the specification of any initial or final stub calculation periods. A calculation period schedule consists of an optional initial stub calculation period, one or more regular calculation periods and an optional final stub calculation period. In the absence of any initial or final stub calculation periods, the regular part of the calculation period schedule is assumed to be between the effective date and the termination date. No implicit stubs are allowed, i.e. stubs must be explicitly specified using an appropriate combination of firstPeriodStartDate, firstRegularPeriodStartDate and lastRegularPeriodEndDate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:calculationPeriodDates ],
        [ sh:class common_domain_model:Rounding ;
            sh:description "Defines rounding rules and precision to be used in the rounding of observations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:precision ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "Defines time in respect to a business calendar location that the price/benchmark/index is observed" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:observationTime ],
        [ sh:datatype xsd:integer ;
            sh:description "The number of observation dates between observation start date and observation end date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:numberOfObservationDates ] ;
    sh:targetClass common_domain_model:ObservationTerms .

common_domain_model:OtherAgreements a sh:NodeShape ;
    rdfs:comment "The bespoke definition of other agreements or other credit support annex terms as specified by the parties to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:OtherAgreementTerms ;
            sh:description "The bespoke definition of Other CSA as specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:otherCSA ],
        [ sh:class common_domain_model:OtherAgreementTerms ;
            sh:description "The bespoke definition of whether Japanese Law CSA (VM) are specified by the parties to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:japaneseLawCsa ] ;
    sh:targetClass common_domain_model:OtherAgreements .

common_domain_model:PortfolioState a sh:NodeShape ;
    rdfs:comment "State-full representation of a Portfolio that describes all the positions held at a given time, in various states which can be either traded, settled, etc., with lineage information to the previous state" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Position ;
            sh:description "The list of positions, each containing a Quantity and a Product." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:positions ],
        [ sh:class common_domain_model:Lineage ;
            sh:description "Pointer to the previous PortfolioState and new Event(s) leading to the current (new) state. Previous PortfolioState in the Lineage can be Null in case this is the start of the chain of Events." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:lineage ] ;
    sh:targetClass common_domain_model:PortfolioState .

common_domain_model:PriceReturnTerms a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Defines the conversion applied if the quantity unit on contract is different from unit on referenced underlier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:conversionFactor ],
        [ sh:description "The type of return associated with the equity swap." ;
            sh:in ( "Price" "Total" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:returnType ],
        [ sh:datatype xsd:string ;
            sh:description "Performance calculation, in accordance with Part 1 Section 12 of the 2018 ISDA CDM Equity Confirmation for Security Equity Swap, Para 75. 'Equity Performance'. Cumulative performance is used as a notional multiplier factor on both legs of an Equity Swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:performance ] ;
    sh:targetClass common_domain_model:PriceReturnTerms .

common_domain_model:PrimitiveInstruction a sh:NodeShape ;
    rdfs:comment "A Primitive Instruction describes the inputs required to pass into the corresponding PrimitiveEvent function." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ObservationInstruction ;
            sh:description "Specifies inputs needed to process an observation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:observation ],
        [ sh:class common_domain_model:ContractFormationInstruction ;
            sh:description "Specifies instructions describing an contract formation primitive event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:contractFormation ],
        [ sh:class common_domain_model:IndexTransitionInstruction ;
            sh:description "Specifies inputs needed to process a Index Transition business event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:indexTransition ],
        [ sh:class common_domain_model:SplitInstruction ;
            sh:description "Specifies instructions to split a trade into multiple branches." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:split ],
        [ sh:class common_domain_model:ExecutionInstruction ;
            sh:description "Specifies instructions describing an execution primitive event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:execution ],
        [ sh:class common_domain_model:ValuationInstruction ;
            sh:description "Specifies inputs needed to process an update of a valuation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:valuation ],
        [ sh:class common_domain_model:TermsChangeInstruction ;
            sh:description "Specifies instructions describing a terms change primitive event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:termsChange ],
        [ sh:class common_domain_model:ResetInstruction ;
            sh:description "Specifies instructions describing a reset event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:reset ],
        [ sh:class common_domain_model:StockSplitInstruction ;
            sh:description "Specifies inputs needed to process a Stock Split business event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:stockSplit ],
        [ sh:class common_domain_model:ExerciseInstruction ;
            sh:description "Specifies instructions describing an exercise primitive event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:exercise ],
        [ sh:class common_domain_model:PartyChangeInstruction ;
            sh:description "Specifies instructions describing a party change primitive event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:partyChange ],
        [ sh:class common_domain_model:QuantityChangeInstruction ;
            sh:description "Specifies instructions describing an quantity change primitive event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:quantityChange ],
        [ sh:class common_domain_model:TransferInstruction ;
            sh:description "Specifies instructions describing a transfer primitive event." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:transfer ] ;
    sh:targetClass common_domain_model:PrimitiveInstruction .

common_domain_model:ProcessAgent a sh:NodeShape ;
    rdfs:comment "Specifies the Process Agent that might be appointed by the parties as part of a Credit Support Annex/Deed or Collateral Transfer Agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ProcessAgentElection ;
            sh:description "The parties' Process Agent election." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:ProcessAgent .

common_domain_model:QuotedCurrencyPair a sh:NodeShape ;
    rdfs:comment "A class that describes the composition of a rate that has been quoted or is to be quoted. This includes the two currencies and the quotation relationship between the two currencies and is used as a building block throughout the FX specification." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The method by which the exchange rate is quoted." ;
            sh:in ( "Currency1PerCurrency2" "Currency2PerCurrency1" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:quoteBasis ],
        [ sh:datatype xsd:string ;
            sh:description "The first currency specified when a pair of currencies is to be evaluated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:currency1 ],
        [ sh:datatype xsd:string ;
            sh:description "The second currency specified when a pair of currencies is to be evaluated." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:currency2 ] ;
    sh:targetClass common_domain_model:QuotedCurrencyPair .

common_domain_model:ReferenceInformation a sh:NodeShape ;
    rdfs:comment "A class specifying the Credit Default Swap Reference Information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ReferenceObligation ;
            sh:description "The Reference Obligation is a financial instrument that is either issued or guaranteed by the reference entity. It serves to clarify the precise reference entity protection is being offered upon, and its legal position with regard to other related firms (parents/subsidiaries). Furthermore the Reference Obligation is ALWAYS deliverable and establishes the Pari Passu ranking (as the deliverable bonds must rank equal to the reference obligation). ISDA 2003 Term: Reference Obligation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:referenceObligation ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The corporate or sovereign entity which is subject to the swap transaction and any successor that assumes all or substantially all of its contractual and other obligations. Reference Entities cannot be senior or subordinated. It is the obligations of the Reference Entities that can be senior or subordinated. ISDA 2014 Credit definitions article II section 2.1: `Reference Entity` means the entity specified as such in the related Confirmation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:referenceEntity ],
        [ sh:class common_domain_model:Price ;
            sh:description "Used to determine (a) for physically settled trades, the Physical Settlement Amount, which equals the Floating Rate Payer Calculation Amount times the Reference Price and (b) for cash settled trades, the Cash Settlement Amount, which equals the greater of (i) the difference between the Reference Price and the Final Price and (ii) zero. ISDA 2003 Term: Reference Price." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:referencePrice ],
        [ sh:datatype xsd:boolean ;
            sh:description "With respect to any day, the list of Syndicated Secured Obligations of the Designated Priority of the Reference Entity published by Markit Group Limited or any successor thereto appointed by the Specified Dealers (the 'Secured List Publisher') on or most recently before such day, which list is currently available at [http://www.markit.com]. ISDA 2003 Term: Relevant Secured List." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:securedList ],
        [ sh:datatype xsd:boolean ;
            sh:description "Used to indicate that there is no Reference Obligation associated with this Credit Default Swap and that there will never be one." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:noReferenceObligation ],
        [ sh:datatype xsd:boolean ;
            sh:description "Used to indicate that the Reference obligation associated with the Credit Default Swap is currently not known. This is not valid for Legal Confirmation purposes, but is valid for earlier stages in the trade life cycle (e.g. Broker Confirmation)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:unknownReferenceObligation ],
        [ sh:datatype xsd:boolean ;
            sh:description "Applicable to the transactions on mortgage-backed security, which can make use of a reference policy. Presence of the element with value set to 'true' indicates that the reference policy is applicable; absence implies that it is not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:referencePolicy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates whether an obligation of the Reference Entity, guaranteed by the Reference Entity on behalf of a non-Affiliate, is to be considered an Obligation for the purpose of the transaction. It will be considered an obligation if allGuarantees is applicable (true) and not if allGuarantees is inapplicable (false). ISDA 2003 Term: All Guarantees." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:allGuarantees ] ;
    sh:targetClass common_domain_model:ReferenceInformation .

common_domain_model:Resource a sh:NodeShape ;
    rdfs:comment "Describes the resource that contains the media representation of a business event (i.e used for stating the Publicly Available Information). For example, can describe a file or a URL that represents the event. This type is an extended version of a type defined by RIXML (www.rixml.org).  Rosetta restricts the FpML implementation by not providing the ability to associated a document in hexadecimalBinary or base64Binary until such time that actual use cases will come up." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Indicates where the resource can be found, as a URL that references the information on a web server accessible to the message recipient." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:url ],
        [ sh:datatype xsd:string ;
            sh:description "The name of the resource.  It is specified as a NormalizedString in FpML." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:name ],
        [ sh:datatype xsd:string ;
            sh:description "Indicates the type of media used to store the content. mimeType is used to determine the software product(s) that can read the content. MIME Types are described in RFC 2046." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:mimeType ],
        [ sh:datatype xsd:decimal ;
            sh:description "Indicates the size of the resource in bytes. It could be used by the end user to estimate the download time and storage needs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:sizeInBytes ],
        [ sh:datatype xsd:string ;
            sh:description "Any additional comments that are deemed necessary. For example, which software version is required to open the document? Or, how does this resource relate to the others for this event?" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:comments ],
        [ sh:datatype xsd:string ;
            sh:description "Indicates the language of the resource, described using the ISO 639-2/T Code." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:language ],
        [ sh:class common_domain_model:ResourceLength ;
            sh:description "Indicates the length of the resource. For example, if the resource were a PDF file, the length would be in pages." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:length ],
        [ sh:datatype xsd:string ;
            sh:description "The unique identifier of the resource within the event. FpML specifies this element of type resourceIdScheme but with no specified value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:resourceId ],
        [ sh:datatype xsd:string ;
            sh:description "Provides extra information as string. In case the extra information is in XML format, a CDATA section must be placed around the source message to prevent its interpretation as XML content." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:string ],
        [ sh:description "A description of the type of the resource, e.g. a confirmation." ;
            sh:in ( <http://www.fpml.org/coding-scheme/resource-type-1-1#Confirmation> <http://www.fpml.org/coding-scheme/resource-type-1-1#SupplementalMaterialEconomicTerms> <http://www.fpml.org/coding-scheme/resource-type-1-1#TermSheet> ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:resourceType ] ;
    sh:targetClass common_domain_model:Resource .

common_domain_model:TelephoneNumber a sh:NodeShape ;
    rdfs:comment "A class to specify a telephone number as a type of phone number (e.g. work, personal, ...) alongside with the actual number." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The type of telephone number, e.g. work, mobile." ;
            sh:in ( "Work" "Mobile" "Fax" "Personal" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:telephoneNumberType ],
        [ sh:datatype xsd:string ;
            sh:description "The actual telephone number." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:number ] ;
    sh:targetClass common_domain_model:TelephoneNumber .

common_domain_model:Threshold a sh:NodeShape ;
    rdfs:comment "Represents the amount of unsecured risk that a party is willing to tolerate without holding any posted collateral provided by the other party." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ThresholdElection ;
            sh:description "The party specific election for the threshold clause." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:Threshold .

common_domain_model:Valuation a sh:NodeShape ;
    rdfs:comment "Defines the value of an investment, asset, or security" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Date and time of the last valuation marked to market, provided by the central counterparty (CCP) or calculated using the current or last available market price of the inputs." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:timestamp ],
        [ sh:class common_domain_model:Money ;
            sh:description "Current value of the outstanding contract" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:amount ],
        [ sh:class common_domain_model:Price ;
            sh:description "Denotes the price used to compute the valuation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:priceComponent ],
        [ sh:description "Source of the valuation of the transaction by the valuation party." ;
            sh:in ( "CentralCounterparty" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:source ],
        [ sh:datatype xsd:decimal ;
            sh:description "The ratio of the change in the price of a derivative transaction to the change in the price of the underlying. This field is applicable only to options and swaptions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:delta ],
        [ sh:description "Denotes when the valuation was sourced during a business day." ;
            sh:in ( "ClosingPrice" "OpeningPrice" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:valuationTiming ],
        [ sh:description "Method used for the valuation of the transaction by the valuation party." ;
            sh:in ( "MarkToMarket" "MarkToModel" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:method ],
        [ sh:description " Defines the scope of the valuation, what it applies to e.g. the collateral or the trade" ;
            sh:in ( "Collateral" "Trade" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:scope ] ;
    sh:targetClass common_domain_model:Valuation .

common_domain_model:ValuationCalculationDateLocation a sh:NodeShape ;
    rdfs:comment "Specification of the Calculation Date Location for the respective parties to the legal agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ValuationCalculationDateLocationElection ;
            sh:description "The parties' calculation date location election." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:ValuationCalculationDateLocation .

common_domain_model:WorkflowStep a sh:NodeShape ;
    rdfs:comment "A workflow step represents the state of a business event. The workflow step contains a reference to a previous WorkflowStep in order to preserve lineage. A workflow step is accepted if it contains a business event, proposed if proposedEvent is present and is rejected if the rejected flag is set." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies whether the event is a new, a correction or a cancellation." ;
            sh:in ( "New" "Correct" "Cancel" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:action ],
        [ sh:class common_domain_model:EventTimestamp ;
            sh:description "The set of timestamp(s) associated with the event as a collection of [dateTime, qualifier]." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:timestamp ],
        [ sh:class common_domain_model:CounterpartyPositionBusinessEvent ;
            sh:description "Documents the life cycle event for a position." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:counterpartyPositionBusinessEvent ],
        [ sh:class common_domain_model:WorkflowStep ;
            sh:description "Optional previous workflow step that provides lineage to workflow steps that precedes it." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:previousWorkflowStep ],
        [ sh:class common_domain_model:EventInstruction ;
            sh:description "The intended next event can be specified, even if the instructions are not known yet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:nextEvent ],
        [ sh:class common_domain_model:BusinessEvent ;
            sh:description "Life cycle event for the step." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:businessEvent ],
        [ sh:class common_domain_model:Account ;
            sh:description "Optional account information that could be associated to the event." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:account ],
        [ sh:class common_domain_model:WorkflowStepApproval ;
            sh:description "Optional party approvals for the current workflow step. A workflow step can have any number of parties associated to it, thus this object is represented as a list. All parties that are expected to provide approval should have an item in this list that references them." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:approval ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "The identifier(s) that uniquely identify a lifecycle event. The unbounded cardinality is meant to provide the ability to associate identifiers that are issued by distinct parties. As an example, each of the parties to the event may choose to associate their own identifiers to the event." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:eventIdentifier ],
        [ sh:class common_domain_model:EventInstruction ;
            sh:description "The proposed event for a workflow step." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:proposedEvent ],
        [ sh:class common_domain_model:CreditLimitInformation ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path common_domain_model:creditLimitInformation ],
        [ sh:class common_domain_model:Lineage ;
            sh:description "The lineage attribute provides a linkage among lifecycle events through the globalKey hash value. One example is when a given lifecycle event is being corrected or cancelled. In such case, each subsequent event will have lineage into the prior version of that event. The second broad use case is when an event has a dependency upon either another event (e.g. the regular payment associated with a fix/float swap will have a lineage into the reset event, which will in turn have a lineage into the observation event for the floating rate and the contract) or a contract (e.g. the exercise of an option has a lineage into that option)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:lineage ],
        [ sh:datatype xsd:boolean ;
            sh:description "Flags this step as rejected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:rejected ],
        [ sh:class common_domain_model:WorkflowState ;
            sh:description "The event workflow information, i.e. the workflow status, the associated comment and the partyCustomisedWorkflow which purpose is to provide the ability to associate custom workflow information to the CDM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path common_domain_model:workflowState ],
        [ sh:class common_domain_model:MessageInformation ;
            sh:description "Contains all information pertaining the FpML messaging header " ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:messageInformation ],
        [ sh:class common_domain_model:Party ;
            sh:description "The specification of the event parties. This attribute is optional, as not applicable to certain events (e.g. most of the observations)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:WorkflowStep .

common_domain_model:AdjustableOrRelativeDates a sh:NodeShape ;
    rdfs:comment "A class giving the choice between defining a series of dates as an explicit list of dates together with applicable adjustments or as relative to some other series of (anchor) dates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableDates ;
            sh:description "A series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:adjustableDates ],
        [ sh:class common_domain_model:RelativeDates ;
            sh:description "A series of dates specified as some offset to another series of dates (the anchor dates)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:relativeDates ] ;
    sh:targetClass common_domain_model:AdjustableOrRelativeDates .

common_domain_model:AdjustedRelativeDateOffset a sh:NodeShape ;
    rdfs:comment "A type defining a date (referred to as the derived date) as a relative offset from another date (referred to as the anchor date) plus optional date adjustments." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Specifies the anchor as an href attribute. The href attribute value is a pointer style reference to the element or component elsewhere in the document where the anchor date is defined." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:dateRelativeTo ],
        [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2 or 3 etc. A negative value can be used when specifying an offset relative to another date, e.g. -2 days." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "The business center(s), specified either explicitly or by reference to those specified somewhere else in the instance document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:businessCenters ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The business day convention and financial business centers used for adjusting the relative date if it would otherwise fall on a day that is not a business date in the specified business centers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:relativeDateAdjustments ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "A pointer style reference to a set of financial business centers defined elsewhere in the document. This set of business centers is used to determine whether a particular day is a business day or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:businessCentersReference ],
        [ sh:description "A time period, e.g. a day, week, month or year of the stream. If the periodMultiplier value is 0 (zero) then period must contain the value D (day)." ;
            sh:in ( "D" "W" "M" "Y" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:period ],
        [ sh:description "The convention for adjusting a date if it would otherwise fall on a day that is not a business day, as specified by an ISDA convention (e.g. Following, Precedent)." ;
            sh:in ( "FOLLOWING" "FRN" "MODFOLLOWING" "PRECEDING" "MODPRECEDING" "NEAREST" "NONE" "NotApplicable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:businessDayConvention ],
        [ sh:datatype xsd:date ;
            sh:description "The date once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:adjustedDate ],
        [ sh:description "In the case of an offset specified as a number of days, this element defines whether consideration is given as to whether a day is a good business day or not. If a day type of business days is specified then non-business days are ignored when calculating the offset. The financial business centers to use for determination of business days are implied by the context in which this element is used. This element must only be included when the offset is specified as a number of days. If the offset is zero days then the dayType element should not be included." ;
            sh:in ( "Business" "Calendar" "CurrencyBusiness" "ExchangeBusiness" "ScheduledTradingDay" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:dayType ] ;
    sh:targetClass common_domain_model:AdjustedRelativeDateOffset .

common_domain_model:AgencyRatingCriteria a sh:NodeShape ;
    rdfs:comment "Represents a class to specify a credit notation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Indicator for options to be used if several agency ratings (>1) are specified and its necessary to identify specific charateristics. i.e (lowest or highest)." ;
            sh:in ( "Lowest" "Highest" "ReferenceAgency" "Average" "SecondBest" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:mismatchResolution ],
        [ sh:description "identifies the dominant reference agency if there is a missmatch and several reference agencies exsist." ;
            sh:in ( <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#AMBest> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#CBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#DBRS> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Fitch> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Japanagency> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#Moodys> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation> <http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors> ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:referenceAgency ],
        [ sh:class common_domain_model:CreditNotation ;
            sh:description "Indicates the agency rating criteria specified for the asset or issuer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:creditNotation ],
        [ sh:description "Indicates the boundary of a credit agency rating i.e minimum or maximum." ;
            sh:in ( "Minimum" "Maximum" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:boundary ] ;
    sh:targetClass common_domain_model:AgencyRatingCriteria .

common_domain_model:AllCriteria a sh:NodeShape ;
    rdfs:comment "Used to combine two or more Collateral Criteria using AND logic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:AnyEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:RatingAgencyValue ] [ sh:class common_domain_model:AmountOfNetCapital ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:allCriteria ] ;
    sh:targetClass common_domain_model:AllCriteria .

common_domain_model:AnyCriteria a sh:NodeShape ;
    rdfs:comment "Used to combine two or more Collateral Criteria using OR logic." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:AnyEligibilityToHoldCollateralCriteria ] [ sh:class common_domain_model:RatingAgencyValue ] [ sh:class common_domain_model:AmountOfNetCapital ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:anyCriteria ] ;
    sh:targetClass common_domain_model:AnyCriteria .

common_domain_model:Asset a sh:NodeShape ;
    rdfs:comment "An Asset is defined as something that can be owned and transferred in the financial markets. As a choice data type, one and only one of the attributes must be used." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type common_domain_model:economicTerms ) ;
    sh:targetClass common_domain_model:Asset .

common_domain_model:AssetAgencyRating a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AgencyRatingCriteria ;
            sh:description "Represents an agency rating based on default risk and creditors claim in event of default associated with specific instrument." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:assetAgencyRating ] ;
    sh:targetClass common_domain_model:AssetAgencyRating .

common_domain_model:AssetCountryOfOrigin a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents a filter on the asset country of origin based on the ISO Standard 3166." ;
            sh:in ( "AF" "AL" "DZ" "AS" "AD" "AO" "AI" "AQ" "AG" "AR" "AM" "AW" "AU" "AT" "AZ" "BS" "BH" "BD" "BB" "BY" "BE" "BZ" "BJ" "BM" "AX" "BT" "BO" "BQ" "BA" "BW" "BV" "BR" "IO" "BN" "BG" "BF" "BI" "CV" "KH" "CM" "CA" "KY" "CF" "TD" "CL" "CN" "CX" "CC" "CO" "KM" "CD" "CG" "CK" "CR" "HR" "CU" "CW" "CY" "CZ" "CI" "DK" "DJ" "DM" "DO" "EC" "EG" "SV" "GQ" "ER" "EE" "SZ" "ET" "FK" "FO" "FJ" "FI" "FR" "GF" "PF" "TF" "GA" "GM" "GE" "DE" "GH" "GI" "GR" "GL" "GD" "GP" "GU" "GT" "GG" "GN" "GW" "GY" "HT" "HM" "VA" "HN" "HK" "HU" "IS" "IN" "ID" "IR" "IQ" "IE" "IM" "IL" "IT" "JM" "JP" "JE" "JO" "KZ" "KE" "KI" "KP" "KR" "KW" "KG" "LA" "LV" "LB" "LS" "LR" "LY" "LI" "LT" "LU" "MO" "MG" "MW" "MY" "MV" "ML" "MT" "MH" "MQ" "MR" "MU" "YT" "MX" "FM" "MD" "MC" "MN" "ME" "MS" "MA" "MZ" "MM" "NA" "NR" "NP" "NL" "NC" "NZ" "NI" "NE" "NG" "NU" "NF" "MK" "MP" "NO" "OM" "PK" "PW" "PS" "PA" "PG" "PY" "PE" "PH" "PN" "PL" "PT" "PR" "QA" "RO" "RU" "RW" "RE" "BL" "SH" "KN" "LC" "MF" "PM" "VC" "WS" "SM" "ST" "SA" "SN" "RS" "SC" "SL" "SG" "SX" "SK" "SI" "SB" "SO" "ZA" "GS" "SS" "ES" "LK" "SD" "SR" "SJ" "SE" "CH" "SY" "TW" "TJ" "TZ" "TH" "TL" "TG" "TK" "TO" "TT" "TN" "TM" "TC" "TV" "TR" "UG" "UA" "AE" "GB" "UM" "US" "UY" "UZ" "VU" "VE" "VN" "VG" "VI" "WF" "EH" "YE" "ZM" "ZW" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:assetCountryOfOrigin ] ;
    sh:targetClass common_domain_model:AssetCountryOfOrigin .

common_domain_model:AssetMaturity a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies whether the maturity range is the remaining or original maturity." ;
            sh:in ( "RemainingMaturity" "OriginalMaturity" "FromIssuance" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:maturityType ],
        [ sh:class common_domain_model:PeriodRange ;
            sh:description "Represents a filter based on the underlying asset maturity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:maturityRange ] ;
    sh:targetClass common_domain_model:AssetMaturity .

common_domain_model:AssetPayout a sh:NodeShape ;
    rdfs:comment "Security finance payout specification in case the product payout involves some form of security collateral, as in a securities financing transaction. Plus additional description for ICMA." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:AssetLeg ;
            sh:description "Defines each asset movement as a buy/sell at different dates, typically 1 near leg and 1 far leg in a securities financing transaction." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:assetLeg ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:principalPayment ],
        [ sh:class common_domain_model:Money ;
            sh:description "A contractual minimum amount which the borrower will pay, regardless of the duration of the loan. A mechanism for making sure that a trade generates enough income." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:minimumFee ],
        [ sh:description "The trade type, eg repurchase transaction or buy/sell-back." ;
            sh:in ( "Repo" "BuySellBack" "SecurityLending" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:tradeType ],
        [ sh:class common_domain_model:DividendTerms ;
            sh:description "Specifies the terms under which dividends received by the borrower are passed through to the lender." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:dividendTerms ],
        [ sh:description "Specifies the Purchased Asset, usually a Security." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Observable ] [ sh:class common_domain_model:Product ] ) ;
            sh:order 1 ;
            sh:path common_domain_model:underlier ] ;
    sh:targetClass common_domain_model:AssetPayout .

common_domain_model:AveragingCalculation a sh:NodeShape ;
    rdfs:comment "Defines parameters for use in cases when a valuation or other term is based on an average of market observations." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Rounding ;
            sh:description "Rounding applied to the average calculation. " ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:precision ],
        [ sh:class common_domain_model:AveragingCalculationMethod ;
            sh:description "Specifies enumerations for the type of averaging calculation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:averagingMethod ] ;
    sh:targetClass common_domain_model:AveragingCalculation .

common_domain_model:Basket a sh:NodeShape ;
    rdfs:comment "Defines a custom basket by referencing an identifier and its constituents." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:assetType ],
        [ sh:class common_domain_model:BasketConstituent ;
            sh:description "Identifies the constituents of the basket" ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:basketConstituent ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:exchange ] ;
    sh:targetClass common_domain_model:Basket .

common_domain_model:CalculationAgent a sh:NodeShape ;
    rdfs:comment "A class defining the ISDA calculation agent responsible for performing duties as defined in the applicable product definitions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The city in which the office through which ISDA Calculation Agent is acting for purposes of the transaction is located The short-form confirm for a trade that is executed under a Sovereign or Asia Pacific Master Confirmation Agreement ( MCA ), does not need to specify the Calculation Agent. However, the confirm does need to specify the Calculation Agent City. This is due to the fact that the MCA sets the value for Calculation Agent but does not set the value for Calculation Agent City." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:calculationAgentBusinessCenter ],
        [ sh:description "Specifies the ISDA calculation agent responsible for performing duties as defined in the applicable product definitions. For example, the Calculation Agent may be defined as being the Non-exercising Party." ;
            sh:in ( "ExercisingParty" "NonExercisingParty" "AsSpecifiedInMasterAgreement" "AsSpecifiedInStandardTermsSupplement" "Both" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:calculationAgentPartyEnum ],
        [ sh:description "Specifies the party which is the ISDA Calculation Agent for the trade. If more than one party is referenced then the parties are assumed to be co-calculation agents, i.e. they have joint responsibility." ;
            sh:in ( "DisruptionEventsDeterminingParty" "ExtraordinaryDividendsParty" "PredeterminedClearingOrganizationParty" "ExerciseNoticeReceiverPartyManual" "ExerciseNoticeReceiverPartyOptionalEarlyTermination" "ExerciseNoticeReceiverPartyCancelableProvision" "ExerciseNoticeReceiverPartyExtendibleProvision" "CalculationAgentIndependent" "CalculationAgentOptionalEarlyTermination" "CalculationAgentMandatoryEarlyTermination" "CalculationAgentFallback" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:calculationAgentParty ] ;
    sh:targetClass common_domain_model:CalculationAgent .

common_domain_model:CalculationSchedule a sh:NodeShape ;
    rdfs:comment "A class that allows the full representation of a payout by defining a set of schedule periods. It supports standard schedule customization by expressing all the dates, quantities, and pricing data in a non-parametric way." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:SchedulePeriod ;
            sh:description "Defines a period of a calculation schedule structure." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:schedulePeriod ] ;
    sh:targetClass common_domain_model:CalculationSchedule .

common_domain_model:CollateralGuarantorType a sh:NodeShape ;
    rdfs:comment "Specifies the origin of entity guaranteeing the collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the origin of entity guaranteeing the collateral." ;
            sh:in ( "SupraNational" "SovereignCentralBank" "QuasiGovernment" "RegionalGovernment" "Corporate" "Fund" "SpecialPurposeVehicle" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:guarantorType ] ;
    sh:targetClass common_domain_model:CollateralGuarantorType .

common_domain_model:CollateralRounding a sh:NodeShape ;
    rdfs:comment "A class to specify the rounding methodology applicable to the Delivery Amount and the Return Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "The nearest integral multiple of Base Currency units to which the Return Amount will be rounded in accordance with the specified rounding direction." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:returnAmount ],
        [ sh:description "The currency in which the Delivery Amount and Return Amount rounding amounts are specified." ;
            sh:in ( "AED" "AFN" "ALL" "AMD" "AOA" "ARS" "AUD" "AWG" "AZN" "BAM" "BBD" "BDT" "BHD" "BIF" "BMD" "BND" "BOB" "BOV" "BRL" "BSD" "BTN" "BWP" "BYN" "BZD" "CAD" "CDF" "CHE" "CHF" "CHW" "CLF" "CLP" "CNY" "COP" "COU" "CRC" "CUP" "CVE" "CZK" "DJF" "DKK" "DOP" "DZD" "EGP" "ERN" "ETB" "EUR" "FJD" "FKP" "GBP" "GEL" "GHS" "GIP" "GMD" "GNF" "GTQ" "GYD" "HKD" "HNL" "HTG" "HUF" "IDR" "ILS" "INR" "IQD" "IRR" "ISK" "JMD" "JOD" "JPY" "KES" "KGS" "KHR" "KMF" "KPW" "KRW" "KWD" "KYD" "KZT" "LAK" "LBP" "LKR" "LRD" "LSL" "LYD" "MAD" "MDL" "MGA" "MKD" "MMK" "MNT" "MOP" "MRU" "MUR" "MVR" "MWK" "MXN" "MXV" "MYR" "MZN" "NAD" "NGN" "NIO" "NOK" "NPR" "NZD" "OMR" "PAB" "PEN" "PGK" "PHP" "PKR" "PLN" "PYG" "QAR" "RON" "RSD" "RUB" "RWF" "SAR" "SBD" "SCR" "SDG" "SEK" "SGD" "SHP" "SLE" "SOS" "SRD" "SSP" "STN" "SVC" "SYP" "SZL" "THB" "TJS" "TMT" "TND" "TOP" "TRY" "TTD" "TWD" "TZS" "UAH" "UGX" "USD" "USN" "UYI" "UYU" "UYW" "UZS" "VED" "VES" "VND" "VUV" "WST" "XAD" "XAF" "XAG" "XAU" "XBA" "XBB" "XBC" "XBD" "XCD" "XCG" "XDR" "XOF" "XPD" "XPF" "XPT" "XSU" "XTS" "XUA" "XXX" "YER" "ZAR" "ZMW" "ZWG" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:currency ],
        [ sh:description "The rounding rule applicable to the Return Amount (which can be (i) up to nearest; (ii) down to nearest)." ;
            sh:in ( "Down" "Up" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:returnDirection ],
        [ sh:datatype xsd:string ;
            sh:description "Utilised where the clause data structure is not able to capture a material aspect of the clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:other ],
        [ sh:description "The rounding rule applicable to the Delivery Amount (which can be (i) up to nearest; (ii) down to nearest)." ;
            sh:in ( "Down" "Up" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:deliveryDirection ],
        [ sh:datatype xsd:decimal ;
            sh:description "The nearest integral multiple of Base Currency units to which the Delivery Amount will be rounded in accordance with the specified rounding direction." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:deliveryAmount ] ;
    sh:targetClass common_domain_model:CollateralRounding .

common_domain_model:CollateralTaxonomy a sh:NodeShape ;
    rdfs:comment "Specifies the collateral taxonomy, which is composed of a taxonomy value and a taxonomy source." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CollateralTaxonomyValue ;
            sh:description "Specifies the taxonomy value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:taxonomyValue ],
        [ sh:description "Specifies the taxonomy source." ;
            sh:in ( "CFI" "ISDA" "ICAD" "EMIR" "EU_EMIR_EligibleCollateralAssetClass" "UK_EMIR_EligibleCollateralAssetClass" "CFTC" "US_CFTC_PR_EligibleCollateralAssetClass" "MAS" "CSA" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:taxonomySource ] ;
    sh:targetClass common_domain_model:CollateralTaxonomy .

common_domain_model:CommodityPayout a sh:NodeShape ;
    rdfs:comment "Payout based on the averaged price of a referenced underlier. (e.g. Commodities). Can represent both average (average of many) & bullet (average of 1) pricing" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:FxFeature ;
            sh:description "Defines quanto or composite FX features that are included in the swap leg." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:fxFeature ],
        [ sh:class common_domain_model:CalculationSchedule ;
            sh:description "Allows the full representation of a payout by defining a set of schedule periods. It supports standard schedule customization by expressing all the dates, quantities, and pricing data in a non-parametric way." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:schedule ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:CommodityPriceReturnTerms ;
            sh:description "Defines parameters in which the commodity price is assessed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:commodityPriceReturnTerms ],
        [ sh:class common_domain_model:PaymentDates ;
            sh:description "Defines the payment date schedule, as defined by the parameters that are needed to specify it, either in a parametric way or by reference to another schedule of dates (e.g. the valuation dates)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:paymentDates ],
        [ sh:class common_domain_model:AssetDeliveryInformation ;
            sh:description "Contains the information relative to the delivery of the asset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:delivery ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:AveragingCalculation ;
            sh:description "Indicates if the averaging calculation, when applicable, is weighted or unweighted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:averagingFeature ],
        [ sh:class common_domain_model:CalculationPeriodDates ;
            sh:description "Defines the calculation period dates schedule." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:calculationPeriodDates ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:description "Identifies the underlying product that is referenced for pricing of the applicable leg in a swap. Referenced in the '2018 ISDA CDM Equity Confirmation for Security Equity Swap' as Security." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Observable ] [ sh:class common_domain_model:Product ] ) ;
            sh:order 6 ;
            sh:path common_domain_model:underlier ],
        [ sh:class common_domain_model:PricingDates ;
            sh:description "Specifies specific dates or parametric rules for the dates on which the price will be determined." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:pricingDates ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:principalPayment ] ;
    sh:targetClass common_domain_model:CommodityPayout .

common_domain_model:CounterpartyOwnIssuePermitted a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Represents a filter based on whether it is permitted for the underlying asset to be issued by the posting entity or part of their corporate family." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:counterpartyOwnIssuePermitted ] ;
    sh:targetClass common_domain_model:CounterpartyOwnIssuePermitted .

common_domain_model:CreditDefaultPayout a sh:NodeShape ;
    rdfs:comment " The credit default payout specification provides the details necessary for determining when a credit payout will be triggered as well as the parameters for calculating the payout and the settlement terms. The associated globalKey denotes the ability to associate a hash value to the CreditDefaultPayout instantiations for the purpose of model cross-referencing, in support of functionality such as the event effect and the lineage." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:principalPayment ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:GeneralTerms ;
            sh:description "The specification of the non-monetary terms for the Credit Derivative Transaction, including the buyer and seller and selected items from the ISDA 2014 Credit Definition article II, such as the reference obligation and related terms." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:generalTerms ],
        [ sh:class common_domain_model:ProtectionTerms ;
            sh:description "Specifies the terms for calculating a payout to protect the buyer of the swap in the case of a qualified credit event. These terms include the applicable credit events, the reference obligation, and in the case of a CDS on mortgage-backed securities, the floatingAmountEvents." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:protectionTerms ],
        [ sh:class common_domain_model:TransactedPrice ;
            sh:description "The qualification of the price at which the contract has been transacted, in terms of market fixed rate, initial points, market price and/or quotation style. In FpML, those attributes are positioned as part of the fee leg." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:transactedPrice ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:priceQuantity ] ;
    sh:targetClass common_domain_model:CreditDefaultPayout .

common_domain_model:DistributionAndInterestPayment a sh:NodeShape ;
    rdfs:comment "A class to specify the Distributions and Interest Payment provisions applicable to the collateral agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CollateralInterestParameters ;
            sh:description "Represents the interest parameters for the various currencies, margin types, posting parties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:interestParameters ] ;
    sh:targetClass common_domain_model:DistributionAndInterestPayment .

common_domain_model:DividendApplicability a sh:NodeShape ;
    rdfs:comment "The parameters which define whether dividends are applicable" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "If present and true, then additional dividends are applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalDividends ],
        [ sh:datatype xsd:boolean ;
            sh:description "If present and true, then options exchange dividends are applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:optionsExchangeDividends ],
        [ sh:datatype xsd:boolean ;
            sh:description "Represents the European Master Confirmation value of 'All Dividends' which, when applicable, signifies that, for a given Ex-Date, the daily observed Share Price for that day is adjusted (reduced) by the cash dividend and/or the cash value of any non cash dividend per Share (including Extraordinary Dividends) declared by the Issuer. All Dividends in accordance with the ISDA 2002 Equity Derivatives Definitions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:allDividends ] ;
    sh:targetClass common_domain_model:DividendApplicability .

common_domain_model:DomesticCurrencyIssued a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Identifies that the Security must be denominated in the domestic currency of the issuer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:domesticCurrencyIssued ] ;
    sh:targetClass common_domain_model:DomesticCurrencyIssued .

common_domain_model:EquityUnderlierProvisions a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The ISO 3166 standard code for the country within which the postal address is located." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:relevantJurisdiction ],
        [ sh:datatype xsd:string ;
            sh:description "The ISO 3166 standard code for the country within which the postal address is located." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:localJurisdiction ],
        [ sh:datatype xsd:boolean ;
            sh:description "For an index option or swap transaction, a flag to indicate whether a relevant Component Security Index Annex is applicable to the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:componentSecurityIndexAnnexFallback ],
        [ sh:datatype xsd:boolean ;
            sh:description "For an index option or swap transaction, a flag to indicate whether a relevant Multiple Exchange Index Annex is applicable to the transaction. This annex defines additional provisions which are applicable where an index is comprised of component securities that are traded on multiple exchanges." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:multipleExchangeIndexAnnexFallback ] ;
    sh:targetClass common_domain_model:EquityUnderlierProvisions .

common_domain_model:ExecutionDetails a sh:NodeShape ;
    rdfs:comment "Defines specific attributes that relate to trade executions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identifies the type of execution, e.g. via voice, electronically..." ;
            sh:in ( <http://www.fpml.org/coding-scheme/execution-type-1-0#Electronic> "OffFacility" "OnVenue" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:executionType ],
        [ sh:class common_domain_model:IdentifiedList ;
            sh:description "A reference to the package linking the trade with other trades, in case the trade was executed as part of a package (hence this attribute is optional)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:packageReference ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Represents the venue on which a trade was executed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:executionVenue ] ;
    sh:targetClass common_domain_model:ExecutionDetails .

common_domain_model:ExerciseNotice a sh:NodeShape ;
    rdfs:comment "Defines to whom and where notice of execution should be given. The exerciseNoticeGiver refers to one or both of the principal parties of the trade. If present the exerciseNoticeReceiver refers to a party, other than the principal party, to whom notice should be given." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the party to which notice of exercise should be given, e.g. by the buyer of the option. Although in many cases it is the buyer of the option who sends the exercise notice to the seller of the option, this component is reused, e.g. in case of OptionEarlyTermination, either or both parties have the right to exercise." ;
            sh:in ( "DisruptionEventsDeterminingParty" "ExtraordinaryDividendsParty" "PredeterminedClearingOrganizationParty" "ExerciseNoticeReceiverPartyManual" "ExerciseNoticeReceiverPartyOptionalEarlyTermination" "ExerciseNoticeReceiverPartyCancelableProvision" "ExerciseNoticeReceiverPartyExtendibleProvision" "CalculationAgentIndependent" "CalculationAgentOptionalEarlyTermination" "CalculationAgentMandatoryEarlyTermination" "CalculationAgentFallback" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:exerciseNoticeReceiver ],
        [ sh:description "Specifies the principal party of the trade that has the right to exercise." ;
            sh:in ( "Buyer" "Seller" "Both" "AsSpecifiedInMasterAgreement" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:exerciseNoticeGiver ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the location where the exercise must be reported, e.g. where the exercise notice receiver is based." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:businessCenter ] ;
    sh:targetClass common_domain_model:ExerciseNotice .

common_domain_model:ExerciseTerms a sh:NodeShape ;
    rdfs:comment "A class defining the exercise period for an option together with any rules governing the notional amount of the underlying which can be exercised on any given exercise date and any associated exercise fees." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The first day of the exercise period for an American style option." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:commencementDate ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The latest time for exercise on expirationDate. It is made mandatory given that for all option styles, this field is required." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:expirationTime ],
        [ sh:description "The time of day at which the equity option expires, for example the official closing time of the exchange." ;
            sh:in ( "Close" "Open" "OSP" "SpecificTime" "XETRA" "DerivativesClose" "AsSpecifiedInMasterConfirmation" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:expirationTimeType ],
        [ sh:class common_domain_model:PartialExercise ;
            sh:description "As defined in the 2000 ISDA Definitions, Section 12.3. Partial Exercise, the buyer of the option has the right to exercise all or less than all the notional amount of the underlying swap on the expiration date, but may not exercise less than the minimum notional amount, and if an integral multiple amount is specified, the notional amount exercised must be equal to, or be an integral multiple of, the integral multiple amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:partialExercise ],
        [ sh:class common_domain_model:AdjustableOrRelativeDates ;
            sh:description "The dates that define the Bermuda option exercise dates and the expiration date. The last specified date is assumed to be the expiration date. The dates can either be specified as a series of explicit dates and associated adjustments or as a series of dates defined relative to another schedule of dates, for example, the calculation period start dates. Where a relative series of dates are defined the first and last possible exercise dates can be separately specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:exerciseDates ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The earliest time at which notice of exercise can be given by the buyer to the seller (or seller's agent) to, and including, the expiration date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:earliestExerciseTime ],
        [ sh:description "Whether the option has a single exercise (european), multiple exercise dates (bermuda), or a continuous range of exercise (american)." ;
            sh:in ( "European" "Bermuda" "American" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:style ],
        [ sh:class common_domain_model:ExerciseFeeSchedule ;
            sh:description "The fees associated with an exercise date. The fees are conditional on the exercise occurring. The fees can be specified as actual currency amounts or as percentages of the notional amount being exercised." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:exerciseFeeSchedule ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "For a Bermuda or American style option, the latest time on an exercise business day (excluding the expiration date) within the exercise period that notice can be given by the buyer to the seller or seller's agent. Notice of exercise given after this time will be deemed to have been given on the next exercise business day." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:latestExerciseTime ],
        [ sh:class common_domain_model:MultipleExercise ;
            sh:description "As defined in the 2000 ISDA Definitions, Section 12.4. Multiple Exercise, the buyer of the option has the right to exercise all or less than all the unexercised notional amount of the underlying swap on one or more days in the exercise period, but on any such day may not exercise less than the minimum notional amount or more that the maximum notional amount, and if an integral multiple amount is specified, the notional amount exercised must be equal to, or be an integral multiple of, the integral multiple amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:multipleExercise ],
        [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "The last day within an exercise period for an American style option. For a European style option it is the only day within the exercise period." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:expirationDate ],
        [ sh:class common_domain_model:ExerciseProcedure ;
            sh:description "The set of parameters defining the procedure associated with the exercise, e.g. manual exercise." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:exerciseProcedure ],
        [ sh:class common_domain_model:AdjustableOrRelativeDates ;
            sh:description "The effective date on the underlying product if the option is exercised.  For example, for a swaption it is the swap effective date, for an option on an FX spot or forward it is the value date for settlement, and in an extendible/cancelable provision it is the swap termination date, which is the date on which the termination is effective.'" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:relevantUnderlyingDate ],
        [ sh:class common_domain_model:ExerciseFee ;
            sh:description "A fee to be paid on exercise. This could be represented as an amount or a rate and notional reference on which to apply the rate." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:exerciseFee ] ;
    sh:targetClass common_domain_model:ExerciseTerms .

common_domain_model:FixedPricePayout a sh:NodeShape ;
    rdfs:comment "Represents a fixed price payout. There is no underlier associated with this payout type and is based on fixed pricing per a given unit (e.g. in commodities price per barrel)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CalculationSchedule ;
            sh:description "Allows the full representation of a payout by defining a set of schedule periods. It supports standard schedule customization by expressing all the dates, quantities, and pricing data in a non-parametric way." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:schedule ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:FixedPrice ;
            sh:description "Specifies the fixed price on which fixed forward payments are based." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:fixedPrice ],
        [ sh:class common_domain_model:PaymentDates ;
            sh:description "Specifies the parameters to generate the payment date schedule, either through a parametric representation or by reference to specified dates." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:paymentDates ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:principalPayment ] ;
    sh:targetClass common_domain_model:FixedPricePayout .

common_domain_model:FloatingRateCalculationParameters a sh:NodeShape ;
    rdfs:comment "Defines the structures needed to represent the calculation parameters for daily averaged and compounded modular rates as defined in the 2021 ISDA Definitions in Section 7. This type is used to represent modular computed rates in interestRatePayouts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:OffsetCalculation ;
            sh:description "any lookback  parameters if applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:lookbackCalculation ],
        [ sh:description "calculation type (averaging or compounding)." ;
            sh:in ( "Averaging" "Compounding" "CompoundedIndex" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:calculationMethod ],
        [ sh:class common_domain_model:ObservationParameters ;
            sh:description " any applicable observation parameters, such as daily caps or floors." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:observationParameters ],
        [ sh:class common_domain_model:OffsetCalculation ;
            sh:description "any lockout  parameters if applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:lockoutCalculation ],
        [ sh:class common_domain_model:ObservationShiftCalculation ;
            sh:description "any obervation shift parameters if applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:observationShiftCalculation ],
        [ sh:class common_domain_model:BusinessCenters ;
            sh:description "the business days that are applicable for the calculation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:applicableBusinessDays ] ;
    sh:targetClass common_domain_model:FloatingRateCalculationParameters .

common_domain_model:HoldingAndUsingPostedCollateral a sh:NodeShape ;
    rdfs:comment "Specifies the conditions that need to be satisfied before the Secured Party or Custodian acting on its behalf can hold and use posted collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:class common_domain_model:HoldingAndUsingPostedCollateralElection ;
            sh:description "The parties' elections for the holding and using of posted collateral." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:HoldingAndUsingPostedCollateral .

common_domain_model:IdentifiedList a sh:NodeShape ;
    rdfs:comment "Attaches an identifier to a collection of objects, when those objects themselves can each be represented by an identifier. One use case is the representation of package transactions, where each component is a separate trade with its own identifier, and those trades are linked together as a package with its own identifier. The data type has been named generically rather than referring to 'packages' as it may have a number of other uses." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Identifier ;
            sh:description "Identifiers for each component of the list. Since the data type is used to link multiple identified objects together, at least 2 components are required in the list. Creating an identified list with only 1 identified component has been deemed unnecessary, because it would just create a redundant identifier." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:componentId ],
        [ sh:class common_domain_model:Price ;
            sh:description "The price of the package." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:price ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "The identifier for the list. In the case of a package transaction, this would be the package identifier. This attribute is mandatory to allow the list itself to be identified." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:listId ] ;
    sh:targetClass common_domain_model:IdentifiedList .

common_domain_model:Index a sh:NodeShape ;
    rdfs:comment "An Index is an Observable which is computed based on the prices, rates or valuations of a number of assets that are tracked in a standardized way.  Examples include equity market indices as well as indices on interest rates, inflation and credit instruments." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:Index .

common_domain_model:IndexType a sh:NodeShape ;
    rdfs:comment "Specification of an index." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "An enumerated list for equity indices." ;
            sh:in ( "AEX" "ALLORD" "AMSMID" "AASHR" "ASCIX" "ARBG" "ARGMI" "ATHEX" "ATX50" "ATX" "BEL20" "BELAS" "BELMD" "BGBEL" "BELSM" "BGREIT" "BULG30" "BGBX40" "TRKSTN" "TIN30" "BKADR" "BKBRIC" "BUMIX" "BUDPES" "PBVGEN" "CAC40" "FCASH" "SBF250" "CACL60" "CAC190" "FCAM" "CAC20" "CSM90" "CDAX" "CECE" "CINT10" "CSMGL" "CSMST" "CNX100" "MILBCI" "CZSEC" "CSI500" "CZT" "DAX" "DJTB30" "DOWCOM" "DOWI" "DJT30" "DJTCOM" "DOWTRA" "DOWUTI" "DJES50" "DJEUR" "DJESTX" "EURNXT" "TSEFSI" "FT100" "FTSE25" "FT350" "FTAIM" "FTSEAL" "FALLW" "BEMAS" "BHSH" "KLCOMP" "FCHA50" "FTE100" "EURTP1" "FTSFLG" "GWADV" "FTIASI" "FTIMCI" "FITSMC" "ALLSTR" "SPMIB" "FTSMCA" "SNGSES" "FTSE" "TAI50" "FSA20" "FTS40" "JSEAS" "JOHT25" "FTJAS" "FTJ40" "JOHT40" "EUR300" "XDAX" "HKHS" "HSCEI" "HSCI" "HSENG" "HSM100" "HSREIT" "HDAX" "EHRMS" "HUNTRI" "IBEX35" "IBEXM" "IBEXS" "BOVESP" "JKCM" "LQ45" "SPAMAD" "IMC30" "ISEQ" "ISEQ20" "NK400" "DBMIDC" "SKKD" "KO100" "KORK20" "KO50" "KSPI" "KORLRG" "KOSPM" "KOSPS" "KRX100" "LXBORG" "DAXMID" "MICEX" "MSAPAC" "MSEME" "MSACEJ" "MSACW" "MSALL" "MSACES" "MSWDEJ" "MAUIMI" "MAUSLC" "MAUSMC" "MSAUST" "AUSIMI" "MSBELG" "MSBRZ" "MSCNDA" "MCHA50" "MSCHIN" "MSCRLC" "MSCRMC" "MSDIMI" "MSIMI" "MSEAFE" "MSEMAS" "MSCIEM" "MSERO" "MSEESG" "MSUREE" "MSCIE" "MSESC" "MESMID" "MSFDLC" "MSFDMC" "MSFIMI" "MSFRLP" "MHKIMI" "MSIND" "MIRIMI" "MSITAL" "MSITLC" "MSITMC" "ITSMCI" "JAPIMI" "MSCIJP" "MSKOR" "MSMEX" "MSNETH" "MSNEMC" "MNZIMI" "MSNORW" "MSCIPE" "MPOLLC" "MPOLMC" "MSPIMI" "MSSING" "MSCSA" "MSSIMI" "SWEIMI" "MSWELC" "SWIIMI" "MSSWLP" "MSTAI" "MSTHAI" "UKIMI" "MSCIUK" "UKSMCI" "MSUSAL" "MSUSEE" "MSCIUS" "MSWESG" "MSDWEE" "MSCIWD" "MSLCBL" "MSWSCS" "MWSMID" "MWIG" "NASDAQ" "NASCOM" "NEXT15" "NIK500" "NIKKEI" "NK300O" "NYSE" "OBX25" "OMXAFG" "KAX" "KFX" "KBX" "OMXCPM" "OMXCPS" "HEXGEN" "HEX25" "HEXP" "OMHSM" "OMHSS" "NOMXT" "ICEX" "ICEM" "ICES" "OMX" "GENX" "SOXP" "OBX" "OEBI" "OSEMF" "OESC" "RUSTRA" "PSECOM" "PSIGI" "PSI" "PRAGE" "PRIMAL" "ASPMTI" "ASPGEN" "RRTS" "RU1000" "RU2000" "RU250" "RU3000" "SP100" "SP1500" "SPFINA" "SP500" "SPINDU" "SP600" "SPADR" "BMIFR" "INSPCN" "BS100" "BS200" "BOM500" "BMIEMG" "SPGNRG" "SPGLBL" "SPLT40" "SPMIDC" "TX150" "ASX100" "_20LEAD" "ASX200" "ASX300" "ASX50" "ASXM50" "ASPA" "SPASX" "INMEX" "MEXCM" "IPC" "IPCM" "PEGEN" "INSENS" "SPHG" "SPLC" "NZX10" "NZSE50" "NZSEAL" "NZXMI" "NZXSI" "SP60" "CSPT" "TSE300" "SNPPF" "CSPS" "TSXVEN" "SBF120" "SBITOP" "SDAX" "SET100" "BNGK50" "CHSHG" "C180" "CHSA" "CHSB" "CSSC" "S300" "_S300" "CHZA" "CHZB" "CSZC" "SLISWS" "SMIEX" "SMI" "SMIM" "BSOFIX" "PAC600" "DJSE" "STXE6B" "DJS600" "DJSTXL" "SX1800" "SNGSTR" "SWIG" "SPI" "ISTMI" "TELAVI" "TDWTAS" "TWSE" "TAIOTC" "TECDAX" "BNGKSE" "TPX100" "TS1000" "JT500" "TCOR30" "TOPIX" "TPXLRG" "TMID40" "TPXSMA" "TSEGMC" "TSEGMI" "TKMOTH" "TSEPMC" "TSEPMI" "TSER" "TSESMI" "TSES20" "VENGEN" "AVSE" "PWWGI" "PWG20" "WIG30" "WFEXCH" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:equityIndex ] ;
    sh:targetClass common_domain_model:IndexType .

common_domain_model:IssuerAgencyRating a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AgencyRatingCriteria ;
            sh:description "Represents an agency rating based on default risk and creditors claim in event of default associated with asset issuer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:issuerAgencyRating ] ;
    sh:targetClass common_domain_model:IssuerAgencyRating .

common_domain_model:IssuerCountryOfOrigin a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents a filter on the issuing entity country of origin based on the ISO Standard 3166, which is the same as filtering by eligible Sovereigns." ;
            sh:in ( "AF" "AL" "DZ" "AS" "AD" "AO" "AI" "AQ" "AG" "AR" "AM" "AW" "AU" "AT" "AZ" "BS" "BH" "BD" "BB" "BY" "BE" "BZ" "BJ" "BM" "AX" "BT" "BO" "BQ" "BA" "BW" "BV" "BR" "IO" "BN" "BG" "BF" "BI" "CV" "KH" "CM" "CA" "KY" "CF" "TD" "CL" "CN" "CX" "CC" "CO" "KM" "CD" "CG" "CK" "CR" "HR" "CU" "CW" "CY" "CZ" "CI" "DK" "DJ" "DM" "DO" "EC" "EG" "SV" "GQ" "ER" "EE" "SZ" "ET" "FK" "FO" "FJ" "FI" "FR" "GF" "PF" "TF" "GA" "GM" "GE" "DE" "GH" "GI" "GR" "GL" "GD" "GP" "GU" "GT" "GG" "GN" "GW" "GY" "HT" "HM" "VA" "HN" "HK" "HU" "IS" "IN" "ID" "IR" "IQ" "IE" "IM" "IL" "IT" "JM" "JP" "JE" "JO" "KZ" "KE" "KI" "KP" "KR" "KW" "KG" "LA" "LV" "LB" "LS" "LR" "LY" "LI" "LT" "LU" "MO" "MG" "MW" "MY" "MV" "ML" "MT" "MH" "MQ" "MR" "MU" "YT" "MX" "FM" "MD" "MC" "MN" "ME" "MS" "MA" "MZ" "MM" "NA" "NR" "NP" "NL" "NC" "NZ" "NI" "NE" "NG" "NU" "NF" "MK" "MP" "NO" "OM" "PK" "PW" "PS" "PA" "PG" "PY" "PE" "PH" "PN" "PL" "PT" "PR" "QA" "RO" "RU" "RW" "RE" "BL" "SH" "KN" "LC" "MF" "PM" "VC" "WS" "SM" "ST" "SA" "SN" "RS" "SC" "SL" "SG" "SX" "SK" "SI" "SB" "SO" "ZA" "GS" "SS" "ES" "LK" "SD" "SR" "SJ" "SE" "CH" "SY" "TW" "TJ" "TZ" "TH" "TL" "TG" "TK" "TO" "TT" "TN" "TM" "TC" "TV" "TR" "UG" "UA" "AE" "GB" "UM" "US" "UY" "UZ" "VU" "VE" "VN" "VG" "VI" "WF" "EH" "YE" "ZM" "ZW" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:issuerCountryOfOrigin ] ;
    sh:targetClass common_domain_model:IssuerCountryOfOrigin .

common_domain_model:IssuerName a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:LegalEntity ;
            sh:description "Specifies the issuing entity name or LEI." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:issuerName ] ;
    sh:targetClass common_domain_model:IssuerName .

common_domain_model:ListingExchange a sh:NodeShape ;
    rdfs:comment "Specifies a filter based on a stock exchange." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Represents a filter based on the Primary Stock Exchange facilitating the listing of companies, exchange of Stocks, Exchange traded Derivatives, Bonds, and other Securities expressed in ISO standard 10383." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:exchange ] ;
    sh:targetClass common_domain_model:ListingExchange .

common_domain_model:ListingSector a sh:NodeShape ;
    rdfs:comment "Specifies a filter based on an industry sector." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Represents a filter based on an industry sector defined under a system for classifying industry types such as Global Industry Classification Standard (GICS) and North American Industry Classification System (NAICS)" ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:sector ] ;
    sh:targetClass common_domain_model:ListingSector .

common_domain_model:MarginCallExposure a sh:NodeShape ;
    rdfs:comment "Represents attributes required for mark to market value or IM calculation value of the trade portfolio as recorded by the principle (in base currency)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral legal agreement threshold amount in base currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:agreementThreshold ],
        [ sh:class common_domain_model:Exposure ;
            sh:description "Represents the whole overall mark to market value or IM calculation value of the trade portfolio as recorded by the principle (in base currency)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:overallExposure ],
        [ sh:class common_domain_model:MarginCallInstructionType ;
            sh:description "Identifies the enumeration values to specify the call notification type, direction, specific action type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:instructionType ],
        [ sh:description "Identifies margin type and if related regulatory mandate" ;
            sh:in ( "VM" "RegIM" "NonRegIM" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path common_domain_model:regMarginType ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Represents a unique Identifier for a margin call message, that can be referenced throughout all points of the process." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:callIdentifier ],
        [ sh:class common_domain_model:Party ;
            sh:description "Indicates the name of the Clearing Broker FCM/DCM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:clearingBroker ],
        [ sh:class common_domain_model:Exposure ;
            sh:description "Represents Initial Margin (IM) exposure derived from schedule or Grid calculation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:scheduleGridIMExposure ],
        [ sh:class common_domain_model:Party ;
            sh:description "Represents the parties to the margin call. The cardinality is optional to address the case where both parties of the event are specified and a third party if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:party ],
        [ sh:class common_domain_model:CollateralPortfolio ;
            sh:description "Represents attributes to define the details of collateral assets within a collateral portfolio to be used in margin call messaging and contribute to collateral balances e.g securities in a collateral account recorded by the principal as held or posted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path common_domain_model:collateralPortfolio ],
        [ sh:description "Indicates the role of the party in an regulatory initial margin call instruction (i.e Pledgor party or Secured party)." ;
            sh:in ( "Pledgor" "Secured" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path common_domain_model:regIMRole ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Represents the role each specified party takes in the margin call. further to the principal roles, payer and receiver." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:partyRole ],
        [ sh:class common_domain_model:CollateralBalance ;
            sh:description "Represents additional credit support amount over and above mark to market value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path common_domain_model:independentAmountBalance ],
        [ sh:class common_domain_model:AgreementName ;
            sh:description "Specifies the legal agreement type the margin call is generated from and governed by." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:callAgreementType ],
        [ sh:class common_domain_model:Exposure ;
            sh:description "Represents Initial Margin (IM) exposure derived from ISDA SIMM calculation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:simmIMExposure ],
        [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral legal agreement rounding in base currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:agreementRounding ],
        [ sh:class common_domain_model:MarginCallExposure ;
            sh:description "Represents the current mark to market value or IM calculation value of the trade portfolio as recorded by the principle (in base currency), to be referenced in a margin call." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path common_domain_model:baseCurrencyExposure ],
        [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral legal agreement minimum transfer amount in base currency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:agreementMinimumTransferAmount ] ;
    sh:targetClass common_domain_model:MarginCallExposure .

common_domain_model:MarginCallInstructionType a sh:NodeShape ;
    rdfs:comment "Represents enumeration values to specify the call notification type, direction, specific action type." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Indicates the choice if the call instruction is visible or not to the other party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:visibilityIndicator ],
        [ sh:description "Indicates the status of the call message type, such as expected call, notification of a call or an actionable margin call." ;
            sh:in ( "MarginCall" "Notification" "ExpectedCall" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:callType ] ;
    sh:targetClass common_domain_model:MarginCallInstructionType .

common_domain_model:MasterAgreementDatedAsOfDate a sh:NodeShape ;
    rdfs:comment "Defines the dates agreed by the parties as the date of the Credit Support Annex or Credit Support Deed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date agreed by the parties as the Dated as of Date for the Master Agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:masterAgreementDatedAsOfDate ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:MasterAgreementDatedAsOfDate .

common_domain_model:NegativeCriteria a sh:NodeShape ;
    rdfs:comment "Used to apply a NOT logic condition to a single Collateral Criteria." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllCriteria ] [ sh:class common_domain_model:AnyCriteria ] [ sh:class common_domain_model:NegativeCriteria ] [ sh:class common_domain_model:CollateralIssuerType ] [ sh:class common_domain_model:CollateralGuarantorType ] [ sh:class common_domain_model:AssetType ] [ sh:class common_domain_model:IssuerCountryOfOrigin ] [ sh:class common_domain_model:AssetCountryOfOrigin ] [ sh:in ( "CNH" "CNT" "GGP" "IMP" "JEP" "KID" "MCF" "SML" "VAL" ) ] [ sh:class common_domain_model:IssuerName ] [ sh:class common_domain_model:IssuerAgencyRating ] [ sh:class common_domain_model:SovereignAgencyRating ] [ sh:class common_domain_model:AssetAgencyRating ] [ sh:class common_domain_model:AssetMaturity ] [ sh:class common_domain_model:SpecificAsset ] [ sh:class common_domain_model:CollateralTaxonomy ] [ sh:class common_domain_model:ListingExchange ] [ sh:class common_domain_model:ListingSector ] [ sh:class common_domain_model:IndexType ] [ sh:class common_domain_model:CounterpartyOwnIssuePermitted ] [ sh:class common_domain_model:DomesticCurrencyIssued ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:negativeCriteria ] ;
    sh:targetClass common_domain_model:NegativeCriteria .

common_domain_model:NonDeliverableSubstitute a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustedRelativeDateOffset ;
            sh:description "Details of the days on which calculations are to be made to determine the Delivery Amount and/or Return Amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:valuationDate ],
        [ sh:class common_domain_model:AdjustedRelativeDateOffset ;
            sh:description "The date for settlement of the transfer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:class common_domain_model:SettlementRateOption ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:settlementRateOption ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:nonDeliverableSubstituteIsApplicable ] ;
    sh:targetClass common_domain_model:NonDeliverableSubstitute .

common_domain_model:NumberBound a sh:NodeShape ;
    rdfs:comment "The number bound is defined as a number and whether the bound is inclusive." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether the number bound is inclusive, e.g. for a lower bound, false would indicate greater than, whereas true would indicate greater than or equal to." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:inclusive ],
        [ sh:datatype xsd:decimal ;
            sh:description "The number to be used as the bound, e.g. 5." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:number ] ;
    sh:targetClass common_domain_model:NumberBound .

common_domain_model:OtherEligibleAndPostedSupport a sh:NodeShape ;
    rdfs:comment "Specifies the Other Eligible Support elections." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CollateralValueMethod ;
            sh:description "Details how particular types of collateral are valued (other than in respect of a default)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:value ],
        [ sh:datatype xsd:boolean ;
            sh:description "The definition of 'Transfer' with respect to Other Eligible Support and Other Posted Support." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:applicableTransfer ],
        [ sh:datatype xsd:boolean ;
            sh:description "The definition of 'Value' with respect to Other Eligible Support and Other Posted Support." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicableValue ] ;
    sh:targetClass common_domain_model:OtherEligibleAndPostedSupport .

common_domain_model:PerformancePayout a sh:NodeShape ;
    rdfs:comment "Contains the necessary specifications for all performance payouts, encompassing equity return, dividend, variance, volatility and correlation products." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies the net final valuation price(s) of the underlier at Performance Payout level. This price can be expressed either as an actual amount/currency, as a determination method, or by reference to another value specified in the swap document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:finalValuationPrice ],
        [ sh:class common_domain_model:FxFeature ;
            sh:description "Defines quanto or composite FX features that are included in the swap leg." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:fxFeature ],
        [ sh:description "Identifies the underlying product that is referenced for pricing of the applicable leg in a swap.  Referenced in the '2018 ISDA CDM Equity Confirmation for Security Equity Swap' as Security." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:Observable ] [ sh:class common_domain_model:Product ] ) ;
            sh:order 3 ;
            sh:path common_domain_model:underlier ],
        [ sh:class common_domain_model:ReturnTerms ;
            sh:description "Specifies the type of return of a performance payout." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:returnTerms ],
        [ sh:class common_domain_model:ValuationDates ;
            sh:description "Defines how and when a performance type option or performance type swap is to be valued, including both interim and final valuation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:valuationDates ],
        [ sh:class common_domain_model:ObservationTerms ;
            sh:description "Defines how and when a performance type option or performance type swap is to be observed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:observationTerms ],
        [ sh:class common_domain_model:PortfolioReturnTerms ;
            sh:description "Specifies an individual type of return of a Performance Payout, when such individual return is part of an aggregation of multiple similar returns, at Performance Payout level" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:portfolioReturnTerms ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:PaymentDates ;
            sh:description "Defines the payment date schedule, as defined by the parameters that are needed to specify it, either in a parametric way or by reference to another schedule of dates (e.g. the valuation dates)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:paymentDates ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies the net initial valuation price(s) of the underlier at Performance Payout level. This price can be expressed either as an actual amount/currency, as a determination method, or by reference to another value specified in the swap document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:initialValuationPrice ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies the net initial valuation price(s) of the underlier at Performance Payout level. This price can be expressed either as an actual amount/currency, as a determination method, or by reference to another value specified in the swap document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:interimValuationPrice ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:principalPayment ] ;
    sh:targetClass common_domain_model:PerformancePayout .

common_domain_model:PerformanceValuationDates a sh:NodeShape ;
    rdfs:comment "Defines how and when a performance type option or performance type swap is to be valued." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:description "2018 ISDA CDM Equity Confirmation for Security Equity Swap: Pricing Date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:valuationDate ],
        [ sh:description "Specifies the method according to which an amount or a date is determined." ;
            sh:in ( <http://www.fpml.org/coding-scheme/determination-method-3-4#AgreedInitialPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#AsSpecifiedInMasterConfirmation> <http://www.fpml.org/coding-scheme/determination-method-3-4#CalculationAgent> <http://www.fpml.org/coding-scheme/determination-method-3-4#ClosingPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#DividendCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#ExpiringContractLevel> <http://www.fpml.org/coding-scheme/determination-method-3-4#HedgeExecution> <http://www.fpml.org/coding-scheme/determination-method-3-4#IssuerPaymentCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#NAV> <http://www.fpml.org/coding-scheme/determination-method-3-4#OpenPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#OSPPrice> <http://www.fpml.org/coding-scheme/determination-method-3-4#SettlementCurrency> <http://www.fpml.org/coding-scheme/determination-method-3-4#StrikeDateDetermination> <http://www.fpml.org/coding-scheme/determination-method-3-4#TWAPPrice> "TWAPVE" "TWAPVEExcludingClose" <http://www.fpml.org/coding-scheme/determination-method-3-4#ValuationTime> <http://www.fpml.org/coding-scheme/determination-method-3-4#VWAPPrice> "VWAPVE" "VWAPVEExcludingClose" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:determinationMethod ],
        [ sh:class common_domain_model:AdjustableRelativeOrPeriodicDates ;
            sh:description "2018 ISDA CDM Equity Confirmation for Security Equity Swap: Pricing Date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:valuationDates ],
        [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The specific time of day at which the calculation agent values the underlying. The SpecificTime is the only case when the valuationTime (time + business center location  e.g. 10:00:00 USNY) should be provided. You should be able to provide just the valuationTime without valuationTimeType, which infer that this is a specific time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:valuationTime ],
        [ sh:description "The time of day at which the calculation agent values the underlying, for example the official closing time of the exchange." ;
            sh:in ( "Close" "Open" "OSP" "SpecificTime" "XETRA" "DerivativesClose" "AsSpecifiedInMasterConfirmation" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:valuationTimeType ] ;
    sh:targetClass common_domain_model:PerformanceValuationDates .

common_domain_model:RateSchedule a sh:NodeShape ;
    rdfs:comment "A class defining a schedule of rates or amounts in terms of an initial value and then a series of step date and value pairs. On each step date the rate or amount changes to the new step value. The series of step date and value pairs are optional. If not specified, this implies that the initial value remains unchanged over time." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:seller common_domain_model:buyer common_domain_model:spreadScheduleType ) ;
    sh:property [ sh:class common_domain_model:PriceSchedule ;
            sh:description "The initial rate. An initial rate of 5% would be represented as 0.05." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:price ] ;
    sh:targetClass common_domain_model:RateSchedule .

common_domain_model:ScheduledTransfer a sh:NodeShape ;
    rdfs:comment "A scheduled transfer built into the contract." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:NonNegativeQuantity ;
            sh:description "Represents the amount of the asset to be transferred. The cashflow amount is always a positive number, as the cashflow direction is implied by the payer/receiver attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:AdjustableOrAdjustedOrRelativeDate ;
            sh:description "Represents the date on which the transfer to due." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:class common_domain_model:PartyReferencePayerReceiver ;
            sh:description "Represents the parties to the transfer and their role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:PaymentDiscounting ;
            sh:description "FpML specifies the FpML PaymentDiscounting.model group for representing the discounting elements that can be associated with a payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:paymentDiscounting ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Represents a unique reference to the transfer." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:identifier ],
        [ sh:description "Represents the object that is subject to the transfer, it could be an asset or a reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 6 ;
            sh:path common_domain_model:asset ],
        [ sh:description "Specifies the type of scheduled transfer." ;
            sh:in ( "CorporateAction" "Coupon" "CreditEvent" "DividendReturn" "Exercise" "FixedRateReturn" "FloatingRateReturn" "FractionalAmount" "InterestReturn" "NetInterest" "Performance" "Principal" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:transferType ],
        [ sh:in ( "CashDividend" "StockDividend" "StockSplit" "ReverseStockSplit" "SpinOff" "Merger" "Delisting" "StockNameChange" "StockIdentifierChange" "RightsIssue" "Takeover" "StockReclassification" "BonusIssue" "ClassAction" "EarlyRedemption" "Liquidation" "BankruptcyOrInsolvency" "IssuerNationalization" "Relisting" "BespokeEvent" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:corporateActionTransferType ],
        [ sh:description "Represents the origin to the transfer as a reference for lineage purposes, whether it originated from trade level settlement terms or from payment terms on an economic payout." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:AssetPayout ] [ sh:class common_domain_model:CommodityPayout ] [ sh:class common_domain_model:CreditDefaultPayout ] [ sh:class common_domain_model:FixedPricePayout ] [ sh:class common_domain_model:InterestRatePayout ] [ sh:class common_domain_model:OptionPayout ] [ sh:class common_domain_model:PerformancePayout ] [ sh:class common_domain_model:SettlementPayout ] ) ;
            sh:order 2 ;
            sh:path common_domain_model:payoutReference ] ;
    sh:targetClass common_domain_model:ScheduledTransfer .

common_domain_model:SensitivityMethodology a sh:NodeShape ;
    rdfs:comment "A class to specify the methodology according to which sensitivities are computed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The methodology according to which sensitivities will be computed, when specified through a normalized election." ;
            sh:in ( "Alternative" "Standard" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:specifiedMethodology ],
        [ sh:datatype xsd:string ;
            sh:description "The methodology according to which sensitivities will be computed, when specified through a custom election." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customMethodology ] ;
    sh:targetClass common_domain_model:SensitivityMethodology .

common_domain_model:SettlementPayout a sh:NodeShape ;
    rdfs:comment "Represents a forward settling payout. The underlier attribute captures the underlying payout, which is settled according to the settlementTerms attribute (which is part of PayoutBase). Both FX Spot and FX Forward should use this component." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PayerReceiver ;
            sh:description "Canonical representation of the payer and receiver parties applicable to each payout leg." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:ResolvablePriceQuantity ;
            sh:description "Each payout leg must implement the quantity concept as a 'resolvable' type, which allows for different payout legs to be linked to each other (e.g. in the case of cross-curreny products)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:priceQuantity ],
        [ sh:datatype xsd:string ;
            sh:description "Also called contract month or delivery month. However, it's not always a month. It is usually expressed using a code, e.g. Z23 would be the Dec 2023 contract, (Z = December). For crude oil, the corresponding contract might be called CLZ23." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:deliveryTerm ],
        [ sh:class common_domain_model:SettlementTerms ;
            sh:description "Each payout leg must specifies its settlement terms, including the delivery type (i.e. cash vs physical, and their respective terms), the transfer type (DvP etc.) and settlement date, if any." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:settlementTerms ],
        [ sh:class common_domain_model:AssetDeliveryInformation ;
            sh:description "Contains the information relative to the delivery of the asset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:delivery ],
        [ sh:class common_domain_model:CalculationSchedule ;
            sh:description "Allows the full representation of a payout by defining a set of schedule periods. It supports standard schedule customization by expressing all the dates, quantities, and pricing data in a non-parametric way." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:schedule ],
        [ sh:description "The underlying financial product that will be physically or cash settled, which can be of any type, eg an asset such as cash or a security, or the cash settlement of an index rate." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Observable ] [ sh:class common_domain_model:Product ] ) ;
            sh:order 0 ;
            sh:path common_domain_model:underlier ],
        [ sh:class common_domain_model:PrincipalPayments ;
            sh:description "The specification of the principal exchange. Optional as only applicable in the case of cross-currency or zero-coupon swaps with a final payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:principalPayment ] ;
    sh:targetClass common_domain_model:SettlementPayout .

common_domain_model:SovereignAgencyRating a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AgencyRatingCriteria ;
            sh:description "Represents an agency rating based on default risk of the country of the issuer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:sovereignAgencyRating ] ;
    sh:targetClass common_domain_model:SovereignAgencyRating .

common_domain_model:SpecificAsset a sh:NodeShape ;
    rdfs:comment "A single, specifically identified Asset chosen from the Asset data type" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass common_domain_model:SpecificAsset .

common_domain_model:Trade a sh:NodeShape ;
    rdfs:comment "Defines the output of a financial transaction between parties - a Business Event. A Trade impacts the financial position (i.e. the balance sheet) of involved parties." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TradeIdentifier ;
            sh:description "Represents the identifier(s) that uniquely identify a trade for an identity issuer. A trade can include multiple identifiers, for example a trade that is reportable to both the CFTC and ESMA, and then has an associated USI (Unique Swap Identifier) UTI (Unique Trade Identifier)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tradeIdentifier ],
        [ sh:description "Specifies the conditions that govern the adjustment to the quantity of a product being traded: e.g. execution, portfolio rebalancing etc. It is typically used in the context of Equity Swaps." ;
            sh:in ( "Execution" "PortfolioRebalancing" "Standard" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path common_domain_model:adjustment ],
        [ sh:class common_domain_model:NonTransferableProduct ;
            sh:description "The underlying product to be included in a contract or execution." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path common_domain_model:product ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date on which a trade is cleared (novated) through a central counterparty clearing service." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:clearedDate ],
        [ sh:class common_domain_model:TradeLot ;
            sh:description "Specifies the price, quantity and effective date of each trade lot, when the same product may be traded multiple times in different lots with the same counterparty. In a trade increase, a new trade lot is added to the list, with the corresponding effective date. In a trade decrease, the existing trade lot(s) are decreased of the corresponding quantity (and an unwind fee may have to be settled). The multiple cardinality and the ability to increase existing trades is used for Equity Swaps in particular." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path common_domain_model:tradeLot ],
        [ sh:class common_domain_model:Account ;
            sh:description "Represents a party's granular account information, which may be used in subsequent internal processing." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:account ],
        [ sh:class common_domain_model:PartyRole ;
            sh:description "Represents the role each specified party takes in the trade. further to the principal roles, payer and receiver." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:partyRole ],
        [ sh:class common_domain_model:AncillaryParty ;
            sh:description "Specifies the parties with ancillary roles in the transaction. The product is agnostic to the actual parties involved in the transaction, with the party references abstracted away from the product definition and replaced by the AncillaryRoleEnum. The AncillaryRoleEnum can then be positioned in the product and this AncillaryParty type, which is positioned outside of the product definition, allows the AncillaryRoleEnum to be associated with an actual party reference." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:ancillaryParty ],
        [ sh:datatype xsd:date ;
            sh:description "Specifies the date which the trade was agreed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:tradeDate ],
        [ sh:class common_domain_model:ContractDetails ;
            sh:description "Represents information specific to trades involving contractual products." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:contractDetails ],
        [ sh:class common_domain_model:TimeZone ;
            sh:description "Denotes the trade time and timezone as agreed by the parties to the trade." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:tradeTime ],
        [ sh:class common_domain_model:Collateral ;
            sh:description "Represents the collateral obligations of a party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:collateral ],
        [ sh:class common_domain_model:ExecutionDetails ;
            sh:description "Represents information specific to trades that arose from executions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:executionDetails ],
        [ sh:class common_domain_model:Counterparty ;
            sh:description "Specifies the parties which are the two counterparties to the transaction.  The product is agnostic to the actual parties to the transaction, with the party references abstracted away from the product definition and replaced by the counterparty enum (e.g. CounterpartyEnum values Party1 or Party2). The counterparty enum can then be positioned in the product (e.g. to specify which counterparty is the payer, receiver etc) and this counterparties attribute, which is positioned outside of the product definition, allows the counterparty enum to be associated with an actual party reference." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path common_domain_model:counterparty ],
        [ sh:class common_domain_model:Party ;
            sh:description "Represents the parties to the trade. The cardinality is optional to address the case where the trade is defined within a BusinessEvent data type, in which case the party is specified in BusinessEvent." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:party ] ;
    sh:targetClass common_domain_model:Trade .

common_domain_model:TradeIdentifier a sh:NodeShape ;
    rdfs:comment "Defines a trade identifier as a special case of the generic identifier type, that also includes the trade identifier class." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The enumerated classification of the identifier. Optional as a trade identifier may be party-specific, in which case it may not correspond to any established classification." ;
            sh:in ( "UniqueTransactionIdentifier" "UniqueSwapIdentifier" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:identifierType ],
        [ sh:class common_domain_model:Party ;
            sh:description "The identifier issuer, when specified by reference to a party specified as part of the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:issuerReference ],
        [ sh:datatype xsd:string ;
            sh:description "The identifier issuer, when specified explicitly alongside the identifier value (instead of being specified by reference to a party)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:issuer ],
        [ sh:class common_domain_model:AssignedIdentifier ;
            sh:description "The identifier value. This level of indirection between the issuer and the identifier and its version provides the ability to associate multiple identifiers to one issuer, consistently with the FpML PartyTradeIdentifier." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:assignedIdentifier ] ;
    sh:targetClass common_domain_model:TradeIdentifier .

common_domain_model:UnscheduledTransfer a sh:NodeShape ;
    rdfs:comment "An ad-hoc transfer instigated by a party to the contract." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents the object that is subject to the transfer, it could be an asset or a reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:or ( [ sh:class common_domain_model:Cash ] [ sh:class common_domain_model:Commodity ] [ sh:class common_domain_model:DigitalAsset ] [ sh:class common_domain_model:Instrument ] ) ;
            sh:order 4 ;
            sh:path common_domain_model:asset ],
        [ sh:description "Specifies the type of unscheduled transfer." ;
            sh:in ( "Recall" "Return" "Assignment" "BrokerageCommission" "Increase" "Novation" "PartialTermination" "Premium" "Renegotiation" "Termination" "Upfront" "CreditEvent" "CorporateAction" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:transferType ],
        [ sh:class common_domain_model:NonNegativeQuantity ;
            sh:description "Represents the amount of the asset to be transferred. The cashflow amount is always a positive number, as the cashflow direction is implied by the payer/receiver attribute." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:quantity ],
        [ sh:class common_domain_model:PartyReferencePayerReceiver ;
            sh:description "Represents the parties to the transfer and their role." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Represents a unique reference to the transfer." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:AdjustableOrAdjustedOrRelativeDate ;
            sh:description "Represents the date on which the transfer to due." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:settlementDate ],
        [ sh:class common_domain_model:PaymentDiscounting ;
            sh:description "FpML specifies the FpML PaymentDiscounting.model group for representing the discounting elements that can be associated with a payment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:paymentDiscounting ] ;
    sh:targetClass common_domain_model:UnscheduledTransfer .

common_domain_model:ValuationTerms a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "The number of valuation dates between valuation start date and valuation end date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:numberOfValuationDates ],
        [ sh:description "Specifies the fallback provisions for Hedging Party in the determination of the Final Price." ;
            sh:in ( "FPVClose" "FPVHedgeExecution" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:fPVFinalPriceElectionFallback ],
        [ sh:datatype xsd:boolean ;
            sh:description "The official settlement price as announced by the related exchange is applicable, in accordance with the ISDA 2002 definitions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:futuresPriceValuation ],
        [ sh:class common_domain_model:AdjustableRelativeOrPeriodicDates ;
            sh:description "Specifies the dividend valuation dates of the swap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:dividendValuationDates ],
        [ sh:datatype xsd:boolean ;
            sh:description "For an index option transaction, a flag to indicate whether a relevant Component Security Index Annex is applicable to the transaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:componentSecurityIndexAnnexFallback ],
        [ sh:datatype xsd:boolean ;
            sh:description "For an index option transaction, a flag to indicate whether a relevant Multiple Exchange Index Annex is applicable to the transaction. This annex defines additional provisions which are applicable where an index is comprised of component securities that are traded on multiple exchanges." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:multipleExchangeIndexAnnexFallback ],
        [ sh:datatype xsd:boolean ;
            sh:description "The official settlement price as announced by the related exchange is applicable, in accordance with the ISDA 2002 definitions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:optionsPriceValuation ] ;
    sh:targetClass common_domain_model:ValuationTerms .

common_domain_model:AdditionalRepresentations a sh:NodeShape ;
    rdfs:comment "A class to specify Additional Representations that may be applicable to an agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "The qualification of whether Additional Information related to Regulatory Compliance and Concentration Limits is applicable or not." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:regulatoryComplianceRepresentation ],
        [ sh:class common_domain_model:AdditionalRepresentation ;
            sh:description "The specification of the Additional Representation that may be applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:additionalRepresentation ] ;
    sh:targetClass common_domain_model:AdditionalRepresentations .

common_domain_model:AdjustableDates a sh:NodeShape ;
    rdfs:comment "A class for defining a series of dates that shall be subject to adjustment if they would otherwise fall on a day that is not a business day in the specified business centers, together with the convention for adjusting the dates." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The date(s) once the adjustment has been performed. (Note that this date may change if the business center holidays change)." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:adjustedDate ],
        [ sh:datatype xsd:date ;
            sh:description "A date subject to adjustment." ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:unadjustedDate ],
        [ sh:class common_domain_model:BusinessDayAdjustments ;
            sh:description "The business day convention and financial business centers used for adjusting the date if it would otherwise fall on a day that is not a business date in the specified business centers." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:dateAdjustments ] ;
    sh:targetClass common_domain_model:AdjustableDates .

common_domain_model:AgreementName a sh:NodeShape ;
    rdfs:comment "Specifies the agreement name through an agreement type and optional detailed sub agreement type." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:ContractualTermsSupplement ;
            sh:description "A contractual supplement (such as those published by ISDA) that will apply to the trade." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:contractualTermsSupplement ],
        [ sh:description "The type of master confirmation annex executed between the parties." ;
            sh:in ( <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2004IndexVarianceSwapAmericasInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2004ShareVarianceSwapAmericasInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2007DispersionVarianceSwapEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2007EquityFinanceSwapEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2007IndexVarianceSwapAmericasInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2007ShareVarianceSwapAmericasInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2007VarianceOptionEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2008EquityFinanceSwapAsiaExcludingJapan> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2008EquityFinanceSwapAsiaExcludingJapanRev1> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2008EquityOptionAsiaExcludingJapan> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2008EquityOptionAsiaExcludingJapanRev1> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2008EquityOptionJapan> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2009ClosedMarketsOptionsAsiaExcludingJapan> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2009EquityEuropeanInterdealerSS> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2009EquityEuropeanIS> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2009IndexShareOptionAmericas> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2009IndexSwapEuropeanInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2009IndexSwapPanAsiaInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2009ShareSwapPanAsia> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2010FairValueShareSwapEuropeanInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-annex-type-2-6#ISDA2010IndexShareOptionEMEAInterdealer> ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path common_domain_model:masterConfirmationAnnexType ],
        [ sh:class common_domain_model:ContractualMatrix ;
            sh:description "A reference to a contractual matrix of elected terms/values (such as those published by ISDA) that shall be deemed to apply to the trade. The applicable matrix is identified by reference to a name and optionally a publication date. Depending on the structure of the matrix, an additional term (specified in the matrixTerm element) may be required to further identify a subset of applicable terms/values within the matrix." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:contractualMatrix ],
        [ sh:datatype xsd:string ;
            sh:description "Definition of an agreement that is not enumerated in the CDM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:otherAgreement ],
        [ sh:description "The definitions such as those published by ISDA that will define the terms of the trade." ;
            sh:in ( "ISDA1991InterestRate" "ISDA1993CommodityDerivatives" "ISDA1996EquityDerivatives" "ISDA1997Bullion" "ISDA1997GovernmentBondOption" "ISDA1998FxAndCurrencyOption" "ISDA1999CreditDerivatives" "ISDA2000" "ISDA2002EquityDerivatives" "ISDA2003CreditDerivatives" "ISDA2004Novation" "ISDA2005Commodity" "ISDA2006" "ISDA2006InflationDerivatives" "ISDA2008InflationDerivatives" "ISDA2011EquityDerivatives" "ISDA2014CreditDerivatives" "ISDA2021InterestRateDerivatives" "ISDA2022VerifiedCarbonCredit" "ISDA2023DigitalAssetDerivatives" ) ;
            sh:order 3 ;
            sh:path common_domain_model:contractualDefinitionsType ],
        [ sh:description "Specification of the legal agreement type." ;
            sh:in ( "BrokerConfirmation" "Confirmation" "CreditSupportAgreement" "MasterAgreement" "MasterConfirmation" "SecurityAgreement" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:agreementType ],
        [ sh:description "The type of master confirmation executed between the parties." ;
            sh:in ( "_2003CreditIndex" "_2004EquityEuropeanInterdealer" "_2005VarianceSwapEuropeanInterdealer" "_2006DividendSwapEuropean" "_2006DividendSwapEuropeanInterdealer" "_2014CreditAsia" "_2014CreditAsiaFinancial" "_2014CreditAustraliaNewZealand" "_2014CreditAustraliaNewZealandFinancial" "_2014CreditEuropean" "_2014CreditEuropeanCoCoFinancial" "_2014CreditEuropeanFinancial" "_2014CreditJapan" "_2014CreditJapanFinancial" "_2014CreditNorthAmerican" "_2014CreditNorthAmericanFinancial" "_2014CreditSingapore" "_2014CreditSingaporeFinancial" "_2014CreditSovereignAsia" "_2014CreditSovereignEmergingEuropeanAndMiddleEastern" "_2014CreditSovereignJapan" "_2014CreditSovereignLatinAmerican" "_2014CreditSovereignWesternEuropean" "_2014StandardCreditAsia" "_2014StandardCreditAsiaFinancial" "_2014StandardCreditAustraliaNewZealand" "_2014StandardCreditAustraliaNewZealandFinancial" "_2014StandardCreditEuropean" "_2014StandardCreditEuropeanCoCoFinancial" "_2014StandardCreditEuropeanFinancial" "_2014StandardCreditJapan" "_2014StandardCreditJapanFinancial" "_2014StandardCreditNorthAmerican" "_2014StandardCreditNorthAmericanFinancial" "_2014StandardCreditSingapore" "_2014StandardCreditSingaporeFinancial" "_2014StandardCreditSovereignAsia" "_2014StandardCreditSovereignEmergingEuropeanAndMiddleEastern" "_2014StandardCreditSovereignJapan" "_2014StandardCreditSovereignLatinAmerican" "_2014StandardCreditSovereignWesternEuropean" "DJ_CDX_EM" "DJ_CDX_EM_DIV" "DJ_CDX_NA" "DJ_iTraxx_Europe" <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#EquityAmericas> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#EquityAsia> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#EquityEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA1999Credit> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditAsia> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditAustraliaNewZealand> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditNorthAmerican> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditSingapore> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditSovereignAsia> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditSovereignCentralAndEasternEurope> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditSovereignJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditSovereignLatinAmerica> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditSovereignMiddleEast> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003CreditSovereignWesternEurope> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003StandardCreditAsia> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003StandardCreditAustraliaNewZealand> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003StandardCreditEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003StandardCreditJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003StandardCreditNorthAmerican> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2003StandardCreditSingapore> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004CreditSovereignAsia> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004CreditSovereignEmergingEuropeanAndMiddleEastern> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004CreditSovereignJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004CreditSovereignLatinAmerican> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004CreditSovereignWesternEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004EquityAmericasInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004EquityAmericasInterdealerRev1> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004StandardCreditSovereignAsia> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004StandardCreditSovereignEmergingEuropeanAndMiddleEastern> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004StandardCreditSovereignJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004StandardCreditSovereignLatinAmerican> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2004StandardCreditSovereignWesternEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2005EquityAsiaExcludingJapanInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2005EquityAsiaExcludingJapanInterdealerRev2> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2005EquityJapaneseInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2006VarianceSwapJapanese> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2006VarianceSwapJapaneseInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2007EquityEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2007VarianceSwapAmericas> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2007VarianceSwapAsiaExcludingJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2007VarianceSwapAsiaExcludingJapanRev1> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2007VarianceSwapAsiaExcludingJapanRev2> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2007VarianceSwapEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2007VarianceSwapEuropeanRev1> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2008DividendSwapJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2008DividendSwapJapaneseRev1> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2008EquityAmericas> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2008EquityAsiaExcludingJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2008EquityAsiaExcludingJapanRev1> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2008EquityJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2009EquityAmericas> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2009EquityEuropeanInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2009EquityPanAsia> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2010EquityEMEAInterdealer> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2013VolatilitySwapAmericas> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2013VolatilitySwapAsiaExcludingJapan> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2013VolatilitySwapEuropean> <http://www.fpml.org/coding-scheme/master-confirmation-type-7-7#ISDA2013VolatilitySwapJapanese> ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path common_domain_model:masterConfirmationType ],
        [ sh:description "Specification of the master agreement type." ;
            sh:in ( <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#AFB> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#Bespoke> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#CMA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#CMOF> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#EEIPower> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#EFETElectricity> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#EFETGas> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#EMA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#FBF> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#GasEDI> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#German> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#GMRA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#GMSLA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#GTMA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#ICOM> "IETA_ERPA" "IETA_ETMA" "IETA_IETMA" <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#IFEMA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#IFEOMA> "ISDAMaster" "ISDAFIA_CDEA" "ISDAIIFM_TMA" <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#JSCC> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#LBMA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#LEAP> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#MCPSA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#NAESBGas> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#NBP> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#RussianDerivatives> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#RussianRepo> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#SCoTA> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#Swiss> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#TTF> <http://www.fpml.org/coding-scheme/master-agreement-type-3-2#ZBT> ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path common_domain_model:masterAgreementType ],
        [ sh:description "Specification of the credit support agreement type." ;
            sh:in ( "CreditSupportDeed" "CreditSupportAnnex" "CollateralTransferAgreement" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:creditSupportAgreementType ],
        [ sh:in ( <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#ABX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AsiaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AsiaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AustraliaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#AustraliaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDSonLeveragedLoans> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDSonMBS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXEmergingMarkets> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXEmergingMarketsDiversified> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CDXTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#CMBX> "DJ_CDX_EM_" "DJ_CDX_NA" <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EmergingEuropeanAndMiddleEasternSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EmergingEuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EmergingEuropeanCorporateLPN> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EuropeanCMBS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#EuropeanRMBS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#JapanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#JapanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaCorporateBond> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaCorporateBondOrLoan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#LatinAmericaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#MBX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#MCDX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#NewZealandCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#NewZealandSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#NorthAmericanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#PO> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SingaporeCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SingaporeSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAsiaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAsiaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAustraliaCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardAustraliaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardCDXTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEmergingEuropeanAndMiddleEasternSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEmergingEuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEmergingEuropeanCorporateLPN> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardEuropeanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardJapanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardJapanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDSBullet> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDXBullet> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLCDXBulletTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLatinAmericaCorporateBond> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLatinAmericaCorporateBondOrLoan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardLatinAmericaSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardNewZealandCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardNewZealandSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardNorthAmericanCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardSingaporeCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardSingaporeSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardSubordinatedEuropeanInsuranceCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardWesternEuropeanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#StandardiTraxxEuropeTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SubordinatedEuropeanInsuranceCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SukukCorporate> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SukukSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#SyndicatedSecuredLoanCDS> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#TRX> "TRX_II" <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#USMunicipalFullFaithAndCredit> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#USMunicipalGeneralFund> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#USMunicipalRevenue> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#WesternEuropeanSovereign> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAsiaExJapan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAsiaExJapanSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAsiaExJapanTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAustralia> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAustraliaSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxAustraliaTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxCJ> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxCJTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxEurope> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxEuropeSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxEuropeTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxJapan> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxJapanSwaption> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxJapanTranche> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxLevX> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxSDI75> <http://www.fpml.org/coding-scheme/broker-confirmation-type-5-0#iTraxxSovX> ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:brokerConfirmationType ],
        [ sh:description "specifies the type of margin for which a legal agreement is named." ;
            sh:in ( "VariationMargin" "InitialMargin" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:creditSupportAgreementMarginType ] ;
    sh:targetClass common_domain_model:AgreementName .

common_domain_model:AncillaryParty a sh:NodeShape ;
    rdfs:comment "Defines an ancillary role enumerated value with an associated party reference. The product is agnostic to the actual parties involved in the transaction, with the party references abstracted away from the product definition and replaced by the AncillaryRoleEnum. The AncillaryRoleEnum can then be positioned in the product and this AncillaryParty type, which is positioned outside of the product definition, allows the AncillaryRoleEnum to be associated with an actual party reference." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Optionally specifies the counterparty that the ancillary party is acting on behalf of." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path common_domain_model:onBehalfOf ],
        [ sh:class common_domain_model:Party ;
            sh:description "Specifies the party, or parties, associated to the ancillary role." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:partyReference ],
        [ sh:description "Specifies the AncillaryRoleEnum that is associated to the party reference. An ancillary party is any involved party that is not one of the two principal parties to the transaction." ;
            sh:in ( "DisruptionEventsDeterminingParty" "ExtraordinaryDividendsParty" "PredeterminedClearingOrganizationParty" "ExerciseNoticeReceiverPartyManual" "ExerciseNoticeReceiverPartyOptionalEarlyTermination" "ExerciseNoticeReceiverPartyCancelableProvision" "ExerciseNoticeReceiverPartyExtendibleProvision" "CalculationAgentIndependent" "CalculationAgentOptionalEarlyTermination" "CalculationAgentMandatoryEarlyTermination" "CalculationAgentFallback" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:role ] ;
    sh:targetClass common_domain_model:AncillaryParty .

common_domain_model:AssetType a sh:NodeShape ;
    rdfs:comment "Represents a class to allow specification of the asset product type." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:EquityType ;
            sh:description "Represents a filter based on the type of equity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:equityType ],
        [ sh:class common_domain_model:DebtType ;
            sh:description "Represents a filter based on the type of bond." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:debtType ],
        [ sh:description "Represents a filter based on the type of fund." ;
            sh:in ( "MoneyMarketFund" "ExchangeTradedFund" "MutualFund" "OtherFund" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:fundType ],
        [ sh:description "Represents a filter based on the type of collateral asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:assetType ],
        [ sh:description "Represents a filter based on the type of security." ;
            sh:in ( "Debt" "Equity" "Fund" "Warrant" "Certificate" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:securityType ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies the eligible asset type when not enumerated." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:otherAssetType ] ;
    sh:targetClass common_domain_model:AssetType .

common_domain_model:BaseAndEligibleCurrency a sh:NodeShape ;
    rdfs:comment "The base and eligible currency(ies) for the document as specified by the parties to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Utilised where the clause data structure is not able to capture a material aspect of the clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:eligibleCurrencyOther ],
        [ sh:description "A definition of a currency agreed by the parties, typically to indicate the currencies of eligible cash collateral." ;
            sh:in ( "AED" "AFN" "ALL" "AMD" "AOA" "ARS" "AUD" "AWG" "AZN" "BAM" "BBD" "BDT" "BHD" "BIF" "BMD" "BND" "BOB" "BOV" "BRL" "BSD" "BTN" "BWP" "BYN" "BZD" "CAD" "CDF" "CHE" "CHF" "CHW" "CLF" "CLP" "CNY" "COP" "COU" "CRC" "CUP" "CVE" "CZK" "DJF" "DKK" "DOP" "DZD" "EGP" "ERN" "ETB" "EUR" "FJD" "FKP" "GBP" "GEL" "GHS" "GIP" "GMD" "GNF" "GTQ" "GYD" "HKD" "HNL" "HTG" "HUF" "IDR" "ILS" "INR" "IQD" "IRR" "ISK" "JMD" "JOD" "JPY" "KES" "KGS" "KHR" "KMF" "KPW" "KRW" "KWD" "KYD" "KZT" "LAK" "LBP" "LKR" "LRD" "LSL" "LYD" "MAD" "MDL" "MGA" "MKD" "MMK" "MNT" "MOP" "MRU" "MUR" "MVR" "MWK" "MXN" "MXV" "MYR" "MZN" "NAD" "NGN" "NIO" "NOK" "NPR" "NZD" "OMR" "PAB" "PEN" "PGK" "PHP" "PKR" "PLN" "PYG" "QAR" "RON" "RSD" "RUB" "RWF" "SAR" "SBD" "SCR" "SDG" "SEK" "SGD" "SHP" "SLE" "SOS" "SRD" "SSP" "STN" "SVC" "SYP" "SZL" "THB" "TJS" "TMT" "TND" "TOP" "TRY" "TTD" "TWD" "TZS" "UAH" "UGX" "USD" "USN" "UYI" "UYU" "UYW" "UZS" "VED" "VES" "VND" "VUV" "WST" "XAD" "XAF" "XAG" "XAU" "XBA" "XBB" "XBC" "XBD" "XCD" "XCG" "XDR" "XOF" "XPD" "XPF" "XPT" "XSU" "XTS" "XUA" "XXX" "YER" "ZAR" "ZMW" "ZWG" ) ;
            sh:order 3 ;
            sh:path common_domain_model:eligibleCurrency ],
        [ sh:description "The common agreed currency into which relevant amounts of all collateral arrangements between the parties are converted, or if not an actual currency, the process through which this is determined. Where hardcoded (e.g. under the 1994 ISDA Credit Support Annex (Security Interest  NY Law)), the currency that effectively performs this function." ;
            sh:in ( "AED" "AFN" "ALL" "AMD" "AOA" "ARS" "AUD" "AWG" "AZN" "BAM" "BBD" "BDT" "BHD" "BIF" "BMD" "BND" "BOB" "BOV" "BRL" "BSD" "BTN" "BWP" "BYN" "BZD" "CAD" "CDF" "CHE" "CHF" "CHW" "CLF" "CLP" "CNY" "COP" "COU" "CRC" "CUP" "CVE" "CZK" "DJF" "DKK" "DOP" "DZD" "EGP" "ERN" "ETB" "EUR" "FJD" "FKP" "GBP" "GEL" "GHS" "GIP" "GMD" "GNF" "GTQ" "GYD" "HKD" "HNL" "HTG" "HUF" "IDR" "ILS" "INR" "IQD" "IRR" "ISK" "JMD" "JOD" "JPY" "KES" "KGS" "KHR" "KMF" "KPW" "KRW" "KWD" "KYD" "KZT" "LAK" "LBP" "LKR" "LRD" "LSL" "LYD" "MAD" "MDL" "MGA" "MKD" "MMK" "MNT" "MOP" "MRU" "MUR" "MVR" "MWK" "MXN" "MXV" "MYR" "MZN" "NAD" "NGN" "NIO" "NOK" "NPR" "NZD" "OMR" "PAB" "PEN" "PGK" "PHP" "PKR" "PLN" "PYG" "QAR" "RON" "RSD" "RUB" "RWF" "SAR" "SBD" "SCR" "SDG" "SEK" "SGD" "SHP" "SLE" "SOS" "SRD" "SSP" "STN" "SVC" "SYP" "SZL" "THB" "TJS" "TMT" "TND" "TOP" "TRY" "TTD" "TWD" "TZS" "UAH" "UGX" "USD" "USN" "UYI" "UYU" "UYW" "UZS" "VED" "VES" "VND" "VUV" "WST" "XAD" "XAF" "XAG" "XAU" "XBA" "XBB" "XBC" "XBD" "XCD" "XCG" "XDR" "XOF" "XPD" "XPF" "XPT" "XSU" "XTS" "XUA" "XXX" "YER" "ZAR" "ZMW" "ZWG" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:baseCurrency ],
        [ sh:datatype xsd:string ;
            sh:description "Utilised where the clause data structure is not able to capture a material aspect of the clause." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:baseCurrencyOther ],
        [ sh:datatype xsd:boolean ;
            sh:description "A flag detailing whether the Base Currency is included as an Eligible Currency." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:eligibleCurrencyInclBaseCurrency ],
        [ sh:datatype xsd:boolean ;
            sh:description "A flag detailing whether the Base Currency is set to  the Termination Currency as defined in the related  Master Agreement." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:baseCurrencyTerminationCurrency ] ;
    sh:targetClass common_domain_model:BaseAndEligibleCurrency .

common_domain_model:BespokeTransferTiming a sh:NodeShape ;
    rdfs:comment "A class to specify any bespoke Transfer Timing language by each party to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The bespoke transfer timing terms applicable to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:bespokeTransferTimingTerms ],
        [ sh:datatype xsd:boolean ;
            sh:description "A boolean flag to specify whether bespoke transfer terms are applicable or not." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isApplicable ] ;
    sh:targetClass common_domain_model:BespokeTransferTiming .

common_domain_model:CSADeliveryAmount a sh:NodeShape ;
    rdfs:comment "In respect of a Valuation Date, the amount of collateral which a party is entitled to demand to be transferred to it as a Delivery Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:description "Specifies whether the meaning of Delivery Amount follows the pre-print definition or deviates from this (either based on a rating or some other methodology)." ;
            sh:in ( "Standard" "NonStandardRatings" "NonStandardOther" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:deliveryAmount ] ;
    sh:targetClass common_domain_model:CSADeliveryAmount .

common_domain_model:CSAReturnAmount a sh:NodeShape ;
    rdfs:comment "In respect of a Valuation Date, the amount of collateral which a party is entitled to demand to be recalled to it as a Return Amount." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies whether the meaning of Return Amount follows the pre-print definition or deviates from this (either based on a rating or some other methodology)." ;
            sh:in ( "Standard" "NonStandardRatings" "NonStandardOther" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:returnAmount ] ;
    sh:targetClass common_domain_model:CSAReturnAmount .

common_domain_model:Collateral a sh:NodeShape ;
    rdfs:comment "A type for defining the obligations of the counterparty subject to credit support requirements." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Identifier ;
            sh:description "A list of identifiers pointing to the collateral portfolios which contain the collateral which covers a trade." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:portfolioIdentifier ],
        [ sh:class common_domain_model:CollateralPortfolio ;
            sh:description "The collateral portfolios which contain the collateral which covers a trade. (NB: this can be provided by reference to a global key for each CollateralPortfolio object)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:collateralPortfolio ],
        [ sh:class common_domain_model:CollateralProvisions ;
            sh:description "specifies the collateral provisions of the product." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:collateralProvisions ],
        [ sh:class common_domain_model:IndependentAmount ;
            sh:description "Independent Amount is an amount that usually less creditworthy counterparties are asked to provide. It can either be a fixed amount or a percentage of the Transaction's value. The Independent Amount can be: (i) transferred before any trading between the parties occurs (as a deposit at a third party's account or with the counterparty) or (ii) callable after trading has occurred (typically because a downgrade has occurred). In situation (i), the Independent Amount is not included in the calculation of Exposure, but in situation (ii), it is included in the calculation of Exposure. Thus, for situation (ii), the Independent Amount may be transferred along with any collateral call. Independent Amount is a defined term in the ISDA Credit Support Annex. ('with respect to a party, the amount specified as such for that party in Paragraph 13; if no amount is specified, zero')." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:independentAmount ] ;
    sh:targetClass common_domain_model:Collateral .

common_domain_model:CollateralBalance a sh:NodeShape ;
    rdfs:comment "Represents common attributes to define a collateral balance recorded by the principal as held or posted." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "Specifies the collateral balance amount in base currency determined within a collateral legal agreement, or defined for reporting purposes." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:amountBaseCurrency ],
        [ sh:class common_domain_model:PartyReferencePayerReceiver ;
            sh:description "Specifies each of the parties in the collateral balance and its perspective with regards to the direction of the collateral balance, posted or received." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:payerReceiver ],
        [ sh:description "Indicates if the collateral balance amount is based on pre or post haircut, if a haircut is associated with the collateral asset" ;
            sh:in ( "PreHaircut" "PostHaircut" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:haircutIndicator ],
        [ sh:description "Defines the collateral balance breakdown of settlement status." ;
            sh:in ( "FullAmount" "SettledAmount" "InTransitAmount" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:collateralBalanceStatus ] ;
    sh:targetClass common_domain_model:CollateralBalance .

common_domain_model:CollateralIssuerType a sh:NodeShape ;
    rdfs:comment "Represents a class to allow specification of the type of entity issuing the collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies debt issued by international organisations and multilateral banks." ;
            sh:in ( "InternationalOrganisation" "MultilateralBank" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:supraNationalType ],
        [ sh:description "Specifies the origin of entity issuing the collateral." ;
            sh:in ( "SupraNational" "SovereignCentralBank" "QuasiGovernment" "RegionalGovernment" "Corporate" "Fund" "SpecialPurposeVehicle" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:issuerType ],
        [ sh:class common_domain_model:QuasiGovernmentIssuerType ;
            sh:description "Specifies debt issues by institutions or bodies, typically constituted by statute, with a function mandated by the government and subject to government supervision inclusive of profit- and non-profit making bodies. Includes the US Agencies and GSEs and the EU concept of public sector entities. Excluding any entities which are also Regional Government." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:quasiGovernmentType ],
        [ sh:class common_domain_model:SpecialPurposeVehicleIssuerType ;
            sh:description "Specifies a subsidiary company that is formed to undertake a specific business purpose of acquisition and financing of specific assets on a potentially limited recourse basis dependent of how it is designed. E.g. asset backed securities, including securitisations." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:specialPurposeVehicleType ],
        [ sh:class common_domain_model:RegionalGovernmentIssuerType ;
            sh:description "Specifies Regional government, local authority or municipal." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:regionalGovernmentType ] ;
    sh:targetClass common_domain_model:CollateralIssuerType .

common_domain_model:CollateralPortfolio a sh:NodeShape ;
    rdfs:comment "Represents common attributes to define the details of collateral assets, to be used in margin call messaging and contribute to collateral balances e.g securities in a collateral account." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Identifier ;
            sh:description "Specifies a unique identifier for a set of collateral positions in a portfolio." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:portfolioIdentifier ],
        [ sh:class common_domain_model:LegalAgreement ;
            sh:description " The specification of a legal agreement between two parties governing the collateral relationship such as Credit Support Agreement or Collateral Transfer Agreement etc. (NB: this can be provided by reference to a global key for each LegalAgreement object)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:legalAgreement ],
        [ sh:class common_domain_model:CollateralPosition ;
            sh:description "Specifies the individual components of the collateral positions in the collateral portfolio." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:collateralPosition ],
        [ sh:class common_domain_model:CollateralBalance ;
            sh:description "Represents the populated or calculated collateral aggregate balance amount for the collateral portfolio." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:collateralBalance ] ;
    sh:targetClass common_domain_model:CollateralPortfolio .

common_domain_model:CollateralTransferTiming a sh:NodeShape ;
    rdfs:comment "Specification of transfer / settlement timing for cash and securities collateral assuming that the notice is provided before the Notification Time (and with a 1LBD lag introduced if the notice is delivered after the Notification Time), and that securities allow for a further Local Business Day for transfer / settlement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CollateralTransferTimingDefinition ;
            sh:description "Bespoke language removing the pre-print requirement to transfer legal title of securities collateral through written instructions to the relevant depository institution or other securities intermediaries solely for the purposes of the 1994 New York Law Credit Support Annex." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:collateralTransferTimingDefinition ],
        [ sh:class common_domain_model:TransferSettlementTiming ;
            sh:description "Specification of transfer / settlement timing for cash and securities collateral assuming that the notice is provided before the Notification Time (and with a 1LBD lag introduced if the notice is delivered after the Notification Time), and that securities allow for a further Local Business Day for transfer / settlement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:transferSettlementTiming ] ;
    sh:targetClass common_domain_model:CollateralTransferTiming .

common_domain_model:ConditionsPrecedent a sh:NodeShape ;
    rdfs:comment "A class to specify the two set of elections that may overwrite the default Condition Precedent provision." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The election to specify whether the standard Conditions Precedent apply." ;
            sh:in ( "Applicable" "NotApplicable" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:conditionsPrecedentElection ],
        [ sh:datatype xsd:string ;
            sh:description "The custom provisions that might be specified by the parties to the agreement for the purpose of overwriting the default Condition Precedent provision specified in the CSA." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customProvision ],
        [ sh:class common_domain_model:SpecifiedConditionOrAccessCondition ;
            sh:description "Specifies the events elected by the parties that are deemed an Access Condition (for Initial Margin CSA) or a Specified Condition (for Variation Margin and Legacy CSA), which, if triggered, may temporarily or permanently suspend rights to rehypothecate, transfer, or substitute collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:specifiedConditionOrAccessCondition ] ;
    sh:targetClass common_domain_model:ConditionsPrecedent .

common_domain_model:CustomisableOffset a sh:NodeShape ;
    rdfs:comment "A class to specify an offset either as a normalized [multiplier, period, dayType] or as a custom provision of type string." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Offset ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:offset ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:customProvision ] ;
    sh:targetClass common_domain_model:CustomisableOffset .

common_domain_model:DisputeResolution a sh:NodeShape ;
    rdfs:comment "A class to specify the election terms under which a party disputes the Value of any Transfer of Eligible Credit Support or Posted Credit Support." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:BusinessCenterTime ;
            sh:description "The time by which the dispute needs to be resolved, failure of which would trigger a recalculation alongside a process that is specified as part of the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:resolutionTime ],
        [ sh:class common_domain_model:RecalculationOfValue ;
            sh:description "The elections to specify terms for recalculation of the market value of posted collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:recalculationOfValue ],
        [ sh:datatype xsd:string ;
            sh:description "The alternative dispute resolution procedure if specified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:alternativeTerms ],
        [ sh:class common_domain_model:LegacyResolutionAlternative ;
            sh:description "Alternative procedures to those in the pre-print for resolving collateral related disputes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:legacyAlternative ],
        [ sh:datatype xsd:string ;
            sh:description "The custom Resolution Time election that might be specified by the parties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:otherTerms ],
        [ sh:class common_domain_model:ResolutionValue ;
            sh:description "Methodology for resolving disputes in respect of the determination of the value of collateral." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:value ] ;
    sh:targetClass common_domain_model:DisputeResolution .

common_domain_model:EligibleCollateralCriteria a sh:NodeShape ;
    rdfs:comment "Represents a set of criteria used to specify eligible collateral." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Restrict the criteria to only apply to a specific type of margin, ie IM or VM." ;
            sh:in ( "VariationMargin" "InitialMargin" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:restrictTo ],
        [ sh:class common_domain_model:CollateralTreatment ;
            sh:description "Identifies the treatment of specified collateral, e.g., haircuts,holding limits or exclusions." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:treatment ],
        [ sh:description "Specifies which of the two counterparties the criteria applies to (either one or both counterparties). This attribute is optional, in case the applicable party is already specified elsewhere within a party election." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:order 2 ;
            sh:path common_domain_model:appliesTo ],
        [ sh:description "The specific criteria that applies. It can be created using AND, OR and NOT logic, and both asset and issuer characteristics." ;
            sh:maxCount 1 ;
            sh:or ( [ sh:class common_domain_model:AllCriteria ] [ sh:class common_domain_model:AnyCriteria ] [ sh:class common_domain_model:NegativeCriteria ] [ sh:class common_domain_model:CollateralIssuerType ] [ sh:class common_domain_model:CollateralGuarantorType ] [ sh:class common_domain_model:AssetType ] [ sh:class common_domain_model:IssuerCountryOfOrigin ] [ sh:class common_domain_model:AssetCountryOfOrigin ] [ sh:in ( "CNH" "CNT" "GGP" "IMP" "JEP" "KID" "MCF" "SML" "VAL" ) ] [ sh:class common_domain_model:IssuerName ] [ sh:class common_domain_model:IssuerAgencyRating ] [ sh:class common_domain_model:SovereignAgencyRating ] [ sh:class common_domain_model:AssetAgencyRating ] [ sh:class common_domain_model:AssetMaturity ] [ sh:class common_domain_model:SpecificAsset ] [ sh:class common_domain_model:CollateralTaxonomy ] [ sh:class common_domain_model:ListingExchange ] [ sh:class common_domain_model:ListingSector ] [ sh:class common_domain_model:IndexType ] [ sh:class common_domain_model:CounterpartyOwnIssuePermitted ] [ sh:class common_domain_model:DomesticCurrencyIssued ] ) ;
            sh:order 1 ;
            sh:path common_domain_model:collateralCriteria ],
        [ sh:description "Denotes which Criteria has priority if more than one agency rating applies." ;
            sh:in ( "Issuer" "Asset" "Lowest" "Highest" "Average" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:ratingPriorityResolution ] ;
    sh:targetClass common_domain_model:EligibleCollateralCriteria .

common_domain_model:FinalReturns a sh:NodeShape ;
    rdfs:comment "A clause providing that final return collateral is to be provided without consideration of any Minimum Transfer Amount and collateral haircut." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalLanguage ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines if the clause is applicable to this agreement or any other exceptions." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:applicable ] ;
    sh:targetClass common_domain_model:FinalReturns .

common_domain_model:FloatingRateIndex a sh:NodeShape ;
    rdfs:comment "Specification of an interest rate index which can change over time, e.g. the SONIA (Sterling Overnight Index Average) in the UK." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies the type of asset." ;
            sh:in ( "Security" "Cash" "Commodity" "ListedDerivative" "Loan" "LetterOfCredit" "Other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 10 ;
            sh:path common_domain_model:assetType ],
        [ sh:datatype xsd:string ;
            sh:description "A description of the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:name ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "If the Asset is listed, defines the public exchange of the listing." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:exchange ],
        [ sh:description "The Asset Class of the Index." ;
            sh:in ( <http://www.fpml.org/coding-scheme/asset-class-2-1#Commodity> <http://www.fpml.org/coding-scheme/asset-class-2-1#Credit> <http://www.fpml.org/coding-scheme/asset-class-2-1#Equity> <http://www.fpml.org/coding-scheme/asset-class-2-1#ForeignExchange> <http://www.fpml.org/coding-scheme/asset-class-2-1#InterestRate> "MoneyMarket" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path common_domain_model:assetClass ],
        [ sh:datatype xsd:boolean ;
            sh:description "Defines whether the Asset is listed on a public exchange." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path common_domain_model:isExchangeListed ],
        [ sh:class common_domain_model:Period ;
            sh:description "The ISDA Designated Maturity, i.e. the floating rate tenor." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:indexTenor ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "The organisation that creates or maintains the Index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:provider ],
        [ sh:class common_domain_model:AssetIdentifier ;
            sh:description "Asset Identifiers are used to uniquely identify an Asset, using a specified Asset Identifier Type." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:LegalEntity ;
            sh:description "Provides the related Exchanges, if applicable." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path common_domain_model:relatedExchange ],
        [ sh:class common_domain_model:Taxonomy ;
            sh:description "Defines the taxonomy of an object by combining a taxonomy source (i.e. the rules to classify the object) and a value (i.e. the output of those rules on the object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:taxonomy ],
        [ sh:description "The reference index that is used to specify the floating interest rate." ;
