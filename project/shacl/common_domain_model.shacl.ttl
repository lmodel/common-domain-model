common_domain_model:Address a sh:NodeShape ;
    rdfs:comment "A class to specify a post or street address." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The city component of the postal address." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:city ],
        [ sh:datatype xsd:string ;
            sh:description "The code, required for computerized mail sorting systems, that is allocated to a physical address by a national postal authority." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:postalCode ],
        [ sh:datatype xsd:string ;
            sh:description "The set of street and building number information that identifies a postal address within a city." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:street ],
        [ sh:datatype xsd:string ;
            sh:description "A country subdivision used in postal addresses in some countries. For example, US states, Canadian provinces, Swiss cantons, ..." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:state ],
        [ sh:datatype xsd:string ;
            sh:description "The ISO 3166 standard code for the country within which the postal address is located." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:country ] ;
    sh:targetClass common_domain_model:Address .

common_domain_model:AddressesForTransfer a sh:NodeShape ;
    rdfs:comment "Specifies the address for transfer as specified by the respective parties to the agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:TransferInformationElection ;
            sh:description "The parties' contact and transfer information election." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:partyElection ] ;
    sh:targetClass common_domain_model:AddressesForTransfer .

common_domain_model:AssetDeliveryInformation a sh:NodeShape ;
    rdfs:comment "Contains the information relative to the delivery of the asset." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Grade of product being delivered (e.g., grade of oil)." ;
            sh:in ( "_0_1_Percent" "_0_5_Percent" "_1_0_Percent" "_10_PPM" "_10_PPM_95_R" "_10_PPM_Premium_Unleaded" "_10_PPM_Regular_Unleaded" "_180_CST" "_3_5_Percent" "_380_CST" "_50_PPM" "_54" "_55" "_87_M" "_87_Unleaded" "_87_Unleaded_ULS_30" "_92_Unleaded" "_93_Unleaded" "_95_Unleaded" "_97_Unleaded" "_98_Unleaded" "Arabian_Light" "Brass_Blend" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Brent> <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#CARBOB> <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#CBOB> "Cold_Lake" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Dubai> "Edmonton_High_Sulphur_Sour" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#EUROBOB> "German_10PPM" "Gulf_Coast_Sweet" "Hardisty_Light" "Iranian_Light_1" "Iranian_Light" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Jet> "Kirkuk_Light" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Kuwait> "Light_Louisiana_Sweet" "Low_Sulphur" "Low_Sulphur_Jet" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Mars> "Mixed_Sour_Blend" "Mixed_Sweet_Blend" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Murban> "Natural_Gasoline" "No__2" "No__6_0_3_Percent" "No__6_0_3_Percent_HP" "No__6_0_3_Percent_LP" "No__6_0_7_Percent" "No__6_1_0_Percent" "No__6_2_2_Percent" "No__6_3_Percent" "Normal_Butane" "North_Dakota_Light" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Oman> "Polymer_Grade" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#RBOB> <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Saharan> <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Sour> "Southern_Green_Canyon" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Tapis> "Thunder_Horse" "Ultra_Low_Sulphur" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Urals> "Urals_Sour" "US_Regular_Unleaded" "Western_Canadian_Select" <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#WTI> <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#WTS> <http://www.fpml.org/coding-scheme/commodity-oil-product-grade-1-0#Zuetina> ) ;
            sh:order 3 ;
            sh:path common_domain_model:commodityGrade ],
        [ sh:class common_domain_model:Quantity ;
            sh:description "The number of units included in the transaction for each delivery interval" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:deliveryCapacity ],
        [ sh:class common_domain_model:AssetDeliveryPeriods ;
            sh:description "Defines the periods of delivery, including the delivery profile." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:periods ],
        [ sh:class common_domain_model:LocationIdentifier ;
            sh:description "Defines the location of the delivery of the commodity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:location ] ;
    sh:targetClass common_domain_model:AssetDeliveryInformation .

common_domain_model:BasketConstituent a sh:NodeShape ;
    rdfs:comment "Identifies the constituents of the basket" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies a final price schedule to be associated to an individual underlier that is a basket constituent. The multiple cardinality is aligned to the one of the PriceQuantity->price that this price is referencing." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:finalValuationPrice ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies an interim price schedule to be associated to an individual underlier that is a basket constituent. The multiple cardinality is aligned to the one of the PriceQuantity->price that this price is referencing." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path common_domain_model:interimValuationPrice ],
        [ sh:class common_domain_model:PriceSchedule ;
            sh:description "Specifies an initial price schedule to be associated to an individual underlier that is a basket constituent. The multiple cardinality is aligned to the one of the PriceQuantity->price that this price is referencing." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:initialValuationPrice ],
        [ sh:class common_domain_model:NonNegativeQuantitySchedule ;
            sh:description "Specifies a quantity schedule to be associated to an individual underlier that is a basket constituent. The multiple cardinality is aligned to the one of the PriceQuantity->quantity that this quantity is referencing." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:quantity ] ;
    sh:targetClass common_domain_model:BasketConstituent .

common_domain_model:BuyerSeller a sh:NodeShape ;
    rdfs:comment "This class corresponds to the FpML BuyerSeller.model construct." ;
    sh:closed true ;
    sh:ignoredProperties ( common_domain_model:extendibleProvisionAdjustedDates common_domain_model:finalCalculationPeriodDateAdjustment rdf:type common_domain_model:effectivePeriod common_domain_model:effectiveDate common_domain_model:noticeDeadlinePeriod common_domain_model:callingParty common_domain_model:noticeDeadlineDateTime common_domain_model:followUpConfirmation common_domain_model:extensionPeriod common_domain_model:expirationDate common_domain_model:cancelableProvisionAdjustedDates common_domain_model:extensionTerm common_domain_model:exerciseNotice common_domain_model:singlePartyOption common_domain_model:exerciseTerms common_domain_model:latestCancelationTime common_domain_model:earliestCancellationTime common_domain_model:earliestDate common_domain_model:initialFee ) ;
    sh:property [ sh:description "Seller party that can be resolved as one of the two principal parties to the transaction. The party that sells ('writes') this instrument, i.e. that grants the rights defined by this instrument and in return receives a payment for it. ISDA 2002 Equity Definitions section 1.19: `Seller` means the party specified as such in the related Confirmation. | ISDA 2006 Definitions article 12.1 (a)(i) relating to a Swaption: 'Seller' means the party the party specified as such or as writer in the related Confirmation | ISDA 2006 Definitions article 12.1 (a)(ii) relating to Swap Transactions with applicable Early Termination: the party specified as such or as writer in the related Confirmation or, if neither party is specified as such, the Non-exercising Party | ISDA 2006 Definitions article 12.1 (a)(iii) relating to any other Option Transaction: the party specified as such in the related Confirmation. | ISDA 2014 Credit Definition article 1.4: `Seller` means the Floating Rate Payer." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:seller ],
        [ sh:description "Buyer party that can be resolved as one of the two principal parties to the transaction. The party that buys this instrument, i.e. pays for this instrument and receives the rights defined by it. ISDA 2002 Equity Definitions section 1.18: `Buyer` means the party specified as such in the related Confirmation. | ISDA 2006 Definitions article 12.1 (b)(i) relating to a Swaption: 'Buyer' means the party that will, on each Premium Payment Date, pay to Seller the Premium | ISDA 2006 Definitions article 12.1 (b)(ii) relating to Swap Transactions with applicable Early Termination: the party specified as such in the related Confirmation, or the Exercising Party if neither party is specified | ISDA 2006 Definitions article 12.1 (b)(iii) relating to any other Option Transaction: the party specified as such in the related Confirmation. | ISDA 2014 Credit Definition article 1.4: `Buyer` means the Fixed Rate Payer." ;
            sh:in ( "Party1" "Party2" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:buyer ] ;
    sh:targetClass common_domain_model:BuyerSeller .

common_domain_model:CalculationPeriodFrequency a sh:NodeShape ;
    rdfs:comment "A class to specify the frequency at which calculation period end dates occur within the regular part of the calculation period schedule and their roll date convention." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "A time period, e.g. a day, week, month, year or term of the stream." ;
            sh:in ( "H" "D" "W" "M" "Y" "T" "C" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path common_domain_model:period ],
        [ sh:datatype xsd:integer ;
            sh:description "A time period multiplier, e.g. 1, 2, or 3. If the period value is T (Term) then period multiplier must contain the value 1." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:periodMultiplier ],
        [ sh:datatype xsd:boolean ;
            sh:description "Indicates, when true, that that the first Calculation Period should run from the Effective Date to the end of the calendar period in which the Effective Date falls, e.g. Jan 15 - Jan 31 if the calculation periods are one month long and Effective Date is Jan 15. If false, the first Calculation Period should run from the Effective Date for one whole period, e.g. Jan 15 to Feb 14 if the calculation periods are one month long and Effective Date is Jan 15. Mostly used in Commmodity Swaps." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:balanceOfFirstPeriod ],
        [ sh:description "The roll convention specifies the period term as part of a periodic schedule, i.e. the calculation period end date within the regular part of the calculation period. The value could be a rule, e.g. IMM Settlement Dates, which is the 3rd Wednesday of the month, or it could be a specific day of the month, such as the first day of the applicable month. It is used in conjunction with a frequency and the regular period start date of a calculation period." ;
            sh:in ( "EOM" "FRN" "IMM" "IMMCAD" "IMMAUD" "IMMNZD" "SFE" "NONE" "TBILL" "_1" "_2" "_3" "_4" "_5" "_6" "_7" "_8" "_9" "_10" "_11" "_12" "_13" "_14" "_15" "_16" "_17" "_18" "_19" "_20" "_21" "_22" "_23" "_24" "_25" "_26" "_27" "_28" "_29" "_30" "MON" "TUE" "WED" "THU" "FRI" "SAT" "SUN" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:rollConvention ] ;
    sh:targetClass common_domain_model:CalculationPeriodFrequency .

common_domain_model:ContractDetails a sh:NodeShape ;
    rdfs:comment "Defines specific attributes that relate to contractual details of trades." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Represents the law governing the trade and associated contractual product terms." ;
            sh:in ( <http://www.fpml.org/coding-scheme/governing-law-1-2#AsSpecifiedInMasterAgreement> "BE" <http://www.fpml.org/coding-scheme/governing-law-1-2#CAAB> <http://www.fpml.org/coding-scheme/governing-law-1-2#CABC> <http://www.fpml.org/coding-scheme/governing-law-1-2#CAMN> <http://www.fpml.org/coding-scheme/governing-law-1-2#CAON> <http://www.fpml.org/coding-scheme/governing-law-1-2#CAQC> <http://www.fpml.org/coding-scheme/governing-law-1-2#DE> <http://www.fpml.org/coding-scheme/governing-law-1-2#FR> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBEN> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBGY> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBIM> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBJY> <http://www.fpml.org/coding-scheme/governing-law-1-2#GBSC> "IE" <http://www.fpml.org/coding-scheme/governing-law-1-2#JP> "LU" "RelatedMasterAgreement" <http://www.fpml.org/coding-scheme/governing-law-1-2#USCA> <http://www.fpml.org/coding-scheme/governing-law-1-2#USDE> <http://www.fpml.org/coding-scheme/governing-law-1-2#USIL> <http://www.fpml.org/coding-scheme/governing-law-1-2#USNY> ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path common_domain_model:governingLaw ],
        [ sh:class common_domain_model:LegalAgreement ;
            sh:description "Represents the legal document(s) that governs a trade and associated contractual product terms, either as a reference to such documents when specified as part of the CDM, or through identification of some of the key terms of those documents, such as the type of document, the document identifier, the publisher, the document vintage and the agreement date." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:documentation ] ;
    sh:targetClass common_domain_model:ContractDetails .

common_domain_model:ContractualDefinition a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "2021-06-11" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:publicationDate ],
        [ sh:class common_domain_model:Identifier ;
            sh:description "Corresponds to the unique identifier of the Contractual Definition in which the code is published" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:identifier ],
        [ sh:class common_domain_model:ContractualDefinitionIdentifier ;
            sh:description "Contractual Definition Identifier in which the code is published. Includes Document Type and Document Version" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:contractualDefinitionIdentifier ] ;
    sh:targetClass common_domain_model:ContractualDefinition .

common_domain_model:CreditEvents a sh:NodeShape ;
    rdfs:comment "A class to specify the applicable Credit Events that would trigger a settlement, as specified in the related Confirmation and defined in the ISDA 2014 Credit Definition article IV section 4.1." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "A credit event. Results from the fact that the underlier fails to make principal payments as expected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path common_domain_model:maturityExtension ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. The reference entity, or a governmental authority, either refuses to recognise or challenges the validity of one or more obligations of the reference entity, or imposes a moratorium thereby postponing payments on one or more of the obligations of the reference entity. Subject to the default requirement amount. ISDA 2003 Term: Repudiation/Moratorium." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path common_domain_model:repudiationMoratorium ],
        [ sh:class common_domain_model:FailureToPay ;
            sh:description "A credit event. This credit event triggers, after the expiration of any applicable grace period, if the reference entity fails to make due payments in an aggregate amount of not less than the payment requirement on one or more obligations (e.g. a missed coupon payment). ISDA 2003 Term: Failure to Pay." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:failureToPay ],
        [ sh:class common_domain_model:CreditEventNotice ;
            sh:description "A specified condition to settlement. An irrevocable written or verbal notice that describes a credit event that has occurred. The notice is sent from the notifying party (either the buyer or the seller) to the counterparty. It provides information relevant to determining that a credit event has occurred. This is typically accompanied by Publicly Available Information. ISDA 2003 Term: Credit Event Notice." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path common_domain_model:creditEventNotice ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. Results from the fact that the underlier writes down its outstanding principal amount." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path common_domain_model:writedown ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. Results from the fact that losses occur to the underlying instruments that do not result in reductions of the outstanding principal of the reference obligation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path common_domain_model:impliedWritedown ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. A governmental intervention is an event resulting from an action by a governmental authority that materially impacts the reference entity's obligations, such as an interest rate reduction, principal reduction, deferral of interest or principal, change in priority ranking, or change in currency or composition of payment. ISDA 2014 Term: Governmental Intervention." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path common_domain_model:governmentalIntervention ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. Corresponds to the failure by the Reference Entity to pay an expected interest amount or the payment of an actual interest amount that is less than the expected interest amount. ISDA 2003 Term: Failure to Pay Interest." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:failureToPayInterest ],
        [ sh:class common_domain_model:Restructuring ;
            sh:description "A credit event. A restructuring is an event that materially impacts the reference entity's obligations, such as an interest rate reduction, principal reduction, deferral of interest or principal, change in priority ranking, or change in currency or composition of payment. ISDA 2003 Term: Restructuring." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:restructuring ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. Results from the fact that the rating of the reference obligation is down-graded to a distressed rating level. From a usage standpoint, this credit event is typically not applicable in case of RMBS trades." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path common_domain_model:distressedRatingsDowngrade ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. The reference entity has been dissolved or has become insolvent. It also covers events that may be a precursor to insolvency such as instigation of bankruptcy or insolvency proceedings. Sovereign trades are not subject to Bankruptcy as 'technically' a Sovereign cannot become bankrupt. ISDA 2003 Term: Bankruptcy." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:bankruptcy ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. One or more of the obligations have been declared due and payable before they would otherwise have been due and payable as a result of, or on the basis of, the occurrence of a default, event of default or other similar condition or event other than failure to pay (preferred by the market over Obligation Default, because more definitive and encompasses the definition of Obligation Default - this is more favorable to the Seller). Subject to the default requirement amount. ISDA 2003 Term: Obligation Acceleration." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path common_domain_model:obligationAcceleration ],
        [ sh:class common_domain_model:Money ;
            sh:description "In relation to certain credit events, serves as a threshold for Obligation Acceleration, Obligation Default, Repudiation/Moratorium and Restructuring. Market standard is USD 10,000,000 (JPY 1,000,000,000 for all Japanese Yen trades). This is applied on an aggregate or total basis across all Obligations of the Reference Entity. Used to prevent technical/operational errors from triggering credit events. ISDA 2003 Term: Default Requirement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path common_domain_model:defaultRequirement ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. One or more of the obligations have become capable of being declared due and payable before they would otherwise have been due and payable as a result of, or on the basis of, the occurrence of a default, event of default or other similar condition or event other than failure to pay. ISDA 2003 Term: Obligation Default." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path common_domain_model:obligationDefault ],
        [ sh:datatype xsd:boolean ;
            sh:description "A credit event. Corresponds to the failure by the Reference Entity to pay an expected principal amount or the payment of an actual principal amount that is less than the expected principal amount. ISDA 2003 Term: Failure to Pay Principal." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:failureToPayPrincipal ] ;
    sh:targetClass common_domain_model:CreditEvents .

common_domain_model:CreditRatingDebt a sh:NodeShape ;
    rdfs:comment "Specifies the credit rating debt type(s) associated with the credit rating notation and scale. When several debt types are specified, they must be qualified through an 'any' or 'all'." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:MultipleDebtTypes ;
            sh:description "Specifies if there are several debt types, alongside an 'any' or 'all' or all condition. As an example, Baa1 rating is required for any long term debt and deposit." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:debtTypes ],
        [ sh:datatype xsd:string ;
            sh:description "Specifies when there is only one debt type. FpML doesn't specify values in relation to the associated scheme, which is hence not specified as an enumeration as part of the CDM." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:debtType ] ;
    sh:targetClass common_domain_model:CreditRatingDebt .

common_domain_model:CreditSupportAmount a sh:NodeShape ;
    rdfs:comment "The total amount one counterparty must deliver to the other at any time: the combination of the Exposure to that party and the net Independent Amounts it must post, minus any agreed Threshold." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Specifies whether the meaning of credit support amount follows the pre-print definition or deviates from the standard (either based on a rating or some other methodology)." ;
            sh:in ( "Standard" "IAFloorGIA" "IAFloorGIATIA" "NonStandardRatings" "NonStandardOther" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path common_domain_model:creditSupportAmount ],
        [ sh:datatype xsd:string ;
            sh:description "The additional language that might be specified by the parties to the legal agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:additionalLanguage ] ;
    sh:targetClass common_domain_model:CreditSupportAmount .

common_domain_model:CustodyArrangements a sh:NodeShape ;
    rdfs:comment "Describes how posted collateral is held, maintained, and safeguarded by a custodian or third-party agent, in accordance with the terms of the governing agreement." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:CollateralManagementAgreement ;
            sh:description "The designated Collateral Management Agreement with respect to the elective party as the Obligee." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path common_domain_model:collateralManagementAgreement ],
        [ sh:class common_domain_model:CollateralAccessBreach ;
            sh:description "The elections specific to Collateral Access Breach language." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path common_domain_model:collateralAccessBreach ],
        [ sh:class common_domain_model:ControlAgreement ;
            sh:description "The party-specific election with respect to the control agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path common_domain_model:controlAgreement ],
        [ sh:class common_domain_model:Custodian ;
            sh:description "The custodian and segregated account details for each party to the agreement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path common_domain_model:custodian ],
        [ sh:class common_domain_model:CustodianEvent ;
            sh:description "Specifies if and until when a Custodian Event clause applies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path common_domain_model:custodianEvent ],
        [ sh:datatype xsd:string ;
            sh:description "Other Custom Provisions of Custody Arrangements." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:otherProvisions ],
        [ sh:class common_domain_model:CustodianRisk ;
            sh:description "The qualification of the Custodian Risk." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path common_domain_model:custodianRisk ],
        [ sh:datatype xsd:boolean ;
            sh:description "Control Agreement language is specified when True." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:hasControlAgreementLanguage ],
        [ sh:datatype xsd:boolean ;
            sh:description "Unless specified as True, the Control Agreement is not a Credit Support Document under the agreement with respect to a party." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:isCreditSupportDocument ] ;
    sh:targetClass common_domain_model:CustodyArrangements .

common_domain_model:DateRange a sh:NodeShape ;
    rdfs:comment "A class defining a contiguous series of calendar dates. The date range is defined as all the dates between and including the start and the end date. The start date must fall on or before the end date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type common_domain_model:businessDayConvention common_domain_model:businessCenters ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "The first date of a date range." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path common_domain_model:startDate ],
        [ sh:datatype xsd:date ;
            sh:description "The last date of a date range." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path common_domain_model:endDate ] ;
    sh:targetClass common_domain_model:DateRange .

common_domain_model:DividendPaymentDate a sh:NodeShape ;
    rdfs:comment "A class describing the date on which the dividend will be paid/received. This class is also used to specify the date on which the FX rate will be determined, when applicable." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:AdjustableOrRelativeDate ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:dividendDate ],
        [ sh:class common_domain_model:DividendDateReference ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:dividendDateReference ] ;
    sh:targetClass common_domain_model:DividendPaymentDate .

common_domain_model:Exposure a sh:NodeShape ;
    rdfs:comment "Represents the current mark to market value or IM calculation value of the trade portfolio as recorded by the principle (in base currency)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class common_domain_model:Money ;
            sh:description "Represents the aggregate value of the portfolio in base currency." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path common_domain_model:aggregateValue ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Indicates the valuation date of the exposure underlying the calculation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path common_domain_model:valuationDateTime ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Indicates the date when the exposure is calculated if different from valuation date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path common_domain_model:calculationDateTime ],
        [ sh:class common_domain_model:PortfolioState ;
            sh:description "Represents a Portfolio that describes all the positions held at a given time, in various states which can be either traded, settled, etc., with lineage information to the previous state." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path common_domain_model:tradePortfolio ] ;
    sh:targetClass common_domain_model:Exposure .

common_domain_model:FallbackRateParameters a sh:NodeShape ;
    rdfs:comment "Defines the structure needed to represent fallback rate parameters. This type is used to represent modular computed rates in interestRatePayouts." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
