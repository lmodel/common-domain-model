      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "codes",
      "definition_uri": "https://w3id.org/finos/cdm/codes",
      "description": "Code values",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_codelist",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CodeList.codes"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/codes",
      "owner": "CodeList",
      "domain_of": [
        "CodeList"
      ],
      "range": "CodeValue",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "publicationDate",
      "definition_uri": "https://w3id.org/finos/cdm/publicationDate",
      "description": "The most recent date the code list was published, e.g. 2021-10-05",
