    {
      "name": "BasketReferenceInformation",
      "definition_uri": "https://w3id.org/finos/cdm/BasketReferenceInformation",
      "description": "CDS Basket Reference Information.",
      "comments": [
        "Rosetta condition: BasketReferenceInformationChoice \u2014 required choice nthToDefault, tranche",
        "Rosetta condition: NthToDefault \u2014 if mthToDefault exists then nthToDefault exists",
        "Rosetta condition: MthToDefault \u2014 if (nthToDefault exists and mthToDefault exists) then nthToDefault < mthToDefault"
      ],
      "in_subset": [
        "cdm_product_asset"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
        "common_domain_model:BasketReferenceInformation"
      ],
      "close_mappings": [
        "fpml_5_10:BasketReferenceInformation"
      ],
      "slots": [
        "basketName",
        "basketId",
        "referencePool",
        "nthToDefault",
        "mthToDefault",
        "BasketReferenceInformation_tranche"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "nthToDefault",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "tranche",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Choice rule to represent an FpML choice construct. This choice rule is complemented by the data rule BasketReferenceInformation_nthToDefault to represent the FpML construct where there is a choice between a tranche element and a [required nthToDefault, optional mthToDefault] branch.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "mthToDefault",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "nthToDefault",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "As part of the branch of the choice node, FpML requires the nthToDefault element to be present, while the mthToDefault one is optional.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "nthToDefault",
                "required": true,
                "@type": "SlotDefinition"
              },
              {
                "name": "mthToDefault",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "FpML validation rule cd-39 - Context: BasketReferenceInformation (complex type). If nthToDefault exists, and if mthToDefault exists, then nthToDefault must be less than mthToDefault.",
          "comments": [
            "Rosetta comparison: nthToDefault < mthToDefault"
          ],
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
