                "name": "fxHaircutPercentage",
                "minimum_value": 0,
                "maximum_value": 1,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to validate that if an FX Haircut Percentage is specified it should be between 0 and less than 1.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "additionalHaircutPercentage",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
