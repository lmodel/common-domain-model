                "maximum_value": 1,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to validate that if a Valuation Percentage is specified it should be greater than or equal to 0 and less than 1.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "marginPercentage",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "marginPercentage",
                "minimum_value": 1,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to validate that if a Margin Percentage is specified it should be greater than 1.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "fxHaircutPercentage",
                "required": true,
                "@type": "SlotDefinition"
              }
