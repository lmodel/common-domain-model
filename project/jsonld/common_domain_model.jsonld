    },
    {
      "name": "creditNotations",
      "definition_uri": "https://w3id.org/finos/cdm/creditNotations",
      "description": "Specifies if several credit notations exist, alongside an 'any' or 'all' or all condition.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "slot_uri": "https://w3id.org/finos/cdm/creditNotations",
