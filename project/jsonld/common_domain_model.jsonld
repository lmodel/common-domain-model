    },
    {
      "name": "StandardizedScheduleInitialMargin",
      "definition_uri": "https://w3id.org/finos/cdm/StandardizedScheduleInitialMargin",
      "annotations": [
        {
          "tag": "rosetta_functions",
          "value": "[{\"name\":\"GetNetInitialMarginFromExposure\",\"description\":\"Computes the net initial margin, taking the gross initial margin result and the mark to market value for each trade in the portfolio.\",\"inputs\":[{\"name\":\"exposure\",\"type\":\"Exposure\",\"cardinality\":\"0..1\"}],\"output\":{\"name\":\"initialMargin\",\"type\":\"StandardizedScheduleInitialMargin\",\"cardinality\":\"0..1\"}}]",
          "@type": "Annotation"
        }
      ],
      "comments": [
        "Rosetta condition: NonNegativeNetInitialMargin \u2014 netInitialMargin -> value >= 0",
        "Rosetta func: GetNetInitialMarginFromExposure \u2014 Computes the net initial margin, taking the gross initial margin result and the mark to market value for each trade in the portfolio."
      ],
      "in_subset": [
        "cdm_margin_schedule"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_margin_schedule",
      "exact_mappings": [
        "common_domain_model:StandardizedScheduleInitialMargin"
      ],
      "slots": [
        "tradeInfo",
        "netInitialMargin"
      ],
      "slot_usage": {},
      "@type": "ClassDefinition"
    },
