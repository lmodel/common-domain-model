      ],
      "slots": [
        "callType",
        "visibilityIndicator"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "callType",
                "equals_string": "ExpectedCall",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "visibilityIndicator",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Represents a condition to ensure that a visibility indicator is specifies then the call type must be an expected call.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
