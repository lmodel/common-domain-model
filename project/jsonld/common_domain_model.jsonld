    {
      "name": "Party",
      "definition_uri": "https://w3id.org/finos/cdm/Party",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        },
        {
          "tag": "rosetta_functions",
          "value": "[{\"name\":\"ReplaceParty\",\"description\":\"Removes the old party, and adds the new party.\",\"inputs\":[{\"name\":\"parties\",\"type\":\"Party\",\"cardinality\":\"0..*\"},{\"name\":\"oldParty\",\"type\":\"Party\",\"cardinality\":\"1..1\"},{\"name\":\"newParty\",\"type\":\"Party\",\"cardinality\":\"1..1\"}],\"output\":{\"name\":\"updatedParties\",\"type\":\"Party\",\"cardinality\":\"0..*\"}}]",
          "@type": "Annotation"
        }
      ],
      "description": "A class to specify a party, without a qualification as to whether this party is a legal entity or a natural person, although the model provides the ability to associate a person (or set of persons) to a party, which use case would imply that such party would be a legal entity (even if not formally specified as such). ",
      "comments": [
        "Rosetta func: ReplaceParty \u2014 Removes the old party, and adds the new party."
      ],
      "in_subset": [
        "cdm_base_staticdata_party"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_party",
      "exact_mappings": [
        "common_domain_model:Party"
      ],
      "close_mappings": [
        "gist:Organization",
        "oscal:Party",
        "spdx:Agent"
      ],
      "related_mappings": [
        "gist:Person"
      ],
      "broad_mappings": [
        "iso29100:PrivacyStakeholder"
      ],
