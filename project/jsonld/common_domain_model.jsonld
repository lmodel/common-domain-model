        "materialSubsidiaryTerms",
        "otherSpecifiedEntityTerms"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "specifiedEntityTerms",
                "equals_string": "NamedSpecifiedEntity",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "specifiedEntity",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A validation rule to ensure that a SpecifiedEntity is specified when required.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "specifiedEntityTerms",
                "equals_string": "MaterialSubsidiary",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "materialSubsidiaryTerms",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A validation rule to ensure that Material Subsidiary terms are specified when required.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "specifiedEntityTerms",
                "equals_string": "OtherSpecifiedEntity",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "otherSpecifiedEntityTerms",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A validation rule to ensure that non standard Specified Entity terms are provided when required.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
