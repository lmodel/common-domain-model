    {
      "name": "finalFixingDate",
      "definition_uri": "https://w3id.org/finos/cdm/finalFixingDate",
      "description": "This attribute is not part of the FpML ResetDate, and has been added as part of the CDM to support the credit derivatives final fixing date.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "slot_uri": "https://w3id.org/finos/cdm/finalFixingDate",
      "owner": "ResetDates",
