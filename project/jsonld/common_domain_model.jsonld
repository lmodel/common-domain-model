        "marginPercentage",
        "CollateralValuationTreatment_fxHaircutPercentage",
        "CollateralValuationTreatment_additionalHaircutPercentage"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
