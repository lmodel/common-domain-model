    {
      "name": "stepValue",
      "definition_uri": "https://w3id.org/finos/cdm/stepValue",
      "description": "The non-negative rate or amount which becomes effective on the associated stepDate. A rate of 5% would be represented as 0.05.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "slot_uri": "https://w3id.org/finos/cdm/stepValue",
      "owner": "NonNegativeStep",
