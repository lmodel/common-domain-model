    {
      "name": "EligibilityToHoldCollateral",
      "definition_uri": "https://w3id.org/finos/cdm/EligibilityToHoldCollateral",
      "description": "Specifies the conditions under which a party and its custodian(s) are entitled to hold collateral.",
      "notes": [
        "ISDA CSA_VM_2016 paragraph \"13\" clause \" (h)(i)\" name \"Eligibility to Hold Posted Collateral (VM) Custodians (VM)\""
      ],
      "comments": [
        "Rosetta condition: Custodian \u2014 if custodianEligibility = True then initialCustodian exists else initialCustodian is absent and custodianCondition is absent"
      ],
      "in_subset": [
        "cdm_legaldocumentation_csa"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_csa",
      "see_also": [
        "isda:CSA_VM_2016"
      ],
      "exact_mappings": [
        "common_domain_model:EligibilityToHoldCollateral"
      ],
      "slots": [
        "custodianEligibility",
        "initialCustodian",
        "criteria",
        "eligibleCountry",
        "custodianCondition"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "custodianEligibility",
                "equals_string": "True",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "initialCustodian",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A condition to ensure that if a Custodian is eligible to hold collateral, the Initial Custodian must be specified.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
