    },
    {
      "name": "additionalDividends",
      "definition_uri": "https://w3id.org/finos/cdm/additionalDividends",
      "description": "If present and true, then additional dividends are applicable.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "slot_uri": "https://w3id.org/finos/cdm/additionalDividends",
      "owner": "DividendApplicability",
      "domain_of": [
        "DividendApplicability"
      ],
