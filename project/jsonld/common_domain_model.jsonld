        "QuantitySchedule",
        "CSAValuationDate"
      ],
      "range": "Frequency",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "stepDate",
      "definition_uri": "https://w3id.org/finos/cdm/stepDate",
      "description": "The date on which the associated stepValue becomes effective. This day may be subject to adjustment in accordance with a business day convention.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "slot_uri": "https://w3id.org/finos/cdm/stepDate",
