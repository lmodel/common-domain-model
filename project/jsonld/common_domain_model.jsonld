      "definition_uri": "https://w3id.org/finos/cdm/fxLinkedNotionalSchedule",
      "description": "Multiplier specified as an FX-linked schedule, e.g. for a resetting cross-currency swap..",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "slot_uri": "https://w3id.org/finos/cdm/fxLinkedNotionalSchedule",
      "owner": "QuantityMultiplier",
