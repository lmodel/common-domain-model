    {
      "name": "BusinessCenters",
      "definition_uri": "https://w3id.org/finos/cdm/BusinessCenters",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        },
        {
          "tag": "rosetta_functions",
          "value": "[{\"name\":\"GetAllBusinessCenters\",\"description\":\"Returns a merged list of BusinessCenter codes for the supplied BusinessCenters.\",\"inputs\":[{\"name\":\"businessCenters\",\"type\":\"BusinessCenters\",\"cardinality\":\"1..1\"}],\"output\":{\"name\":\"businessCenterCodes\",\"type\":\"BusinessCenter\",\"cardinality\":\"0..*\"}}]",
          "@type": "Annotation"
        }
      ],
      "description": "A class for specifying the business day calendar location used in determining whether a day is a business day or not, either by specifying this business center by reference to an enumerated list that is maintained by the FpML standard, or by reference to such specification when it exists elsewhere as part of the instance document. This class corresponds to the FpML BusinessCentersOrReference.model.",
      "comments": [
        "Rosetta condition: BusinessCentersChoice \u2014 required choice businessCenter, businessCentersReference, commodityBusinessCalendar",
        "Rosetta func: GetAllBusinessCenters \u2014 Returns a merged list of BusinessCenter codes for the supplied BusinessCenters."
      ],
      "in_subset": [
        "cdm_base_datetime"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_datetime",
      "exact_mappings": [
        "common_domain_model:BusinessCenters"
      ],
      "close_mappings": [
        "fpml_5_10:BusinessCenters"
      ],
      "slots": [
        "businessCenter",
        "commodityBusinessCalendar",
        "businessCentersReference"
      ],
      "slot_usage": {},
      "rules": [
