    {
      "name": "scale",
      "definition_uri": "https://w3id.org/finos/cdm/scale",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Specifies the credit rating scale, with a typical distinction between short term, long term. FpML doesn't specify a default scheme, which is hence not specified as an enumeration as part of the CDM.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "slot_uri": "https://w3id.org/finos/cdm/scale",
      "owner": "CreditNotation",
