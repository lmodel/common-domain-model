    },
    {
      "name": "sizeInBytes",
      "definition_uri": "https://w3id.org/finos/cdm/sizeInBytes",
      "description": "Indicates the size of the resource in bytes. It could be used by the end user to estimate the download time and storage needs.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/sizeInBytes",
      "owner": "Resource",
      "domain_of": [
