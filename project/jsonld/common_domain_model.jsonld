      "@type": "SlotDefinition"
    },
    {
      "name": "lengthValue",
      "definition_uri": "https://w3id.org/finos/cdm/lengthValue",
      "description": "The length value of the resource.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/lengthValue",
      "owner": "ResourceLength",
      "domain_of": [
        "ResourceLength"
      ],
      "range": "decimal",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "agreement",
      "definition_uri": "https://w3id.org/finos/cdm/agreement",
