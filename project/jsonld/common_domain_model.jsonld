      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Identifies the form of applicable matrix.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/matrixType",
      "owner": "ContractualMatrix",
      "domain_of": [
        "ContractualMatrix"
      ],
      "range": "MatrixTypeEnum",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "matrixTerm",
      "definition_uri": "https://w3id.org/finos/cdm/matrixTerm",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Defines any applicable key into the relevant matrix. For example, the Transaction Type would be the single term required for the Credit Derivatives Physical Settlement Matrix. This element should be omitted in the case of the 2000 ISDA Definitions Settlement Matrix for Early Termination and Swaptions.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/matrixTerm",
      "owner": "ContractualMatrix",
      "domain_of": [
        "ContractualMatrix"
      ],
      "range": "MatrixTermEnum",
      "@type": "SlotDefinition"
    },
