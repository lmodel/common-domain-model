      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "rateSpecification",
      "definition_uri": "https://w3id.org/finos/cdm/rateSpecification",
      "description": "The specification of the rate value(s) applicable to the contract using either a floating rate calculation, a single fixed rate, a fixed rate schedule, or an inflation rate calculation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/rateSpecification",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "RateSpecification",
      "inlined": true,
      "inlined_as_list": true,
      "any_of": [
        {
          "range": "FixedRateSpecification",
          "@type": "AnonymousSlotExpression"
        },
        {
          "range": "FloatingRateSpecification",
          "@type": "AnonymousSlotExpression"
        },
        {
          "range": "InflationRateSpecification",
          "@type": "AnonymousSlotExpression"
        }
      ],
      "@type": "SlotDefinition"
    },
    {
      "name": "paymentDelay",
      "definition_uri": "https://w3id.org/finos/cdm/paymentDelay",
      "description": "Applicable to CDS on MBS to specify whether payment delays are applicable to the fixed Amount. RMBS typically have a payment delay of 5 days between the coupon date of the reference obligation and the payment date of the synthetic swap. CMBS do not, on the other hand, with both payment dates being on the 25th of each month.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/paymentDelay",
      "owner": "SettlementDate",
      "domain_of": [
        "InterestRatePayout",
        "SettlementDate"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "resetDates",
      "definition_uri": "https://w3id.org/finos/cdm/resetDates",
      "description": "The reset dates schedule, i.e. the dates on which the new observed index value is applied for each period and the interest rate hence begins to accrue.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/resetDates",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "ResetDates",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "discountingMethod",
      "definition_uri": "https://w3id.org/finos/cdm/discountingMethod",
      "description": "The parameters specifying any discounting conventions that may apply. This element must only be included if discounting applies.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/discountingMethod",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "DiscountingMethod",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "compoundingMethod",
      "definition_uri": "https://w3id.org/finos/cdm/compoundingMethod",
      "description": "If one or more calculation period contributes to a single payment amount this element specifies whether compounding is applicable and, if so, what compounding method is to be used. This element must only be included when more than one calculation period contributes to a single payment amount.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/compoundingMethod",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "CompoundingMethodEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "cashflowRepresentation",
      "definition_uri": "https://w3id.org/finos/cdm/cashflowRepresentation",
      "description": "The cashflow representation of the swap stream.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/cashflowRepresentation",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "CashflowRepresentation",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "stubPeriod",
      "definition_uri": "https://w3id.org/finos/cdm/stubPeriod",
      "description": "The stub calculation period amount parameters. This element must only be included if there is an initial or final stub calculation period. Even then, it must only be included if either the stub references a different floating rate tenor to the regular calculation periods, or if the stub is calculated as a linear interpolation of two different floating rate tenors, or if a specific stub rate or stub amount has been negotiated.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/stubPeriod",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "StubPeriod",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "bondReference",
      "definition_uri": "https://w3id.org/finos/cdm/bondReference",
      "description": "Reference to a bond underlier to represent an asset swap or Condition Precedent Bond.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/bondReference",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "BondReference",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "floatingAmount",
      "definition_uri": "https://w3id.org/finos/cdm/floatingAmount",
      "description": "Floating Amount Calculation",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/floatingAmount",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "spreadCalculationMethod",
      "definition_uri": "https://w3id.org/finos/cdm/spreadCalculationMethod",
      "description": "Method by which spread is calculated. For example on an asset swap: 'ParPar' or 'Proceeds' may be the method indicated.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/spreadCalculationMethod",
      "owner": "InterestRatePayout",
      "domain_of": [
        "InterestRatePayout"
      ],
      "range": "SpreadCalculationMethodEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "totalRatio",
      "definition_uri": "https://w3id.org/finos/cdm/totalRatio",
      "description": "Specifies the total actual dividend payout ratio associated with the equity underlier. A ratio of 90% should be expressed at 0.90.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/totalRatio",
      "owner": "DividendPayoutRatio",
      "domain_of": [
        "DividendPayoutRatio"
      ],
      "range": "decimal",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "cashRatio",
      "definition_uri": "https://w3id.org/finos/cdm/cashRatio",
      "description": "Specifies the cash actual dividend payout ratio associated with the equity underlier. A ratio of 90% should be expressed at 0.90.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/cashRatio",
      "owner": "DividendPayoutRatio",
      "domain_of": [
        "DividendPayoutRatio"
      ],
      "range": "decimal",
      "@type": "SlotDefinition"
    },
    {
      "name": "nonCashRatio",
      "definition_uri": "https://w3id.org/finos/cdm/nonCashRatio",
      "description": "Specifies the non cash actual dividend payout ratio associated with the equity underlier. A ratio of 90% should be expressed at 0.90.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/nonCashRatio",
      "owner": "DividendPayoutRatio",
      "domain_of": [
        "DividendPayoutRatio"
      ],
      "range": "decimal",
      "@type": "SlotDefinition"
    },
    {
      "name": "interestShortfallReimbursement",
      "definition_uri": "https://w3id.org/finos/cdm/interestShortfallReimbursement",
      "description": "An additional Fixed Payment Event. Corresponds to the payment by or on behalf of the Issuer of an actual interest amount in respect to the reference obligation that is greater than the expected interest amount. ISDA 2003 Term: Interest Shortfall Reimbursement.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AdditionalFixedPayments.interestShortfallReimbursement"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/interestShortfallReimbursement",
      "owner": "AdditionalFixedPayments",
      "domain_of": [
        "AdditionalFixedPayments"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "principalShortfallReimbursement",
      "definition_uri": "https://w3id.org/finos/cdm/principalShortfallReimbursement",
      "description": "An additional Fixed Payment Event. Corresponds to the payment by or on behalf of the Issuer of an actual principal amount in respect to the reference obligation that is greater than the expected principal amount. ISDA 2003 Term: Principal Shortfall Reimbursement.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AdditionalFixedPayments.principalShortfallReimbursement"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/principalShortfallReimbursement",
      "owner": "AdditionalFixedPayments",
      "domain_of": [
        "AdditionalFixedPayments"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "writedownReimbursement",
      "definition_uri": "https://w3id.org/finos/cdm/writedownReimbursement",
      "description": "An Additional Fixed Payment. Corresponds to the payment by or on behalf of the issuer of an amount in respect to the reference obligation in reduction of the prior writedowns. ISDA 2003 Term: Writedown Reimbursement.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AdditionalFixedPayments.writedownReimbursement"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/writedownReimbursement",
      "owner": "AdditionalFixedPayments",
      "domain_of": [
        "AdditionalFixedPayments"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "basketName",
      "definition_uri": "https://w3id.org/finos/cdm/basketName",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "The name of the basket expressed as a free format string. FpML does not define usage rules for this element.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#BasketReferenceInformation.basketName"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/basketName",
      "owner": "BasketReferenceInformation",
      "domain_of": [
        "BasketReferenceInformation"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "basketId",
      "definition_uri": "https://w3id.org/finos/cdm/basketId",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A CDS basket identifier.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#BasketReferenceInformation.basketId"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/basketId",
      "owner": "BasketReferenceInformation",
      "domain_of": [
        "BasketReferenceInformation"
      ],
      "range": "string",
      "multivalued": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "referencePool",
      "definition_uri": "https://w3id.org/finos/cdm/referencePool",
      "description": "This element contains all the reference pool items to define the reference entity and reference obligation(s) in the basket.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#BasketReferenceInformation.referencePool"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/referencePool",
      "owner": "BasketReferenceInformation",
      "domain_of": [
        "BasketReferenceInformation"
      ],
      "range": "ReferencePool",
      "required": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "nthToDefault",
      "definition_uri": "https://w3id.org/finos/cdm/nthToDefault",
      "description": "N th reference obligation to default triggers payout.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#BasketReferenceInformation.nthToDefault"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/nthToDefault",
      "owner": "BasketReferenceInformation",
      "domain_of": [
        "BasketReferenceInformation"
      ],
      "range": "integer",
      "@type": "SlotDefinition"
    },
    {
      "name": "mthToDefault",
      "definition_uri": "https://w3id.org/finos/cdm/mthToDefault",
      "description": "M th reference obligation to default to allow representation of N th to M th defaults.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#BasketReferenceInformation.mthToDefault"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/mthToDefault",
      "owner": "BasketReferenceInformation",
      "domain_of": [
        "BasketReferenceInformation"
      ],
      "range": "integer",
      "@type": "SlotDefinition"
    },
    {
      "name": "interestShortfall",
      "definition_uri": "https://w3id.org/finos/cdm/interestShortfall",
      "description": "A floating rate payment event. With respect to any Reference Obligation Payment Date, either (a) the non-payment of an Expected Interest Amount or (b) the payment of an Actual Interest Amount that is less than the Expected Interest Amount. ISDA 2003 Term: Interest Shortfall.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/interestShortfall",
      "owner": "FloatingAmountEvents",
      "domain_of": [
        "FloatingAmountEvents"
      ],
      "range": "InterestShortFall",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "floatingAmountProvisions",
      "definition_uri": "https://w3id.org/finos/cdm/floatingAmountProvisions",
      "description": "Specifies the floating amount provisions associated with the floatingAmountEvents.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/floatingAmountProvisions",
      "owner": "FloatingAmountEvents",
      "domain_of": [
        "FloatingAmountEvents"
      ],
      "range": "FloatingAmountProvisions",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "additionalFixedPayments",
      "definition_uri": "https://w3id.org/finos/cdm/additionalFixedPayments",
      "description": "Specifies the events that will give rise to the payment additional fixed payments.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/additionalFixedPayments",
      "owner": "FloatingAmountEvents",
      "domain_of": [
        "FloatingAmountEvents"
      ],
      "range": "AdditionalFixedPayments",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "wacCapInterestProvision",
      "definition_uri": "https://w3id.org/finos/cdm/wacCapInterestProvision",
      "description": "As specified by the ISDA Supplement for use with trades on mortgage-backed securities, 'WAC Cap' means a weighted average coupon or weighted average rate cap provision (however defined in the Underlying Instruments) of the Underlying Instruments that limits, increases or decreases the interest rate or interest entitlement, as set out in the Underlying Instruments on the Effective Date without regard to any subsequent amendment The presence of the element with value set to 'true' signifies that the provision is applicable. From a usage standpoint, this provision is typically applicable in the case of CMBS and not applicable in case of RMBS trades.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/wacCapInterestProvision",
      "owner": "FloatingAmountProvisions",
      "domain_of": [
        "FloatingAmountProvisions"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "stepUpProvision",
      "definition_uri": "https://w3id.org/finos/cdm/stepUpProvision",
      "description": "As specified by the ISDA Standard Terms Supplement for use with trades on mortgage-backed securities. The presence of the element with value set to 'true' signifies that the provision is applicable. If applicable, the applicable step-up terms are specified as part of that ISDA Standard Terms Supplement. From a usage standpoint, this provision is typically applicable in the case of RMBS and not applicable in case of CMBS trades.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/stepUpProvision",
      "owner": "FloatingAmountProvisions",
      "domain_of": [
        "FloatingAmountProvisions"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "interestShortfallCap",
      "definition_uri": "https://w3id.org/finos/cdm/interestShortfallCap",
      "description": "Specifies the nature of the interest Shortfall cap (i.e. Fixed Cap or Variable Cap) in the case where it is applicable. ISDA 2003 Term: Interest Shortfall Cap.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/interestShortfallCap",
      "owner": "InterestShortFall",
      "domain_of": [
        "InterestShortFall"
      ],
      "range": "InterestShortfallCapEnum",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "compounding",
      "definition_uri": "https://w3id.org/finos/cdm/compounding",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/compounding",
      "owner": "InterestShortFall",
      "domain_of": [
        "InterestShortFall"
      ],
      "range": "boolean",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "rateSource",
      "definition_uri": "https://w3id.org/finos/cdm/rateSource",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "The rate source in the case of a variable cap.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/rateSource",
      "owner": "InterestShortFall",
      "domain_of": [
        "InterestShortFall"
      ],
      "range": "FloatingRateIndexEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "floatingAmountEvents",
      "definition_uri": "https://w3id.org/finos/cdm/floatingAmountEvents",
      "description": "This element contains the ISDA terms relating to the floating rate payment events and the implied additional fixed payments, applicable to the credit derivatives transactions on mortgage-backed securities with pay-as-you-go or physical settlement.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/floatingAmountEvents",
      "owner": "ProtectionTerms",
      "domain_of": [
        "ProtectionTerms"
      ],
      "range": "FloatingAmountEvents",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "referenceEntity",
      "definition_uri": "https://w3id.org/finos/cdm/referenceEntity",
      "description": "The corporate or sovereign entity which is subject to the swap transaction and any successor that assumes all or substantially all of its contractual and other obligations. Reference Entities cannot be senior or subordinated. It is the obligations of the Reference Entities that can be senior or subordinated. ISDA 2014 Credit definitions article II section 2.1: `Reference Entity` means the entity specified as such in the related Confirmation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/referenceEntity",
      "owner": "ReferencePair",
      "domain_of": [
        "ReferenceInformation",
        "ReferencePair"
      ],
      "range": "LegalEntity",
      "required": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "referenceObligation",
      "definition_uri": "https://w3id.org/finos/cdm/referenceObligation",
      "description": "The Reference Obligation is a financial instrument that is either issued or guaranteed by the reference entity. It serves to clarify the precise reference entity protection is being offered upon, and its legal position with regard to other related firms (parents/subsidiaries). Furthermore the Reference Obligation is ALWAYS deliverable and establishes the Pari Passu ranking (as the deliverable bonds must rank equal to the reference obligation). ISDA 2003 Term: Reference Obligation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/referenceObligation",
      "owner": "ReferencePair",
      "domain_of": [
        "ReferenceInformation",
        "ReferencePair"
      ],
      "range": "ReferenceObligation",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "noReferenceObligation",
      "definition_uri": "https://w3id.org/finos/cdm/noReferenceObligation",
      "description": "Used to indicate that there is no Reference Obligation associated with this Credit Default Swap and that there will never be one.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/noReferenceObligation",
      "owner": "ReferencePair",
      "domain_of": [
        "ReferenceInformation",
        "ReferencePair"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "unknownReferenceObligation",
      "definition_uri": "https://w3id.org/finos/cdm/unknownReferenceObligation",
      "description": "Used to indicate that the Reference obligation associated with the Credit Default Swap is currently not known. This is not valid for Legal Confirmation purposes, but is valid for earlier stages in the trade life cycle (e.g. Broker Confirmation).",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/unknownReferenceObligation",
      "owner": "ReferenceInformation",
      "domain_of": [
        "ReferenceInformation"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "allGuarantees",
      "definition_uri": "https://w3id.org/finos/cdm/allGuarantees",
      "description": "Indicates whether an obligation of the Reference Entity, guaranteed by the Reference Entity on behalf of a non-Affiliate, is to be considered an Obligation for the purpose of the transaction. It will be considered an obligation if allGuarantees is applicable (true) and not if allGuarantees is inapplicable (false). ISDA 2003 Term: All Guarantees.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/allGuarantees",
      "owner": "ReferenceInformation",
      "domain_of": [
        "ReferenceInformation"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "referencePrice",
      "definition_uri": "https://w3id.org/finos/cdm/referencePrice",
      "description": "Used to determine (a) for physically settled trades, the Physical Settlement Amount, which equals the Floating Rate Payer Calculation Amount times the Reference Price and (b) for cash settled trades, the Cash Settlement Amount, which equals the greater of (i) the difference between the Reference Price and the Final Price and (ii) zero. ISDA 2003 Term: Reference Price.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/referencePrice",
      "owner": "ReferenceInformation",
      "domain_of": [
        "ReferenceInformation"
      ],
      "range": "Price",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "referencePolicy",
      "definition_uri": "https://w3id.org/finos/cdm/referencePolicy",
      "description": "Applicable to the transactions on mortgage-backed security, which can make use of a reference policy. Presence of the element with value set to 'true' indicates that the reference policy is applicable; absence implies that it is not.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/referencePolicy",
      "owner": "ReferenceInformation",
      "domain_of": [
        "ReferenceInformation"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "securedList",
      "definition_uri": "https://w3id.org/finos/cdm/securedList",
      "description": "With respect to any day, the list of Syndicated Secured Obligations of the Designated Priority of the Reference Entity published by Markit Group Limited or any successor thereto appointed by the Specified Dealers (the 'Secured List Publisher') on or most recently before such day, which list is currently available at [http://www.markit.com]. ISDA 2003 Term: Relevant Secured List.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/securedList",
      "owner": "ReferenceInformation",
      "domain_of": [
        "ReferenceInformation"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "loan",
      "definition_uri": "https://w3id.org/finos/cdm/loan",
      "description": "Identifies the underlying asset when it is a loan.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/loan",
      "owner": "ReferenceObligation",
      "domain_of": [
        "ReferenceObligation"
      ],
      "range": "Loan",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "primaryObligor",
      "definition_uri": "https://w3id.org/finos/cdm/primaryObligor",
      "description": "The entity primarily responsible for repaying debt to a creditor as a result of borrowing or issuing bonds. ISDA 2003 Term: Primary Obligor.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/primaryObligor",
      "owner": "ReferenceObligation",
