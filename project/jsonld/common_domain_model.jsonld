    {
      "name": "ContractualDefinitionsEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ContractualDefinitionsEnum",
      "description": "The enumerated values to specify a set of standard contract definitions relevant to the transaction.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "permissible_values": [
        {
          "text": "ISDA1991InterestRate",
          "description": "ISDA 1991 Interest Rate Definitions"
        },
        {
          "text": "ISDA1993CommodityDerivatives",
          "description": "ISDA 1993 Commodity Derivatives Definitions"
        },
        {
          "text": "ISDA1996EquityDerivatives",
          "description": "ISDA 1996 Equity Derivatives Definitions"
        },
        {
          "text": "ISDA1997Bullion",
          "description": "ISDA 1997 Bullion Definitions"
        },
        {
          "text": "ISDA1997GovernmentBondOption",
          "description": "ISDA 1997 Government Bond Option Definitions"
        },
        {
          "text": "ISDA1998FxAndCurrencyOption",
          "description": "ISDA 1998 FX and Currency Option Definitions"
        },
        {
          "text": "ISDA1999CreditDerivatives",
          "description": "ISDA 1999 Credit Derivatives Definitions"
        },
        {
          "text": "ISDA2000",
          "description": "ISDA 2000 Definitions"
        },
        {
          "text": "ISDA2002EquityDerivatives",
          "description": "ISDA 2002 Equity Derivatives Definitions"
        },
        {
          "text": "ISDA2003CreditDerivatives",
          "description": "ISDA 2003 Credit Derivatives Definitions"
        },
        {
          "text": "ISDA2004Novation",
          "description": "ISDA 2004 Novation Definitions"
        },
        {
          "text": "ISDA2005Commodity",
          "description": "ISDA 2005 Commodity Definitions"
        },
        {
          "text": "ISDA2006",
          "description": "ISDA 2006 Definitions"
        },
        {
          "text": "ISDA2006InflationDerivatives",
          "description": "ISDA 2006 Inflation Derivatives Definitions"
        },
        {
          "text": "ISDA2008InflationDerivatives",
          "description": "ISDA 2008 Inflation Derivatives Definitions"
        },
        {
          "text": "ISDA2011EquityDerivatives",
          "description": "ISDA 2011 Equity Derivatives Definitions"
        },
        {
          "text": "ISDA2014CreditDerivatives",
          "description": "ISDA 2014 Credit Derivatives Definitions"
        },
        {
          "text": "ISDA2021InterestRateDerivatives",
          "description": "ISDA 2021 Interest Rate Derivatives Definitions"
        },
        {
          "text": "ISDA2022VerifiedCarbonCredit",
          "description": "ISDA 2022 Verified Carbon Credit Transactions Definitions"
        },
