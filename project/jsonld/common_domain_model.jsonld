      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "standardLanguage",
                "equals_string": "False",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "numberOfOriginals",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to enforce that the number of original documents should only be specified when standard execution language is used.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "standardLanguage",
                "equals_string": "False",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "otherLanguage",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to enforce that bespoke execution language must be included if non-standard execution language is specified.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
