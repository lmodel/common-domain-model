      "name": "attachment",
      "definition_uri": "https://w3id.org/finos/cdm/attachment",
      "description": "A human readable document, for example a confirmation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/attachment",
      "owner": "LegalAgreementBase",
      "domain_of": [
        "LegalAgreementBase"
      ],
      "range": "Resource",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "agreementName",
      "definition_uri": "https://w3id.org/finos/cdm/agreementName",
      "description": "The legal agreement name, e.g. Credit Support Annex for Variation Margin.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "related_mappings": [
        "https://www.icmagroup.org/market-practice-and-regulatory-policy/AM_1_0#documentName"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/agreementName",
      "owner": "LegalAgreementIdentification",
      "domain_of": [
        "LegalAgreementIdentification"
      ],
      "range": "AgreementName",
      "required": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "publisher",
      "definition_uri": "https://w3id.org/finos/cdm/publisher",
      "description": "The legal agreement publisher, e.g. ISDA.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "related_mappings": [
        "https://www.icmagroup.org/market-practice-and-regulatory-policy/AM_1_0#publisher"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/publisher",
      "owner": "LegalAgreementIdentification",
      "domain_of": [
        "LegalAgreementIdentification"
      ],
      "range": "LegalAgreementPublisherEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "vintage",
      "definition_uri": "https://w3id.org/finos/cdm/vintage",
      "description": "In the case where successive definitions of the legal agreement have been developed, the vintage identification. This is typically (but not necessarily) done by referencing the year, e.g. 2013 in the case of the ISDA 2013 Standard Credit Support Annex.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "related_mappings": [
        "https://www.icmagroup.org/market-practice-and-regulatory-policy/AM_1_0#csaVersion"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/vintage",
      "owner": "LegalAgreementIdentification",
      "domain_of": [
        "LegalAgreementIdentification"
      ],
      "range": "integer",
      "@type": "SlotDefinition"
    },
    {
      "name": "agreementType",
      "definition_uri": "https://w3id.org/finos/cdm/agreementType",
      "description": "Specification of the legal agreement type.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AgreementName.agreementType"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/agreementType",
      "owner": "AgreementName",
      "domain_of": [
        "AgreementName"
      ],
      "range": "LegalAgreementTypeEnum",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "creditSupportAgreementType",
      "definition_uri": "https://w3id.org/finos/cdm/creditSupportAgreementType",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Specification of the credit support agreement type.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AgreementName.creditSupportAgreementType"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/creditSupportAgreementType",
      "owner": "AgreementName",
      "domain_of": [
        "AgreementName"
      ],
      "range": "CreditSupportAgreementTypeEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "creditSupportAgreementMarginType",
      "definition_uri": "https://w3id.org/finos/cdm/creditSupportAgreementMarginType",
      "description": "specifies the type of margin for which a legal agreement is named.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AgreementName.creditSupportAgreementMarginType"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/creditSupportAgreementMarginType",
      "owner": "AgreementName",
      "domain_of": [
        "AgreementName"
      ],
      "range": "CollateralMarginTypeEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "contractualDefinitionsType",
      "definition_uri": "https://w3id.org/finos/cdm/contractualDefinitionsType",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "The definitions such as those published by ISDA that will define the terms of the trade.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AgreementName.contractualDefinitionsType"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/contractualDefinitionsType",
      "owner": "AgreementName",
      "domain_of": [
        "AgreementName"
      ],
      "range": "ContractualDefinitionsEnum",
      "multivalued": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "contractualTermsSupplement",
      "definition_uri": "https://w3id.org/finos/cdm/contractualTermsSupplement",
      "description": "A contractual supplement (such as those published by ISDA) that will apply to the trade.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AgreementName.contractualTermsSupplement"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/contractualTermsSupplement",
      "owner": "AgreementName",
      "domain_of": [
        "AgreementName"
      ],
      "range": "ContractualTermsSupplement",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "contractualMatrix",
      "definition_uri": "https://w3id.org/finos/cdm/contractualMatrix",
      "description": "A reference to a contractual matrix of elected terms/values (such as those published by ISDA) that shall be deemed to apply to the trade. The applicable matrix is identified by reference to a name and optionally a publication date. Depending on the structure of the matrix, an additional term (specified in the matrixTerm element) may be required to further identify a subset of applicable terms/values within the matrix.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AgreementName.contractualMatrix"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/contractualMatrix",
      "owner": "AgreementName",
      "domain_of": [
        "AgreementName"
      ],
      "range": "ContractualMatrix",
