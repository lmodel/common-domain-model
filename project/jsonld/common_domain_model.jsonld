      ],
      "range": "CreditRatingCreditWatchEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "creditNotation",
      "definition_uri": "https://w3id.org/finos/cdm/creditNotation",
      "description": "Specifies only one credit notation is determined.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "slot_uri": "https://w3id.org/finos/cdm/creditNotation",
      "owner": "AgencyRatingCriteria",
