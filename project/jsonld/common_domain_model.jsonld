      "name": "contractualParty",
      "definition_uri": "https://w3id.org/finos/cdm/contractualParty",
      "annotations": [
        {
          "tag": "metadata_reference",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "The two contractual parties to the legal agreement, which reference information is positioned as part of the partyInformation attribute.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/contractualParty",
      "owner": "LegalAgreementBase",
      "domain_of": [
        "LegalAgreementBase"
      ],
      "range": "Party",
      "required": true,
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "otherParty",
      "definition_uri": "https://w3id.org/finos/cdm/otherParty",
      "description": "The role(s) that other party(ies) may have in relation to the legal agreement, further to the contractual parties.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/otherParty",
      "owner": "MasterAgreementClauseVariant",
      "domain_of": [
        "LegalAgreementBase",
        "MasterAgreementClause",
        "MasterAgreementClauseVariant"
      ],
      "range": "PartyRole",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
