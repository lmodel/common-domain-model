          "meaning": "http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#RatingAndInvestmentInformation"
        },
        {
          "text": "StandardAndPoors",
          "description": "Standard And Poor's",
          "meaning": "http://www.fpml.org/coding-scheme/credit-rating-agency-1-0#StandardAndPoors"
        }
      ]
    },
    {
      "name": "CreditRatingOutlookEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CreditRatingOutlookEnum",
      "description": "Represents the enumerated values to specify the credit rating outlook.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "permissible_values": [
        {
          "text": "Positive",
          "description": "Denotes a rating may be raised."
        },
        {
          "text": "Negative",
          "description": "Denotes a rating may be lowered."
        },
        {
          "text": "Stable",
          "description": "Denotes a rating is not likely to change."
        },
        {
          "text": "Developing",
          "description": "Denotes a rating may be raised, lowered, or affirmed."
        }
      ]
    },
    {
      "name": "CreditRatingCreditWatchEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CreditRatingCreditWatchEnum",
      "description": "Represents the enumerated values to specify the credit watch rating.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "permissible_values": [
