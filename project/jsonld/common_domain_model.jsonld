                    "name": "notificationTime",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "customNotification",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "The Notification Time is specified either as a time that is qualified by a standard business center or as a custom election.",
