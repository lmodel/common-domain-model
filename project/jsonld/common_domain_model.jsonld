                "@type": "SlotDefinition"
              },
              {
                "name": "datedValue",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "The amount must exist when the price represents a single value, and steps must be absent.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
