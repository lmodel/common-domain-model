    {
      "name": "ExerciseTerms",
      "definition_uri": "https://w3id.org/finos/cdm/ExerciseTerms",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A class defining the exercise period for an option together with any rules governing the notional amount of the underlying which can be exercised on any given exercise date and any associated exercise fees.",
      "comments": [
        "Rosetta condition: ExerciseDateExpirationDateChoice \u2014 required choice exerciseDates, expirationDate",
        "Rosetta condition: CommencementAndExpirationDate \u2014 if commencementDate exists then expirationDate exists",
        "Rosetta condition: AmericanExercise \u2014 if style = OptionExerciseStyleEnum -> American then commencementDate exists and exerciseFee is absent and partialExercise is absent and expirationDate count = 1",
        "Rosetta condition: EuropeanExercise \u2014 if style = OptionExerciseStyleEnum -> European then expirationDate exists and exerciseFeeSchedule is absent and multipleExercise is absent and latestExerciseTime is absent and commencementDate is absent",
        "Rosetta condition: BermudaExercise \u2014 if style = OptionExerciseStyleEnum -> Bermuda then exerciseDates exists and earliestExerciseTime exists and partialExercise is absent and exerciseFee is absent",
        "Rosetta condition: ExpirationTimeChoice \u2014 (if expirationTime exists then expirationTimeType = ExpirationTimeTypeEnum -> SpecificTime and if expirationTimeType = ExpirationTimeTypeEnum -> SpecificTime then expirationTime exists)"
      ],
      "in_subset": [
        "cdm_product_template"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "exact_mappings": [
        "common_domain_model:ExerciseTerms"
      ],
      "slots": [
        "style",
        "commencementDate",
        "exerciseDates",
        "ExerciseTerms_expirationDate",
        "relevantUnderlyingDate",
        "earliestExerciseTime",
        "latestExerciseTime",
        "expirationTime",
        "expirationTimeType",
        "multipleExercise",
        "exerciseFeeSchedule",
        "exerciseProcedure",
        "exerciseFee",
        "partialExercise"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "exerciseDates",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "expirationDate",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Required choice rule between exercise dates and expiration date. The exerciseDates field can be used to extract the expiration date of a bermuda option, while the expirationDate field refers to the expiration date of an american or european option.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "commencementDate",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "expirationDate",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Condition to check that expiration date is present when commencement date is present.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "style",
                "equals_string": "European",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "expirationDate",
                "required": true,
                "@type": "SlotDefinition"
              },
              {
                "name": "exerciseFeeSchedule",
                "@type": "SlotDefinition"
              },
              {
                "name": "multipleExercise",
                "@type": "SlotDefinition"
              },
              {
                "name": "latestExerciseTime",
                "@type": "SlotDefinition"
              },
              {
                "name": "commencementDate",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Condition to check that only fields expected for a european option are present.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "style",
                "equals_string": "Bermuda",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "exerciseDates",
                "required": true,
                "@type": "SlotDefinition"
              },
              {
                "name": "earliestExerciseTime",
                "required": true,
                "@type": "SlotDefinition"
              },
              {
                "name": "partialExercise",
                "@type": "SlotDefinition"
              },
              {
                "name": "exerciseFee",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Condition to check that only fields expected for a bermuda option are present.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "AutomaticExercise",
      "definition_uri": "https://w3id.org/finos/cdm/AutomaticExercise",
      "description": "A type to define automatic exercise of a swaption. With automatic exercise the option is deemed to have exercised if it is in the money by more than the threshold amount on the exercise date.",
