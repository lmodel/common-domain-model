          "aliases": [
            "Australia"
          ]
        },
        {
          "text": "CanadaMarginRules",
          "description": "Guideline E-22, Margin Requirements for Non-Centrally Cleared Derivatives issued by the Canadian Office of the Superintendent of Financial Institutions in February 2016.",
          "aliases": [
            "Canada"
          ]
        },
        {
          "text": "CFTC_MarginRules",
          "description": "Margin requirements adopted by the U.S. Commodity Futures Trading Commission pursuant to CEA  4s(e).",
          "aliases": [
            "CFTC"
          ]
        },
        {
          "text": "EMIR_MarginRules",
          "description": "Regulation (EU) No 648/2012 of the European Parliament and of the Council of 4 July 2012 on OTC derivatives, central counterparties and trade repositories (including the EMIR RTS, which means the published regulatory technical standards on risk-mitigation techniques for OTC-derivative contracts not cleared by a CCP under Article 11(15) of EMIR).",
          "aliases": [
            "EMIR"
          ]
        },
        {
          "text": "HongKongMarginRules",
          "description": "Chapter CR-G-14 'Non-centrally Cleared OTC Derivatives Transactions  Margin and Other Risk Mitigation Standards' in the Banking Supervisory Policy Manual issued by the Hong Kong Monetary Authority.",
          "aliases": [
            "Hong Kong"
          ]
        },
        {
          "text": "JapanMarginRules",
          "description": "Margin rules adopted by the Financial Services Agency of Japan pursuant to Article 40, Item 2 of the Financial Instruments and Exchange Act (kinyuu shouhin torihiki hou) (Act No. 25 of 1948) and by the Ministry of Agriculture, Forestry and Fisheries and the Ministry of Economy, Trade and Industry pursuant to the Commodity Derivatives Act (shouhin sakimono torihiki hou) (Act No. 239 of 1950) (including their subordinated regulations and the related supervisory guidelines).",
          "aliases": [
            "Japan"
          ]
        },
        {
          "text": "US_PrudentialMarginRules",
          "description": "Margin requirements adopted by a 'prudential regulator' (as defined in CEA  1a(39)) pursuant to CEA  4s(e) and Exchange Act  15F(e).",
          "aliases": [
            "Prudential"
          ]
        },
        {
          "text": "SEC_MarginRules",
          "description": "Margin requirements adopted by the U.S. Securities and Exchange Commission pursuant to Exchange Act  15F(e).",
          "aliases": [
            "SEC"
          ]
        },
        {
          "text": "SingaporeMarginRules",
