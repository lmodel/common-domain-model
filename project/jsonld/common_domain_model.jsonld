      "name": "VarianceCapFloor",
      "definition_uri": "https://w3id.org/finos/cdm/VarianceCapFloor",
      "comments": [
        "Rosetta condition: PositiveUnadjustedVarianceCap \u2014 if unadjustedVarianceCap exists then unadjustedVarianceCap > 0",
        "Rosetta condition: CapFloorApplicability \u2014 if varianceCap = True then unadjustedVarianceCap exists or boundedVariance exists // If CapFloor is applicable at least one cap expression must exist else unadjustedVarianceCap is absent and boundedVariance is absent // If CapFloor is not applicable, then there cannot be any volatility caps"
      ],
      "in_subset": [
        "cdm_product_asset"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
        "common_domain_model:VarianceCapFloor"
      ],
      "slots": [
        "varianceCap",
        "unadjustedVarianceCap",
        "boundedVariance"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "unadjustedVarianceCap",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "unadjustedVarianceCap",
                "comments": [
                  "Rosetta: strictly greater than"
                ],
                "minimum_value": 0,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Unadjusted variance cap must be positive",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "varianceCap",
                "equals_string": "True",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "unadjustedVarianceCap",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "boundedVariance",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Caps/floors can and must be specified if varianceCap is set to true. If false, barriers cannot be established",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "BoundedVariance",
      "definition_uri": "https://w3id.org/finos/cdm/BoundedVariance",
      "comments": [
        "Rosetta condition: NonNegativeBarriers \u2014 if upperBarrier exists then upperBarrier >= 0 and if lowerBarrier exists then lowerBarrier >= 0"
      ],
      "in_subset": [
        "cdm_product_asset"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
