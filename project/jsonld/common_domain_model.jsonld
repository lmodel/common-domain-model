        "CashCollateralValuationMethod"
      ],
      "range": "PartyDeterminationEnum",
      "multivalued": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "prescribedDocumentationAdjustment",
      "definition_uri": "https://w3id.org/finos/cdm/prescribedDocumentationAdjustment",
      "description": "This may be used to indicate that 'prescribed documentation adjustment' is applicable.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CashCollateralValuationMethod.prescribedDocumentationAdjustment"
