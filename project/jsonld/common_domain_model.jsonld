    },
    {
      "name": "calculationPeriodNumberOfDays",
      "definition_uri": "https://w3id.org/finos/cdm/calculationPeriodNumberOfDays",
      "description": "The number of days from the adjusted calculation period start date to the adjusted value date, calculated in accordance with the applicable day count fraction.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/calculationPeriodNumberOfDays",
      "owner": "CalculationPeriod",
      "domain_of": [
