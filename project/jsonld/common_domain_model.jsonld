      "definition_uri": "https://w3id.org/finos/cdm/SimmVersion",
      "description": "A class to specify the ISDA SIMM version that applies to the ISDA 2018 CSA for Initial Margin.",
      "notes": [
        "ISDA CSA_IM_2018 paragraph \"13 General Principles\" clause \"(ee)(1)\""
      ],
      "comments": [
        "Rosetta condition: VersionNotSpecified \u2014 if isSpecified = False then partyVersion is absent",
        "Rosetta condition: VersionSpecified \u2014 if isSpecified = True then partyVersion exists"
      ],
      "in_subset": [
        "cdm_legaldocumentation_csa"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_csa",
      "see_also": [
        "isda:CSA_IM_2018"
      ],
      "exact_mappings": [
        "common_domain_model:SimmVersion"
      ],
      "slots": [
        "SimmVersion_isSpecified",
        "partyVersion",
        "SimmVersion_asSpecified"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "isSpecified",
                "equals_string": "False",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "partyVersion",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to enforce that the version attribute should be absent when the SIMM version is stated as not specified for the CSA.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "isSpecified",
                "equals_string": "True",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "partyVersion",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to enforce that the version attribute should be specified when the SIMM version is stated as specified for the CSA.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "SubstitutedRegime",
