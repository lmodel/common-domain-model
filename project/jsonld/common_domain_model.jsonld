      "slot_uri": "https://w3id.org/finos/cdm/lastRegularPeriodEndDate",
      "owner": "CalculationPeriodDates",
      "domain_of": [
        "CalculationPeriodDates"
      ],
      "range": "date",
      "@type": "SlotDefinition"
    },
    {
      "name": "stubPeriodType",
      "definition_uri": "https://w3id.org/finos/cdm/stubPeriodType",
      "description": "Method to allocate any irregular period remaining after regular periods have been allocated between the effective and termination date. The multiplicity of 2 allows the possibility of expressing the type for both an initial and final stub at the same time.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "close_mappings": [
