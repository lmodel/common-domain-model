      "description": "Contains all common elements in variance, volatility and correlation return Terms.",
      "comments": [
        "Rosetta condition: InitialLevelOrInitialLevelSource \u2014 if initialLevel is absent then initialLevelSource exists and if initialLevelSource is absent then initialLevel exists",
        "Rosetta condition: PositiveExpectedN \u2014 expectedN > 0"
      ],
      "in_subset": [
