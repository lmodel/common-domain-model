      "@type": "ClassDefinition"
    },
    {
      "name": "VolatilityCapFloor",
      "definition_uri": "https://w3id.org/finos/cdm/VolatilityCapFloor",
      "description": "Contains volatility-based barriers. Volatility Cap needs to be specified in accordance with the ISDA 2011 Equity Derivatives Definitions.",
      "comments": [
        "Rosetta condition: CapFloorApplicability \u2014 if applicable = True then totalVolatilityCap exists or volatilityCapFactor exists // If CapFloor is applicable at least one cap expression must exist else totalVolatilityCap is absent and volatilityCapFactor is absent // If CapFloor is not applicable, then there cannot be any volatility caps",
        "Rosetta condition: PositiveCaps \u2014 if totalVolatilityCap exists then totalVolatilityCap >= 0 and if volatilityCapFactor exists then volatilityCapFactor >= 0"
      ],
      "in_subset": [
        "cdm_product_asset"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
        "common_domain_model:VolatilityCapFloor"
      ],
      "slots": [
        "VolatilityCapFloor_applicable",
        "totalVolatilityCap",
        "volatilityCapFactor"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "applicable",
                "equals_string": "True",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "totalVolatilityCap",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "volatilityCapFactor",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Caps/floors can and must be specified if applicable is set to true. If false, barriers cannot be established",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "totalVolatilityCap",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "totalVolatilityCap",
                "minimum_value": 0,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Barriers must be set to positive values",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
