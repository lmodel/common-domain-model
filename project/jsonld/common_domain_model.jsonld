      "description": "Specifies debt issues by institutions or bodies, typically constituted by statute, with a function mandated by the government and subject to government supervision inclusive of profit- and non-profit making bodies. Includes the US Agencies and GSEs and the EU concept of public sector entities. Excluding any entities which are also Regional Government.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CollateralIssuerType.quasiGovernmentType"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/quasiGovernmentType",
      "owner": "CollateralIssuerType",
      "domain_of": [
        "CollateralIssuerType"
      ],
      "range": "QuasiGovernmentIssuerType",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "regionalGovernmentType",
      "definition_uri": "https://w3id.org/finos/cdm/regionalGovernmentType",
      "description": "Specifies Regional government, local authority or municipal.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CollateralIssuerType.regionalGovernmentType"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/regionalGovernmentType",
      "owner": "CollateralIssuerType",
      "domain_of": [
        "CollateralIssuerType"
      ],
      "range": "RegionalGovernmentIssuerType",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "specialPurposeVehicleType",
      "definition_uri": "https://w3id.org/finos/cdm/specialPurposeVehicleType",
      "description": "Specifies a subsidiary company that is formed to undertake a specific business purpose of acquisition and financing of specific assets on a potentially limited recourse basis dependent of how it is designed. E.g. asset backed securities, including securitisations.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CollateralIssuerType.specialPurposeVehicleType"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/specialPurposeVehicleType",
      "owner": "CollateralIssuerType",
      "domain_of": [
        "CollateralIssuerType"
      ],
      "range": "SpecialPurposeVehicleIssuerType",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "sovereignEntity",
      "definition_uri": "https://w3id.org/finos/cdm/sovereignEntity",
      "description": "True if sovereign entity (e.g. not separate legal personality from sovereign) or false if non-sovereign entity (e.g. separate legal personality from sovereign).",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "slot_uri": "https://w3id.org/finos/cdm/sovereignEntity",
      "owner": "QuasiGovernmentIssuerType",
      "domain_of": [
        "QuasiGovernmentIssuerType"
      ],
      "range": "boolean",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "sovereignRecourse",
      "definition_uri": "https://w3id.org/finos/cdm/sovereignRecourse",
      "description": "Applies to non-sovereign entity (e.g. separate legal personality from sovereign).  True if entity has recourse to sovereign (e.g. debt guaranteed by government).  False if entity does not have recourse to sovereign.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "slot_uri": "https://w3id.org/finos/cdm/sovereignRecourse",
      "owner": "RegionalGovernmentIssuerType",
      "domain_of": [
        "QuasiGovernmentIssuerType",
        "RegionalGovernmentIssuerType"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
