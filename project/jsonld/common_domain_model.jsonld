      "description": "A class to specify execution language terms of a Security Agreement.",
      "comments": [
        "Rosetta condition: NumberOfOriginals \u2014 if standardLanguage = False then numberOfOriginals is absent",
        "Rosetta condition: OtherLanguage \u2014 if standardLanguage = False then otherLanguage exists"
      ],
      "in_subset": [
        "cdm_legaldocumentation_csa"
      ],
