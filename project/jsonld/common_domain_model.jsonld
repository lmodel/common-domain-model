      "description": "The last payment when specified as an adjustable or relative date, as in the FpML total return construct.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "slot_uri": "https://w3id.org/finos/cdm/finalPaymentDate",
      "owner": "PaymentDateSchedule",
      "domain_of": [
        "PaymentDateSchedule"
