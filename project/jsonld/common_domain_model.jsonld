        "CreditDefaultPayout"
      ],
      "range": "ProtectionTerms",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "transactedPrice",
      "definition_uri": "https://w3id.org/finos/cdm/transactedPrice",
      "description": "The qualification of the price at which the contract has been transacted, in terms of market fixed rate, initial points, market price and/or quotation style. In FpML, those attributes are positioned as part of the fee leg.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/transactedPrice",
      "owner": "CreditDefaultPayout",
      "domain_of": [
        "CreditDefaultPayout"
      ],
      "range": "TransactedPrice",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "indexReferenceInformation",
      "definition_uri": "https://w3id.org/finos/cdm/indexReferenceInformation",
      "description": "This attribute contains all the terms relevant to the underlying Index.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/indexReferenceInformation",
      "owner": "GeneralTerms",
      "domain_of": [
        "GeneralTerms"
      ],
      "range": "CreditIndex",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "basketReferenceInformation",
      "definition_uri": "https://w3id.org/finos/cdm/basketReferenceInformation",
      "description": "This attribute contains all the terms relevant to defining the Credit Default Swap Basket.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/basketReferenceInformation",
      "owner": "GeneralTerms",
      "domain_of": [
        "GeneralTerms"
      ],
      "range": "BasketReferenceInformation",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "additionalTerm",
      "definition_uri": "https://w3id.org/finos/cdm/additionalTerm",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "This attribute is used for representing information contained in the Additional Terms field of the 2003 Master Credit Derivatives confirm.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/additionalTerm",
      "owner": "GeneralTerms",
      "domain_of": [
        "GeneralTerms"
      ],
      "range": "string",
      "multivalued": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "modifiedEquityDelivery",
      "definition_uri": "https://w3id.org/finos/cdm/modifiedEquityDelivery",
      "description": "Value of this attribute set to 'true' indicates that modified equity delivery is applicable.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/modifiedEquityDelivery",
      "owner": "GeneralTerms",
      "domain_of": [
