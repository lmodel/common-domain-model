      "@type": "SlotDefinition"
    },
    {
      "name": "exerciseNoticeReceiver",
      "definition_uri": "https://w3id.org/finos/cdm/exerciseNoticeReceiver",
      "description": "Specifies the party to which notice of exercise should be given, e.g. by the buyer of the option. Although in many cases it is the buyer of the option who sends the exercise notice to the seller of the option, this component is reused, e.g. in case of OptionEarlyTermination, either or both parties have the right to exercise.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "slot_uri": "https://w3id.org/finos/cdm/exerciseNoticeReceiver",
      "owner": "ExerciseNotice",
      "domain_of": [
        "ExerciseNotice"
      ],
      "range": "AncillaryRoleEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "manualExercise",
      "definition_uri": "https://w3id.org/finos/cdm/manualExercise",
      "description": "Specifies that the notice of exercise must be given by the buyer to the seller or seller's agent.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "slot_uri": "https://w3id.org/finos/cdm/manualExercise",
      "owner": "ExerciseProcedure",
      "domain_of": [
