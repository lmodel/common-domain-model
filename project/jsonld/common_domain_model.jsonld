      "name": "OtherAgreementTerms",
      "definition_uri": "https://w3id.org/finos/cdm/OtherAgreementTerms",
      "description": "A class to specify a related legal agreement. For example, ISDA 2016 Credit Support Annex for Initial Margin, paragraph 13, General Principles, (s): Other CSA and Japanese Law CSA (VM). | ISDA 2016 Credit Support Annex for Variation Margin, paragraph 13, (o): Other CSA.",
      "comments": [
        "Rosetta condition: LegalDocumentNotSpecified \u2014 if isSpecified = False then legalDocument is absent",
        "Rosetta condition: LegalDocumentSpecified \u2014 if isSpecified = True then legalDocument exists"
      ],
      "in_subset": [
        "cdm_legaldocumentation_common"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "exact_mappings": [
        "common_domain_model:OtherAgreementTerms"
      ],
      "slots": [
        "isSpecified",
        "legalDocument"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "isSpecified",
                "equals_string": "False",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "legalDocument",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to enforce that the related legal agreement should not be referenced if it is deemed as not specified as part of the boolean attribute.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "isSpecified",
                "equals_string": "True",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "legalDocument",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A data rule to enforce that the related legal agreement should be referenced if it is deemed as specified as part of the boolean attribute.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
