    {
      "name": "RelativeDates",
      "definition_uri": "https://w3id.org/finos/cdm/RelativeDates",
      "description": "A class describing a set of dates defined as relative to another set of dates.",
      "comments": [
        "Rosetta condition: PeriodSkipGreaterThanOne \u2014 if periodSkip exists then periodSkip > 1"
      ],
      "in_subset": [
        "cdm_base_datetime"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_datetime",
