              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "calendarDay",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "If a specific calendar day is specified, it must be defined.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "date",
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "frequency",
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "additionalLanguage",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "If no methodology is defined, additional language must be specified.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
