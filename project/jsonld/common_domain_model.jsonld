    {
      "name": "Frequency",
      "definition_uri": "https://w3id.org/finos/cdm/Frequency",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A class for defining a date frequency, e.g. one day, three months, through the combination of an integer value and a standardized period value that is specified as part of an enumeration.",
      "comments": [
        "Rosetta condition: TermPeriod \u2014 if period = PeriodExtendedEnum -> T then periodMultiplier = 1",
        "Rosetta condition: PositivePeriodMultiplier \u2014 periodMultiplier > 0"
      ],
      "in_subset": [
        "cdm_base_datetime"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_datetime",
      "exact_mappings": [
        "common_domain_model:Frequency"
      ],
      "slots": [
        "periodMultiplier",
        "period"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "period",
                "equals_string": "PeriodExtendedEnum.T",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "periodMultiplier",
                "equals_string": "1",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "FpML specifies that if period value is T (Term) then periodMultiplier must contain the value 1.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "periodMultiplier",
                "comments": [
                  "Rosetta: strictly greater than"
                ],
                "minimum_value": 0,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "FpML specifies periodMultiplier as a positive integer.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
