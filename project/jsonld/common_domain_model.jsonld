    {
      "name": "MarginCallInstructionType",
      "definition_uri": "https://w3id.org/finos/cdm/MarginCallInstructionType",
      "description": "Represents enumeration values to specify the call notification type, direction, specific action type.",
      "comments": [
        "Rosetta condition: CallTypeExpectedVisibility \u2014 if callType = CallTypeEnum -> ExpectedCall then visibilityIndicator exists"
      ],
      "in_subset": [
        "cdm_event_common"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_common",
      "exact_mappings": [
