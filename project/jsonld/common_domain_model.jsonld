      "definition_uri": "https://w3id.org/finos/cdm/LegacyIndependentAmountParty",
      "description": "The party specific elections for the Independent Amount clause.",
      "comments": [
        "Rosetta condition: LegacyIAMethod \u2014 required choice fixedAmount, ratingsBased, ratingsXExposure"
      ],
      "in_subset": [
        "cdm_legaldocumentation_csa"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_csa",
      "exact_mappings": [
