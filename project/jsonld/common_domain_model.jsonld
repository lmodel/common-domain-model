        "AssetFlowBase_settlementDate",
        "paymentDiscounting",
        "TransferBase_identifier",
        "TransferBase_payerReceiver",
        "ScheduledTransfer_transferType",
        "corporateActionTransferType",
        "payoutReference"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "transferType",
                "equals_string": "CorporateAction",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "corporateActionTransferType",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "When transfer type is Performance or Transfer then the type of event must be specified.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
