      "slot_uri": "https://w3id.org/finos/cdm/weeklyRollConvention",
      "owner": "ResetFrequency",
      "domain_of": [
        "ResetFrequency"
      ],
      "range": "WeeklyRollConventionEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "relevantUnderlyingDateReference",
