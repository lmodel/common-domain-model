          "description": "Other"
        }
      ]
    },
    {
      "name": "NegativeInterestRateTreatmentEnum",
      "definition_uri": "https://w3id.org/finos/cdm/NegativeInterestRateTreatmentEnum",
      "description": "The enumerated values to specify the method of calculating payment obligations when a floating rate is negative (either due to a quoted negative floating rate or by operation of a spread that is subtracted from the floating rate).",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "NegativeInterestRateMethod",
          "description": "Negative Interest Rate Method. Per 2000 ISDA Definitions, Section 6.4 Negative Interest Rates, paragraphs (b) and (c)."
        },
        {
          "text": "ZeroInterestRateMethod",
          "description": "Zero Interest Rate Method. Per 2000 ISDA Definitions, Section 6.4. Negative Interest Rates, paragraphs (d) and (e)."
        },
        {
          "text": "ZeroInterestRateExcludingSpreadMethod",
          "description": "Per 2021 ISDA Definitions section 6.8.6"
        }
      ]
    },
    {
      "name": "NonCashDividendTreatmentEnum",
      "definition_uri": "https://w3id.org/finos/cdm/NonCashDividendTreatmentEnum",
      "description": "The enumerated values to specify the treatment of Non-Cash Dividends.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "PotentialAdjustmentEvent",
          "description": "The treatment of any non-cash dividend shall be determined in accordance with the Potential Adjustment Event provisions."
        },
        {
          "text": "CashEquivalent",
          "description": "Any non-cash dividend shall be treated as a Declared Cash Equivalent Dividend."
        }
      ]
    },
    {
      "name": "RateTreatmentEnum",
      "definition_uri": "https://w3id.org/finos/cdm/RateTreatmentEnum",
      "description": "The enumerated values to specify the methods for converting rates from one basis to another.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "BondEquivalentYield",
          "description": "Bond Equivalent Yield. Per Annex to the 2000 ISDA Definitions (June 2000 Version), Section 7.3. Certain General Definitions Relating to Floating Rate Options, paragraph (g)."
        },
        {
          "text": "MoneyMarketYield",
          "description": "Money Market Yield. Per Annex to the 2000 ISDA Definitions (June 2000 Version), Section 7.3. Certain General Definitions Relating to Floating Rate Options, paragraph (h)."
        }
      ]
    },
    {
      "name": "ReturnTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ReturnTypeEnum",
      "description": "The enumerated values to specify the type of return associated the equity payout.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "Price",
          "description": "Price return, i.e. excluding dividends."
        },
        {
          "text": "Total",
          "description": "Total return, i.e. including dividend and price components."
        }
      ]
    },
    {
      "name": "SettledEntityMatrixSourceEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SettledEntityMatrixSourceEnum",
      "description": "The enumerated values to specify the relevant settled entity matrix source.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/settled-entity-matrix-source"
      ],
      "permissible_values": [
        {
          "text": "ConfirmationAnnex",
          "description": "The Relevant Settled Entity Matrix shall be the list agreed for this purpose by the parties. The list is not included as part of the electronic confirmation.",
          "meaning": "http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#ConfirmationAnnex"
        },
        {
          "text": "NotApplicable",
          "description": "The term is not applicable.",
          "meaning": "http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#NotApplicable"
        },
        {
          "text": "Publisher",
          "description": "The Settled Entity Matrix published by the Index Publisher.",
          "meaning": "http://www.fpml.org/coding-scheme/settled-entity-matrix-source-1-0#Publisher"
        }
      ]
    },
    {
      "name": "SpreadScheduleTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SpreadScheduleTypeEnum",
      "description": "The enumerated values to specify a long or short spread value.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/spread-schedule-type"
      ],
      "permissible_values": [
        {
          "text": "Long",
          "description": "Represents a Long Spread Schedule. Spread schedules defined as 'Long' will be applied to Long Positions.",
          "meaning": "http://www.fpml.org/coding-scheme/spread-schedule-type-1-0#Long"
        },
        {
          "text": "Short",
          "description": "Represents a Short Spread Schedule. Spread schedules defined as 'Short' will be applied to Short Positions.",
          "meaning": "http://www.fpml.org/coding-scheme/spread-schedule-type-1-0#Short"
        }
      ]
    },
    {
      "name": "RollSourceCalendarEnum",
      "definition_uri": "https://w3id.org/finos/cdm/RollSourceCalendarEnum",
      "description": "Used in conjunction with an exchange-based pricing source. Identifies a date source calendar from which the pricing dates and thus roll to the next contract will be based off (e.g. pricing is based on the NYMEX WTI First Nearby Futures Contract, if Future is chosen, the pricing will roll to the next futures contract on expiration, if ListedOption is chosen, the pricing will roll to the next futures contract on the Option expiration date which is three business days before the expiration of the NYMEX WTI futures contract.) Omitting this element will result in the default behavior expected with the pricing source described within the commodity element.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "ListedOption"
        },
        {
          "text": "Future"
        }
      ]
    },
    {
      "name": "CreditSeniorityEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CreditSeniorityEnum",
      "description": "Seniority of debt instruments comprising the index.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/credit-seniority"
      ],
      "permissible_values": [
        {
          "text": "Other",
          "description": "Other as defined under EMIR.",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#Other"
        },
        {
          "text": "SeniorLossAbsorbingCapacity",
          "description": "Senior Loss Absorbing Capacity (RED Tier Code: SNRLAC).",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#SeniorLossAbsorbingCapacity"
        },
        {
          "text": "SeniorSec",
          "description": "Senior domestic (RED Tier Code: SECDOM).",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#SeniorSec"
        },
        {
          "text": "SeniorUnSec",
          "description": "Senior foreign (RED Tier Code: SNRFOR).",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#SeniorUnSec"
        },
        {
          "text": "SubLowerTier2",
          "description": "Subordinate, Lower Tier 2 (RED Tier Code: SUBLT2).",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubLowerTier2"
        },
        {
          "text": "SubTier1",
          "description": "Subordinate Tier 1 (RED Tier Code: PREFT1).",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubTier1"
        },
        {
          "text": "SubTier3",
          "description": "Subordinate, Tier 3.",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubTier3"
        },
        {
          "text": "SubUpperTier2",
          "description": "Subordinate, Upper Tier 2 (RED Tier Code: JRSUBUT2).",
          "meaning": "http://www.fpml.org/coding-scheme/credit-seniority-2-3#SubUpperTier2"
        }
      ]
    },
    {
      "name": "RealisedVarianceMethodEnum",
      "definition_uri": "https://w3id.org/finos/cdm/RealisedVarianceMethodEnum",
      "description": "The contract specifies which price must satisfy the boundary condition.  Used for variance, volatility and correlation caps and floors.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "Previous",
          "description": "For a return on day T, the observed price on T-1 must be in range."
        },
        {
          "text": "Last",
          "description": "For a return on day T, the observed price on T must be in range."
        },
        {
          "text": "Both",
          "description": "For a return on day T, the observed prices on both T and T-1 must be in range"
        }
      ]
    },
    {
      "name": "FPVFinalPriceElectionFallbackEnum",
      "definition_uri": "https://w3id.org/finos/cdm/FPVFinalPriceElectionFallbackEnum",
      "description": "Specifies the fallback provisions in respect to the applicable Futures Price Valuation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "FPVClose",
          "description": "In respect of the Early Final Valuation Date, the provisions for FPV Close shall apply."
        },
        {
          "text": "FPVHedgeExecution",
          "description": "In respect of the Early Final Valuation Date, the provisions for FPV Hedge Execution shall apply."
        }
      ]
    },
    {
      "name": "FinalPrincipalExchangeCalculationEnum",
      "definition_uri": "https://w3id.org/finos/cdm/FinalPrincipalExchangeCalculationEnum",
      "description": "To be specified only for products that embed a redemption payment.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "Floored",
          "description": "If Floored is set then Principal Exchange takes the form: Notional Amount * Max(1, Index Final/ Index Base)."
        },
        {
          "text": "NonFloored",
          "description": "If NonFloored is set then the Principal Exchange takes the form: Notional Amount * Index Final / Index Base."
        }
      ]
    },
    {
      "name": "SpreadCalculationMethodEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SpreadCalculationMethodEnum",
      "description": "Method by which spread is calculated. For example on an asset swap: 'ParPar' or 'Proceeds' may be the method indicated.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "permissible_values": [
        {
          "text": "ParPar"
        },
        {
          "text": "Proceeds"
        }
      ]
    },
    {
      "name": "FloatingRateIndexProcessingTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/FloatingRateIndexProcessingTypeEnum",
      "description": "This enumeration provides guidance on how to process a given floating rate index.  It's based on the ISDA Floating Rate Index information, but transforms it into the specific categories needed for calculation ",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset_floatingrate",
      "permissible_values": [
        {
          "text": "Screen",
          "description": "These values are just looked up from the screen and applied."
        },
        {
          "text": "CompoundIndex",
          "description": "A published index calculated using compounding; the implied rate must be backed out."
        },
        {
          "text": "OIS",
          "description": "These are calculated by the calculation agent based on a standard OIS FRO definition."
        },
        {
          "text": "OvernightAvg",
          "description": "These are calculated by the calculation agent based on a standard overnight averaging FRO definition."
        },
        {
          "text": "Modular",
          "description": "These are calculated by the calculation agent based on deal-specific parameters (e.g. lookback compound based on an RFR)."
        },
        {
          "text": "RefBanks",
          "description": "These must be looked up using a manual process"
        }
      ]
    },
    {
      "name": "CollateralTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CollateralTypeEnum",
      "description": "Specifies the types of collateral that are accepted by the Lender",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/collateral-type"
      ],
      "permissible_values": [
        {
          "text": "Cash",
          "description": "Security Lending Trades against Cash collateral"
        },
        {
          "text": "NonCash",
          "description": "Security Lending Trades against NonCash collateral"
        },
        {
          "text": "CashPool",
          "description": "Security Lending Trades against CashPool collateral"
        }
      ]
    },
    {
      "name": "ConcentrationLimitTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ConcentrationLimitTypeEnum",
      "description": "Represents the enumerated values to identify where a concentration limit is applied in the eligible collateral schedule.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "permissible_values": [
        {
          "text": "Asset",
          "description": "Specifies a limit on a single asset in the eligible collateral schedule"
        },
        {
          "text": "BaseCurrencyEquivalent",
          "description": "Specifies a limit on all cash valued in the base currency of the eligible collateral schedule."
        },
        {
          "text": "Issuer",
          "description": "Specifies a limit on a single issuer in the eligible collateral schedule."
        },
        {
          "text": "PrimaryExchange",
          "description": "Specifies a limit on a single exchange in the eligible collateral schedule."
        },
        {
          "text": "IndustrySector",
          "description": "Specifies a limit on a single industry sector in the eligible collateral schedule."
        },
        {
          "text": "UltimateParentInstitution",
          "description": "Specifies a limit on a single issuer in the eligible collateral schedule at the ultimate parent institution level."
        },
        {
          "text": "IssueOutstandingAmount",
          "description": "Specifies a limit of the issue compared to the outstanding amount of the asset on the market."
        },
        {
          "text": "MarketCapitalisation",
          "description": "Specifies a limit of the issue calculated as a percentage of the market capitalisation of the asset on the market."
        },
        {
          "text": "OutstandingBalance",
          "description": "Specifies a limit on the total outstanding balance for an asset in the portfolio."
        }
      ]
    },
    {
      "name": "AverageTradingVolumeMethodologyEnum",
      "definition_uri": "https://w3id.org/finos/cdm/AverageTradingVolumeMethodologyEnum",
      "description": "Indicates the type of equity average trading volume (single) the highest amount on one exchange, or (consolidated) volumes across more than one exchange.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "permissible_values": [
        {
          "text": "Single",
          "description": "Single, the highest amount on one exchange."
        },
        {
          "text": "Consolidated",
          "description": "Consolidated volume across more than one exchange."
        }
      ]
    },
    {
      "name": "CreditSupportAgreementTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CreditSupportAgreementTypeEnum",
      "description": "The enumerated values to specify the type of Credit Support Agreement governing the transaction.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/credit-support-agreement-type"
      ],
      "permissible_values": [
        {
          "text": "CreditSupportDeed",
          "description": "A Credit Support Deed legal agreement."
        },
        {
          "text": "CreditSupportAnnex",
          "description": "A Credit Support Annex legal agreement."
        },
        {
          "text": "CollateralTransferAgreement",
          "description": "A Collateral Transfer Agreement"
        }
      ]
    },
    {
      "name": "AlternativeToInterestAmountEnum",
      "definition_uri": "https://w3id.org/finos/cdm/AlternativeToInterestAmountEnum",
      "description": "If there is an alternative to interest amounts, how is it specified?",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "permissible_values": [
        {
          "text": "Standard",
          "description": "Interest amount is not transferred if transfer would create or increase a delivery amount."
        },
        {
          "text": "ActualAmountReceived",
          "description": "The standard calculation of the Interest Amount is replaced with the amount of interest the secured party actually receives in relation to the Cash collateral."
        },
        {
          "text": "TransferIfDeliveryAmountBelowMTA",
          "description": "Interest amount is not transferred if transfer would create or increase a delivery amount. (This is the 'Standard' provision). However, interest Amount will be transferred if Delivery Amount is below Minimum Transfer Amount."
        },
        {
          "text": "Other",
          "description": "An other alternative option outside these choices that can be described as an alternative provision."
        }
      ]
    },
    {
      "name": "CollateralInterestHandlingEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CollateralInterestHandlingEnum",
      "description": "How is collateral interest to be handled?",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "permissible_values": [
        {
          "text": "Transfer",
          "description": " Transfer the interest each period "
        },
        {
          "text": "Adjust",
          "description": " Adjust the collateral balance to include the interest amount "
        },
        {
          "text": "Transfer_or_Adjust",
          "description": " Transfer the interest if it meets certain criteria, or otherwise adjust the collateral balance to reflect the interest amount  "
        }
      ]
    },
    {
      "name": "DeliveryAmountElectionEnum",
      "definition_uri": "https://w3id.org/finos/cdm/DeliveryAmountElectionEnum",
      "description": "The enumerated values to specify the application of Interest Amount with respect to the Delivery Amount through standard language.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "permissible_values": [
        {
          "text": "LastLocalBusinessDay",
          "description": "The delivery only includes `Transfer on last Local Business Day."
        },
        {
          "text": "LastAndAnyLocalBusinessDay",
          "description": "The delivery includes both `Transfer on last Local Business Day` and `Transfer a Delivery Amount (IM) consisting of cash on any Local Business Day.`"
        }
      ]
    },
    {
      "name": "CollateralMarginTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CollateralMarginTypeEnum",
      "description": "The enumerated values to specify the type of margin for which a legal agreement is named.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "permissible_values": [
        {
          "text": "VariationMargin",
          "description": "Denotes a margin agreement that is identified for use with Variation Margin/VM."
        },
        {
          "text": "InitialMargin",
          "description": "Denotes a margin agreement that is identified for use with Initial Margin/IM."
        }
      ]
    },
    {
      "name": "RatingPriorityResolutionEnum",
      "definition_uri": "https://w3id.org/finos/cdm/RatingPriorityResolutionEnum",
      "description": "Represents an enumeration list to identify which Collateral Criteria type should have priority over others. If set to 'Issuer', the rating in the  Issuer Criteria has priority or is used if there is no Asset criteria. If set to 'Asset', the rating in the Asset Criteria has priority or is used if there is no Issuer rating.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "permissible_values": [
        {
          "text": "Issuer",
          "description": "Denotes that the Issuer Criteria has priority."
        },
        {
          "text": "Asset",
          "description": "Denotes that the Asset Criteria has priority."
        },
        {
          "text": "Lowest",
          "description": "Denotes that lowest rating should be used if several criteria apply."
        },
        {
          "text": "Highest",
          "description": "Denotes that highest rating should be used if several criteria apply."
        },
        {
          "text": "Average",
          "description": "Denotes that average rating should be used if several criteria apply."
        }
      ]
    },
