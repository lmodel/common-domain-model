    },
    {
      "name": "precision",
      "definition_uri": "https://w3id.org/finos/cdm/precision",
      "description": "Specifies the rounding precision in terms of a number of decimal places when the number is evaluated in decimal form (not percentage), e.g. 0.09876543 rounded to the nearest 5 decimal places is  0.0987654.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "slot_uri": "https://w3id.org/finos/cdm/precision",
      "owner": "AveragingCalculation",
      "domain_of": [
        "Rounding",
        "ObservationTerms",
        "AveragingCalculation"
      ],
      "range": "integer",
      "@type": "SlotDefinition"
    },
    {
      "name": "number",
      "definition_uri": "https://w3id.org/finos/cdm/number",
      "description": "The number to be used as the bound, e.g. 5.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "slot_uri": "https://w3id.org/finos/cdm/number",
