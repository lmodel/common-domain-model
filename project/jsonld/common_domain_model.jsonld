    {
      "name": "AdjustableRelativeOrPeriodicDates",
      "definition_uri": "https://w3id.org/finos/cdm/AdjustableRelativeOrPeriodicDates",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        },
        {
          "tag": "rosetta_functions",
          "value": "[{\"name\":\"ResolveAdjustableDates\",\"inputs\":[{\"name\":\"adjustableRelativeOrPeriodicDates\",\"type\":\"AdjustableRelativeOrPeriodicDates\",\"cardinality\":\"1..1\"}],\"output\":{\"name\":\"adjustedDates\",\"type\":\"date\",\"cardinality\":\"0..*\"},\"code_implementation\":true}]",
          "@type": "Annotation"
        }
      ],
      "description": "A class giving the choice between defining a series of dates as an explicit list of dates together with applicable adjustments or as relative to some other series of (anchor) dates, or as a calculation period schedule.",
      "comments": [
        "Rosetta condition: AdjustableRelativeOrPeriodicDatesChoice \u2014 required choice adjustableDates, relativeDates, periodicDates",
        "Rosetta func: ResolveAdjustableDates"
      ],
      "in_subset": [
        "cdm_base_datetime"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_datetime",
      "exact_mappings": [
