      "@type": "SlotDefinition"
    },
    {
      "name": "url",
      "definition_uri": "https://w3id.org/finos/cdm/url",
      "description": "Indicates where the resource can be found, as a URL that references the information on a web server accessible to the message recipient.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/url",
      "owner": "Resource",
      "domain_of": [
        "Resource"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "lengthUnit",
      "definition_uri": "https://w3id.org/finos/cdm/lengthUnit",
      "description": "The length unit of the resource. For example, pages (pdf, text documents) or time (audio, video files).",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/lengthUnit",
