    {
      "name": "PositionBase",
      "definition_uri": "https://w3id.org/finos/cdm/PositionBase",
      "description": "Base class to describe a Position, which could be a group of products (e.g. trade portfolio) or a group of assets (e.g. collateral portfolio).",
      "comments": [
        "Rosetta condition: ProductOrAsset \u2014 required choice product, asset"
      ],
      "in_subset": [
        "cdm_event_position"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_position",
      "exact_mappings": [
        "common_domain_model:PositionBase"
      ],
      "slots": [
        "PositionBase_priceQuantity",
        "PositionBase_product",
        "asset",
        "cashBalance",
        "PositionBase_tradeReference"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "product",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "asset",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "A Position must either refer to a grouping by product or a grouping by asset.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "Position",
      "definition_uri": "https://w3id.org/finos/cdm/Position",
      "description": "A Position describes how much of a given Product is being held and constitutes the atomic element of a Portfolio.",
      "in_subset": [
        "cdm_event_position"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_position",
      "exact_mappings": [
