      "comments": [
        "Rosetta condition: CalendarDay \u2014 if date = ValuationDateDateEnum -> CalendarDay then calendarDay exists else calendarDay is absent",
        "Rosetta condition: AdditionalLanguage \u2014 if date is absent or frequency is absent then additionalLanguage exists"
      ],
      "in_subset": [
