    {
      "name": "calculationAgentParty",
      "definition_uri": "https://w3id.org/finos/cdm/calculationAgentParty",
      "description": "Specifies the party which is the ISDA Calculation Agent for the trade. If more than one party is referenced then the parties are assumed to be co-calculation agents, i.e. they have joint responsibility.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CalculationAgent.calculationAgentParty"
