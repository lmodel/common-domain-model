                    ],
                    "@type": "AnonymousSlotExpression"
                  }
                ],
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "alternativeProvision",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Alternative2",
          "comments": [
