          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "fxDesignatedCurrency",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "The FX Designated Currency should be specified when the reference currency for the purpose of specifying the FX Haircut relating to a posting obligation is specified as not being the Termination Currency.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
