    {
      "name": "onBehalfOf",
      "definition_uri": "https://w3id.org/finos/cdm/onBehalfOf",
      "description": "Optionally specifies the counterparty that the ancillary party is acting on behalf of.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_party",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AncillaryParty.onBehalfOf"
