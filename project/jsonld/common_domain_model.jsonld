      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "agreementDate",
      "definition_uri": "https://w3id.org/finos/cdm/agreementDate",
      "description": "The date on which the legal agreement has been agreed between the parties. This corresponds to the Date of Deed in an English Law document.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/agreementDate",
      "owner": "LegalAgreementBase",
