    {
      "name": "Obligations",
      "definition_uri": "https://w3id.org/finos/cdm/Obligations",
      "description": "A class to specify the underlying obligations of the reference entity on which protection is purchased or sold through the Credit Default Swap.",
      "comments": [
        "Rosetta condition: ObligationsChoice \u2014 optional choice fullFaithAndCreditObLiability, generalFundObligationLiability, revenueObligationLiability"
      ],
      "in_subset": [
        "cdm_base_staticdata_asset_credit"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_credit",
      "exact_mappings": [
        "common_domain_model:Obligations"
      ],
      "slots": [
        "category",
        "notSubordinated",
        "specifiedCurrency",
        "notSovereignLender",
        "notDomesticCurrency",
        "notDomesticLaw",
        "listed",
        "notDomesticIssuance",
        "fullFaithAndCreditObLiability",
        "generalFundObligationLiability",
        "revenueObligationLiability",
        "notContingent",
        "excluded",
        "othReferenceEntityObligations",
        "designatedPriority",
        "cashSettlementOnly",
        "deliveryOfCommitments",
        "continuity"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "fullFaithAndCreditObLiability",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "generalFundObligationLiability",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "revenueObligationLiability",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Choice rule to represent an FpML choice construct.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
