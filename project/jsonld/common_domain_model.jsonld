      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A description of the type of the resource, e.g. a confirmation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
