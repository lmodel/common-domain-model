        "additionalRegime",
        "regimeTerms",
        "additionalType",
        "additionalTerms"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "regime",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "additionalRegime",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "The applicable regime should be specified either as an enumeration or as an additional regime specified by the parties.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "AppropriatedCollateralValuation",
      "definition_uri": "https://w3id.org/finos/cdm/AppropriatedCollateralValuation",
      "description": "A class to specify the Valuation of Appropriated Collateral.",
      "notes": [
        "ISDA CSD_IM_English_2016 paragraph \"13 General Principles\" clause \"(u)\" name \"Valuation of Appropriated Collateral\""
      ],
      "comments": [
        "Rosetta condition: Specified \u2014 if isSpecified = True then election exists",
        "Rosetta condition: NotSpecified \u2014 if isSpecified = False then election is absent"
      ],
      "in_subset": [
        "cdm_legaldocumentation_csa"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_csa",
