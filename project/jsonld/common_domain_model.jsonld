      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "This may be used to indicate the interest rate to be used for cash collateral for cash settlement purposes.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CashCollateralValuationMethod.cashCollateralInterestRate"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/cashCollateralInterestRate",
      "owner": "CashCollateralValuationMethod",
      "domain_of": [
        "CashCollateralValuationMethod"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "agreedDiscountRate",
      "definition_uri": "https://w3id.org/finos/cdm/agreedDiscountRate",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "This may be used to indicate the discount rate to be used for cash collateral for cash settlement purposes.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CashCollateralValuationMethod.agreedDiscountRate"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/agreedDiscountRate",
      "owner": "CashCollateralValuationMethod",
      "domain_of": [
        "CashCollateralValuationMethod"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "protectedParty",
      "definition_uri": "https://w3id.org/finos/cdm/protectedParty",
      "description": "This may be used to specify which party is protected (e.g. under Replacement Value cash settlement methods).",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CashCollateralValuationMethod.protectedParty"
