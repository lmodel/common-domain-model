          "tag": "rosetta_functions",
          "value": "[{\"name\":\"LoadCodeList\",\"description\":\"Loads a code list JSON resource into memory in the form of cdm.base.staticdata.codelist.CodeList Rune object\",\"inputs\":[{\"name\":\"domain\",\"type\":\"string\",\"cardinality\":\"1..1\"}],\"output\":{\"name\":\"codelist\",\"type\":\"CodeList\",\"cardinality\":\"0..1\"},\"code_implementation\":true}]",
          "@type": "Annotation"
        }
      ],
      "description": "A type hold a list of codes for business data validation",
      "comments": [
        "Rosetta func: LoadCodeList \u2014 Loads a code list JSON resource into memory in the form of cdm.base.staticdata.codelist.CodeList Rune object"
      ],
      "in_subset": [
