    {
      "name": "WeatherUnitEnum",
      "definition_uri": "https://w3id.org/finos/cdm/WeatherUnitEnum",
      "description": "Provides enumerated values for weather units, generally used in the context of defining quantities for commodities.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "permissible_values": [
        {
          "text": "CDD",
          "description": "Denotes Cooling Degree Days as a standard unit."
        },
        {
          "text": "CPD",
          "description": "Denotes Critical Precipitation Day as a standard unit."
        },
        {
          "text": "HDD",
          "description": "Heating Degree Day as a standard unit."
        }
      ]
    },
    {
      "name": "FinancialUnitEnum",
      "definition_uri": "https://w3id.org/finos/cdm/FinancialUnitEnum",
      "description": "Provides enumerated values for financial units, generally used in the context of defining quantities for securities.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "permissible_values": [
        {
          "text": "Contract",
          "description": "Denotes financial contracts, such as listed futures and options."
        },
        {
          "text": "ContractualProduct",
          "description": "Denotes a Contractual Product as defined in the CDM.  This unit type would be used when the price applies to the whole product, for example, in the case of a premium expressed as a cash amount."
        },
        {
          "text": "IndexUnit",
          "description": "Denotes a price expressed in index points, e.g. for a stock index."
        },
        {
          "text": "LogNormalVolatility",
          "description": "Denotes a log normal volatility, expressed in %/month, where the percentage is represented as a decimal. For example, 0.15 means a log-normal volatility of 15% per month."
        },
        {
          "text": "Share",
          "description": "Denotes the number of units of financial stock shares."
        },
        {
          "text": "ValuePerDay",
          "description": "Denotes a value (expressed in currency units) for a one day change in a valuation date, which is typically used for expressing sensitivity to the passage of time, also known as theta risk, or carry, or other names."
        },
        {
          "text": "ValuePerPercent",
          "description": "Denotes a value (expressed in currency units) per percent change in the underlying rate which is typically used for expressing sensitivity to volatility changes, also known as vega risk."
        },
        {
          "text": "Weight",
          "description": "Denotes a quantity (expressed as a decimal value) represented the weight of a component in a basket."
        }
      ]
    },
    {
      "name": "ArithmeticOperationEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ArithmeticOperationEnum",
      "description": "An arithmetic operator that can be passed to a function",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "permissible_values": [
        {
          "text": "Add",
          "description": "Addition of 2 values"
        },
        {
          "text": "Subtract",
          "description": "Subtraction of 2nd value from 1st value"
        },
        {
          "text": "Multiply",
          "description": "Multiplication of 2 values"
        },
        {
          "text": "Divide",
          "description": "Division of 1st value by 2nd value"
        },
        {
          "text": "Max",
          "description": "Maximum of 2 values"
        },
        {
          "text": "Min",
          "description": "Minimum of 2 values"
        }
      ]
    },
    {
      "name": "QuantityChangeDirectionEnum",
      "definition_uri": "https://w3id.org/finos/cdm/QuantityChangeDirectionEnum",
      "description": "Specifies whether a quantity change is an increase, a decrease or a replacement, whereby the quantity is always specified as a positive number.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_math",
      "permissible_values": [
        {
          "text": "Increase",
          "description": "When the quantity should go up by the specified amount."
        },
        {
          "text": "Decrease",
          "description": "When the quantity should go down by the specified amount."
        },
        {
          "text": "Replace",
          "description": "When the quantity should be replaced by the specified amount."
        }
      ]
    },
    {
      "name": "ProductGradeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ProductGradeEnum",
      "description": "Identifies the grade of physical commodity product to be delivered.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_commodity",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/commodity-oil-product-grade"
      ],
      "permissible_values": [
        {
          "text": "_0_1_Percent",
          "description": "Applies to Oil Product Type Fuel Oil.",
          "aliases": [
            "0.1-Percent"
          ]
        },
        {
          "text": "_0_5_Percent",
          "description": "Applies to Oil Product Type Fuel Oil.",
          "aliases": [
            "0.5-Percent"
          ]
        },
        {
          "text": "_1_0_Percent",
          "description": "Applies to Oil Product Type Fuel Oil.",
          "aliases": [
            "1.0-Percent"
          ]
        },
        {
