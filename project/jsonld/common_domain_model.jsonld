                "name": "isApplicable",
                "equals_string": "True",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "The Pledgor/Obligor/Chargor Additional Rights should be qualified only when the Pledgor Additional Rights Event election is specified as applicable.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "AdditionalTerminationEvent",
      "definition_uri": "https://w3id.org/finos/cdm/AdditionalTerminationEvent",
      "description": "A class to specify an optional termination event, additional to the Termination Events that will be deemed an Access Condition (Initial Margin CSA) or a Specified Condition (Variation Margin CSA).",
      "in_subset": [
        "cdm_legaldocumentation_csa"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_csa",
