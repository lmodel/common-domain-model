        "Rosetta condition: AccountTotal \u2014 if summaryAmountType = RecordAmountTypeEnum -> AccountTotal then summaryTransfer ->> payerReceiver -> payerAccountReference exists and summaryTransfer ->> payerReceiver -> receiverAccountReference exists",
        "Rosetta func: Create_BillingSummary \u2014 Creates a billing summary to be included in a Security Lending Billing Invoice."
      ],
