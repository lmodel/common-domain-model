        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "security",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "loan",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Represents the choice in a CDS contract.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "primaryObligor",
