        },
        {
          "text": "Negative",
          "description": "Denotes a rating may be lowered."
        },
        {
          "text": "Developing",
          "description": "Denotes a rating may be raised, lowered, or affirmed."
        }
      ]
    },
    {
      "name": "CreditNotationMismatchResolutionEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CreditNotationMismatchResolutionEnum",
      "description": "Represents an enumeration list to identify the characteristics of the rating if there are several agency issue ratings but not equivalent, reference will be made to label characteristics of the rating such as the lowest/highest available.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "permissible_values": [
        {
          "text": "Lowest",
          "description": "Denotes the lowest credit notation if several notations are listed."
        },
        {
          "text": "Highest",
          "description": "Denotes the highest credit notation if several notations are listed."
        },
        {
          "text": "ReferenceAgency",
          "description": "Denotes that a credit notation issued from a defined reference agency is used if several notations are listed."
        },
        {
          "text": "Average",
          "description": "Denotes the average credit notation if several notations are listed."
        },
        {
          "text": "SecondBest",
          "description": "Denotes the second best credit notation if several notations are listed."
        },
        {
          "text": "Other",
          "description": "Utilised where bespoke language represents the label characteristics of the rating."
        }
      ]
    },
    {
      "name": "CreditNotationBoundaryEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CreditNotationBoundaryEnum",
