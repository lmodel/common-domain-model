    },
    {
      "name": "optionsExchangeDividends",
      "definition_uri": "https://w3id.org/finos/cdm/optionsExchangeDividends",
      "description": "If present and true, then options exchange dividends are applicable.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "slot_uri": "https://w3id.org/finos/cdm/optionsExchangeDividends",
      "owner": "DividendApplicability",
