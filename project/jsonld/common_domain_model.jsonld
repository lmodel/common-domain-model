      ],
      "range": "AdjustableOrRelativeDate",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "firstRegularPeriodStartDate",
      "definition_uri": "https://w3id.org/finos/cdm/firstRegularPeriodStartDate",
      "description": "The start date of the regular part of the calculation period schedule. It must only be specified if there is an initial stub calculation period. This day may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CalculationPeriodDates.firstRegularPeriodStartDate"
      ],
