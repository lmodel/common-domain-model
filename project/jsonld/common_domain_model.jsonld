        "ReferenceObligation"
      ],
      "range": "LegalEntity",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "primaryObligorReference",
      "definition_uri": "https://w3id.org/finos/cdm/primaryObligorReference",
      "annotations": [
        {
          "tag": "metadata_reference",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the primary obligor.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/primaryObligorReference",
      "owner": "ReferenceObligation",
      "domain_of": [
        "ReferenceObligation"
      ],
      "range": "LegalEntity",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "guarantor",
      "definition_uri": "https://w3id.org/finos/cdm/guarantor",
      "description": "The party that guarantees by way of a contractual arrangement to pay the debts of an obligor if the obligor is unable to make the required payments itself. ISDA 2003 Term: Guarantor.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/guarantor",
      "owner": "ReferenceObligation",
      "domain_of": [
        "ReferenceObligation"
      ],
      "range": "LegalEntity",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "guarantorReference",
      "definition_uri": "https://w3id.org/finos/cdm/guarantorReference",
      "description": "A pointer style reference to a reference entity defined elsewhere in the document. Used when the reference entity is the guarantor.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/guarantorReference",
      "owner": "ReferenceObligation",
      "domain_of": [
        "ReferenceObligation"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "standardReferenceObligation",
      "definition_uri": "https://w3id.org/finos/cdm/standardReferenceObligation",
      "description": "Indicates if the reference obligation is a Standard Reference Obligation. ISDA 2014 Term: Standard Reference Obligation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/standardReferenceObligation",
      "owner": "ReferenceObligation",
      "domain_of": [
        "ReferenceObligation"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "entityType",
      "definition_uri": "https://w3id.org/finos/cdm/entityType",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
