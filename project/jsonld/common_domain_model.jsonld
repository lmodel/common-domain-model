    {
      "name": "SettlementDate",
      "definition_uri": "https://w3id.org/finos/cdm/SettlementDate",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A data defining the settlement date(s) for cash or physical settlement as either a set of explicit dates, together with applicable adjustments, or as a date relative to some other (anchor) date, or as any date in a range of contiguous business days. This data type provides a level of abstraction on top of the different legacy methods used to specify a settlement / payment date, which vary across product types, asset classes and delivery types.",
      "comments": [
        "Rosetta condition: BusinessDays \u2014 if cashSettlementBusinessDays exists then cashSettlementBusinessDays >= 0 else adjustableOrRelativeDate exists or valueDate exists or adjustableDates exists or businessDateRange exists",
        "Rosetta condition: DateChoice \u2014 optional choice adjustableOrRelativeDate, valueDate, adjustableDates, businessDateRange"
      ],
      "in_subset": [
        "cdm_product_common_settlement"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "exact_mappings": [
        "common_domain_model:SettlementDate"
      ],
      "slots": [
        "adjustableOrRelativeDate",
        "SettlementDate_valueDate",
        "SettlementDate_adjustableDates",
        "businessDateRange",
        "cashSettlementBusinessDays",
        "paymentDelay"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "cashSettlementBusinessDays",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "cashSettlementBusinessDays",
                "minimum_value": 0,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "FpML specifies cashSettlementBusinessDays as a nonNegativeInteger. If cashSettlementBusinessDays is not specified, then another settlement date method must be specified.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "adjustableOrRelativeDate",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "valueDate",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "adjustableDates",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "businessDateRange",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Settlement date must be specified either throught the 'settlementDate' or 'valueDate' attribute. This is a temporary work-around until such time when we can retire the 'valueDate' attribute.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
