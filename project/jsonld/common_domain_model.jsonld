    {
      "name": "PaymentDates",
      "definition_uri": "https://w3id.org/finos/cdm/PaymentDates",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Specifies the parameters to generate the payment date schedule, either through a parametric representation or by reference to specified dates.",
      "comments": [
        "Rosetta condition: FpML_ird_35_cd_31 \u2014 if firstPaymentDate exists and lastRegularPaymentDate exists then firstPaymentDate < lastRegularPaymentDate",
        "Rosetta condition: NonZeroPeriodMultiplier \u2014 if paymentDaysOffset exists then paymentDaysOffset -> periodMultiplier <> 0"
      ],
      "in_subset": [
        "cdm_product_common_schedule"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
