      ],
      "slots": [
        "referenceEntity",
        "referenceObligation",
        "noReferenceObligation",
        "unknownReferenceObligation",
        "allGuarantees",
        "referencePrice",
        "referencePolicy",
        "securedList"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "referenceObligation",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "noReferenceObligation",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "unknownReferenceObligation",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Choice rule to represent an FpML choice construct.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "ReferenceObligation",
      "definition_uri": "https://w3id.org/finos/cdm/ReferenceObligation",
      "description": "A class to specify the reference obligation that is associated with a credit derivative instrument.",
      "comments": [
        "Rosetta condition: AssetChoice \u2014 required choice security, loan",
        "Rosetta condition: MustBeDebtSecurity \u2014 if security exists then security -> securityType = Debt",
        "Rosetta condition: LegalEntityChoice \u2014 optional choice primaryObligor, primaryObligorReference"
      ],
