    },
    {
      "name": "qualification",
      "definition_uri": "https://w3id.org/finos/cdm/qualification",
      "description": "The timestamp qualifier is specified through an enumeration because the experience of integrating the DTCC and CME data representations suggests that a wide set of timestamps are currently utilized among service providers, while there is not at present an objective set of criteria that could help suggest a defined set of timestamps as part of the CDM. At some future point, one possible baseline could be developed from the review of the set of timestamps specified across regulatory regimes and regulations (incl. regulations such as high frequency trading). Also, the integration with a further set of implementations and the specification of business workflows such as clearing as part of the CDM development should help confirm the implementation approach in this respect.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/qualification",
      "owner": "CustodianRiskElection",
      "domain_of": [
        "EventTimestamp",
        "AdditionalRightsEvent",
        "CustodianRiskElection"
      ],
      "range": "EventTimestampQualificationEnum",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "workflowStatus",
      "definition_uri": "https://w3id.org/finos/cdm/workflowStatus",
      "description": "The workflow status indicator, e.g. Accepted, Rejected, ...",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/workflowStatus",
      "owner": "WorkflowState",
      "domain_of": [
        "WorkflowState"
      ],
      "range": "WorkflowStatusEnum",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "comment",
      "definition_uri": "https://w3id.org/finos/cdm/comment",
      "description": "A comment field to be associated with the workflow, e.g. to specify why a transaction event was rejected by a party.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/comment",
      "owner": "WorkflowState",
      "domain_of": [
        "WorkflowState"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "partyCustomisedWorkflow",
      "definition_uri": "https://w3id.org/finos/cdm/partyCustomisedWorkflow",
      "description": "Workflow data that is specific to certain market participants and is expressed as part of the CDM in a very generic manner, which can be party-specific. The initial use cases have been derived from the CME clearing and the DTCC TIW submissions.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/partyCustomisedWorkflow",
      "owner": "WorkflowState",
      "domain_of": [
        "WorkflowState"
      ],
      "range": "PartyCustomisedWorkflow",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "warehouseIdentity",
      "definition_uri": "https://w3id.org/finos/cdm/warehouseIdentity",
      "description": "The identity of the warehouse, if any, that is executing that workflow step.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/warehouseIdentity",
      "owner": "WorkflowState",
      "domain_of": [
        "WorkflowState"
      ],
      "range": "WarehouseIdentityEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "limitType",
      "definition_uri": "https://w3id.org/finos/cdm/limitType",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Standard code to indicate which type of credit line is being referred to - i.e. IM, DV01, PV01, CS01, Notional, Clip Size, Notional, maximumOrderQuantity.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/limitType",
      "owner": "LimitApplicable",
      "domain_of": [
        "LimitApplicable"
      ],
      "range": "CreditLimitTypeEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "clipSize",
      "definition_uri": "https://w3id.org/finos/cdm/clipSize",
      "description": "This element is required in FpML, optional in CDM for the purpose of accommodating the CME data representation while making reference to the FpML one.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/clipSize",
      "owner": "LimitApplicable",
      "domain_of": [
        "LimitApplicable"
      ],
      "range": "integer",
      "@type": "SlotDefinition"
    },
    {
      "name": "amountUtilized",
      "definition_uri": "https://w3id.org/finos/cdm/amountUtilized",
      "description": "The limit utilised by all the cleared trades for the limit level and limit type. While the attribute is of type integer in FpML and the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/amountUtilized",
      "owner": "LimitApplicable",
      "domain_of": [
        "LimitApplicable"
      ],
      "range": "decimal",
      "@type": "SlotDefinition"
    },
    {
      "name": "utilization",
      "definition_uri": "https://w3id.org/finos/cdm/utilization",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/utilization",
      "owner": "LimitApplicable",
      "domain_of": [
        "LimitApplicable"
      ],
      "range": "CreditLimitUtilisation",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "amountRemaining",
      "definition_uri": "https://w3id.org/finos/cdm/amountRemaining",
      "description": "The limit remaining for the limit level and limit type. This does not take into account any pending trades. While the attribute is of type integer in FpML and the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/amountRemaining",
      "owner": "LimitApplicable",
      "domain_of": [
        "LimitApplicable"
      ],
      "range": "decimal",
      "@type": "SlotDefinition"
    },
    {
      "name": "velocity",
      "definition_uri": "https://w3id.org/finos/cdm/velocity",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/velocity",
      "owner": "LimitApplicable",
      "domain_of": [
        "LimitApplicable"
      ],
      "range": "Velocity",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "limitLevel",
      "definition_uri": "https://w3id.org/finos/cdm/limitLevel",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "The level at which the limit is set: customer business, proprietary business or account level. This attribute is specified as a string as part of the CME clearing confirmation specification.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/limitLevel",
      "owner": "LimitApplicableExtended",
      "domain_of": [
        "LimitApplicableExtended"
      ],
      "range": "LimitLevelEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "limitAmount",
      "definition_uri": "https://w3id.org/finos/cdm/limitAmount",
      "description": "The total limit available for the limit level and limit type. While the attribute is of type integer in the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/limitAmount",
      "owner": "LimitApplicableExtended",
      "domain_of": [
        "LimitApplicableExtended"
      ],
      "range": "decimal",
      "@type": "SlotDefinition"
    },
    {
      "name": "limitImpactDueToTrade",
      "definition_uri": "https://w3id.org/finos/cdm/limitImpactDueToTrade",
      "description": "The limit utilized by this specific trade. While the attribute is of type integer in the CME schema, it has been specified to be of type number in the CDM to take into consideration java size limits as well as for consistency purposes with the way most monetary amounts are expressed.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/limitImpactDueToTrade",
      "owner": "LimitApplicableExtended",
      "domain_of": [
        "LimitApplicableExtended"
      ],
      "range": "decimal",
      "@type": "SlotDefinition"
    },
    {
      "name": "messageId",
      "definition_uri": "https://w3id.org/finos/cdm/messageId",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A unique identifier assigned to the message.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
