      "name": "referencePoolItem",
      "definition_uri": "https://w3id.org/finos/cdm/referencePoolItem",
      "description": "This type contains all the constituent weight and reference information.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/referencePoolItem",
