    {
      "name": "CollateralInterestCalculationParameters",
      "definition_uri": "https://w3id.org/finos/cdm/CollateralInterestCalculationParameters",
      "description": "Represents parameters for calculating the amount the floating interest calculation, e.g.  for a single currency or defaults for all currencies.",
      "comments": [
        "Rosetta condition: InterestRate \u2014 required choice fixedRate, floatingRate",
        "Rosetta condition: DCF \u2014 dayCountFraction = DayCountFractionEnum -> ACT_360 or dayCountFraction = DayCountFractionEnum -> ACT_365_FIXED",
        "Rosetta condition: CompoundingBC1 \u2014 if compoundingType = CompoundingTypeEnum -> Business then compoundingBusinessCenter exists",
        "Rosetta condition: CompoundingBC2 \u2014 if compoundingType <> CompoundingTypeEnum -> Business then compoundingBusinessCenter is absent"
      ],
      "in_subset": [
        "cdm_product_collateral"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_collateral",
      "exact_mappings": [
        "common_domain_model:CollateralInterestCalculationParameters"
      ],
      "close_mappings": [
        "fpml_5_10:CollateralInterestCalculationParameters"
      ],
      "slots": [
        "CollateralInterestCalculationParameters_fixedRate",
        "CollateralInterestCalculationParameters_floatingRate",
        "inBaseCurrency",
        "compoundingType",
        "compoundingBusinessCenter",
        "CollateralInterestCalculationParameters_dayCountFraction",
        "CollateralInterestCalculationParameters_rounding",
        "roundingFrequency",
        "withholdingTaxRate"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "fixedRate",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "floatingRate",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "InterestRate",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "compoundingType",
                "equals_string": "Business",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "compoundingBusinessCenter",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "CompoundingBC1",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "compoundingType",
                "none_of": [
                  {
                    "equals_string_in": [
                      "Business"
                    ],
                    "@type": "AnonymousSlotExpression"
                  }
                ],
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "compoundingBusinessCenter",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "CompoundingBC2",
          "comments": [
            "Rosetta negation: compoundingType <> CompoundingTypeEnum -> Business"
          ],
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
