        "PayoutBase_settlementTerms",
        "SettlementPayout_underlier",
        "SettlementPayout_deliveryTerm",
        "delivery",
        "SettlementPayout_schedule"
      ],
      "slot_usage": {},
      "@type": "ClassDefinition"
    },
