      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "The identifier for the originator of a message instance.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/sentBy",
      "owner": "MessageInformation",
