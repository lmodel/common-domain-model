    {
      "name": "DateRange",
      "definition_uri": "https://w3id.org/finos/cdm/DateRange",
      "description": "A class defining a contiguous series of calendar dates. The date range is defined as all the dates between and including the start and the end date. The start date must fall on or before the end date.",
      "comments": [
        "Rosetta condition: DatesOrdered \u2014 startDate <= endDate"
      ],
      "in_subset": [
        "cdm_base_datetime"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_datetime",
      "exact_mappings": [
