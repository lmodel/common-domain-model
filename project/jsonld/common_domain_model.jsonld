    {
      "name": "exerciseNoticeGiver",
      "definition_uri": "https://w3id.org/finos/cdm/exerciseNoticeGiver",
      "description": "Specifies the principal party of the trade that has the right to exercise.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "slot_uri": "https://w3id.org/finos/cdm/exerciseNoticeGiver",
