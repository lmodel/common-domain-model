    {
      "name": "CurrencyCodeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CurrencyCodeEnum",
      "description": "Union of the enumerated values defined by the International Standards Organization (ISO) and the FpML nonISOCurrencyScheme which consists of offshore and historical currencies (https://www.fpml.org/coding-scheme/non-iso-currency), as of 28-Oct-2016.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "CNH",
          "description": "Offshore Chinese Yuan traded in Hong Kong."
        },
        {
          "text": "CNT",
          "description": "Offshore Chinese Yuan traded in Taiwan."
        },
        {
          "text": "GGP",
          "description": "Guernsey Pound."
        },
        {
          "text": "IMP",
          "description": "Isle of Man Pound."
        },
        {
          "text": "JEP",
          "description": "Jersey Pound."
        },
        {
          "text": "KID",
          "description": "Tuvaluan Dollar."
        },
        {
