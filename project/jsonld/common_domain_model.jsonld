      ],
      "slots": [
        "startDate",
        "endDate"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "description": "The start date must fall on or before the end date (a date range of only one date is allowed).",
          "comments": [
            "Rosetta comparison: startDate <= endDate"
          ],
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
