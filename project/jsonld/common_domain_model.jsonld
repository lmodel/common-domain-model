    },
    {
      "name": "debt",
      "definition_uri": "https://w3id.org/finos/cdm/debt",
      "description": "Specifies the credit rating debt type (e.g. long term, high yield, deposits, ...) associated with the credit rating notation and scale.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_observable_asset",
      "slot_uri": "https://w3id.org/finos/cdm/debt",
      "owner": "CreditNotation",
