      "name": "clauseLibrary",
      "definition_uri": "https://w3id.org/finos/cdm/clauseLibrary",
      "description": "Specification of whether the agreement terms have been negotiated using the clause library methodology.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#AgreementTerms.clauseLibrary"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/clauseLibrary",
      "owner": "AgreementTerms",
