          "aliases": [
            "Singapore"
          ]
        },
        {
          "text": "SwitzerlandMarginRules",
          "description": "Margin rules adopted by the Swiss Federal Council pursuant to Article 110-111 of the Financial Market Infrastructure Act as well as Articles 100 to 107 and Annexes 3 to 5 of the Financial Market Infrastructure Ordinance.",
          "aliases": [
            "Switzerland"
          ]
        },
        {
          "text": "BrazilMarginRules",
