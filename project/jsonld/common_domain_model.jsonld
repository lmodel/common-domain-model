        "IndependentAmountRatings_compare",
        "IndependentAmountRatings_ratedParty",
        "IndependentAmountRatings_namedAffiliate",
        "IndependentAmountRatings_namedEntity",
        "ratingType",
        "highestLowestVariableSet",
        "compareVariableSet"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "compare",
                "equals_string": "Compare",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "compareVariableSet",
                "required": true,
                "@type": "SlotDefinition"
              },
              {
                "name": "highestLowestVariableSet",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Ensures the appropriate variable set is populated based on how the Ratings are compared.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "compare",
                "equals_string": "Lowest",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "highestLowestVariableSet",
                "required": true,
                "@type": "SlotDefinition"
              },
              {
                "name": "compareVariableSet",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Ensures the appropriate variable set is populated based on how the Ratings are compared.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "compare",
                "equals_string": "Highest",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "highestLowestVariableSet",
                "required": true,
                "@type": "SlotDefinition"
              },
              {
                "name": "compareVariableSet",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Ensures the appropriate variable set is populated based on how the Ratings are compared.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
