    },
    {
      "name": "legalAgreementIdentification",
      "definition_uri": "https://w3id.org/finos/cdm/legalAgreementIdentification",
      "description": "The type of legal agreement, identified via a set of composable attributes: agreementName, publisher, governing law and version, e.g. ISDA 2013 Standard Credit Support Annex English Law.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/legalAgreementIdentification",
      "owner": "LegalAgreementBase",
      "domain_of": [
        "LegalAgreementBase"
      ],
      "range": "LegalAgreementIdentification",
      "required": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
