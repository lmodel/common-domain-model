    },
    {
      "name": "pricePublisher",
      "definition_uri": "https://w3id.org/finos/cdm/pricePublisher",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Defines a publication in which the price can be found. (e.g Gas Daily, Platts Bloomberg. Commodity publishers can be found at this URL:  http://www.fpml.org/coding-scheme/commodity-information-provider>",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "slot_uri": "https://w3id.org/finos/cdm/pricePublisher",
      "owner": "PriceSource",
      "domain_of": [
        "PriceSource"
      ],
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "priceSourceLocation",
      "definition_uri": "https://w3id.org/finos/cdm/priceSourceLocation",
      "description": "Specifies the location of the price which may be a specific page, electornic screen name, or a code (e.g. a RIC code) where the price can be found.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "slot_uri": "https://w3id.org/finos/cdm/priceSourceLocation",
      "owner": "PriceSource",
      "domain_of": [
        "PriceSource"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "priceSourceHeading",
      "definition_uri": "https://w3id.org/finos/cdm/priceSourceHeading",
      "description": "Specifies the heading or field name for the price  on a given page or screen, where applicable.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "slot_uri": "https://w3id.org/finos/cdm/priceSourceHeading",
      "owner": "PriceSource",
      "domain_of": [
        "PriceSource"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "priceSourceTime",
      "definition_uri": "https://w3id.org/finos/cdm/priceSourceTime",
      "description": "Specifies the time at which the price should be observed.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "slot_uri": "https://w3id.org/finos/cdm/priceSourceTime",
      "owner": "PriceSource",
      "domain_of": [
        "PriceSource"
      ],
      "range": "time",
      "@type": "SlotDefinition"
    },
    {
      "name": "applicable",
      "definition_uri": "https://w3id.org/finos/cdm/applicable",
      "description": "Indicates whether the Not Domestic Currency provision is applicable.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_credit",
      "slot_uri": "https://w3id.org/finos/cdm/applicable",
      "owner": "PCDeliverableObligationCharac",
      "domain_of": [
        "NotDomesticCurrency",
        "SpecifiedCurrency",
        "FinalReturns",
        "FailureToPay",
        "GracePeriodExtension",
        "Restructuring",
        "VolatilityCapFloor",
        "PCDeliverableObligationCharac"
      ],
      "range": "boolean",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "category",
      "definition_uri": "https://w3id.org/finos/cdm/category",
      "description": "Used in both obligations and deliverable obligations to represent a class or type of securities which apply. ISDA 2003 Term: Obligation Category/Deliverable Obligation Category.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_credit",
      "slot_uri": "https://w3id.org/finos/cdm/category",
      "owner": "DeliverableObligations",
