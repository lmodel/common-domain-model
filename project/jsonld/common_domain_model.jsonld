    {
      "name": "spreadScheduleType",
      "definition_uri": "https://w3id.org/finos/cdm/spreadScheduleType",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "An element which purpose is to identify a long or short spread value.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/spreadScheduleType",
      "owner": "SpreadSchedule",
