    },
    {
      "name": "length",
      "definition_uri": "https://w3id.org/finos/cdm/length",
      "description": "Indicates the length of the resource. For example, if the resource were a PDF file, the length would be in pages.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/length",
      "owner": "Resource",
      "domain_of": [
        "Resource"
      ],
      "range": "ResourceLength",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "mimeType",
      "definition_uri": "https://w3id.org/finos/cdm/mimeType",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Indicates the type of media used to store the content. mimeType is used to determine the software product(s) that can read the content. MIME Types are described in RFC 2046.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/mimeType",
      "owner": "Resource",
      "domain_of": [
        "Resource"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "comments",
      "definition_uri": "https://w3id.org/finos/cdm/comments",
      "description": "Any additional comments that are deemed necessary. For example, which software version is required to open the document? Or, how does this resource relate to the others for this event?",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/comments",
      "owner": "Resource",
      "domain_of": [
        "Resource"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "string",
      "definition_uri": "https://w3id.org/finos/cdm/string",
      "description": "Provides extra information as string. In case the extra information is in XML format, a CDATA section must be placed around the source message to prevent its interpretation as XML content.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_common",
      "slot_uri": "https://w3id.org/finos/cdm/string",
