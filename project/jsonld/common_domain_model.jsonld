        "EligibleCollateralSpecification_party",
        "EligibleCollateralSpecification_counterparty",
        "EligibleCollateralSpecification_criteria",
        "EligibleCollateralSpecification_partyRole"
      ],
      "slot_usage": {},
      "tree_root": true,
      "@type": "ClassDefinition"
    },
