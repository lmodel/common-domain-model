      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "priceQuantity",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "When there is an OptionPayout the quantity can be expressed as part of the payoutQuantity, or as part of the underlier in the case of a Swaption.  For all other payouts that extend PayoutBase the payoutQuantity is a mandatory attribute.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "CancelableProvision",
      "definition_uri": "https://w3id.org/finos/cdm/CancelableProvision",
      "description": "A data defining:  the right of a party to cancel a swap transaction on the specified exercise dates. The provision is for 'walk-away' cancellation (i.e. the fair value of the swap is not paid). A fee payable on exercise can be specified. As a difference from the FpML construct, the canonical model extends the BuyerSeller class.",
      "comments": [
        "Rosetta condition: EffectiveDate \u2014 optional choice effectiveDate, effectivePeriod",
        "Rosetta condition: CancelableProvisionExerciseNoticeReceiverParty \u2014 if exerciseNotice -> exerciseNoticeReceiver exists then exerciseNotice -> exerciseNoticeReceiver = AncillaryRoleEnum -> ExerciseNoticeReceiverPartyCancelableProvision"
      ],
      "in_subset": [
        "cdm_product_template"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "exact_mappings": [
        "common_domain_model:CancelableProvision"
      ],
      "close_mappings": [
        "fpml_5_10:CancelableProvision"
      ],
      "is_a": "BuyerSeller",
      "slots": [
        "buyer",
        "seller",
        "exerciseNotice",
        "followUpConfirmation",
        "cancelableProvisionAdjustedDates",
        "finalCalculationPeriodDateAdjustment",
        "initialFee",
        "callingParty",
        "earliestDate",
        "expirationDate",
        "CancelableProvision_effectiveDate",
        "effectivePeriod",
        "earliestCancellationTime",
        "latestCancelationTime",
        "CancelableProvision_exerciseTerms"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "any_of": [
              {
                "slot_conditions": [
                  {
                    "name": "effectiveDate",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "effectivePeriod",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Must select one of predefined cancellation types of effectiveDate or effectivePeriod.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
