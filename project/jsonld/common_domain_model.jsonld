    {
      "name": "NotionalAdjustmentEnum",
      "definition_uri": "https://w3id.org/finos/cdm/NotionalAdjustmentEnum",
      "description": "The enumerated values to specify the conditions that govern the adjustment to the number of units of the return swap.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common",
      "permissible_values": [
        {
          "text": "Execution",
          "description": "The adjustments to the number of units are governed by an execution clause."
        },
        {
          "text": "PortfolioRebalancing",
          "description": "The adjustments to the number of units are governed by a portfolio rebalancing clause."
        },
        {
          "text": "Standard",
          "description": "The adjustments to the number of units are not governed by any specific clause."
        }
      ]
    },
    {
      "name": "PayRelativeToEnum",
      "definition_uri": "https://w3id.org/finos/cdm/PayRelativeToEnum",
      "description": "The enumerated values to specify whether payments occur relative to the calculation period start date or end date, each reset date, valuation date or the last pricing date.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "permissible_values": [
        {
          "text": "CalculationPeriodStartDate",
          "description": "Payments will occur relative to the first day of each calculation period."
        },
        {
          "text": "CalculationPeriodEndDate",
          "description": "Payments will occur relative to the last day of each calculation period."
        },
        {
          "text": "LastPricingDate",
          "description": "Payments will occur relative to the last Pricing Date of each Calculation Period."
        },
        {
          "text": "ResetDate",
          "description": "Payments will occur relative to the reset date."
        },
        {
          "text": "ValuationDate",
          "description": "Payments will occur relative to the valuation date."
        }
      ]
    },
    {
      "name": "ResetRelativeToEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ResetRelativeToEnum",
      "description": "The enumerated values to specify whether resets occur relative to the first or last day of a calculation period.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "permissible_values": [
        {
          "text": "CalculationPeriodStartDate",
          "description": "Resets occur relative to the first day of a calculation period."
        },
        {
          "text": "CalculationPeriodEndDate",
          "description": "Resets occur relative to the last day of a calculation period."
        }
      ]
    },
    {
      "name": "StubPeriodTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/StubPeriodTypeEnum",
      "description": "The enumerated values to specify how to deal with a non standard calculation period within a swap stream.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "permissible_values": [
        {
          "text": "ShortInitial",
          "description": "If there is a non regular period remaining it is left shorter than the streams calculation period frequency and placed at the start of the stream."
        },
        {
          "text": "ShortFinal",
          "description": "If there is a non regular period remaining it is left shorter than the streams calculation period frequency and placed at the end of the stream."
        },
        {
          "text": "LongInitial",
          "description": "If there is a non regular period remaining it is placed at the start of the stream and combined with the adjacent calculation period to give a long first calculation period."
        },
        {
          "text": "LongFinal",
          "description": "If there is a non regular period remaining it is placed at the end of the stream and combined with the adjacent calculation period to give a long last calculation period."
        }
      ]
    },
    {
      "name": "WeeklyRollConventionEnum",
      "definition_uri": "https://w3id.org/finos/cdm/WeeklyRollConventionEnum",
      "description": "The enumerated values to specify the weekly roll day.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "permissible_values": [
        {
          "text": "TBILL",
          "description": "13-week and 26-week U.S. Treasury Bill Auction Dates. Each Monday except for U.S. (New York) holidays when it will occur on a Tuesday"
        }
      ],
      "inherits": [
        "DayOfWeekEnum"
      ]
    },
    {
      "name": "DeliveryMethodEnum",
      "definition_uri": "https://w3id.org/finos/cdm/DeliveryMethodEnum",
      "description": "Specifies delivery methods for securities transactions. This coding-scheme defines the possible delivery methods for securities.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/delivery-method"
      ],
      "permissible_values": [
        {
          "text": "DeliveryVersusPayment",
          "description": "Indicates that a securities delivery must be made against payment in simultaneous transmissions and stipulate each other.",
          "meaning": "http://www.fpml.org/coding-scheme/delivery-method-1-0#DeliveryVersusPayment"
        },
        {
          "text": "FreeOfPayment",
          "description": "Indicates that a securities delivery can be made without a simultaneous cash payment in exchange and not depending on if payment obligations are fulfilled or not and vice versa.",
          "meaning": "http://www.fpml.org/coding-scheme/delivery-method-1-0#FreeOfPayment"
        },
        {
          "text": "PreDelivery",
          "description": "Indicates that a securities delivery must be made in full before the payment for the securities; fulfillment of payment obligations depends on securities delivery obligations fulfillment.",
          "meaning": "http://www.fpml.org/coding-scheme/delivery-method-1-0#PreDelivery"
        },
        {
          "text": "PrePayment",
          "description": "Indicates that a payment in full amount must be made before the securities delivery; fulfillment of securities delivery obligations depends on payment obligations fulfillment.",
          "meaning": "http://www.fpml.org/coding-scheme/delivery-method-1-0#PrePayment"
        }
      ]
    },
    {
      "name": "ScheduledTransferEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ScheduledTransferEnum",
      "description": "The qualification of the type of transfers and cash flows associated with contracts and their lifecycle events.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "permissible_values": [
        {
          "text": "CorporateAction",
          "description": "A cash flow corresponding to a corporate action event."
        },
        {
          "text": "Coupon",
          "description": "A cash flow corresponding to the periodic accrued interests."
        },
        {
          "text": "CreditEvent",
          "description": "A cashflow resulting from a credit event."
        },
        {
          "text": "DividendReturn",
          "description": "A cash flow corresponding to the synthetic dividend of an equity underlier asset traded through a derivative instrument."
        },
        {
          "text": "Exercise",
          "description": "A cash flow associated with an exercise lifecycle event."
        },
        {
          "text": "FixedRateReturn",
          "description": "A cash flow corresponding to the return of the fixed interest rate portion of a derivative instrument that has different types of underlying assets, such as a total return swap."
        },
        {
          "text": "FloatingRateReturn",
          "description": "A cash flow corresponding to the return of the floating interest rate portion of a derivative instrument that has different types of underlying assets, such as a total return swap."
        },
        {
          "text": "FractionalAmount",
          "description": "A cash flow corresponding to the compensation for missing assets due to the rounding of digits in the original number of assets to be delivered as per payout calculation."
        },
        {
          "text": "InterestReturn",
          "description": "A cash flow corresponding to the return of the interest rate portion of a derivative instrument that has different types of underlying assets, such as a total return swap."
        },
        {
          "text": "NetInterest",
          "description": "Net interest across payout components. Applicable to products such as interest rate swaps."
        },
        {
          "text": "Performance",
          "description": "A cash flow corresponding to a performance return.  The settlementOrigin attribute on the Transfer should point to the relevant Payout defining the performance calculation."
        },
        {
          "text": "Principal",
          "description": "An amount which corresponds to the notional of the contract for various business reasons. This could be associated to a cashflow (e.g. a principal payment) or a transfer (e.g. delivery of an asset)."
        }
      ]
    },
    {
      "name": "UnscheduledTransferEnum",
      "definition_uri": "https://w3id.org/finos/cdm/UnscheduledTransferEnum",
      "description": "The qualification of the type of ad-hoc transfers and cash flows that can be associated with contracts and their lifecycle events.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "permissible_values": [
        {
          "text": "Recall",
          "description": "A recall of securities by the lender who has lent them out."
        },
        {
          "text": "Return",
          "description": "A return by the borrower to the lender of the full or partial quantity of securities on the contract."
        },
        {
          "text": "Assignment",
          "description": "A transfer resulting from the assignment of a contract to a new counterparty."
        },
        {
          "text": "BrokerageCommission",
          "description": "The brokerage commission."
        },
        {
          "text": "Increase",
          "description": "A transfer associated with an increase lifecycle event."
        },
        {
          "text": "Novation",
          "description": "The novation fee."
        },
        {
          "text": "PartialTermination",
          "description": "A transfer associated with a partial termination lifecycle event."
        },
        {
          "text": "Premium",
          "description": "Denotes the amount payable by the buyer to the seller for an option. The premium is paid on the specified premium payment date or on each premium payment date if specified."
        },
        {
          "text": "Renegotiation",
          "description": "A transfer associated with a renegotiation lifecycle event."
        },
        {
          "text": "Termination",
          "description": "A transfer associated with a termination lifecycle event."
        },
        {
          "text": "Upfront",
          "description": "An upfront transfer associated to the swap to adjust for a difference between the swap price and the current market price."
        },
        {
          "text": "CreditEvent",
          "description": "A transfer associated with a credit event."
        },
        {
          "text": "CorporateAction",
          "description": "A transfer associated with a corporate action"
        }
      ]
    },
    {
      "name": "SettlementTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SettlementTypeEnum",
      "description": "The enumeration values to specify how the option is to be settled when exercised.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "permissible_values": [
        {
          "text": "Cash",
          "description": "The intrinsic value of the option will be delivered by way of a cash settlement amount determined, (i) by reference to the differential between the strike price and the settlement price; or (ii) in accordance with a bilateral agreement between the parties."
        },
        {
          "text": "Physical",
          "description": "The securities underlying the transaction will be delivered by (i) in the case of a call, the seller to the buyer, or (ii) in the case of a put, the buyer to the seller versus a settlement amount equivalent to the strike price per share."
        },
        {
          "text": "Election",
          "description": "Allow Election of either Cash or Physical settlement."
        },
        {
          "text": "CashOrPhysical",
          "description": "Allow use of either Cash or Physical settlement without prior Election."
        }
      ]
    },
    {
      "name": "TransferSettlementEnum",
      "definition_uri": "https://w3id.org/finos/cdm/TransferSettlementEnum",
      "description": "The enumeration values to specify how the transfer will settle, e.g. DvP.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "permissible_values": [
        {
          "text": "DeliveryVersusDelivery",
          "description": "Simultaneous transfer of two assets, typically securities, as a way to avoid settlement risk."
        },
        {
          "text": "DeliveryVersusPayment",
          "description": "Settlement in which the transfer of the asset and the cash settlement are simultaneous."
        },
        {
          "text": "PaymentVersusPayment",
          "description": "Simultaneous transfer of cashflows."
        },
        {
          "text": "NotCentralSettlement",
          "description": "No central settlement."
        }
      ]
    },
    {
      "name": "StandardSettlementStyleEnum",
      "definition_uri": "https://w3id.org/finos/cdm/StandardSettlementStyleEnum",
      "description": "The enumerated values to specify whether a trade is settling using standard settlement instructions as well as whether it is a candidate for settlement netting.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "permissible_values": [
        {
          "text": "Standard",
          "description": "This trade will settle using standard predetermined funds settlement instructions."
        },
        {
          "text": "Net",
          "description": "This trade is a candidate for settlement netting."
        },
        {
          "text": "StandardAndNet",
          "description": "This trade will settle using standard predetermined funds settlement instructions and is a candidate for settlement netting."
        },
        {
          "text": "PairAndNet",
          "description": "These trades have been paired and are a candidate for settlement netting."
        }
      ]
    },
    {
      "name": "CashSettlementMethodEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CashSettlementMethodEnum",
      "description": "Defines the different cash settlement methods for a product where cash settlement is applicable.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "permissible_values": [
        {
          "text": "CashPriceMethod",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2006 ISDA Definitions, Section 18.3. Cash Settlement Methods, paragraph (a)."
        },
        {
          "text": "CashPriceAlternateMethod",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2006 ISDA Definitions, Section 18.3. Cash Settlement Methods, paragraph (b)."
        },
        {
          "text": "ParYieldCurveAdjustedMethod",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2006 ISDA Definitions, Section 18.3. Cash Settlement Methods, paragraph (c)."
        },
        {
          "text": "ZeroCouponYieldAdjustedMethod",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2006 ISDA Definitions, Section 18.3. Cash Settlement Methods, paragraph (d)."
        },
        {
          "text": "ParYieldCurveUnadjustedMethod",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2006 ISDA Definitions, Section 18.3. Cash Settlement Methods, paragraph (e)."
        },
        {
          "text": "CrossCurrencyMethod",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2006 ISDA Definitions, Section 18.3. Cash Settlement Methods, paragraph (f) (published in Supplement number 23)."
        },
        {
          "text": "CollateralizedCashPriceMethod",
          "description": "An ISDA defined cash settlement method (yield curve) used for the determination of the applicable cash settlement amount. The method is defined in the 2006 ISDA Definitions, Section 18.3. Cash Settlement Methods, paragraph (g) (published in Supplement number 28). The method is defined in the 2021 ISDA Definitions, section 18.2.6."
        },
        {
          "text": "MidMarketIndicativeQuotations",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2021 ISDA Definitions, Section 18.2.1."
        },
        {
          "text": "MidMarketIndicativeQuotationsAlternate",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2021 ISDA Definitions, Section 18.2.2."
        },
        {
          "text": "MidMarketCalculationAgentDetermination",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2021 ISDA Definitions, Section 18.2.3."
        },
        {
          "text": "ReplacementValueFirmQuotations",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2021 ISDA Definitions, Section 18.2.4."
        },
        {
          "text": "ReplacementValueCalculationAgentDetermination",
          "description": "An ISDA defined cash settlement method used for the determination of the applicable cash settlement amount. The method is defined in the 2021 ISDA Definitions, Section 18.2.5"
        }
      ]
    },
    {
      "name": "SettlementCentreEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SettlementCentreEnum",
      "description": "Defines the settlement centre for a securities transaction.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_settlement",
      "permissible_values": [
        {
          "text": "EuroclearBank",
          "description": "Euroclear Bank"
        },
        {
          "text": "ClearstreamBankingLuxembourg",
          "description": "ClearStream Banking Luxembourg"
        }
      ]
    },
    {
      "name": "AveragingInOutEnum",
      "definition_uri": "https://w3id.org/finos/cdm/AveragingInOutEnum",
      "description": "The enumerated values to specify the type of averaging used in an Asian option.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "In",
          "description": "The average price is used to derive the strike price. Also known as 'Asian strike' style option."
        },
        {
          "text": "Out",
          "description": "The average price is used to derive the expiration price. Also known as 'Asian price' style option."
        },
        {
          "text": "Both",
          "description": "The average price is used to derive both the strike and the expiration price."
        }
      ]
    },
    {
      "name": "OptionTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/OptionTypeEnum",
      "description": "The enumerated values to specify the type or strategy of the option.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "exact_mappings": [
        "http://www.fpml.org/coding-scheme/option-type"
      ],
      "permissible_values": [
        {
          "text": "Payer",
          "description": "A 'payer' option: If you buy a 'payer' option you have the right but not the obligation to enter into the underlying swap transaction as the 'fixed' rate/price payer and receive float."
        },
        {
          "text": "Receiver",
          "description": "A 'receiver' option: If you buy a 'receiver' option you have the right but not the obligation to enter into the underlying swap transaction as the 'fixed' rate/price receiver and pay float."
        },
        {
          "text": "Straddle",
          "description": "A straddle strategy, which involves the simultaneous buying of a put and a call of the same underlier, at the same strike and same expiration date",
          "meaning": "http://www.fpml.org/coding-scheme/option-type-1-0#Straddle"
        }
      ],
      "inherits": [
        "PutCallEnum"
      ]
    },
    {
      "name": "OptionExerciseStyleEnum",
      "definition_uri": "https://w3id.org/finos/cdm/OptionExerciseStyleEnum",
      "description": "The enumerated values to specify the option exercise style. i.e., European, Bermuda or American.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "European",
          "description": "Single Exercise"
        },
        {
          "text": "Bermuda",
          "description": "Multiple specified exercise dates"
        },
        {
          "text": "American",
          "description": "Continuous exercise over a range of dates"
        }
      ]
    },
    {
      "name": "CallingPartyEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CallingPartyEnum",
      "description": "Identifies a party to the on-demand repo transaction that has a right to demand for termination of the Security Finance transaction.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "InitialBuyer",
          "description": "Initial buyer to the repo transaction."
        },
        {
          "text": "InitialSeller",
          "description": "Initial seller to the repo transaction."
        },
        {
          "text": "Either",
          "description": "Either, Buyer or Seller to the repo transaction."
        },
        {
          "text": "AsDefinedInMasterAgreement",
          "description": "As defined in Master Agreement."
        }
      ]
    },
    {
      "name": "ExerciseNoticeGiverEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ExerciseNoticeGiverEnum",
      "description": "Defines the principal party to the trade that has the right to exercise.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "Buyer",
          "description": "Specifies that only the option buyer has the right to exercise."
        },
        {
          "text": "Seller",
          "description": "Specifies that only the option seller has the right to exercise."
        },
        {
          "text": "Both",
          "description": "Specifies that both the option buyer and option seller has the right to exercise."
        },
        {
          "text": "AsSpecifiedInMasterAgreement",
          "description": "Specifies that the Master Agreement defines the principal party to the trade that has the right to exercise."
        }
      ]
    },
    {
      "name": "MarginTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/MarginTypeEnum",
      "description": "This indicator defines which type of assets (cash or securities) is specified to apply as margin to the repo transaction.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "Cash",
          "description": "When the margin type is Cash, the margin factor is applied to the cash value of the transaction."
        },
        {
          "text": "Instrument",
          "description": "When the margin type is Instrument, the margin factor is applied to the instrument value for the transaction. In the 'instrument' case, the haircut would be applied to the securities."
        }
      ]
    },
    {
      "name": "RepoDurationEnum",
      "definition_uri": "https://w3id.org/finos/cdm/RepoDurationEnum",
      "description": "A duration code for a Repo (or Securities Lending) transaction. There are many business and market rules that are derived from the duration of the transaction.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "Overnight",
          "description": "Indicates that a contract is classified as overnight, meaning that there is one business day difference between the start and end date of the contract. Business rule: When the repo is overnight, the number of business days between the spot and forward value dates must be one. Forward leg must be specified."
        },
        {
          "text": "Term",
          "description": "Indicates that a contract is a regular term contract, with a start date and an end date. Business rule: When the repo is 'Term', both spot and forward legs must be specified."
        }
      ]
    },
    {
      "name": "AssetPayoutTradeTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/AssetPayoutTradeTypeEnum",
      "description": "An enumerator to differentiate the different trade types used in securities finance and modelled on an AssetPayout.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "Repo",
          "description": "In the case of a repurchase transaction, an immediate and equal income payment (often call a manufactured payment) is made by the buyer to the seller."
        },
        {
          "text": "BuySellBack",
          "description": "In the case of a buy/sell-back, there is no income payment between buyer and seller. Instead, the repurchase price to be paid on the repurchase date is reduced by the amount of the income payment on the collateral plus some extra interest to compensate the seller for the delay between the income payment date on the collateral and the repurchase date of the repo.",
          "aliases": [
            "Buy/Sell-Back"
          ]
        },
        {
          "text": "SecurityLending",
          "description": "Denotes this payout as being associated to the security being lent as part of a securities lending contract."
        }
      ]
    },
    {
      "name": "ExpirationTimeTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ExpirationTimeTypeEnum",
      "description": "The time of day at which the equity option expires, for example the official closing time of the exchange.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "permissible_values": [
        {
          "text": "Close",
          "description": "The official closing time of the exchange on the valuation date."
        },
        {
          "text": "Open",
          "description": "The official opening time of the exchange on the valuation date."
        },
        {
          "text": "OSP",
          "description": "The time at which the official settlement price is determined."
        },
        {
          "text": "SpecificTime",
          "description": "The time specified in the element equityExpirationTime or valuationTime (as appropriate)"
        },
        {
          "text": "XETRA",
          "description": "The time at which the official settlement price (following the auction by the exchange) is determined by the exchange."
        },
        {
          "text": "DerivativesClose",
          "description": "The official closing time of the derivatives exchange on which a derivative contract is listed on that security underlyer."
        },
        {
          "text": "AsSpecifiedInMasterConfirmation",
          "description": "The time is determined as provided in the relevant Master Confirmation."
        }
      ]
    }
  ],
  "slots": [
