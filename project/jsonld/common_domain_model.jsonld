        "LegacyIndependentAmountParty_ratingsBased",
        "ratingsXExposure"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "fixedAmount",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "ratingsBased",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "ratingsXExposure",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "Ensures that the Independent Amount is specified as only one of Fixed Amount, Ratings Based or RatingsXExposure.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "IndependentAmountRatings",
      "definition_uri": "https://w3id.org/finos/cdm/IndependentAmountRatings",
      "description": "A logical container designed to hold a set of related data. In this case, designed to hold a set of information required when Independent Amount is determined using credit ratings.",
      "comments": [
        "Rosetta condition: RestrictCompare \u2014 if compare exists then compare = IndependentAmountCompareEnum -> Compare or compare = IndependentAmountCompareEnum -> Lowest or compare = IndependentAmountCompareEnum -> Highest",
        "Rosetta condition: NamedAffiliate \u2014 if ratedParty = RatedPartyEnum -> NamedAffiliate then namedAffiliate exists else namedAffiliate is absent",
        "Rosetta condition: NamedEntity \u2014 if ratedParty = RatedPartyEnum -> NamedEntity then namedEntity exists else namedEntity is absent"
      ],
