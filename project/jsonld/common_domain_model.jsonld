    {
      "name": "Identifier",
      "definition_uri": "https://w3id.org/finos/cdm/Identifier",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "A class to specify a generic identifier, applicable to CDM artefacts such as executions, contracts, lifecycle events and legal documents. An issuer can be associated with the actual identifier value as a way to properly qualify it.",
      "comments": [
        "Rosetta condition: IssuerChoice \u2014 required choice issuerReference, issuer"
      ],
      "in_subset": [
        "cdm_base_staticdata_identifier"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_identifier",
      "exact_mappings": [
        "common_domain_model:Identifier"
      ],
      "close_mappings": [
        "gist:ID",
        "oscal:PartyExternalId",
        "spdx:ExternalIdentifier"
      ],
      "slots": [
        "issuerReference",
        "issuer",
        "assignedIdentifier"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "issuerReference",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "issuer",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "The identifier issuer is specified either explicitly or by reference to one of the parties.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
    {
      "name": "IdentifiedList",
      "definition_uri": "https://w3id.org/finos/cdm/IdentifiedList",
      "annotations": [
        {
          "tag": "metadata_key",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Attaches an identifier to a collection of objects, when those objects themselves can each be represented by an identifier. One use case is the representation of package transactions, where each component is a separate trade with its own identifier, and those trades are linked together as a package with its own identifier. The data type has been named generically rather than referring to 'packages' as it may have a number of other uses.",
      "in_subset": [
        "cdm_base_staticdata_identifier"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_identifier",
      "exact_mappings": [
        "common_domain_model:IdentifiedList"
      ],
      "slots": [
        "listId",
        "componentId",
        "price"
      ],
      "slot_usage": {},
      "@type": "ClassDefinition"
    },
