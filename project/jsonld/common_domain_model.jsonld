      "owner": "CalculationPeriodDates",
      "domain_of": [
        "CalculationPeriodDates"
      ],
      "range": "date",
      "@type": "SlotDefinition"
    },
    {
      "name": "firstCompoundingPeriodEndDate",
      "definition_uri": "https://w3id.org/finos/cdm/firstCompoundingPeriodEndDate",
      "description": "The end date of the initial compounding period when compounding is applicable. It must only be specified when the compoundingMethod element is present and not equal to a value of None. This date may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CalculationPeriodDates.firstCompoundingPeriodEndDate"
      ],
      "slot_uri": "https://w3id.org/finos/cdm/firstCompoundingPeriodEndDate",
      "owner": "CalculationPeriodDates",
      "domain_of": [
        "CalculationPeriodDates"
      ],
      "range": "date",
      "@type": "SlotDefinition"
    },
    {
      "name": "lastRegularPeriodEndDate",
      "definition_uri": "https://w3id.org/finos/cdm/lastRegularPeriodEndDate",
      "description": "The end date of the regular part of the calculation period schedule. It must only be specified if there is a final stub calculation period. This day may be subject to adjustment in accordance with any adjustments specified in calculationPeriodDatesAdjustments.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "close_mappings": [
        "https://www.fpml.org/spec/fpml-5-10#CalculationPeriodDates.lastRegularPeriodEndDate"
