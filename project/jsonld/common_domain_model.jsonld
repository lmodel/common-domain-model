    {
      "name": "ApplicabilityOfElectionEnum",
      "definition_uri": "https://w3id.org/finos/cdm/ApplicabilityOfElectionEnum",
      "description": "The potential options for specifying whether a particular election applies in a GMSLA.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_master_isla",
      "permissible_values": [
        {
          "text": "Applicable",
          "description": "The election is applicable."
        },
        {
          "text": "NotApplicable",
          "description": "The election is not applicable."
        },
        {
          "text": "NotSpecified",
          "description": "The applicability of the election has not been specified."
        }
      ]
    },
    {
      "name": "AggregationSpecificationEnum",
      "definition_uri": "https://w3id.org/finos/cdm/AggregationSpecificationEnum",
      "description": "The potential options for specifying whether mark to market value of collateral is determined on an aggregated or loan by loan basis.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_legaldocumentation_master_isla",
      "permissible_values": [
        {
          "text": "Aggregated",
          "description": "The market value is determined on an aggregated basis."
        },
        {
          "text": "LoanByLoan",
          "description": "The market value is determined on a loan by loan basis."
        },
        {
          "text": "AggregatedAndLoanByLoan",
          "description": "The market value is determined on an aggregated basis for some loans but on a Loan by Loan basis for others."
        },
        {
          "text": "NotSpecified",
          "description": "It is not specified how the market value is determined."
        }
      ]
    },
