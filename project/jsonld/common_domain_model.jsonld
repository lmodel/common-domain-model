        "exchange",
        "relatedExchange",
        "assetType",
        "securityType",
        "debtType",
        "equityType",
        "fundType"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "securityType",
                "none_of": [
                  {
                    "equals_string_in": [
                      "Debt"
                    ],
                    "@type": "AnonymousSlotExpression"
                  }
                ],
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "debtType",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "DebtSubType",
          "comments": [
            "Rosetta negation: securityType <> Debt"
          ],
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "securityType",
                "none_of": [
                  {
                    "equals_string_in": [
                      "Equity"
                    ],
                    "@type": "AnonymousSlotExpression"
                  }
                ],
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "equityType",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "EquitySubType",
          "comments": [
            "Rosetta negation: securityType <> Equity"
          ],
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "securityType",
                "none_of": [
                  {
                    "equals_string_in": [
                      "Fund"
                    ],
                    "@type": "AnonymousSlotExpression"
                  }
                ],
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "fundType",
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": "FundSubType",
          "comments": [
            "Rosetta negation: securityType <> Fund"
          ],
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
