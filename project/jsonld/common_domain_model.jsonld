    {
      "name": "ObservationInstruction",
      "definition_uri": "https://w3id.org/finos/cdm/ObservationInstruction",
      "annotations": [
        {
          "tag": "rosetta_functions",
          "value": "[{\"name\":\"Create_Observation\",\"description\":\"Function specification to create an observation that incorporates an observation event into the observation history of a given trade state.\",\"inputs\":[{\"name\":\"instruction\",\"type\":\"ObservationInstruction\",\"cardinality\":\"1..1\"},{\"name\":\"before\",\"type\":\"TradeState\",\"cardinality\":\"1..1\"}],\"output\":{\"name\":\"after\",\"type\":\"TradeState\",\"cardinality\":\"1..1\"}}]",
          "@type": "Annotation"
        }
      ],
      "description": "Specifies inputs needed to process an observation.",
      "comments": [
        "Rosetta func: Create_Observation \u2014 Function specification to create an observation that incorporates an observation event into the observation history of a given trade state."
      ],
      "in_subset": [
        "cdm_event_common"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_common",
