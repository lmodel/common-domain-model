        "ProtectionTerms_obligations",
        "floatingAmountEvents"
      ],
      "slot_usage": {},
      "@type": "ClassDefinition"
    },
    {
      "name": "ReferenceInformation",
      "definition_uri": "https://w3id.org/finos/cdm/ReferenceInformation",
      "description": "A class specifying the Credit Default Swap Reference Information.",
      "comments": [
        "Rosetta condition: ReferenceInformationChoice \u2014 required choice referenceObligation, noReferenceObligation , unknownReferenceObligation"
      ],
      "in_subset": [
        "cdm_product_asset"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "exact_mappings": [
