          "description": "Sammarinese Lira."
        },
        {
          "text": "VAL",
          "description": "Vatican Lira."
        }
      ],
      "inherits": [
        "ISOCurrencyCodeEnum"
      ]
    },
    {
      "name": "CollateralEntityTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CollateralEntityTypeEnum",
      "description": "Represents an enumeration list to identify the type of entity issuing or guaranteeing the collateral asset.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "SupraNational",
          "description": "Specifies international organisations and multilateral banks, entities constituted by treaties or with multiple sovereign members includes Multilateral development Banks."
        },
        {
          "text": "SovereignCentralBank",
          "description": "Specifies Sovereign, Government Debt Securities including Central Banks."
        },
        {
          "text": "QuasiGovernment",
          "description": "Specifies institutions or bodies, typically constituted by statute, with a function mandated by the government and subject to government supervision inclusive of profit- and non-profit making bodies. Includes the US Agencies and GSEs and the EU concept of public sector entities. Excluding any entities which are also Regional Government."
        },
        {
          "text": "RegionalGovernment",
          "description": "Specifies Regional Governments including states within countries, local authorities and municipalities."
        },
        {
          "text": "Corporate",
          "description": "Specifies corporate bodies including Banks."
        },
        {
          "text": "Fund",
          "description": "Specifies a vehicle (with or without separate legal personality) designed for the purposes of collective investment towards a defined investment goal."
        },
        {
          "text": "SpecialPurposeVehicle",
          "description": "Specifies a vehicle setup for the purpose of acquisition and financing of specific assets on a limited recourse basis. E.g. asset backed securities, including securitisations."
        }
      ]
    },
    {
      "name": "SupraNationalIssuerTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SupraNationalIssuerTypeEnum",
      "description": "Represents an enumeration list to identify the type of supranational entity issuing the asset.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "InternationalOrganisation",
          "description": "Specifies International Financial Institution."
        },
        {
          "text": "MultilateralBank",
          "description": "Specifies Multilateral Bank or Multilateral Development Bank."
        }
      ]
    },
    {
      "name": "CreditRiskEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CreditRiskEnum",
      "description": "Represents an enumeration list to identify tranched or untranched credit risk.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "TranchedCreditRisk",
          "description": "Indicates tranched credit risk, including securitizations."
        },
        {
          "text": "UntranchedCreditRisk",
          "description": "Indicates tranched credit risk, including repackagings."
        }
      ]
    },
    {
      "name": "SecurityTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SecurityTypeEnum",
      "description": "Represents an enumeration list to indentify the type of a security.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Debt",
          "description": "Identifies a security as a fixed income security of debt issued and securitized as a tradable asset."
        },
        {
          "text": "Equity",
          "description": "Identifies a security as an Equity value of holding of shares in listed company."
        },
        {
          "text": "Fund",
          "description": "Identifies a security as representing holding in an investment fund."
        },
        {
          "text": "Warrant",
          "description": "Identifies a security as a Warrant that give the right, but not the obligation, to buy or sell a security \u2014 most commonly an equity \u2014 at a certain price before expiration, or to receive the cash equivalent."
        },
        {
          "text": "Certificate",
          "description": "Identifies a security as one that that offers a derivative-based economic return which is not structured as a bond, an equity or a warrant. Note that this security type is not a Certificate of Deposit (aka CD)."
        }
      ]
    },
    {
      "name": "PutCallEnum",
      "definition_uri": "https://w3id.org/finos/cdm/PutCallEnum",
      "description": "The enumerated values to specify the types of listed derivative options.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Put",
          "description": "A put option gives the holder the right to sell the underlying asset by a certain date for a certain price."
        },
        {
          "text": "Call",
          "description": "A call option gives the holder the right to buy the underlying asset by a certain date for a certain price."
        }
      ]
    },
    {
      "name": "EquityTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/EquityTypeEnum",
      "description": "Represents an enumeration list to identify the type of Equity.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Ordinary",
          "description": "Identifies an Equity of Common stocks and shares."
        },
        {
          "text": "NonConvertiblePreference",
          "description": "Identifies an Equity of Non-Convertible Preference, Shares which hold priority to receive capital return in event of issuer liquidation."
        },
        {
          "text": "DepositaryReceipt",
          "description": "Identifies a negotiable depositary receipt certificate issued by a bank representing shares in a foreign company traded on a local stock exchange."
        },
        {
          "text": "ConvertiblePreference",
          "description": "Identifies an Equity of Convertible Preference, a stock which can be converted into a predetermined number of common shares and holds priority to receive capital return in event of issuer liquidation."
        }
      ]
    },
    {
      "name": "DepositaryReceiptTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/DepositaryReceiptTypeEnum",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "ADR",
          "description": "American Depositary Receipts. Identifies a depositary receipt that are issued only by U.S. banks for foreign stocks that are traded on a U.S. exchange."
        },
        {
          "text": "GDR",
          "description": "Global Depositary Receipts. Identifies a depositary receipt that is listed on European and other international exchanges."
        },
        {
          "text": "IDR",
          "description": "Indian Depositary Receipts. Identifies a depositary receipt that are issued only by domestic depositories for foreign stocks that are traded on an Indian exchange."
        },
        {
          "text": "EDR",
          "description": "European Depositary Receipts. Identifies a depositary receipt that are issued only by European banks for foreign stocks that are traded on a European exchange."
        }
      ]
    },
    {
      "name": "FundProductTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/FundProductTypeEnum",
      "description": "Represents an enumeration list to identify the fund product type.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "MoneyMarketFund",
          "description": "Denotes a fund that invests only in highly liquid near-term instruments such as cash, cash equivalent securities, and high credit rating debt instruments with a short-term maturity."
        },
        {
          "text": "ExchangeTradedFund",
          "description": "Denotes an investment fund consisting of stocks, bonds, and/or other assets that is passively managed and traded on a stock exchange."
        },
        {
          "text": "MutualFund",
          "description": "Denotes an investment fund consisting of stocks, bonds, and/or other assets that is actively managed and can only be purchased or sold through the investment manager."
        },
        {
          "text": "OtherFund",
          "description": "Denotes a fund that is not an Exchange Traded Fund, Money Market Fund or Mutual Fund."
        }
      ]
    },
    {
      "name": "MaturityTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/MaturityTypeEnum",
      "description": "Represents an enumeration list to identify the Maturity.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "RemainingMaturity",
          "description": "Denotes a period from now until maturity date."
        },
        {
          "text": "OriginalMaturity",
          "description": "Denotes a period from issuance until maturity date."
        },
        {
          "text": "FromIssuance",
          "description": "Denotes a period from issuance date until now."
        }
      ]
    },
    {
      "name": "SecuredTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/SecuredTypeEnum",
      "description": "Specifies the type of secured debt.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "AssetBacked",
          "description": "Debt instrument with periodic income payments and value derived from or backed by a specified pool of underlying assets."
        },
        {
          "text": "CollateralizedObligation",
          "description": "Complex product that is backed by a pool of loans and other assets and sold to institutional investors."
        },
        {
          "text": "CoveredBonds",
          "description": "Specifies a debt obligations issued by credit institutions which offer a so-called double-recourse protection to bondholders."
        }
      ]
    },
    {
      "name": "AssetBackedEnum",
      "definition_uri": "https://w3id.org/finos/cdm/AssetBackedEnum",
      "description": "Specifies the underlying asset or asset pool securing an Asset Backed debt instrument.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "HomeEquity",
          "description": "When the asset(s) backing the debt are home equity loans, in which the borrower uses the equity of their home as collateral."
        },
        {
          "text": "AutoLoan",
          "description": "When the asset(s) backing the debt are auto loans."
        },
        {
          "text": "StudentLoan",
          "description": "When the asset(s) backing the debt are student loans."
        },
        {
          "text": "CreditCard",
          "description": "When the asset(s) backing the debt are credit card loans."
        },
        {
          "text": "Property",
          "description": "When the asset(s) backing the debt are property, typically when the debt is a mortgage loan."
        },
        {
          "text": "Mortgage",
          "description": "When the asset(s) backing the debt instrument is a pool of mortgage loans, e.g. for a mortgage backed security."
        },
        {
          "text": "Other",
          "description": "Any other asset which generates receivables for an Asset Backed Security."
        }
      ]
    },
    {
      "name": "PropertyTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/PropertyTypeEnum",
      "description": "Specifies different types of property.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Commercial",
          "description": "Commercial property."
        },
        {
          "text": "Residential",
          "description": "Residential property."
        }
      ]
    },
    {
      "name": "CollateralizedObligationEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CollateralizedObligationEnum",
      "description": "Specifies the type of Collateralized Obligation.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "CDO",
          "description": "Collateralized Debt Obligation."
        },
        {
          "text": "CMO",
          "description": "Collateralized Mortgage Obligation."
        },
        {
          "text": "CLO",
          "description": "Collateralized Loan Obligation."
        },
        {
          "text": "CBO",
          "description": "Collateralized Bond Obligation."
        }
      ]
    },
    {
      "name": "CoveredBondEnum",
      "definition_uri": "https://w3id.org/finos/cdm/CoveredBondEnum",
      "description": "Specifies the type of Covered Bond.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Pfandbriefe",
          "description": "German bank debenture collateralized by long-term assets."
        },
        {
          "text": "JumboPfandbriefe",
          "description": "Pfandbriefe with an issuing syndicate and a minimum issuance volume of EUR 1 billion."
        }
      ]
    },
    {
      "name": "DebtSeniorityEnum",
      "definition_uri": "https://w3id.org/finos/cdm/DebtSeniorityEnum",
      "description": "Specifies the order of repayment in the event of a sale or bankruptcy of the issuer or a related party (eg guarantor).",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Secured",
          "description": "Denotes debt which is secured over assets of the issuer or a related party (eg guarantor)."
        },
        {
          "text": "Senior",
          "description": "Denotes debt  which ranks pari passu with all other unsecured creditors of the issuer."
        },
        {
          "text": "Subordinated",
          "description": "Denotes debt  owed to an unsecured creditor that in the event of a liquidation can only be paid after the claims of secured and senior creditors have been met."
        }
      ]
    },
    {
      "name": "DebtInterestEnum",
      "definition_uri": "https://w3id.org/finos/cdm/DebtInterestEnum",
      "description": "Represents an enumeration list that specifies the general rule for periodic interest rate payment.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Fixed",
          "description": "Denotes payment calculated with reference to a fixed interest rate."
        },
        {
          "text": "Floating",
          "description": "Denotes payment calculated with reference to a floating interest rate."
        },
        {
          "text": "InflationLinked",
          "description": "Denotes payment calculated with reference to one or more specified inflation rates."
        },
        {
          "text": "IndexLinked",
          "description": "Denotes payment calculated with reference to one or more price or other indices (other than inflation rates)."
        },
        {
          "text": "InterestOnly",
          "description": "Denotes a stripped bond representing only the interest component."
        },
        {
          "text": "OtherStructured",
          "description": "Denotes payment calculated with reference to other underlyings (not being floating interest rates, inflation rates or indices) or with a non-linear relationship to floating interest rates, inflation rates or indices."
        },
        {
          "text": "InverseFloating",
          "description": "Denotes payment calculated with reference to the inverse of a floating interest rate."
        },
        {
          "text": "ZeroCoupon",
          "description": "Denotes a zero coupon bond that does not pay intetrest."
        }
      ]
    },
    {
      "name": "DebtPrincipalEnum",
      "definition_uri": "https://w3id.org/finos/cdm/DebtPrincipalEnum",
      "description": "Represents an enumeration list that specifies the general rule for repayment of principal.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Bullet",
          "description": "Denotes that the principal is paid all at once on maturity of the debt insrument. Bullet debt instruments cannot be redeemed early by an issuer, which means they are non-callable."
        },
        {
          "text": "Callable",
          "description": "Denotes that the principal on the debt can be repaid early, in whole or in part, at the option of the issuer."
        },
        {
          "text": "Puttable",
          "description": "Denotes that the principal on the debt can be repaid early, in whole or in part, at the option of the holder."
        },
        {
          "text": "Amortising",
          "description": "Denotes that the principal on the debt is paid down regularly, along with its interest expense over the life of the debt instrument.  Includes amortising instruments with a bullet balance repayment at maturity."
        },
        {
          "text": "InflationLinked",
          "description": "Denotes that the principal on the debt is calculated with reference to one or more specified inflation rates."
        },
        {
          "text": "IndexLinked",
          "description": "Denotes that the  principal on the debt is calculated with reference to one or more price or other indices (other than inflation rates)."
        },
        {
          "text": "OtherStructured",
          "description": "Denotes that the  principal on the debt is calculated with reference to other underlyings (not being floating interest rates, inflation rates or indices) or with a non-linear relationship to floating interest rates, inflation rates or indices."
        },
        {
          "text": "PrincipalOnly",
          "description": "Denotes a stripped bond representing only the principal component."
        }
      ]
    },
    {
      "name": "RedemptionTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/RedemptionTypeEnum",
      "description": "Specifies the contractual redemption or conversion features associated with a debt security.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Convertible",
          "description": "Specifies a debt instrument that can be converted into common shares."
        },
        {
          "text": "Exchangeable",
          "description": "Specifies a debt security that can be converted to equity in a company other than the issuing company."
        },
        {
          "text": "ContingentConvertible",
          "description": "Specifies a debt security that can be converted into equity if a pre-defined trigger event occurs."
        },
        {
          "text": "Sinkable",
          "description": "Specifies a debt security that requires the issuer to periodically set aside money to buy back portions of the debt."
        },
        {
          "text": "Extraordinary",
          "description": "Specifies a debt security that can be redeemed early if certain extraordinary events occur."
        }
      ]
    },
    {
      "name": "RedemptionPartyEnum",
      "definition_uri": "https://w3id.org/finos/cdm/RedemptionPartyEnum",
      "description": "Specifies the redeeming party of a debt security.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Holder",
          "description": "Specifies the holder of a debt security."
        },
        {
          "text": "Issuer",
          "description": "Specifies the issuer of a debt security."
        }
      ]
    },
    {
      "name": "AssetTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/AssetTypeEnum",
      "description": "Represents an enumeration list to identify the asset type.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
        {
          "text": "Security",
          "description": "Identifies negotiable financial instrument of monetary value with an issue ownership position."
        },
        {
          "text": "Cash",
          "description": "Identifies cash in a currency form."
        },
        {
          "text": "Commodity",
          "description": "Identifies basic good used in commerce that is interchangeable with other goods of the same type."
        },
        {
          "text": "ListedDerivative",
          "description": "Identifies an asset as a listed derivative on an exchange."
        },
        {
          "text": "Loan",
          "description": "An asset that represents a loan or borrow obligation."
        },
        {
          "text": "LetterOfCredit",
          "description": "Identifies an asset as a letter of credit or documentary credit/ bankers commercial credit.  A payment mechanism used in international trade to provide economic guarantee of payment by a creditworthy issuer for payment of exported goods."
        },
        {
          "text": "Other",
          "description": "Identifies other asset types."
        }
      ]
    },
    {
      "name": "MoneyMarketTypeEnum",
      "definition_uri": "https://w3id.org/finos/cdm/MoneyMarketTypeEnum",
      "from_schema": "https://w3id.org/finos/cdm/cdm_base_staticdata_asset_common",
      "permissible_values": [
