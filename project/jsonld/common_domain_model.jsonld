      "name": "partyName",
      "definition_uri": "https://w3id.org/finos/cdm/partyName",
      "description": "The party name to which the workflow pertains to.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_event_workflow",
      "slot_uri": "https://w3id.org/finos/cdm/partyName",
      "owner": "PartyCustomisedWorkflow",
      "domain_of": [
