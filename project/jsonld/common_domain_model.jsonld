          "tag": "rosetta_functions",
          "value": "[{\"name\":\"GenerateObservationDatesAndWeights\",\"description\":\"Apply shifts to generate the list of observation dates and weights for each of those date.\",\"inputs\":[{\"name\":\"calculationParams\",\"type\":\"FloatingRateCalculationParameters\",\"cardinality\":\"1..1\"},{\"name\":\"resetDates\",\"type\":\"ResetDates\",\"cardinality\":\"0..1\"},{\"name\":\"calculationPeriod\",\"type\":\"CalculationPeriodBase\",\"cardinality\":\"1..1\"},{\"name\":\"priorCalculationPeriod\",\"type\":\"CalculationPeriodBase\",\"cardinality\":\"0..1\"}],\"output\":{\"name\":\"results\",\"type\":\"CalculatedRateObservationDatesAndWeights\",\"cardinality\":\"1..1\"}}]",
          "@type": "Annotation"
        }
      ],
