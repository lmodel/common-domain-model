    },
    {
      "name": "WeightedAveragingObservation",
      "definition_uri": "https://w3id.org/finos/cdm/WeightedAveragingObservation",
      "description": "A single weighted averaging observation.",
      "comments": [
        "Rosetta condition: WeightedAveragingObservationChoice \u2014 required choice dateTime, observationNumber",
        "Rosetta condition: PositiveObservationNumber \u2014 if observationNumber exists then observationNumber >= 0",
        "Rosetta condition: PositiveWeight \u2014 weight >= 0.0"
      ],
      "in_subset": [
        "cdm_product_common_schedule"
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_common_schedule",
      "exact_mappings": [
        "common_domain_model:WeightedAveragingObservation"
      ],
      "slots": [
        "WeightedAveragingObservation_dateTime",
        "observationNumber",
        "WeightedAveragingObservation_weight"
      ],
      "slot_usage": {},
      "rules": [
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "exactly_one_of": [
              {
                "slot_conditions": [
                  {
                    "name": "dateTime",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              },
              {
                "slot_conditions": [
                  {
                    "name": "observationNumber",
                    "required": true,
                    "@type": "SlotDefinition"
                  }
                ],
                "@type": "AnonymousClassExpression"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": " Choice rule to represent an FpML choice construct between date times for literal date values, and observation numbers for schedule generated observations.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "slot_conditions": [
              {
                "name": "observationNumber",
                "required": true,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "observationNumber",
                "minimum_value": 0,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": " FpML specifies observationNumber as a positive integer.",
          "@type": "ClassRule"
        },
        {
          "preconditions": {
            "@type": "AnonymousClassExpression"
          },
          "postconditions": {
            "slot_conditions": [
              {
                "name": "weight",
                "minimum_value": 0.0,
                "@type": "SlotDefinition"
              }
            ],
            "@type": "AnonymousClassExpression"
          },
          "description": " FpML specifies observationNumber as a non-negative decimal.",
          "@type": "ClassRule"
        }
      ],
      "@type": "ClassDefinition"
    },
