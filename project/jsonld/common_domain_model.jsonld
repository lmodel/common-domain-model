    {
      "name": "ValuationInstruction",
      "definition_uri": "https://w3id.org/finos/cdm/ValuationInstruction",
      "annotations": [
        {
          "tag": "rosetta_functions",
          "value": "[{\"name\":\"Create_Valuation\",\"description\":\"Function specification to incorporate a new assessment of the valuation in the valuation history of a given trade state.\",\"inputs\":[{\"name\":\"instruction\",\"type\":\"ValuationInstruction\",\"cardinality\":\"1..1\"},{\"name\":\"before\",\"type\":\"TradeState\",\"cardinality\":\"1..1\"}],\"output\":{\"name\":\"after\",\"type\":\"TradeState\",\"cardinality\":\"1..1\"}}]",
          "@type": "Annotation"
        }
      ],
      "description": "Specifies inputs needed to process a valuation.",
      "comments": [
        "Rosetta func: Create_Valuation \u2014 Function specification to incorporate a new assessment of the valuation in the valuation history of a given trade state."
      ],
