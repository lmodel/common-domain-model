    {
      "name": "earliestExerciseTime",
      "definition_uri": "https://w3id.org/finos/cdm/earliestExerciseTime",
      "description": "The earliest time at which notice of exercise can be given by the buyer to the seller (or seller's agent) to, and including, the expiration date.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_template",
      "slot_uri": "https://w3id.org/finos/cdm/earliestExerciseTime",
