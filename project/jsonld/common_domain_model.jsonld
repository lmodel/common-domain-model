    {
      "name": "matrixSource",
      "definition_uri": "https://w3id.org/finos/cdm/matrixSource",
      "annotations": [
        {
          "tag": "metadata_scheme",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Relevant settled entity matrix source.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/matrixSource",
      "owner": "SettledEntityMatrix",
      "domain_of": [
        "SettledEntityMatrix"
      ],
      "range": "SettledEntityMatrixSourceEnum",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "attachmentPoint",
      "definition_uri": "https://w3id.org/finos/cdm/attachmentPoint",
      "description": "Lower bound percentage of the loss that the Tranche can endure, expressed as a decimal. An attachment point of 5% would be represented as 0.05. The difference between Attachment and Exhaustion points is called the width of the Tranche.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/attachmentPoint",
      "owner": "Tranche",
      "domain_of": [
        "Tranche"
      ],
      "range": "decimal",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "exhaustionPoint",
      "definition_uri": "https://w3id.org/finos/cdm/exhaustionPoint",
      "description": "Upper bound percentage of the loss that the Tranche can endure, expressed as a decimal. An exhaustion point of 5% would be represented as 0.05. The difference between Attachment and Exhaustion points is call the width of the Tranche.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/exhaustionPoint",
      "owner": "Tranche",
      "domain_of": [
        "Tranche"
      ],
      "range": "decimal",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "incurredRecoveryApplicable",
      "definition_uri": "https://w3id.org/finos/cdm/incurredRecoveryApplicable",
      "description": "Outstanding Swap Notional Amount is defined at any time on any day, as the greater of: (a) Zero; If Incurred Recovery Amount Applicable: (b) The Original Swap Notional Amount minus the sum of all Incurred Loss Amounts and all Incurred Recovery Amounts (if any) determined under this Confirmation at or prior to such time.Incurred Recovery Amount not populated: (b) The Original Swap Notional Amount minus the sum of all Incurred Loss Amounts determined under this Confirmation at or prior to such time.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/incurredRecoveryApplicable",
      "owner": "Tranche",
      "domain_of": [
        "Tranche"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "currencyReference",
      "definition_uri": "https://w3id.org/finos/cdm/currencyReference",
      "annotations": [
        {
          "tag": "metadata_reference",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "description": "Reference to a currency specified elsewhere in the document",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/currencyReference",
      "owner": "DividendCurrency",
      "domain_of": [
        "DividendCurrency"
      ],
      "range": "string",
      "@type": "SlotDefinition"
    },
    {
      "name": "dateReference",
      "definition_uri": "https://w3id.org/finos/cdm/dateReference",
      "description": "Specification of the dividend date using an enumeration, with values such as the pay date, the ex-date or the record date.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/dateReference",
      "owner": "DividendDateReference",
      "domain_of": [
        "DividendDateReference"
      ],
      "range": "DividendDateReferenceEnum",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "paymentDateOffset",
      "definition_uri": "https://w3id.org/finos/cdm/paymentDateOffset",
      "description": "Only to be used when SharePayment has been specified in the dividendDateReference element. The number of Currency Business Days following the day on which the Issuer of the Shares pays the relevant dividend to holders of record of the Shares.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/paymentDateOffset",
      "owner": "DividendDateReference",
      "domain_of": [
        "DividendDateReference"
      ],
      "range": "Offset",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "dividendDateReference",
      "definition_uri": "https://w3id.org/finos/cdm/dividendDateReference",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/dividendDateReference",
      "owner": "DividendPaymentDate",
      "domain_of": [
        "DividendPaymentDate"
      ],
      "range": "DividendDateReference",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "dividendDate",
      "definition_uri": "https://w3id.org/finos/cdm/dividendDate",
      "annotations": [
        {
          "tag": "metadata_reference",
          "value": true,
          "@type": "Annotation"
        }
      ],
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/dividendDate",
      "owner": "DividendPaymentDate",
      "domain_of": [
        "DividendPaymentDate"
      ],
      "range": "AdjustableOrRelativeDate",
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "dividendPayoutRatio",
      "definition_uri": "https://w3id.org/finos/cdm/dividendPayoutRatio",
      "description": "Specifies the dividend payout ratio associated with each underlier. In FpML 5.10 the payout is positioned at the underlier level, although there is an intent to reconsider this approach and position it at the leg level. This is approach adopted by the CDM.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/dividendPayoutRatio",
      "owner": "DividendReturnTerms",
      "domain_of": [
        "DividendReturnTerms"
      ],
      "range": "DividendPayoutRatio",
      "multivalued": true,
      "inlined": true,
      "inlined_as_list": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "dividendReinvestment",
      "definition_uri": "https://w3id.org/finos/cdm/dividendReinvestment",
      "description": "Boolean element that defines whether the dividend will be reinvested or not.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/dividendReinvestment",
      "owner": "DividendReturnTerms",
      "domain_of": [
        "DividendReturnTerms"
      ],
      "range": "boolean",
      "@type": "SlotDefinition"
    },
    {
      "name": "dividendEntitlement",
      "definition_uri": "https://w3id.org/finos/cdm/dividendEntitlement",
      "description": "Defines the date on which the receiver of the equity return is entitled to the dividend.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/dividendEntitlement",
      "owner": "DividendTerms",
      "domain_of": [
        "DividendReturnTerms",
        "DividendTerms"
      ],
      "range": "DividendEntitlementEnum",
      "@type": "SlotDefinition"
    },
    {
      "name": "dividendAmountType",
      "definition_uri": "https://w3id.org/finos/cdm/dividendAmountType",
