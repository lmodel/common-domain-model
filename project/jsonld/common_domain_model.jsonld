      "name": "valueDate",
      "definition_uri": "https://w3id.org/finos/cdm/valueDate",
      "description": "Adjusted value date of the future value amount.",
      "from_schema": "https://w3id.org/finos/cdm/cdm_product_asset",
      "slot_uri": "https://w3id.org/finos/cdm/valueDate",
