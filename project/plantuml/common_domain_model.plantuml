abstract "Observable" [[{Specifies the object to be observed for a price, it could be an asset or a reference.}]] {

}
class "NonNegativeQuantitySchedule" [[{None}]] {
    {field} value(i) : decimal  
}
class "VarianceCapFloor" [[{None}]] {
    {field} varianceCap : boolean  
    {field} unadjustedVarianceCap : decimal  
}
