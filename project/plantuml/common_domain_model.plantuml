    {field} applicable : boolean  
    {field} totalVolatilityCap : decimal  
    {field} volatilityCapFactor : decimal  
}
class "VarianceReturnTerms" [[{None}]] {
    {field} annualizationFactor(i) : integer  
    {field} sharePriceDividendAdjustment(i) : boolean  
    {field} expectedN(i) : integer  
    {field} initialLevel(i) : decimal  
    {field} initialLevelSource(i) : DeterminationMethodEnum  
    {field} meanAdjustment(i) : boolean  
    {field} performance(i) : string  
}
"VolatilityReturnTerms" *--> "0..1" "VolatilityCapFloor" : "volatilityCapFloor"
"VarianceReturnTerms" *--> "0..1" "VolatilityCapFloor" : "volatilityCapFloor"
"VolatilityReturnTerms" *--> "0..1" "VolatilityCapFloor" : "volatilityCapFloor"(i)
class "ListedDerivative" [[{A securitized derivative on another asset.}]] {
    {field} deliveryTerm : string  
    {field} optionType : PutCallEnum  
    {field} strike : decimal  
    {field} isExchangeListed(i) : boolean  
    {field} assetType(i) : AssetTypeEnum  
}
class "Price" [[{Specifies a price as a single value to be associated to a financial product. This data type extends PriceSchedule and requires that only the amount value exists.}]] {
    {field} priceType(i) : PriceTypeEnum  
    {field} priceSubType(i) : PriceSubTypeEnum  
    {field} priceExpression(i) : PriceExpressionEnum  
    {field} arithmeticOperator(i) : ArithmeticOperationEnum  
    {field} premiumType(i) : PremiumTypeEnum  
    {field} value(i) : decimal  
}
class "ReturnTerms" [[{Specifies the type of return of a performance payout.}]] {

}
class "ReturnTermsBase" [[{Contains all common elements in variance, volatility and correlation return Terms.}]] {
    {field} annualizationFactor : integer  
    {field} sharePriceDividendAdjustment : boolean  
    {field} expectedN : integer  
    {field} initialLevel : decimal  
    {field} initialLevelSource : DeterminationMethodEnum  
