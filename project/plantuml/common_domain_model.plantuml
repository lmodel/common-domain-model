@startuml
skinparam nodesep 10
hide circle
hide empty members
class "WorkflowStepApproval" [[{Party approvals associated to the current WorkflowStep. }]] {
    {field} approved : boolean  
    {field} rejectedReason : string  
}
class "EventTimestamp" [[{A class to represent the various set of timestamps that can be associated with lifecycle events, as a collection of [dateTime, qualifier].}]] {
    {field} dateTime : datetime  [1..*]
    {field} qualification : EventTimestampQualificationEnum  
}
class "Party" [[{A class to specify a party, without a qualification as to whether this party is a legal entity or a natural person, although the model provides the ability to associate a person (or set of persons) to a party, which use case would imply that such party would be a legal entity (even if not formally specified as such). }]] {
    {field} name : string  
}
class "WorkflowStep" [[{A workflow step represents the state of a business event. The workflow step contains a reference to a previous WorkflowStep in order to preserve lineage. A workflow step is accepted if it contains a business event, proposed if proposedEvent is present and is rejected if the rejected flag is set.}]] {
    {field} rejected : boolean  
    {field} action : ActionEnum  
}
"WorkflowStepApproval" *--> "1" "EventTimestamp" : "timestamp"
"WorkflowStepApproval" *--> "1" "Party" : "party"
"WorkflowStep" *--> "0..*" "WorkflowStepApproval" : "approval"
class "WorkflowState" [[{A class to specify workflow information, which is conceptually applicable to all lifecycle events.}]] {
    {field} workflowStatus : WorkflowStatusEnum  
    {field} comment : string  
    {field} warehouseIdentity : WarehouseIdentityEnum  
}
class "CreditLimitInformation" [[{A class to represent the credit limit utilisation information.}]] {

}
class "Lineage" [[{A class to provide lineage information across lifecycle events through a pointer or set of pointers into the event(s), contract(s) and, possibly, payout components that the event is dependent on or relates to. As an example, if an contractFormation event is corrected, the correction event will have a lineage into the initial event, which takes the form of a globalKey into that initial contract formation event. Two referencing mechanisms are provided as part of the CDM: either the globalKey, which corresponds to the hash value of the CDM class which is referred to, or a reference qualifier which is meant to provide support for the ingestion of xml documents with id/href mechanisms. The CDM recommends the use of the globalKey and provides a default implementation which is accessible in the generated code through org.isda.cdm.globalKey.GlobalKeyHashCalculator. If implementers want to use an alternative hashing mechanism, the API in which they need to plug it is com.rosetta.model.lib.HashFunction.}]] {

}
class "Account" [[{A class to specify an account as an account number alongside, optionally. an account name, an account type, an account beneficiary and a servicing party.}]] {
    {field} accountNumber : string  
    {field} accountName : string  
    {field} accountType : AccountTypeEnum  
}
class "Identifier" [[{A class to specify a generic identifier, applicable to CDM artefacts such as executions, contracts, lifecycle events and legal documents. An issuer can be associated with the actual identifier value as a way to properly qualify it.}]] {
    {field} issuer : string  
}
class "MessageInformation" [[{This class corresponds to the components of the FpML MessageHeader.model.}]] {
    {field} messageId : string  
    {field} sentBy : string  
    {field} sentTo : string  [0..*]
    {field} copyTo : string  [0..*]
}
class "EventInstruction" [[{Specifies instructions to create a BusinessEvent.}]] {
    {field} intent : EventIntentEnum  
    {field} corporateActionIntent : CorporateActionTypeEnum  
    {field} eventDate : date  
    {field} effectiveDate : date  
}
class "CounterpartyPositionBusinessEvent" [[{A business event represents a life cycle event of a position. The combination of the state changes results in a qualifiable life cycle event.}]] {
    {field} intent : PositionEventIntentEnum  
    {field} corporateActionIntent : CorporateActionTypeEnum  
    {field} eventDate : date  
    {field} effectiveDate : date  
}
class "BusinessEvent" [[{A business event represents a life cycle event of a trade. The combination of the state changes results in a qualifiable life cycle event. An example of a Business Event is a PartialTermination which is a defined by a quantity change primitive event.}]] {
    {field} eventQualifier : string  
    {field} intent(i) : EventIntentEnum  
    {field} corporateActionIntent(i) : CorporateActionTypeEnum  
    {field} eventDate(i) : date  
    {field} effectiveDate(i) : date  
}
class "Workflow" [[{A collection of workflow steps which together make up an entire workflow sequence.}]] {

}
"WorkflowStep" *--> "0..1" "WorkflowState" : "workflowState"
"WorkflowStep" *--> "0..1" "CreditLimitInformation" : "creditLimitInformation"
"WorkflowStep" *--> "1" "Lineage" : "lineage"
"WorkflowStep" *--> "0..*" "Account" : "account"
"WorkflowStep" *--> "0..*" "Party" : "party"
"WorkflowStep" *--> "1..*" "Identifier" : "eventIdentifier"
"WorkflowStep" *--> "1..*" "EventTimestamp" : "timestamp"
"WorkflowStep" *--> "0..1" "MessageInformation" : "messageInformation"
"WorkflowStep" *--> "0..1" "EventInstruction" : "nextEvent"
"WorkflowStep" *--> "0..1" "WorkflowStep" : "previousWorkflowStep"
"WorkflowStep" *--> "0..1" "EventInstruction" : "proposedEvent"
"WorkflowStep" *--> "0..1" "CounterpartyPositionBusinessEvent" : "counterpartyPositionBusinessEvent"
"WorkflowStep" *--> "0..1" "BusinessEvent" : "businessEvent"
"Lineage" *--> "0..*" "WorkflowStep" : "eventReference"
"Workflow" *--> "1..*" "WorkflowStep" : "steps"
class "PartyCustomisedWorkflow" [[{A class to specify a party-related, non-standardized data in a generic form.}]] {
    {field} partyName : string  
}
"WorkflowState" *--> "0..*" "PartyCustomisedWorkflow" : "partyCustomisedWorkflow"
class "AveragingObservationList" [[{An unordered list of weighted averaging observations.}]] {

}
class "WeightedAveragingObservation" [[{A single weighted averaging observation.}]] {
    {field} dateTime : datetime  [1..*]
    {field} observationNumber : integer  
    {field} weight : decimal  
}
"AveragingObservationList" *--> "1..*" "WeightedAveragingObservation" : "averagingObservation"
