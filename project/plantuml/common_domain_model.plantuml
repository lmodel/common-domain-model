"SettlementDate" *--> "0..1" "AdjustableDates" : "adjustableDates"(i)
class "AdditionalType" [[{The specification of the Additional Type of transaction that can require the collection or delivery of initial margin under a given regulatory regime for the purposes of Covered Transactions.}]] {
    {field} standardValue : AdditionalTypeEnum  
    {field} customValue : string  
}
class "AdditionalTerminationEvent" [[{A class to specify an optional termination event, additional to the Termination Events that will be deemed an Access Condition (Initial Margin CSA) or a Specified Condition (Variation Margin CSA).}]] {
    {field} name : string  
    {field} applicableParty : CounterpartyRoleEnum  [1..*]
}
class "AdditionalRepresentation" [[{A class to specify the Additional Representation.}]] {
    {field} customElection : string  
}
"AdditionalRepresentations" *--> "0..1" "AdditionalRepresentation" : "additionalRepresentation"
class "AdditionalRepresentationElection" [[{A class to specify the parties' Additional Representation(s) election.}]] {
    {field} party : CounterpartyRoleEnum  
    {field} isApplicable : boolean  
    {field} additionalLanguage : string  
}
"AdditionalRepresentation" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"
"ValuationCalculationDateLocation" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"CollateralManagementAgreement" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"ControlAgreement" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"Custodian" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"CustodianRisk" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"FrenchLawAddendum" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"HoldingAndUsingPostedCollateral" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"PostingObligations" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"ProcessAgent" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"RecalculationOfValue" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"SecurityProviderRightsEvent" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"SensitivityMethodologies" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"SimmCalculationCurrency" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"Substitution" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"TerminationCurrencyAmendment" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"EligibleCreditSupport" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"Threshold" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"MinimumTransferAmount" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"ExposureScope" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"SpecifiedConditionOrAccessCondition" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"LegacyIndependentAmount" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"DemandsAndNotices" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"AddressesForTransfer" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"AutomaticEarlyTermination" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"TerminationCurrencySelection" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"EventsOfDefault" *--> "1..*" "AdditionalRepresentationElection" : "partyElection"(i)
"AccrualFactor" *--> "0..1" "AccrualFactorCalculationTerms" : "calculationTerms"
"Trade" *--> "0..1" "Account" : "account"(i)
"WorkflowStep" *--> "0..1" "Account" : "account"(i)
"TransferContactInformation" *--> "0..1" "Account" : "account"(i)
@enduml
